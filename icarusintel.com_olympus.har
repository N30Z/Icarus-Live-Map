          "content": {
            "size": 31076,
            "mimeType": "text/javascript",
            "text": "const deepOreShowPopupWithImage = true;\n\nlet mapLayerOres = null;\nlet mapLayerOresMap = '';\nlet cachedOresData = {};\n\nfunction matchesSelectedDrill(drillType, selectedDrills, options = {}) {\n    const {\n        requireKnownOre = false,\n        oreType\n    } = options;\n\n    if (!selectedDrills || selectedDrills.length === 0) {\n        return true;\n    }\n\n    if (requireKnownOre && oreType === '?') {\n        return false;\n    }\n\n    if (selectedDrills.includes('none') && !drillType) {\n        return true;\n    }\n\n    return getKnownDrillTypeIds().some(drillId => selectedDrills.includes(drillId) && drillType === drillId);\n}\n\nfunction createOreMarkerIcon(baseIcon, drillStatus) {\n    if (!drillStatus) {\n        // No drill, use regular icon\n        return baseIcon;\n    }\n\n    // Create divIcon with base image and drill overlay\n    const iconUrl = baseIcon.options.iconUrl;\n    const iconSize = baseIcon.options.iconSize || [32, 32];\n\n    const drillType = getDrillTypeConfig(drillStatus);\n    if (!drillType) {\n        return baseIcon;\n    }\n\n    const html = `\n        <div style=\"position: relative; width: ${iconSize[0]}px; height: ${iconSize[1]}px;\">\n            <img src=\"${iconUrl}\" style=\"width: ${iconSize[0]}px; height: ${iconSize[1]}px;\">\n            <i class=\"material-symbols-outlined drill-overlay ${drillType.cssClass}\">${drillType.icon}</i>\n        </div>\n    `;\n\n    return L.divIcon({\n        html: html,\n        iconSize: iconSize,\n        iconAnchor: baseIcon.options.iconAnchor || [iconSize[0] / 2, iconSize[1]],\n        popupAnchor: baseIcon.options.popupAnchor || [0, -iconSize[1] / 2],\n        className: 'ore-marker-with-drill'\n    });\n}\n\nfunction toggleOreDepositLayer(state, isProgrammatic = false) {\n    if (!state) {\n        if (mapLayerOres != null && map.hasLayer(mapLayerOres)) {\n            map.removeLayer(mapLayerOres);\n        }\n        // Reset ore filter ONLY when user manually turns off the layer\n        if (!isProgrammatic && typeof setOreFilterSelection !== 'undefined') {\n            setOreFilterSelection([]);\n            // Don't reset cave filter checkbox - let user control it independently\n            if (typeof updateOreFilterButtonState !== 'undefined') {\n                updateOreFilterButtonState();\n            }\n            // Reset visual filtering effects on caves\n            if (typeof applyOreFiltering === 'function') {\n                applyOreFiltering();\n            }\n        }\n        return;\n    }\n\n    const mapName = selectedMapParent;\n\n    if (mapLayerOresMap !== mapName) {\n        //Load new map - requires data to be pre-loaded\n        if (cachedOresData[mapName]) {\n            setOreDepositsData(mapName, cachedOresData[mapName], true);\n        }\n    } else {\n        if (mapLayerOres != null && !map.hasLayer(mapLayerOres)) {\n            const onLayerAdd = function () {\n                // Apply NULL sector filtering immediately when layer is added\n                if (selectedMapParent === 'prometheus' && typeof applyOreDepositFiltering === 'function') {\n                    applyOreDepositFiltering();\n                }\n                mapLayerOres.off('add', onLayerAdd);\n            };\n            mapLayerOres.on('add', onLayerAdd);\n            mapLayerOres.addTo(map);\n        }\n    }\n}\n\nfunction setOreDepositsData(mapName, data, showInMap) {\n    //Remove\n    if (mapLayerOres != null && map.hasLayer(mapLayerOres)) {\n        map.removeLayer(mapLayerOres);\n    }\n\n    // Check cache first\n    if (mapLayerOresMap === mapName && mapLayerOres != null) {\n        if (showInMap) {\n            mapLayerOres.addTo(map);\n            updateOreDepositState();\n        }\n        return;\n    }\n\n    mapLayerOresMap = mapName;\n    cachedOresData[mapName] = data;\n\n    filterSetDisabledState(filterOreDeposits, true);\n\n    let deepOreDepositMarkers = [];\n\n    Object.values(data).forEach(deepOreDeposit => {\n        let popupText = addDevTooltip('UNKNOWN ORE', deepOreDeposit);\n        let depositIcon = mining_unknown;\n        switch (deepOreDeposit.variant) {\n            case 'ice':\n                popupText = addDevTooltip('SUPER COOLED ICE', deepOreDeposit);\n                depositIcon = mining_supercooledice;\n                break;\n            case 'limestone':\n                popupText = addDevTooltip('LIMESTONE', deepOreDeposit);\n                depositIcon = mining_limestone;\n                break;\n            case 'wood':\n                popupText = addDevTooltip('FROZEN TRUNK', deepOreDeposit);\n                depositIcon = mining_frozenwood;\n                break;\n        }\n\n        let deepOreDepositMarker = L.marker(map.unproject([deepOreDeposit.x, deepOreDeposit.y], MAP_ZOOM), { icon: createOreMarkerIcon(depositIcon) }).bindPopup(popupText, { autoPan: false });\n\n        // Deep ore deposits use the code directly from data (already in correct format)\n        deepOreDepositMarker.depositId = deepOreDeposit.code;\n        deepOreDepositMarker.depositData = deepOreDeposit;\n\n        // Mark NULL sector ore nodes (for Prometheus map filtering)\n        deepOreDepositMarker.isNullSectorOre = mapName === 'prometheus' && deepOreDeposit.isNullSector === true;\n\n        deepOreDepositMarker.on('mouseover', function (e) {\n            this.openPopup();\n        });\n\n        deepOreDepositMarker.on('mouseout', function (e) {\n            this.closePopup();\n        });\n\n        deepOreDepositMarker.on('click', function (e) {\n            let mapState = getMapState().rights;\n            if (mapState == \"ro\") return;\n\n            if (!window.mobileAndTabletCheck()) {\n                if (this.getPopup().isOpen()) {\n                    this.closePopup()\n                }\n            }\n\n            showDeepOreVeinContextMenu(e, this);\n        });\n\n        // Stop map zoom and map move when quickly clicking on DOV\n        deepOreDepositMarker.on('dblclick', function (e) {\n            L.DomEvent.stopPropagation(e);\n        });\n\n\n        deepOreDepositMarkers.push(deepOreDepositMarker);\n    });\n\n\n    //Empty ores.\n    if (deepOreDepositMarkers.length === 0) {\n        filterHideRow(filterOreDeposits, true);\n        filterSetDisabledState(filterOreDeposits, false);\n        return;\n    }\n\n    filterHideRow(filterOreDeposits, false);\n\n    mapLayerOres = L.layerGroup(deepOreDepositMarkers);\n\n    if (showInMap) {\n        const onAdd = () => {\n            if (typeof applyOreFiltering === 'function') {\n                applyOreFiltering();\n            }\n            // Also apply NULL sector filtering if on Prometheus map\n            if (mapName === 'prometheus' && typeof applyOreDepositFiltering === 'function') {\n                applyOreDepositFiltering();\n            }\n            mapLayerOres.off('add', onAdd);\n        };\n        mapLayerOres.on('add', onAdd);\n        mapLayerOres.addTo(map);\n    }\n\n    updateOreDepositState();\n\n    filterSetDisabledState(filterOreDeposits, false);\n}\n\nfunction updateOreDepositState() {\n    updateLayerState(mapLayerOres, (layer) => {\n        const dovDepositState = getDepositState(layer.depositId);\n        const drillStatus = getDepositDrill(layer.depositId);\n        const currentState = oreDepositTypes.find(item => item.stateId === dovDepositState) || (oreDepositTypesByVariant[layer.depositData.variant] || oreDepositTypes)[0];\n\n        return {\n            icon: createOreMarkerIcon(currentState.icon, drillStatus),\n            popup: addDevTooltip(currentState.text, layer.depositData)\n        };\n    }, {\n        onComplete: () => {\n            // Apply filtering after updating states\n            setTimeout(() => {\n                if (typeof applyOreFiltering === 'function') {\n                    applyOreFiltering();\n                }\n            }, 50);\n        }\n    });\n}\n\nfunction setMarker(marker, markerType) {\n    const currentDrill = getDepositDrill(marker.depositId);\n\n    // Clear drill status if setting to empty or unknown\n    if (markerType.stateId === 'm' || markerType.stateId === '?') {\n        setOreDepositState(marker.depositId, markerType.stateId);\n        // Drill is automatically cleared since we're not preserving it\n    } else {\n        // Keep existing drill status when changing ore type\n        setOreDepositState(marker.depositId, markerType.stateId, currentDrill);\n    }\n\n    // Update the visual icon\n    const newIcon = createOreMarkerIcon(markerType.icon, markerType.stateId === 'm' || markerType.stateId === '?' ? undefined : currentDrill);\n    marker.setIcon(newIcon);\n    marker.bindPopup(markerType.text, { autoPan: false });\n\n    // Apply filtering after changing marker state\n    setTimeout(() => {\n        if (typeof applyOreFiltering === 'function') {\n            applyOreFiltering();\n        }\n    }, 50);\n}\n\n//Context menu with icon\n/**\n * Generic ore menu builder that works for both deep ore veins and cave ores\n * @param {Object} config - Configuration object\n * @param {Array} config.oreList - List of ore types to display\n * @param {string} config.currentOreState - Current ore state ID\n * @param {string} config.currentDrillState - Current drill state\n * @param {boolean} config.showImages - Whether to show ore icons\n * @param {Function} config.onOreSelect - Callback when ore is selected\n * @param {Function} config.onDrillSelect - Callback when drill is selected\n * @returns {HTMLElement} The constructed menu container\n */\nfunction buildOreSelectionMenu(config) {\n    const {\n        oreList,\n        currentOreState,\n        currentDrillState,\n        showImages = true,\n        onOreSelect,\n        onDrillSelect\n    } = config;\n\n    const container = document.createElement('div');\n    container.className = 'popup-dov-container';\n\n    // Create ore list section\n    const menu = document.createElement('ul');\n    menu.className = 'popup-dov-select';\n\n    oreList.forEach(item => {\n        const li = document.createElement('li');\n\n        // Highlight currently selected ore (but never highlight unknown ore)\n        if (item.stateId === currentOreState && item.stateId !== '?') {\n            li.classList.add('selected');\n        }\n\n        if (showImages) {\n            const iconImg = document.createElement('img');\n            iconImg.src = item.icon.options.iconUrl;\n            li.appendChild(iconImg);\n        }\n\n        li.appendChild(document.createTextNode(item.text));\n\n        li.onclick = (clickEvent) => {\n            if (onOreSelect) {\n                onOreSelect(item, clickEvent);\n            }\n        };\n\n        menu.appendChild(li);\n    });\n\n    container.appendChild(menu);\n\n    // Add drill selection section\n    const drillSection = document.createElement('div');\n    drillSection.className = 'popup-dov-drill-section';\n    drillSection.innerHTML = '<div class=\"popup-dov-drill-title\">Drill</div>';\n\n    const drillOptions = document.createElement('div');\n    drillOptions.className = 'popup-dov-drill-options';\n\n    const drillTypes = getDrillMenuOptions();\n\n    drillTypes.forEach(drillType => {\n        const drillOption = document.createElement('div');\n        drillOption.className = 'popup-dov-drill-option';\n        drillOption.title = drillType.tooltip;\n        // Highlight the selected drill option\n        // For undefined drill (None), both should be undefined or falsy\n        const isSelected = (drillType.id === undefined)\n            ? (!currentDrillState || currentDrillState === undefined)\n            : (currentDrillState === drillType.id);\n        if (isSelected) {\n            drillOption.classList.add('selected');\n        }\n\n        // Disable drill selection if ore is unknown or empty\n        // Check explicitly for both unknown ('?') and empty ('m') states\n        // BUT allow clearing drill (undefined) even on unknown/empty ores\n        const isOreUnknownOrEmpty = !currentOreState || currentOreState === '?' || currentOreState === 'm';\n        if (isOreUnknownOrEmpty && drillType.id !== undefined) {\n            drillOption.classList.add('disabled');\n            drillOption.style.opacity = '0.3';\n            drillOption.style.cursor = 'not-allowed';\n            drillOption.title = drillType.tooltip + ' (Select ore type first)';\n        }\n\n        drillOption.innerHTML = `<i class=\"material-symbols-outlined ${drillType.cssClass}\">${drillType.icon}</i>${drillType.label}`;\n\n        drillOption.onclick = (event) => {\n            event.stopPropagation();\n            event.preventDefault();\n\n            // Allow clearing drill (undefined) even if ore is unknown or empty\n            // But block setting biofuel or electric drill on unknown/empty ores\n            if (isOreUnknownOrEmpty && drillType.id !== undefined) {\n                return;\n            }\n\n            if (onDrillSelect) {\n                onDrillSelect(drillType, event);\n            }\n        };\n\n        drillOptions.appendChild(drillOption);\n    });\n\n    drillSection.appendChild(drillOptions);\n    container.appendChild(drillSection);\n\n    return container;\n}\n\nfunction showDeepOreVeinContextMenu(e, marker) {\n    let oreList = oreDepositTypesNoPrometheus;\n    if (mapselect == 'prometheus') {\n        oreList = oreDepositTypes;\n    }\n    const variantTypes = oreDepositTypesByVariant[marker.depositData.variant];\n    if (variantTypes) {\n        oreList = variantTypes;\n    }\n\n    let currentDepositState = getDepositState(marker.depositId);\n    const currentDrillStatus = getDepositDrill(marker.depositId);\n\n    // Auto-mark deposit state for variants\n    if (!currentDepositState && oreList.length == 2) {\n        setMarker(marker, oreList[0]);\n        currentDepositState = oreList[0].stateId;\n    }\n\n    const container = buildOreSelectionMenu({\n        oreList: oreList,\n        currentOreState: currentDepositState,\n        currentDrillState: currentDrillStatus,\n        showImages: deepOreShowPopupWithImage,\n        onOreSelect: (item) => {\n            setMarker(marker, item);\n            map.closePopup();\n        },\n        onDrillSelect: (drillType) => {\n            setDepositDrill(marker.depositId, drillType.id);\n            updateOreDepositState();\n            map.closePopup();\n        }\n    });\n\n    openPopupOnMarker(e, marker, container);\n}\n\nfunction openPopupOnMarker(e, marker, content) {\n    const offset = marker.options.icon.options.popupAnchor || [0, 0];\n    const point = map.latLngToContainerPoint(e.latlng);\n\n    point.x += offset[0];\n    point.y += offset[1];\n\n    const shiftedLatLng = map.containerPointToLatLng(point);\n\n    L.popup({\n        autoPan: true,\n        autoPanPadding: [20, 20]\n    })\n        .setLatLng(shiftedLatLng)\n        .setContent(content)\n        .openOn(map);\n}\n\n// Ore Filter Functionality\nlet oreFilterPopup = null;\n\nconst ORE_FILTER_POPUP_LAYOUT_KEY = 'oreFilterPopupLayout';\n\nfunction initOreFilter() {\n    const filterButton = document.getElementById('oreFilterButton');\n    if (!filterButton) return;\n\n    filterButton.addEventListener('click', (e) => {\n        e.stopPropagation();\n        e.preventDefault();\n        toggleOreFilterPopup();\n    });\n\n    // Update button state on load\n    updateOreFilterButtonState();\n}\n\nfunction toggleOreFilterPopup() {\n    if (oreFilterPopup) {\n        closeOreFilterPopup();\n        return;\n    }\n\n    showOreFilterPopup();\n}\n\nfunction showOreFilterPopup() {\n    // Close cave filter popup if it's open\n    if (typeof closeCaveTierFilterPopup === 'function') {\n        closeCaveTierFilterPopup();\n    }\n\n    const filterButton = document.getElementById('oreFilterButton');\n    if (!filterButton) return;\n\n    const content = createOreFilterContent();\n\n    // Create custom popup div\n    const popupDiv = document.createElement('div');\n    popupDiv.id = 'oreFilterPopupDiv';\n    popupDiv.className = 'ore-filter-popup-overlay';\n\n    popupDiv.appendChild(content);\n    document.body.appendChild(popupDiv);\n\n    if (window.PopupOverlayManager && typeof window.PopupOverlayManager.attachToPopup === 'function') {\n        window.PopupOverlayManager.attachToPopup({\n            key: ORE_FILTER_POPUP_LAYOUT_KEY,\n            popupId: 'oreFilterPopupDiv',\n            anchorId: 'oreFilterButton',\n            options: {\n                margin: 12,\n                gap: 10,\n                minHeight: 140,\n                minWidth: 160,\n                zIndex: 10000,\n                centerOnMobile: true,\n                centerViewportWidthThreshold: 600,\n                centerVerticalRatio: 0.5\n            }\n        });\n    }\n\n    // Close on clicking outside\n    setTimeout(() => {\n        document.addEventListener('click', closeOreFilterOnClickOutside);\n    }, 100);\n\n    oreFilterPopup = popupDiv;\n}\n\nfunction closeOreFilterOnClickOutside(e) {\n    const popup = document.getElementById('oreFilterPopupDiv');\n    const filterButton = document.getElementById('oreFilterButton');\n\n    if (popup && !popup.contains(e.target) && e.target !== filterButton && !filterButton.contains(e.target)) {\n        closeOreFilterPopup();\n    }\n}\n\nfunction closeOreFilterPopup() {\n    const popup = document.getElementById('oreFilterPopupDiv');\n    if (popup) {\n        popup.remove();\n        document.removeEventListener('click', closeOreFilterOnClickOutside);\n    }\n\n    if (window.PopupOverlayManager && typeof window.PopupOverlayManager.detachFromPopup === 'function') {\n        window.PopupOverlayManager.detachFromPopup(ORE_FILTER_POPUP_LAYOUT_KEY);\n    }\n\n    oreFilterPopup = null;\n}\n\nfunction createOreFilterContent() {\n    const wrapper = document.createElement('div');\n    wrapper.className = 'ore-filter-popup';\n\n    // Header with close button\n    const header = document.createElement('div');\n    header.className = 'ore-filter-header';\n\n    const title = document.createElement('h3');\n    title.textContent = 'Ore Search Tool';\n    header.appendChild(title);\n\n    const closeBtn = document.createElement('button');\n    closeBtn.className = 'ore-filter-close';\n    closeBtn.innerHTML = '&times;';\n    closeBtn.onclick = () => closeOreFilterPopup();\n    header.appendChild(closeBtn);\n\n    wrapper.appendChild(header);\n\n    // Cave filtering toggle\n    const caveToggle = document.createElement('div');\n    caveToggle.className = 'ore-filter-cave-toggle';\n\n    const caveCheckbox = document.createElement('input');\n    caveCheckbox.type = 'checkbox';\n    caveCheckbox.id = 'oreFilterIncludeCaves';\n    caveCheckbox.checked = getOreFilterIncludeCaves();\n    caveCheckbox.onchange = () => {\n        setOreFilterIncludeCaves(caveCheckbox.checked);\n        applyCaveOreFiltering();\n    };\n\n    const caveLabel = document.createElement('label');\n    caveLabel.htmlFor = 'oreFilterIncludeCaves';\n    caveLabel.textContent = 'Search in Caves';\n\n    caveToggle.appendChild(caveCheckbox);\n    caveToggle.appendChild(caveLabel);\n    wrapper.appendChild(caveToggle);\n\n    // Actions\n    const actions = document.createElement('div');\n    actions.className = 'ore-filter-actions';\n\n    const selectAllBtn = document.createElement('button');\n    selectAllBtn.textContent = 'All';\n    selectAllBtn.onclick = () => selectAllOres();\n    actions.appendChild(selectAllBtn);\n\n    const clearAllBtn = document.createElement('button');\n    clearAllBtn.textContent = 'Clear';\n    clearAllBtn.onclick = () => clearAllOres();\n    actions.appendChild(clearAllBtn);\n\n    wrapper.appendChild(actions);\n\n    // Ore list\n    const list = document.createElement('div');\n    list.className = 'ore-filter-list';\n    list.id = 'oreFilterList';\n\n    let oreList = oreDepositTypesNoPrometheus;\n    if (mapselect === 'prometheus') {\n        oreList = oreDepositTypes;\n    }\n    // Add variant types to oreList\n    oreList = oreList.slice();\n    Object.values(oreDepositTypesByVariant).forEach(variantOres => {\n        variantOres.forEach(ore => {\n            if (!oreList.some(item => item.stateId === ore.stateId)) {\n                oreList.push(ore);\n            }\n        });\n    });\n\n    const selectedOres = getOreFilterSelection();\n\n    // Exclude unknown and mined from filter options\n    const filterableOres = oreList.filter(ore => ore.stateId !== '?' && ore.stateId !== 'm');\n\n    filterableOres.forEach(ore => {\n        const item = document.createElement('div');\n        item.className = 'ore-filter-item';\n\n        const checkbox = document.createElement('input');\n        checkbox.type = 'checkbox';\n        checkbox.id = `ore-filter-${ore.stateId}`;\n        checkbox.checked = selectedOres.includes(ore.stateId);\n\n        const icon = document.createElement('img');\n        icon.src = ore.icon.options.iconUrl;\n        icon.alt = ore.text;\n\n        const label = document.createElement('label');\n        label.htmlFor = `ore-filter-${ore.stateId}`;\n        label.textContent = ore.text;\n\n        item.appendChild(checkbox);\n        item.appendChild(icon);\n        item.appendChild(label);\n\n        // Handle checkbox change\n        checkbox.addEventListener('change', (e) => {\n            e.stopPropagation();\n            toggleOreFilter(ore.stateId);\n        });\n\n        // Make entire row clickable (trigger checkbox)\n        item.onclick = (e) => {\n            if (e.target !== checkbox) {\n                e.preventDefault();\n                checkbox.click();\n            }\n        };\n\n        list.appendChild(item);\n    });\n\n    wrapper.appendChild(list);\n\n    // Drill filter section\n    const drillFilterSection = document.createElement('div');\n    drillFilterSection.className = 'ore-filter-drill-section';\n\n    const drillTitle = document.createElement('h4');\n    drillTitle.textContent = 'Mining Setup';\n    drillFilterSection.appendChild(drillTitle);\n\n    const drillFilterList = document.createElement('div');\n    drillFilterList.className = 'ore-filter-drill-list';\n\n    const selectedDrills = getOreFilterDrills();\n\n    const drillTypes = getDrillFilterOptions();\n\n    drillTypes.forEach(drillType => {\n        const item = document.createElement('div');\n        item.className = 'ore-filter-item';\n\n        const checkbox = document.createElement('input');\n        checkbox.type = 'checkbox';\n        checkbox.id = `drill-filter-${drillType.id}`;\n        checkbox.checked = selectedDrills.includes(drillType.id);\n\n        const label = document.createElement('label');\n        label.htmlFor = `drill-filter-${drillType.id}`;\n\n        if (drillType.icon) {\n            const iconClassSuffix = drillType.cssClass ? ` ${drillType.cssClass}` : '';\n            label.innerHTML = `<i class=\"material-symbols-outlined ore-filter-drill-icon${iconClassSuffix}\">${drillType.icon}</i> ${drillType.label}`;\n        } else {\n            label.textContent = drillType.label;\n        }\n\n        item.appendChild(checkbox);\n        item.appendChild(label);\n\n        checkbox.addEventListener('change', (e) => {\n            e.stopPropagation();\n            toggleDrillFilter(drillType.id);\n        });\n\n        item.onclick = (e) => {\n            if (e.target !== checkbox && !e.target.classList.contains('material-symbols-outlined')) {\n                e.preventDefault();\n                checkbox.click();\n            }\n        };\n\n        drillFilterList.appendChild(item);\n    });\n\n    drillFilterSection.appendChild(drillFilterList);\n    wrapper.appendChild(drillFilterSection);\n\n    return wrapper;\n}\n\nfunction toggleOreFilter(oreStateId) {\n    let selectedOres = getOreFilterSelection();\n\n    if (selectedOres.includes(oreStateId)) {\n        selectedOres = selectedOres.filter(id => id !== oreStateId);\n    } else {\n        selectedOres.push(oreStateId);\n    }\n\n    setOreFilterSelection(selectedOres);\n    updateOreFilterButtonState();\n    applyOreFiltering();\n}\n\nfunction toggleDrillFilter(drillId) {\n    let selectedDrills = getOreFilterDrills();\n\n    if (selectedDrills.includes(drillId)) {\n        selectedDrills = selectedDrills.filter(id => id !== drillId);\n    } else {\n        selectedDrills.push(drillId);\n    }\n\n    setOreFilterDrills(selectedDrills);\n    updateOreFilterButtonState();\n    applyOreFiltering();\n}\n\nfunction selectAllOres() {\n    let oreList = oreDepositTypesNoPrometheus;\n    if (mapselect === 'prometheus') {\n        oreList = oreDepositTypes;\n    }\n\n    const filterableOres = oreList.filter(ore => ore.stateId !== '?' && ore.stateId !== 'm');\n    const allOreIds = filterableOres.map(ore => ore.stateId);\n\n    setOreFilterSelection(allOreIds);\n    updateOreFilterButtonState();\n    applyOreFiltering();\n\n    // Update checkboxes\n    filterableOres.forEach(ore => {\n        const checkbox = document.getElementById(`ore-filter-${ore.stateId}`);\n        if (checkbox) checkbox.checked = true;\n    });\n}\n\nfunction clearAllOres() {\n    setOreFilterSelection([]);\n    setOreFilterDrills([]);\n    updateOreFilterButtonState();\n    applyOreFiltering();\n\n    // Update checkboxes\n    const checkboxes = document.querySelectorAll('.ore-filter-item input[type=\"checkbox\"]');\n    checkboxes.forEach(cb => cb.checked = false);\n}\n\nfunction updateOreFilterButtonState() {\n    const filterButton = document.getElementById('oreFilterButton');\n    if (!filterButton) return;\n\n    if (isOreFilterActive()) {\n        filterButton.classList.add('active');\n    } else {\n        filterButton.classList.remove('active');\n    }\n}\n\nfunction applyOreFiltering() {\n    if (!mapLayerOres) return;\n\n    // Check if required functions exist\n    if (typeof getOreFilterSelection !== 'function' || typeof getDepositState !== 'function') {\n        return;\n    }\n\n    const selectedOres = getOreFilterSelection();\n    const selectedDrills = getOreFilterDrills();\n    const isOreFilterActive = selectedOres.length > 0;\n    const isDrillFilterActive = selectedDrills.length > 0;\n\n    mapLayerOres.eachLayer(layer => {\n        if (!layer || !layer.depositId) return;\n\n        const depositState = getDepositState(layer.depositId);\n        const drillStatus = getDepositDrill(layer.depositId);\n        const icon = layer.getElement();\n        const variant = layer.depositData.variant;\n\n        if (!icon) return;\n\n        // Remove existing filter classes\n        icon.classList.remove('ore-highlighted', 'ore-dimmed');\n\n        if (isOreFilterActive || isDrillFilterActive) {\n            let matchesOreFilter = !isOreFilterActive || selectedOres.includes(depositState) || selectedOres.includes(variant);\n            let matchesDrillFilter = !isDrillFilterActive || matchesSelectedDrill(drillStatus, selectedDrills);\n\n            if (matchesOreFilter && matchesDrillFilter) {\n                icon.classList.add('ore-highlighted');\n            } else {\n                icon.classList.add('ore-dimmed');\n            }\n        }\n    });\n\n    // Apply cave filtering if enabled\n    applyCaveOreFiltering();\n}\n\nfunction applyCaveOreFiltering() {\n    // Check if cave filtering is enabled\n    if (typeof getOreFilterIncludeCaves !== 'function' || !getOreFilterIncludeCaves()) {\n        // Remove filtering from caves but preserve cave-has-ores class\n        if (typeof mapLayerCaves !== 'undefined' && mapLayerCaves) {\n            mapLayerCaves.eachLayer(layer => {\n                const icon = layer.getElement();\n                if (icon) {\n                    icon.classList.remove('ore-highlighted', 'ore-dimmed');\n                    // cave-has-ores class is preserved\n                }\n            });\n        }\n        return;\n    }\n\n    // Check if ore filtering is active\n    if (typeof getOreFilterSelection !== 'function') return;\n    const selectedOres = getOreFilterSelection();\n    const selectedDrills = getOreFilterDrills();\n\n    if (selectedOres.length === 0 && selectedDrills.length === 0) {\n        // No ore or drill filter active, remove cave highlighting but preserve cave-has-ores\n        if (typeof mapLayerCaves !== 'undefined' && mapLayerCaves) {\n            mapLayerCaves.eachLayer(layer => {\n                const icon = layer.getElement();\n                if (icon) {\n                    icon.classList.remove('ore-highlighted', 'ore-dimmed');\n                    // cave-has-ores class is preserved\n                }\n            });\n        }\n        return;\n    }\n\n    // Apply filtering to caves\n    if (typeof mapLayerCaves === 'undefined' || !mapLayerCaves) return;\n    if (typeof getCaveDeepOres !== 'function') return;\n\n    const isOreFilterActive = selectedOres.length > 0;\n    const isDrillFilterActive = selectedDrills.length > 0;\n\n    mapLayerCaves.eachLayer(layer => {\n        if (!layer || !layer.caveId) return;\n\n        const caveOres = getCaveDeepOres(layer.caveId) || ['?', '?', '?'];\n        const icon = layer.getElement();\n\n        if (!icon) return;\n\n        // Remove existing filter classes but preserve cave-has-ores\n        icon.classList.remove('ore-highlighted', 'ore-dimmed');\n        // cave-has-ores class is preserved\n\n        let hasMatch = false;\n\n        if (!isOreFilterActive && !isDrillFilterActive) {\n            // No filters active - don't apply any highlighting\n            return;\n        }\n\n        // Check each ore slot in the cave\n        for (let i = 0; i < 3; i++) {\n            const oreType = caveOres[i];\n            const drillType = getCaveOreDrill(layer.caveId, i);\n\n            if (isOreFilterActive && isDrillFilterActive) {\n                // BOTH filters active: slot must match BOTH (ore AND drill on same slot)\n                const oreMatches = selectedOres.includes(oreType);\n                const drillMatches = matchesSelectedDrill(drillType, selectedDrills);\n\n                if (oreMatches && drillMatches) {\n                    hasMatch = true;\n                    break;\n                }\n            } else if (isOreFilterActive) {\n                // ONLY ore filter active: match if ore matches (any drill state)\n                if (selectedOres.includes(oreType)) {\n                    hasMatch = true;\n                    break;\n                }\n            } else if (isDrillFilterActive) {\n                // ONLY drill filter active: match if drill matches on any identified ore (not unknown)\n                const drillMatches = matchesSelectedDrill(drillType, selectedDrills, {\n                    requireKnownOre: true,\n                    oreType\n                });\n\n                if (drillMatches) {\n                    hasMatch = true;\n                    break;\n                }\n            }\n        }\n\n        if (hasMatch) {\n            icon.classList.add('ore-highlighted');\n        } else {\n            icon.classList.add('ore-dimmed');\n        }\n    });\n}\n\n// Function to apply NULL sector ore filtering (for Prometheus map)\nfunction applyOreDepositFiltering() {\n    if (!mapLayerOres) return;\n\n    const filterState = getFilterState();\n    if (!filterState || !filterState.prometheusNull) return;\n\n    const showNullSectorOres = filterState.prometheusNull.ore;\n\n    mapLayerOres.eachLayer(layer => {\n        if (!layer || !layer.isNullSectorOre) return;\n\n        const icon = layer.getElement();\n        if (!icon) return;\n\n        // Hide NULL sector ores when filter is disabled\n        icon.style.display = showNullSectorOres ? '' : 'none';\n    });\n}\n\n// Initialize ore filter when DOM is ready\nif (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', initOreFilter);\n} else {\n    initOreFilter();\n}\n"
