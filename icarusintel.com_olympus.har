          "content": {
            "size": 507,
            "mimeType": "text/javascript",
            "text": "(function () {\n  L.GridLayer.IcarusGrid = L.GridLayer.extend({\n    createTile: function (coords) {\n      var tile = document.createElement('div');\n      tile.className = 'icarus-grid-tile';\n      tile.innerHTML = intToChar(coords.x) + (coords.y + 1);\n      return tile;\n    }\n  });\n\n  L.gridLayer.icarusGrid = function (opts) {\n    var icarusGrid = new L.GridLayer.IcarusGrid(opts);\n    return icarusGrid;\n  };\n\n  function intToChar(int) {\n    return String.fromCharCode('A'.charCodeAt(0) + int);\n  }\n})();\n"
