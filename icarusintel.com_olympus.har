          "cookies": [],
          "content": {
            "size": 2239,
            "mimeType": "text/javascript",
            "text": "let mapLayerGeysers = null;\nlet mapLayerGeysersName = '';\nlet cachedGeysersData = {};\n\nfunction toggleGeysersLayer(state) {\n    if (!state) {\n        if (mapLayerGeysers != null && map.hasLayer(mapLayerGeysers)) {\n            map.removeLayer(mapLayerGeysers);\n        }\n        return;\n    }\n\n    const mapName = selectedMapParent;\n\n    if (mapLayerGeysersName !== mapName) {\n        //Load new map - requires data to be pre-loaded\n        if (cachedGeysersData[mapName]) {\n            setGeysersData(mapName, cachedGeysersData[mapName], true);\n        }\n    } else {\n        if (mapLayerGeysers != null && !map.hasLayer(mapLayerGeysers)) {\n            mapLayerGeysers.addTo(map);\n        }\n    }\n}\n\nfunction setGeysersData(mapName, data, showInMap) {\n    //Remove\n    if (mapLayerGeysers != null && map.hasLayer(mapLayerGeysers)) {\n        map.removeLayer(mapLayerGeysers);\n    }\n\n    // Check cache first\n    if (mapLayerGeysersName === mapName && mapLayerGeysers != null) {\n        if (showInMap) {\n            mapLayerGeysers.addTo(map);\n        }\n        return;\n    }\n\n    mapLayerGeysersName = mapName;\n    cachedGeysersData[mapName] = data;\n    filterSetDisabledState(filterGeysers, true);\n\n    let geyserMarkers = [];\n\n    Object.values(data).forEach(enzymeGeyser => {\n        let popupText = addDevTooltip('ENZYME GEYSER<br>TYPE: ' + enzymeGeyser.type, enzymeGeyser);\n\n        let geyserMarker = L.marker(map.unproject([enzymeGeyser.x, enzymeGeyser.y], MAP_ZOOM), { icon: geyser });\n        geyserMarker.bindPopup(popupText, { autoPan: false });\n        geyserMarker.geyserData = enzymeGeyser;\n        geyserMarkers.push(geyserMarker);\n    });\n\n\n    //Empty Geysers.\n    if (geyserMarkers.length === 0) {\n        filterHideRow(filterGeysers, true);\n        filterSetDisabledState(filterGeysers, false);\n        return;\n    }\n\n    filterHideRow(filterGeysers, false);\n\n    mapLayerGeysers = L.layerGroup(geyserMarkers);\n\n    if (showInMap) {\n        mapLayerGeysers.addTo(map);\n    }\n    filterSetDisabledState(filterGeysers, false);\n}\n\nfunction updateGeysersState() {\n    updateLayerState(mapLayerGeysers, (layer) => ({\n        popup: addDevTooltip('ENZYME GEYSER<br>TYPE: ' + layer.geyserData.type, layer.geyserData)\n    }));\n}\n"
          },
          "redirectURL": "",
          "headersSize": -1,
          "bodySize": 0,
          "_transferSize": 0,
