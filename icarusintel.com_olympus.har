            "mimeType": "text/javascript",
            "text": "// SIC Icarus Intel version #\n// Version numbers are now injected from PHP Config\\Version class in map.php\n// const icarusIntelVersion = defined in map.php\n// const icarusGameVersion = defined in map.php\n// const icarusIntelLastestUpdate = defined in map.php\n// Note: Recent changes content is now in map.php in the What's New section HTML\nconst mapAttribution = 'FinallyRage, CheevoSeeker, ENeMy_DaVe';\n\n// Debug global parameters - accessible from browser console via window.DEBUG\n// Example: DEBUG.debugSaving = true; (to enable detailed saving logs)\nwindow.DEBUG = {\n    debugBase: true,        // Enable/disable basic map operations (load, save, conflicts) - ENABLED BY DEFAULT\n    debugSaving: false,     // Enable/disable detailed saving debug logs\n    debugChanges: false,    // Enable/disable change tracking debug logs\n    debugText: false        // Enable/disable general text/UI debug logs\n};\n\n/**\n * Debug logging function that prints based on debug flags\n * @param {string} category - Category of the log: 'base', 'saving', 'changes', 'text'\n * @param {...any} args - Arguments to pass to console.log\n */\nfunction debugLog(category, ...args) {\n    switch (category) {\n        case 'base':\n            if (DEBUG.debugBase) console.log(...args);\n            break;\n        case 'saving':\n            if (DEBUG.debugSaving) console.log(...args);\n            break;\n        case 'changes':\n            if (DEBUG.debugChanges) console.log(...args);\n            break;\n        case 'text':\n            if (DEBUG.debugText) console.log(...args);\n            break;\n        default:\n            // If no category or unknown category, check if any debug flag is enabled\n            if (DEBUG.debugBase || DEBUG.debugSaving || DEBUG.debugChanges || DEBUG.debugText) {\n                console.log(...args);\n            }\n    }\n}\n\nconst filterGrid = \"mapFilterSwitchGrid\";\nconst filterExotics = \"mapFilterSwitchExotics\";\nconst filterGeysers = \"mapFilterSwitchGeysers\";\nconst filterOilGeysers = \"mapFilterSwitchOilGeysers\";\nconst filterOreDeposits = \"mapFilterSwitchOreDeposit\";\nconst filterCaves = \"mapFilterSwitchCaves\";\nconst filterCustomMarkers = \"mapFilterSwitchCustomMarkers\";\nconst filterPrometheusNullCaves = \"mapFilterSwitchPrometheusNullCaves\";\nconst filterPrometheusNullOre = \"mapFilterSwitchPrometheusNullOre\";\nconst filterPrometheusNullMap = \"mapFilterSwitchPrometheusNullMap\";\n\n// Loading overlay functions\nfunction showMapLoading() {\n    const overlay = document.getElementById('mapLoadingOverlay');\n    if (overlay) {\n        overlay.style.display = 'flex';\n    }\n}\n\nfunction hideMapLoading() {\n    const overlay = document.getElementById('mapLoadingOverlay');\n    if (overlay) {\n        overlay.style.display = 'none';\n    }\n}\n\nconst MAP_ZOOM = 5; // zoom, coordinates are based on this zoom level\nconst MAP_SIZE = 8192; // map size in pixels at max zoom level\nconst PASTE_COORDS_ROTATION_OFFSET = 90; // Rotation adjustment for pasted X Y Z Rotation format\n\n// Reverse map code mapping (from single letter to full map name)\nconst MAP_CODE_TO_NAME = {\n    'P': 'prometheus',\n    'S': 'styx',\n    'O': 'olympus',\n    'EL': 'elysium',\n    'W': 'outpost1',\n    'H': 'outpost2',\n    'I': 'outpost3',\n    'T': 'outpost4',\n    'E': 'outpost6',\n    'C': 'outpost7',\n    'R': 'outpost8',\n    'Q': 'outpost12'\n};\n\nconst MAP_CODE_PREFIXES_DESC = Object.keys(MAP_CODE_TO_NAME).sort((a, b) => b.length - a.length);\n\nfunction getMapNameFromDevCaveId(devCaveId) {\n    if (!devCaveId) return null;\n\n    const normalizedId = devCaveId.toString().toUpperCase();\n    const matchedPrefix = MAP_CODE_PREFIXES_DESC.find(prefix => normalizedId.startsWith(prefix));\n\n    return matchedPrefix ? MAP_CODE_TO_NAME[matchedPrefix] : null;\n}\n\n// Declare map object\nvar map = L.map('map', {\n    attributionotificationControl: true,\n    crs: L.CRS.Simple,\n    maxZoom: 6,\n    // tileSize: 512,\n    zoomControl: false\n}).setView([0, 0], 2);\n\n// Flag to track if we should save map view changes\nvar shouldSaveMapView = false;\n\n// Set maxBounds with generous padding to allow panning to see content under the sidebar\n// Sidebar is ~450px wide, so we add extra padding on the left side\n// This prevents infinite panning while allowing users to view all map content even when obscured by UI\nvar mapBounds = L.latLngBounds(\n    map.unproject([-8192, 16384], MAP_ZOOM),  // Extra left padding for sidebar\n    map.unproject([16384, -8192], MAP_ZOOM)   // Symmetric padding on other sides\n);\nmap.setMaxBounds(mapBounds);\n\nconst TILE_BOUNDS = L.latLngBounds(\n    map.unproject([0, MAP_SIZE], MAP_ZOOM),\n    map.unproject([MAP_SIZE, 0], MAP_ZOOM)\n);\n\n// Check if there's a saved view for the current map before applying default fitBounds\n// This allows the saved view to be restored without being overridden\n(function () {\n    try {\n        const currentMap = localStorage.currentMap || 'olympus';\n        const filterStateKey = `filterState_${currentMap}`;\n        const storedState = localStorage.getItem(filterStateKey);\n\n        if (storedState) {\n            const filterState = JSON.parse(storedState);\n            if (filterState.mapView && filterState.mapView.zoom !== null && filterState.mapView.center !== null) {\n                // Set the saved view immediately instead of fitBounds\n                map.setView([filterState.mapView.center.lat, filterState.mapView.center.lng], filterState.mapView.zoom);\n                return; // Skip fitBounds\n            }\n        }\n    } catch (e) {\n        console.warn('Could not restore saved map view during initialization:', e);\n    }\n\n    // If no saved view exists, use default fitBounds\n    map.fitBounds(TILE_BOUNDS);\n})();\n\n// Legacy compatibility wrapper for old Leaflet notification API\n// All notifications now use the custom NotificationSystem (notifications.js)\n// which positions notifications below the map status indicator (top right at 70px)\n// to avoid overlapping with the save/sync status icon\nconst notificationControl = {\n    success: function (title, message, options) {\n        const fullMessage = message ? `${title}: ${message}` : title;\n        const timeout = options && options.timeout !== undefined ? options.timeout : undefined;\n        if (typeof NotificationSystem !== 'undefined') {\n            NotificationSystem.success(fullMessage, timeout);\n        }\n    },\n    info: function (title, message, options) {\n        const fullMessage = message ? `${title}: ${message}` : title;\n        const timeout = options && options.timeout !== undefined ? options.timeout : undefined;\n        if (typeof NotificationSystem !== 'undefined') {\n            NotificationSystem.info(fullMessage, timeout);\n        }\n    },\n    warning: function (title, message, options) {\n        const fullMessage = message ? `${title}: ${message}` : title;\n        const timeout = options && options.timeout !== undefined ? options.timeout : undefined;\n        if (typeof NotificationSystem !== 'undefined') {\n            NotificationSystem.warning(fullMessage, timeout);\n        }\n    },\n    alert: function (title, message, options) {\n        const fullMessage = message ? `${title}: ${message}` : title;\n        const timeout = options && options.timeout !== undefined ? options.timeout : undefined;\n        if (typeof NotificationSystem !== 'undefined') {\n            NotificationSystem.error(fullMessage, timeout);\n        }\n    },\n    danger: function (title, message, options) {\n        const fullMessage = message ? `${title}: ${message}` : title;\n        const timeout = options && options.timeout !== undefined ? options.timeout : undefined;\n        if (typeof NotificationSystem !== 'undefined') {\n            NotificationSystem.error(fullMessage, timeout);\n        }\n    },\n    clear: function () {\n        // NotificationSystem auto-removes notifications, no clear needed\n    }\n};\n\n// Declare tile layer boundaries\n// var tileBounds = L.latLngBounds(map.unproject([0, 8192], MAP_ZOOM), map.unproject([8192, 0], MAP_ZOOM));\n// map.fitBounds(tileBounds);\n\n//Basic Blue Marker open to public\n// Find Cave Marker\n// var marker = L.marker(map.unproject([4096, 4096], MAP_ZOOM), { draggable: true });\nvar marker = L.marker(\n    map.unproject([4096, 4096], MAP_ZOOM),\n    { draggable: true }\n);\n\n\n//Set Marker intial popup\nmarker.bindPopup('Clicked ' + map.project(marker.getLatLng(), MAP_ZOOM.toString()) + '<br><b>Submit new cave or correction in the <strong>Feedback</strong> tab.</b>', { autoPan: false }).openPopup();\n\n//Set new text on marker move\nmarker.on('dragend', function (e) {\n    marker.getPopup().setContent('Clicked ' + map.project(marker.getLatLng(), MAP_ZOOM.toString()) + '<br><b>Submit new cave or correction in the <strong>Feedback</strong> tab.</b>').openOn(map);\n});\n\n\n//Misc Icons\nvar oob = L.icon({ iconUrl: 'icon/oob.png', iconSize: [16, 16], iconAnchor: [8, 8], popupAnchor: [0, -16] });\nvar drop = L.icon({ iconUrl: 'icon/Dropship.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar DeliveryShip = L.icon({ iconUrl: 'icon/DeliveryShip.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar target = L.icon({ iconUrl: 'icon/target.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar target_nav = L.icon({ iconUrl: 'icon/target.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24], className: 'nav-target-icon' });\nvar box = L.icon({ iconUrl: 'icon/box.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar circle = L.icon({ iconUrl: 'icon/circle.png', iconSize: [64, 64], iconAnchor: [32, 32], popupAnchor: [0, -32] });\nvar radar = L.icon({ iconUrl: 'icon/radar.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar danger = L.icon({ iconUrl: 'icon/dang.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar exotic = L.icon({ iconUrl: 'icon/exotic2.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar geyser = L.icon({ iconUrl: 'icon/geyser.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar geyser_oil = L.icon({ iconUrl: 'icon/geyser_oil.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar star = L.icon({ iconUrl: 'icon/star.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\n\nvar deposit = L.icon({ iconUrl: 'icon/exotics_deposit.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar deposit_unknown = L.icon({ iconUrl: 'icon/exotics_deposit_question.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar deposit_marked = L.icon({ iconUrl: 'icon/exotics_deposit_marked.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar deposit_mined = L.icon({ iconUrl: 'icon/exotics_deposit_mined2.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar deposit_invalid = L.icon({ iconUrl: 'icon/exotics_deposit_no.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\n\nvar red_exotics = L.icon({ iconUrl: 'icon/exotics_deposit_red.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar red_exotics_unknown = L.icon({ iconUrl: 'icon/exotics_deposit_red_question.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar red_exotics_marked = L.icon({ iconUrl: 'icon/exotics_deposit_red_marked.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar red_exotics_mined = L.icon({ iconUrl: 'icon/exotics_deposit_red_mined2.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar red_exotics_invalid = L.icon({ iconUrl: 'icon/exotics_deposit_red_no.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar red_exotics_plant = L.icon({ iconUrl: 'icon/exotic_red_plant.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\n\nvar uranium_exotics = L.icon({ iconUrl: 'icon/exotics_deposit_uranium.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar uranium_exotics_unknown = L.icon({ iconUrl: 'icon/exotics_deposit_uranium_question.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar uranium_exotics_marked = L.icon({ iconUrl: 'icon/exotics_deposit_uranium_marked.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar uranium_exotics_mined = L.icon({ iconUrl: 'icon/exotics_deposit_uranium_mined2.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\nvar uranium_exotics_invalid = L.icon({ iconUrl: 'icon/exotics_deposit_uranium_no.png', iconSize: [48, 48], iconAnchor: [24, 24], popupAnchor: [0, -24] });\n\nvar boss_mammoth = L.icon({ iconUrl: 'icon/boss_mammoth.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar boss_scorpion = L.icon({ iconUrl: 'icon/boss_scorpion.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar boss_swords = L.icon({ iconUrl: 'icon/boss_swords.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar fish_hook = L.icon({ iconUrl: 'icon/fish_hook.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar house = L.icon({ iconUrl: 'icon/house.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mission_cave = L.icon({ iconUrl: 'icon/mission_cave.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar beacon = L.icon({ iconUrl: 'icon/beacon.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar construction = L.icon({ iconUrl: 'icon/construction.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar letter_alpha = L.icon({ iconUrl: 'icon/letter_alpha.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar letter_beta = L.icon({ iconUrl: 'icon/letter_beta.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar letter_delta = L.icon({ iconUrl: 'icon/letter_delta.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar letter_epsilon = L.icon({ iconUrl: 'icon/letter_epsilon.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar letter_eta = L.icon({ iconUrl: 'icon/letter_eta.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar letter_gamma = L.icon({ iconUrl: 'icon/letter_gamma.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar letter_lambda = L.icon({ iconUrl: 'icon/letter_lambda.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar letter_omega = L.icon({ iconUrl: 'icon/letter_omega.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar letter_psi = L.icon({ iconUrl: 'icon/letter_psi.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar letter_theta = L.icon({ iconUrl: 'icon/letter_theta.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar letter_zeta = L.icon({ iconUrl: 'icon/letter_zeta.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar npc = L.icon({ iconUrl: 'icon/npc.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\n\n//Deep Ore Vein Icons\nvar mining = L.icon({ iconUrl: 'icon/dov.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_mined = L.icon({ iconUrl: 'icon/dov_mined.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_unknown = L.icon({ iconUrl: 'icon/dov_unknown.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_aluminum = L.icon({ iconUrl: 'icon/dov_aluminum.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_clay = L.icon({ iconUrl: 'icon/dov_clay.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_coal = L.icon({ iconUrl: 'icon/dov_coal.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_copper = L.icon({ iconUrl: 'icon/dov_copper.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_frozenwood = L.icon({ iconUrl: 'icon/dov_frozenwood.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_gold = L.icon({ iconUrl: 'icon/dov_gold.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_iron = L.icon({ iconUrl: 'icon/dov_iron.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_limestone = L.icon({ iconUrl: 'icon/dov_limestone.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_obsidian = L.icon({ iconUrl: 'icon/dov_obsidian.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_oxite = L.icon({ iconUrl: 'icon/dov_oxite.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_platinum = L.icon({ iconUrl: 'icon/dov_platinum.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_salt = L.icon({ iconUrl: 'icon/dov_salt.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_scoria = L.icon({ iconUrl: 'icon/dov_scoria.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_silica = L.icon({ iconUrl: 'icon/dov_silica.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_stone = L.icon({ iconUrl: 'icon/dov_stone.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_sulfur = L.icon({ iconUrl: 'icon/dov_sulfur.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_supercooledice = L.icon({ iconUrl: 'icon/dov_supercooledice.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\nvar mining_titanium = L.icon({ iconUrl: 'icon/dov_titanium.png', iconSize: [32, 32], iconAnchor: [16, 16], popupAnchor: [0, -16] });\n\nconst DRILL_TYPE_CONFIG = Object.freeze({\n    b: Object.freeze({ id: 'b', label: 'Biofuel', tooltip: 'Biofuel', icon: 'network_node', cssClass: 'drill-biofuel' }),\n    e: Object.freeze({ id: 'e', label: 'Electric', tooltip: 'Electric', icon: 'bolt', cssClass: 'drill-electric' }),\n    o: Object.freeze({ id: 'o', label: 'Oil', tooltip: 'Oil', icon: 'water_drops', cssClass: 'drill-oil' })\n});\n\nfunction getDrillTypeConfig(drillType) {\n    return DRILL_TYPE_CONFIG[drillType] || null;\n}\n\nfunction getKnownDrillTypeIds() {\n    return Object.keys(DRILL_TYPE_CONFIG);\n}\n\nfunction getDrillMenuOptions() {\n    const options = [\n        { id: undefined, label: '', icon: 'close', cssClass: '', tooltip: 'None' }\n    ];\n\n    getKnownDrillTypeIds().forEach(drillId => {\n        const drillType = DRILL_TYPE_CONFIG[drillId];\n        options.push({\n            id: drillType.id,\n            label: '',\n            icon: drillType.icon,\n            cssClass: drillType.cssClass,\n            tooltip: drillType.tooltip\n        });\n    });\n\n    return options;\n}\n\nfunction getDrillFilterOptions() {\n    const options = [\n        { id: 'none', label: 'No Drill', icon: '', cssClass: '' }\n    ];\n\n    getKnownDrillTypeIds().forEach(drillId => {\n        const drillType = DRILL_TYPE_CONFIG[drillId];\n        options.push({\n            id: drillType.id,\n            label: drillType.label,\n            icon: drillType.icon,\n            cssClass: drillType.cssClass\n        });\n    });\n\n    return options;\n}\n\n//This defines the order for deep ore deposits, it is used for loading saved data, for deposit switching on click and also changing with context menu\n/**\n * Create drill status icon element\n * @param {string} drillType - 'b' for biofuel, 'e' for electric, 'o' for oil\n * @param {string} additionalClass - Optional additional CSS class\n * @returns {HTMLElement|null} The drill icon element or null if no drill\n */\nfunction createDrillStatusIcon(drillType, additionalClass = '') {\n    if (!drillType) return null;\n\n    const drillConfig = getDrillTypeConfig(drillType);\n    if (!drillConfig) return null;\n\n    const drillOverlay = document.createElement('i');\n    drillOverlay.className = `material-symbols-outlined ${additionalClass}`;\n\n    drillOverlay.textContent = drillConfig.icon;\n    if (drillConfig.cssClass) {\n        drillOverlay.classList.add(drillConfig.cssClass);\n    }\n\n    return drillOverlay;\n}\n\nvar oreDepositTypes = [\n    { icon: mining_unknown, text: 'UNKNOWN', stateId: '?' }, //UNKNOWN\n    { icon: mining_aluminum, text: 'ALUMINUM', stateId: 'a' },\n    { icon: mining_clay, text: 'CLAY', stateId: 'cl' }, //PROMETHEUS ONLY\n    { icon: mining_coal, text: 'COAL', stateId: 'c' },\n    { icon: mining_copper, text: 'COPPER', stateId: 'cu' },\n    { icon: mining_gold, text: 'GOLD', stateId: 'g' },\n    { icon: mining_iron, text: 'IRON', stateId: 'i' },\n    { icon: mining_obsidian, text: 'OBSIDIAN', stateId: 'o' }, //PROMETHEUS ONLY\n    { icon: mining_oxite, text: 'OXITE', stateId: 'ox' },\n    { icon: mining_platinum, text: 'PLATINUM', stateId: 'p' },\n    { icon: mining_salt, text: 'SALT', stateId: 'sa' },\n    { icon: mining_scoria, text: 'SCORIA', stateId: 'sc' }, //PROMETHEUS ONLY\n    { icon: mining_silica, text: 'SILICA', stateId: 'si' },\n    { icon: mining_stone, text: 'STONE', stateId: 'st' },\n    { icon: mining_sulfur, text: 'SULFUR', stateId: 'su' },\n    { icon: mining_titanium, text: 'TITANIUM', stateId: 't' },\n    { icon: mining_mined, text: 'EMPTY ORE', stateId: 'm' },\n];\n\nvar oreDepositTypesVariantIce = [\n    { icon: mining_supercooledice, text: 'SUPER COOLED ICE', stateId: 'ice' },\n    { icon: mining_mined, text: 'EMPTY ORE', stateId: 'm' },\n];\n\nvar oreDepositTypesVariantLimestone = [\n    { icon: mining_limestone, text: 'LIMESTONE', stateId: 'limestone' },\n    { icon: mining_mined, text: 'EMPTY ORE', stateId: 'm' },\n];\n\nvar oreDepositTypesVariantWood = [\n    { icon: mining_frozenwood, text: 'FROZEN TRUNK', stateId: 'wood' },\n    { icon: mining_mined, text: 'EMPTY ORE', stateId: 'm' },\n];\n\n//Filer out prometheus ores, to show on other maps\nvar oreDepositTypesNoPrometheus = oreDepositTypes.filter(i => (i.icon != mining_clay && i.icon != mining_obsidian && i.icon != mining_scoria));\n\nvar oreDepositTypesByVariant = {\n    'ice': oreDepositTypesVariantIce,\n    'limestone': oreDepositTypesVariantLimestone,\n    'wood': oreDepositTypesVariantWood,\n}\n\n//DevMarker for DevTools - using red dev cave icon or pin icon\nvar cave_icon_dev = L.icon({ iconUrl: 'icon/icon_cave_dev.png', iconSize: [32, 32], iconAnchor: [16, 32], popupAnchor: [0, -32] });\nvar pin_icon_dev = L.icon({ iconUrl: 'icon/icon_marker_dev.png', iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], className: 'dev-marker-icon' });\nvar markerC = L.marker(map.unproject([4096, 4096], MAP_ZOOM), { draggable: true, icon: cave_icon_dev });\n\n// Function to get unified dev marker tooltip message\nfunction getDevMarkerTooltip(lat, lng) {\n    return `Lat: ${lat.toFixed(2)}, Lng: ${lng.toFixed(2)}<br>Submit new cave or correction in the <strong>Feedback</strong> tab.`;\n}\n\n// Function to toggle between cave and pin icon\nfunction toggleMarkerIcon(usePinIcon) {\n    if (markerC) {\n        const newIcon = usePinIcon ? pin_icon_dev : cave_icon_dev;\n        markerC.setIcon(newIcon);\n    }\n}\n\n//Set Dev Marker intial popup\nmarkerC.bindPopup('Clicked ' + map.project(markerC.getLatLng(), MAP_ZOOM.toString()) + '<br><b>Submit new cave or correction in the <strong>Feedback</strong> tab.</b>', { autoPan: false }).openPopup();\n\n//Set new text on Dev marker move\nmarkerC.on('dragend', function (e) {\n    markerC.getPopup().setContent('Clicked ' + map.project(markerC.getLatLng(), MAP_ZOOM.toString()) + '<br><b>Submit new cave or correction in the <strong>Feedback</strong> tab.</b>').openOn(map);\n    cave_update();\n});\n\n// Create Sidebar on left side\nvar sidebar = L.control.sidebar('sidebar', { position: 'left' }).addTo(map);\n\nsidebar.open('options');\n\n// Initialize custom zoom control - update button states based on zoom level\nfunction initCustomZoomControl() {\n    const zoomInBtn = document.getElementById('zoomInBtn');\n    const zoomOutBtn = document.getElementById('zoomOutBtn');\n\n    if (!zoomInBtn || !zoomOutBtn) return;\n\n    // Update button states on zoom change\n    function updateZoomButtons() {\n        const currentZoom = map.getZoom();\n        const maxZoom = map.getMaxZoom();\n        const minZoom = map.getMinZoom();\n\n        zoomInBtn.disabled = currentZoom >= maxZoom;\n        zoomOutBtn.disabled = currentZoom <= minZoom;\n    }\n\n    map.on('zoomend', updateZoomButtons);\n    updateZoomButtons(); // Initial state\n}\n\n// Initialize custom zoom control after map is ready\ninitCustomZoomControl();\n\n// Feedback popup functionality\nfunction showFeedbackPopup() {\n    // Check if popup has been shown before (using localStorage)\n    const popupShown = localStorage.getItem('feedbackPopupShown');\n    const lastShown = localStorage.getItem('feedbackPopupLastShown');\n    const now = Date.now();\n    const feedbackPopupCooldownMs = 14 * 24 * 60 * 60 * 1000;\n\n    // Show popup once every 14 days.\n    if (!popupShown || !lastShown || (now - parseInt(lastShown, 10)) > feedbackPopupCooldownMs) {\n        // Create popup element\n        const popup = document.createElement('div');\n        popup.className = 'feedback-popup';\n        popup.innerHTML = `\n            <div class=\"feedback-popup-icon\">\n                <i class=\"material-symbols-outlined\">comment</i>\n            </div>\n            <div class=\"feedback-popup-content\">\n                <h4>Share Your Feedback!</h4>\n                <p>Found a bug or have a suggestion? Let us know and help improve Icarus Intel!</p>\n            </div>\n            <button class=\"feedback-popup-close\" aria-label=\"Close\">&times;</button>\n        `;\n\n        document.body.appendChild(popup);\n\n        // Add pulsing effect to feedback tab\n        const feedbackTab = document.querySelector('a[href=\"#feedback\"]');\n        if (feedbackTab) {\n            feedbackTab.parentElement.classList.add('feedback-tab-pulse');\n        }\n\n        // Auto-hide after 10 seconds\n        const hideTimeout = setTimeout(() => {\n            hideFeedbackPopup(popup, feedbackTab);\n        }, 10000);\n\n        // Close button handler\n        const closeBtn = popup.querySelector('.feedback-popup-close');\n        closeBtn.addEventListener('click', () => {\n            clearTimeout(hideTimeout);\n            hideFeedbackPopup(popup, feedbackTab);\n        });\n\n        // Click on popup to open feedback tab\n        popup.addEventListener('click', (e) => {\n            if (!e.target.classList.contains('feedback-popup-close')) {\n                clearTimeout(hideTimeout);\n                hideFeedbackPopup(popup, feedbackTab);\n                sidebar.open('feedback');\n            }\n        });\n\n        // Mark as shown\n        localStorage.setItem('feedbackPopupShown', 'true');\n        localStorage.setItem('feedbackPopupLastShown', now.toString());\n    }\n}\n\nfunction hideFeedbackPopup(popup, feedbackTab) {\n    popup.style.animation = 'slideInLeft 0.3s ease-out reverse';\n    setTimeout(() => {\n        popup.remove();\n    }, 300);\n\n    if (feedbackTab) {\n        feedbackTab.parentElement.classList.remove('feedback-tab-pulse');\n    }\n}\n\n// Show feedback popup after map loads\nsetTimeout(showFeedbackPopup, 2000);\n\n// Function to expand/collapse dev sections\nfunction expandDevSections(expandAll = false) {\n    const sections = document.querySelectorAll('.dev-section');\n    sections.forEach(section => {\n        section.open = expandAll;\n    });\n\n    // If not expanding all, only expand cave marker section\n    if (!expandAll) {\n        const caveMarkerSection = document.getElementById('caveMarkerSection');\n        if (caveMarkerSection) {\n            caveMarkerSection.open = true;\n        }\n    }\n}\n\n// Function to load dev cave data from URL parameters\nfunction loadDevCaveFromURL() {\n    // Check URL hash for dev tab and dev cave parameters\n    if (!window.location.hash.startsWith('#dev')) return;\n\n    devhide(); // Show dev elements\n    sidebar.open('dev');\n\n    // Expand all sections when URL has #dev\n    expandDevSections(true);\n\n    // Show generate code section\n    const generateCodeSection = document.querySelector('.generate-code-section');\n    if (generateCodeSection) {\n        generateCodeSection.style.display = 'block';\n    }\n\n    // Show resultsC section when #dev is in URL\n    const resultsCSection = document.getElementById('resultsC');\n    if (resultsCSection) {\n        resultsCSection.style.display = 'block';\n    }\n\n    // Check for dev cave parameters\n    const hashParts = window.location.hash.split('&');\n    if (hashParts.length > 1) {\n        // Parse parameters from URL\n        const params = new URLSearchParams(hashParts.slice(1).join('&'));\n        const devCaveId = params.get('devCave');\n        const x = params.get('x');\n        const y = params.get('y');\n        const r = params.get('r');\n        const origX = params.get('origX');\n        const origY = params.get('origY');\n        const origR = params.get('origR');\n\n        // Extract map from devCaveId by matching known map code prefixes.\n        let targetMap = null;\n        if (devCaveId && devCaveId.length > 0) {\n            targetMap = getMapNameFromDevCaveId(devCaveId);\n\n            if (targetMap) {\n                const currentMap = localStorage.currentMap || 'olympus';\n                if (targetMap !== currentMap && typeof switchMap !== 'undefined') {\n                    // Switch to the correct map first\n                    switchMap(targetMap);\n\n                    // Wait for map to load before continuing\n                    setTimeout(() => {\n                        finishLoadingDevCave(params, devCaveId, x, y, r, origX, origY, origR);\n                    }, 600);\n                    return;\n                }\n            }\n        }\n\n        // If no map switch needed, continue immediately\n        finishLoadingDevCave(params, devCaveId, x, y, r, origX, origY, origR);\n    }\n}\n\n// Helper function to complete dev cave loading after map switch\nfunction finishLoadingDevCave(params, devCaveId, x, y, r, origX, origY, origR) {\n    if (x && y && r) {\n        if (devCaveId) {\n            // Moving existing cave\n            window.copiedCaveId = devCaveId;\n            window.copiedCaveOriginalX = origX || x;\n            window.copiedCaveOriginalY = origY || y;\n            window.copiedCaveOriginalRotation = origR || r;\n            window.isAddingNewCave = false;\n\n            // Set the caveId field for SQL generation\n            const caveIdField = document.getElementById('caveId');\n            if (caveIdField) {\n                caveIdField.value = devCaveId;\n            }\n        } else {\n            // Adding new cave\n            window.copiedCaveId = null;\n            window.copiedCaveOriginalX = null;\n            window.copiedCaveOriginalY = null;\n            window.copiedCaveOriginalRotation = null;\n            window.isAddingNewCave = true;\n        }\n\n        // Update form fields\n        updateCaveMarkerFields(x, y, r);\n\n        // Load all metadata from URL\n        const size = params.get('csz');\n        const ore = params.get('cor');\n        const fuzzyOre = params.get('cfo');\n        const deepOre = params.get('cdo');\n        const worm = params.get('cwr');\n        const wormMin = params.get('cwn');\n        const wormMax = params.get('cwx');\n        const water = params.get('cwt');\n        const mush = params.get('cms');\n        const glit = params.get('cuf');\n        const haza = params.get('chz');\n        const tunn = params.get('ctn');\n        const fall = params.get('cwf');\n        const floo = params.get('cfl');\n        const unde = params.get('cuw');\n        const underg = params.get('cug');\n        const notes = params.get('cnt');\n\n        if (size) document.getElementById('csz').value = size;\n        if (ore) document.getElementById('cor').value = ore;\n        if (fuzzyOre) document.getElementById('cfo').checked = (fuzzyOre === '1');\n        if (deepOre) document.getElementById('cdo').value = deepOre;\n        if (worm) document.getElementById('cwr').checked = (worm === '1');\n        if (wormMin) document.getElementById('cwn').value = wormMin;\n        if (wormMax) document.getElementById('cwx').value = wormMax;\n        if (water) document.getElementById('cwt').checked = (water === '1');\n        if (mush) document.getElementById('cms').checked = (mush === '1');\n        if (glit) document.getElementById('cuf').checked = (glit === '1');\n        if (haza) document.getElementById('chz').checked = (haza === '1');\n        if (tunn) document.getElementById('ctn').checked = (tunn === '1');\n        if (fall) document.getElementById('cwf').checked = (fall === '1');\n        if (floo) document.getElementById('cfl').checked = (floo === '1');\n        if (unde) document.getElementById('cuw').checked = (unde === '1');\n        if (underg) document.getElementById('cug').checked = (underg === '1');\n        if (notes) document.getElementById('cnt').value = notes;\n\n        // Update marker position\n        markerC.setLatLng(map.unproject([parseFloat(x), parseFloat(y)], MAP_ZOOM));\n        markerC.setRotationAngle(parseFloat(r));\n\n        // Show marker\n        const markerCheckbox = document.getElementById('marker');\n        if (markerCheckbox && !markerCheckbox.checked) {\n            markerCheckbox.checked = true;\n            markerC.addTo(map);\n        }\n\n        // Update the display\n        updateCopiedCaveInfo();\n\n        // Pan to marker (use a delay to ensure it happens after any saved view restoration)\n        setTimeout(() => {\n            map.panTo(markerC.getLatLng());\n        }, 200);\n\n        // Generate and display SQL INSERT statement\n        if (typeof cave_search === 'function') {\n            cave_search();\n        }\n    }\n}\n\nlet mapselect = 'olympus';\n\n// Navigation marker variable\nlet currentNavMarker = null;\n\n//Function to add the basic cave marker (blue icon)\nfunction scheduleM(event) {\n    if (this.checked == true) {\n        marker.addTo(map);\n    } else {\n        map.removeLayer(marker);\n    }\n}\n\nlet customMarkerLastLatLng = null;\nlet customMarkerPopup = L.popup({\n    closeOnClick: false,\n    autoClose: false,\n    autoPan: true,\n    autoPanPadding: [20, 20]\n});\n\n//Function to add the Dev cave marker (cave icon)\nfunction scheduleMC(event) {\n    if (this.checked == true) {\n        markerC.addTo(map);\n        // If no cave is copied when enabling marker, we're in \"add new cave\" mode\n        if (!window.copiedCaveId && !window.isAddingNewCave) {\n            window.isAddingNewCave = true;\n            updateCopiedCaveInfo();\n        }\n    } else {\n        map.removeLayer(markerC);\n    }\n}\n\nlet activeUiTooltipTarget = null;\nlet uiHoverTooltipElement = null;\n\nfunction getUiHoverTooltipElement() {\n    if (uiHoverTooltipElement) {\n        return uiHoverTooltipElement;\n    }\n\n    uiHoverTooltipElement = document.getElementById('uiHoverTooltip');\n    if (!uiHoverTooltipElement) {\n        uiHoverTooltipElement = document.createElement('div');\n        uiHoverTooltipElement.id = 'uiHoverTooltip';\n        uiHoverTooltipElement.className = 'ui-hover-tooltip';\n        uiHoverTooltipElement.setAttribute('role', 'tooltip');\n        uiHoverTooltipElement.setAttribute('aria-hidden', 'true');\n        document.body.appendChild(uiHoverTooltipElement);\n    }\n\n    return uiHoverTooltipElement;\n}\n\nfunction setIconTooltip(control, tooltipText) {\n    if (!control) {\n        return;\n    }\n\n    const normalizedText = (tooltipText || '').toString().trim();\n    if (normalizedText) {\n        control.setAttribute('data-tooltip', normalizedText);\n        if (!control.getAttribute('aria-label')) {\n            control.setAttribute('aria-label', normalizedText);\n        }\n    } else {\n        control.removeAttribute('data-tooltip');\n    }\n\n    control.removeAttribute('title');\n}\n\nwindow.setIconTooltip = setIconTooltip;\n\nfunction getTooltipTarget(node) {\n    if (!(node instanceof Element)) {\n        return null;\n    }\n\n    return node.closest('[data-tooltip]');\n}\n\nfunction canUseUiHoverTooltips() {\n    if (typeof window === 'undefined' || typeof window.matchMedia !== 'function') {\n        return true;\n    }\n\n    return window.matchMedia('(hover: hover) and (pointer: fine)').matches;\n}\n\nfunction positionUiTooltip(target, tooltipElement) {\n    if (!target || !tooltipElement) {\n        return;\n    }\n\n    const rect = target.getBoundingClientRect();\n    const spacing = 10;\n    const viewportPadding = 8;\n\n    let left = rect.left + (rect.width / 2) - (tooltipElement.offsetWidth / 2);\n    left = Math.max(viewportPadding, Math.min(left, window.innerWidth - tooltipElement.offsetWidth - viewportPadding));\n\n    let top = rect.top - tooltipElement.offsetHeight - spacing;\n    if (top < viewportPadding) {\n        top = rect.bottom + spacing;\n    }\n\n    tooltipElement.style.left = `${Math.round(left)}px`;\n    tooltipElement.style.top = `${Math.round(top)}px`;\n}\n\nfunction showUiTooltip(target) {\n    if (!canUseUiHoverTooltips()) {\n        hideUiTooltip();\n        return;\n    }\n\n    if (!target) {\n        return;\n    }\n\n    const tooltipText = target.getAttribute('data-tooltip');\n    if (!tooltipText) {\n        return;\n    }\n\n    const tooltipElement = getUiHoverTooltipElement();\n    tooltipElement.textContent = tooltipText;\n    tooltipElement.classList.add('visible');\n    tooltipElement.setAttribute('aria-hidden', 'false');\n    activeUiTooltipTarget = target;\n    positionUiTooltip(target, tooltipElement);\n}\n\nfunction hideUiTooltip() {\n    const tooltipElement = getUiHoverTooltipElement();\n    tooltipElement.classList.remove('visible');\n    tooltipElement.setAttribute('aria-hidden', 'true');\n    activeUiTooltipTarget = null;\n}\n\nfunction initIconTooltips() {\n    if (document.body.dataset.uiHoverTooltipBound === 'true') {\n        return;\n    }\n\n    if (!canUseUiHoverTooltips()) {\n        hideUiTooltip();\n        document.body.dataset.uiHoverTooltipBound = 'true';\n        return;\n    }\n\n    document.addEventListener('mouseover', function (event) {\n        const target = getTooltipTarget(event.target);\n        if (!target) {\n            return;\n        }\n\n        const fromTarget = getTooltipTarget(event.relatedTarget);\n        if (fromTarget === target || activeUiTooltipTarget === target) {\n            return;\n        }\n\n        showUiTooltip(target);\n    });\n\n    document.addEventListener('mouseout', function (event) {\n        if (!activeUiTooltipTarget) {\n            return;\n        }\n\n        const target = getTooltipTarget(event.target);\n        const toTarget = getTooltipTarget(event.relatedTarget);\n\n        if (target !== activeUiTooltipTarget || toTarget === activeUiTooltipTarget) {\n            return;\n        }\n\n        hideUiTooltip();\n    });\n\n    document.addEventListener('focusin', function (event) {\n        const target = getTooltipTarget(event.target);\n        if (target) {\n            showUiTooltip(target);\n        }\n    });\n\n    document.addEventListener('focusout', function (event) {\n        const target = getTooltipTarget(event.target);\n        if (target && target === activeUiTooltipTarget) {\n            hideUiTooltip();\n        }\n    });\n\n    document.addEventListener('keydown', function (event) {\n        if (event.key === 'Escape') {\n            hideUiTooltip();\n        }\n    });\n\n    window.addEventListener('resize', hideUiTooltip);\n    window.addEventListener('scroll', hideUiTooltip, true);\n\n    document.body.dataset.uiHoverTooltipBound = 'true';\n}\n\nfunction openWhatsNewPopup() {\n    const overlay = document.getElementById('whatsNewPopupOverlay');\n    if (!overlay) return;\n\n    overlay.classList.add('open');\n    overlay.setAttribute('aria-hidden', 'false');\n    document.body.classList.add('whats-new-popup-open');\n}\n\nfunction closeWhatsNewPopup() {\n    const overlay = document.getElementById('whatsNewPopupOverlay');\n    if (!overlay) return;\n\n    overlay.classList.remove('open');\n    overlay.setAttribute('aria-hidden', 'true');\n    document.body.classList.remove('whats-new-popup-open');\n}\n\nfunction initWhatsNewPopup() {\n    const overlay = document.getElementById('whatsNewPopupOverlay');\n    const popupBody = document.getElementById('whatsNewPopupBody');\n    const section = document.getElementById('whatsNewSection');\n    const openBtn = document.getElementById('openWhatsNewPopupBtn');\n    const closeBtn = document.getElementById('whatsNewPopupClose');\n\n    // Move source What's New content into standalone popup body.\n    if (popupBody && section && section.parentElement !== popupBody) {\n        popupBody.appendChild(section);\n    }\n\n    if (openBtn && !openBtn.dataset.whatsNewBound) {\n        openBtn.addEventListener('click', function () {\n            openWhatsNewPopup();\n        });\n        openBtn.dataset.whatsNewBound = 'true';\n    }\n\n    if (closeBtn && !closeBtn.dataset.whatsNewBound) {\n        closeBtn.addEventListener('click', closeWhatsNewPopup);\n        closeBtn.dataset.whatsNewBound = 'true';\n    }\n\n    if (overlay && !overlay.dataset.whatsNewBound) {\n        overlay.addEventListener('click', function (event) {\n            if (event.target === overlay) {\n                closeWhatsNewPopup();\n            }\n        });\n        overlay.dataset.whatsNewBound = 'true';\n    }\n\n    if (!document.body.dataset.whatsNewEscBound) {\n        document.addEventListener('keydown', function (event) {\n            if (event.key === 'Escape') {\n                closeWhatsNewPopup();\n            }\n        });\n        document.body.dataset.whatsNewEscBound = 'true';\n    }\n}\n\nfunction openMapHelpPopup() {\n    const overlay = document.getElementById('mapHelpPopupOverlay');\n    if (!overlay) return;\n\n    overlay.classList.add('open');\n    overlay.setAttribute('aria-hidden', 'false');\n}\n\nfunction closeMapHelpPopup() {\n    const overlay = document.getElementById('mapHelpPopupOverlay');\n    if (!overlay) return;\n\n    overlay.classList.remove('open');\n    overlay.setAttribute('aria-hidden', 'true');\n}\n\nfunction initMapHelpPopup() {\n    const overlay = document.getElementById('mapHelpPopupOverlay');\n    const openBtn = document.getElementById('openMapHelpPopupBtn');\n    const closeBtn = document.getElementById('mapHelpPopupClose');\n\n    if (openBtn && !openBtn.dataset.mapHelpBound) {\n        openBtn.addEventListener('click', function () {\n            openMapHelpPopup();\n        });\n        openBtn.dataset.mapHelpBound = 'true';\n    }\n\n    if (closeBtn && !closeBtn.dataset.mapHelpBound) {\n        closeBtn.addEventListener('click', closeMapHelpPopup);\n        closeBtn.dataset.mapHelpBound = 'true';\n    }\n\n    if (overlay && !overlay.dataset.mapHelpBound) {\n        overlay.addEventListener('click', function (event) {\n            if (event.target === overlay) {\n                closeMapHelpPopup();\n            }\n        });\n        overlay.dataset.mapHelpBound = 'true';\n    }\n\n    if (!document.body.dataset.mapHelpEscBound) {\n        document.addEventListener('keydown', function (event) {\n            if (event.key === 'Escape') {\n                closeMapHelpPopup();\n            }\n        });\n        document.body.dataset.mapHelpEscBound = 'true';\n    }\n}\n\nfunction openMapSavingHelpPopup() {\n    const overlay = document.getElementById('mapSavingHelpPopupOverlay');\n    if (!overlay) return;\n\n    overlay.classList.add('open');\n    overlay.setAttribute('aria-hidden', 'false');\n}\n\nfunction closeMapSavingHelpPopup() {\n    const overlay = document.getElementById('mapSavingHelpPopupOverlay');\n    if (!overlay) return;\n\n    overlay.classList.remove('open');\n    overlay.setAttribute('aria-hidden', 'true');\n}\n\nfunction initMapSavingHelpPopup() {\n    const overlay = document.getElementById('mapSavingHelpPopupOverlay');\n    const openBtn = document.getElementById('openMapSavingHelpBtn');\n    const closeBtn = document.getElementById('mapSavingHelpPopupClose');\n\n    if (openBtn && !openBtn.dataset.mapSavingHelpBound) {\n        openBtn.addEventListener('click', function () {\n            openMapSavingHelpPopup();\n        });\n        openBtn.dataset.mapSavingHelpBound = 'true';\n    }\n\n    if (closeBtn && !closeBtn.dataset.mapSavingHelpBound) {\n        closeBtn.addEventListener('click', closeMapSavingHelpPopup);\n        closeBtn.dataset.mapSavingHelpBound = 'true';\n    }\n\n    if (overlay && !overlay.dataset.mapSavingHelpBound) {\n        overlay.addEventListener('click', function (event) {\n            if (event.target === overlay) {\n                closeMapSavingHelpPopup();\n            }\n        });\n        overlay.dataset.mapSavingHelpBound = 'true';\n    }\n\n    if (!document.body.dataset.mapSavingHelpEscBound) {\n        document.addEventListener('keydown', function (event) {\n            if (event.key === 'Escape') {\n                closeMapSavingHelpPopup();\n            }\n        });\n        document.body.dataset.mapSavingHelpEscBound = 'true';\n    }\n}\n\nfunction getDisplayLastUpdate(lastUpdateValue) {\n    if (typeof lastUpdateValue !== 'string') {\n        return lastUpdateValue;\n    }\n\n    // Allow cache-busting suffixes like 2026/03/13a while displaying only the date.\n    const matched = lastUpdateValue.match(/^(\\d{4}\\/\\d{2}\\/\\d{2})[a-z]+$/i);\n    return matched ? matched[1] : lastUpdateValue;\n}\n\n// Always populate What's New section and Home version text\nconst whatsNewVersion = document.getElementById('whatsNewVersion');\nif (whatsNewVersion) whatsNewVersion.textContent = icarusIntelVersion;\n\nconst whatsNewGameVersion = document.getElementById('whatsNewGameVersion');\nif (whatsNewGameVersion) whatsNewGameVersion.textContent = icarusGameVersion;\n\nconst displayLastUpdate = getDisplayLastUpdate(icarusIntelLastestUpdate);\n\nconst whatsNewDate = document.getElementById('whatsNewDate');\nif (whatsNewDate) whatsNewDate.textContent = displayLastUpdate;\n\nconst settingsIntelVersion = document.getElementById('settingsIntelVersion');\nif (settingsIntelVersion) settingsIntelVersion.textContent = icarusIntelVersion;\n\nconst settingsLatestUpdate = document.getElementById('settingsLatestUpdate');\nif (settingsLatestUpdate) settingsLatestUpdate.textContent = displayLastUpdate;\n\nconst settingsGameVersion = document.getElementById('settingsGameVersion');\nif (settingsGameVersion) settingsGameVersion.textContent = icarusGameVersion;\n\ninitWhatsNewPopup();\ninitMapHelpPopup();\ninitMapSavingHelpPopup();\ninitIconTooltips();\n\n// Setup map storage help button in settings\nconst mapStorageHelpBtn = document.getElementById('openMapSavingHelpFromSettings');\nif (mapStorageHelpBtn) {\n    mapStorageHelpBtn.addEventListener('click', function () {\n        openMapSavingHelpPopup();\n    });\n}\n\n// Check for new version and open What's New popup\nif (!localStorage.sicversion || localStorage.sicversion != icarusIntelVersion) {\n    localStorage.sicversion = icarusIntelVersion;\n\n    openWhatsNewPopup();\n\n    notificationControl.success('Site was Updated!',\n        'IcarusIntel has been updated to version ' + icarusIntelVersion, {\n        timeout: 15000,\n        closable: true,\n        dismissable: true,\n        icon: 'info',\n        className: 'important-info clickable-notification',\n        onclick: function () {\n            openWhatsNewPopup();\n        }\n    });\n}\n\n// Grid // ON/OFF\ndocument.getElementById(filterGrid).addEventListener(\"change\", function () {\n    const filterState = getFilterState();\n    filterState.grid = this.checked;\n    setFilterState(filterState);\n    mapToggleGridLayer(this.checked);\n});\n\n// Meta Deposit Markers\ndocument.getElementById(filterExotics).addEventListener(\"change\", function () {\n    const filterState = getFilterState();\n    filterState.metaDeposits = this.checked;\n    setFilterState(filterState);\n\n    // Toggle general exotic deposits layer\n    toggleMetaDepositsLayer(this.checked);\n\n    // Toggle mission-specific exotics if they exist\n    if (typeof prospectExoticsGroup !== 'undefined') {\n        if (this.checked) {\n            if (prospectExoticsGroup.getLayers().length > 0 && !map.hasLayer(prospectExoticsGroup)) {\n                prospectExoticsGroup.addTo(map);\n            }\n        } else {\n            if (map.hasLayer(prospectExoticsGroup)) {\n                map.removeLayer(prospectExoticsGroup);\n            }\n        }\n    }\n});\n\n// Enzyme Geyser Markers // ON/OFF\ndocument.getElementById(filterGeysers).addEventListener(\"change\", function () {\n    const filterState = getFilterState();\n    filterState.enzymeGeysers = this.checked;\n    setFilterState(filterState);\n    toggleGeysersLayer(this.checked);\n});\n\n// Oil Geyser Markers // ON/OFF\ndocument.getElementById(filterOilGeysers).addEventListener(\"change\", function () {\n    const filterState = getFilterState();\n    filterState.oilGeysers = this.checked;\n    setFilterState(filterState);\n    toggleOilGeysersLayer(this.checked);\n});\n\n// Deep Ore Deposit Markers // ON/OFF\ndocument.getElementById(filterOreDeposits).addEventListener(\"change\", function (event) {\n    const filterState = getFilterState();\n    filterState.deepOreDeposits = this.checked;\n    setFilterState(filterState);\n\n    // Pass flag indicating if this is a programmatic change (not user click)\n    const isProgrammatic = event.detail?.isProgrammatic || false;\n    toggleOreDepositLayer(this.checked, isProgrammatic);\n\n    // Update cave ore overlay when toggle changes\n    if (typeof applyCaveOreOverlay === 'function') {\n        applyCaveOreOverlay();\n    }\n\n    // Disable/enable ore filter button based on main toggle state\n    const oreFilterButton = document.getElementById('oreFilterButton');\n    if (oreFilterButton) {\n        oreFilterButton.disabled = !this.checked;\n    }\n});\n\n// Caves Markers // ON/OFF\ndocument.getElementById(filterCaves).addEventListener(\"change\", function (event) {\n    const filterState = getFilterState();\n    filterState.caves.all = this.checked;\n    setFilterState(filterState);\n\n    // Pass flag indicating if this is a programmatic change (not user click)\n    const isProgrammatic = event.detail?.isProgrammatic || false;\n    toggleCavesLayer(this.checked, isProgrammatic);\n\n    // Disable/enable cave filter button based on main toggle state\n    const caveFilterButton = document.getElementById('caveFilterButton');\n    if (caveFilterButton) {\n        caveFilterButton.disabled = !this.checked;\n    }\n});\n\n// Custom Markers // ON/OFF\ndocument.getElementById(filterCustomMarkers).addEventListener(\"change\", function () {\n    const filterState = getFilterState();\n    filterState.markers = this.checked;\n    setFilterState(filterState);\n    toggleCustomMarkerLayer(this.checked);\n});\n\n// Initialize filter button states based on current toggle states\nfunction initializeFilterButtonStates() {\n    const cavesToggle = document.getElementById(filterCaves);\n    const oreDepositsToggle = document.getElementById(filterOreDeposits);\n    const caveFilterButton = document.getElementById('caveFilterButton');\n    const oreFilterButton = document.getElementById('oreFilterButton');\n\n    if (caveFilterButton && cavesToggle) {\n        caveFilterButton.disabled = !cavesToggle.checked;\n    }\n\n    if (oreFilterButton && oreDepositsToggle) {\n        oreFilterButton.disabled = !oreDepositsToggle.checked;\n    }\n    \n    // Initialize open world toggle from filter state\n    if (typeof initializeOpenWorldToggle === 'function') {\n        initializeOpenWorldToggle();\n    }\n}\n\n// Initialize filter button states on load\nif (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', initializeFilterButtonStates);\n} else {\n    initializeFilterButtonStates();\n}\n\n// Reset Filters Button\nconst resetFiltersBtn = document.getElementById('resetFiltersBtn');\nif (resetFiltersBtn) {\n    resetFiltersBtn.addEventListener('click', function () {\n        if (typeof resetFiltersToDefault === 'function') {\n            resetFiltersToDefault();\n        }\n    });\n}\n\n/**\n *\n * @param element\n * @param state\n * @param forceUpdate\n * @returns {boolean} false = state not changed\n */\nfunction filterSetCheckedState(element, state, forceUpdate = false) {\n    let box = document.getElementById(element);\n\n    if (box.checked === state) {\n        if (forceUpdate) {\n            box.dispatchEvent(new CustomEvent('change', { detail: { isProgrammatic: true } }));\n        }\n        return false;\n    }\n\n    box.checked = state;\n    box.dispatchEvent(new CustomEvent('change', { detail: { isProgrammatic: true } }));\n\n    return true;\n}\n\nfunction filterSetDisabledState(element, state) {\n    document.getElementById(element).disabled = state;\n}\n\nfunction filterGetState(element) {\n    return document.getElementById(element).checked;\n}\n\nfunction filterHideRow(element, state) {\n    document.getElementById(element + \"Row\").style.display = state ? 'none' : '';\n}\n\n// Utility function to check if dev tooltip is enabled\nfunction isDevTooltipEnabled() {\n    const checkbox = document.getElementById('devTooltipInfo');\n    return checkbox && checkbox.checked;\n}\n\n// Utility function to add dev tooltip info to popup text\nfunction addDevTooltip(baseText, data) {\n    if (!isDevTooltipEnabled() || !data) return baseText;\n\n    let additionalInfo = '';\n    if (data.code) additionalInfo += `<br>Code: ${data.code}`;\n    if (data.name) additionalInfo += `<br>Name: ${data.name}`;\n    if (data.variant) additionalInfo += `<br>Variant: ${data.variant}`;\n    if (data.identifier) additionalInfo += `<br>Identifier: ${data.identifier}`;\n    if (data.x !== undefined && data.y !== undefined) {\n        additionalInfo += `<br>Position: (${data.x}, ${data.y})`;\n    }\n\n    return baseText + additionalInfo;\n}\n\n// Utility function to manage filter state during async operations\nfunction withFilterManagement(filter, workFn) {\n    filterSetDisabledState(filter, true);\n    const result = workFn();\n    // Note: filterSetDisabledState(filter, false) should be called after work completes\n    // This is left to the caller since operations may be async\n    return result;\n}\n\n// Generic layer state updater - reduces boilerplate in update*State() functions\n// @param layer - The Leaflet layer group to update\n// @param updateFn - Function that receives (marker) and returns { popup, icon } or just { popup }\n// @param options - Optional { onComplete } callback after all markers updated\nfunction updateLayerState(layer, updateFn, options = {}) {\n    if (!layer) return;\n\n    layer.eachLayer(marker => {\n        const result = updateFn(marker);\n\n        if (!result) return;\n\n        // Update icon if provided\n        if (result.icon) {\n            marker.setIcon(result.icon);\n        }\n\n        // Update popup if provided\n        if (result.popup !== undefined) {\n            marker.bindPopup(result.popup, { autoPan: false });\n        }\n    });\n\n    // Call completion callback if provided\n    if (options.onComplete) {\n        options.onComplete();\n    }\n}\n\n// Shared popup overlay positioning manager.\n// Use this for fixed-position filter/dialog popups anchored to toolbar buttons.\nwindow.PopupOverlayManager = (function () {\n    const viewportListeners = new Map();\n\n    function getViewportBounds() {\n        const viewport = window.visualViewport;\n        const left = viewport ? viewport.offsetLeft : 0;\n        const top = viewport ? viewport.offsetTop : 0;\n        const width = viewport ? viewport.width : window.innerWidth;\n        const height = viewport ? viewport.height : window.innerHeight;\n\n        return {\n            left,\n            top,\n            right: left + width,\n            bottom: top + height,\n            width,\n            height\n        };\n    }\n\n    function clampValue(value, min, max) {\n        return Math.min(Math.max(value, min), max);\n    }\n\n    function shouldCenterPopup(bounds, options = {}) {\n        if (options.centerOnMobile === false) {\n            return false;\n        }\n\n        const threshold = Number.isFinite(options.centerViewportWidthThreshold)\n            ? options.centerViewportWidthThreshold\n            : 600;\n        const isMobileDevice = typeof window.mobileAndTabletCheck === 'function' && window.mobileAndTabletCheck();\n\n        return isMobileDevice || bounds.width <= threshold;\n    }\n\n    function positionAtAnchor(content, anchorRect, options = {}) {\n        if (!content || !anchorRect) return;\n\n        const margin = Number.isFinite(options.margin) ? options.margin : 12;\n        const gap = Number.isFinite(options.gap) ? options.gap : 10;\n        const minHeight = Number.isFinite(options.minHeight) ? options.minHeight : 140;\n        const minWidth = Number.isFinite(options.minWidth) ? options.minWidth : 160;\n        const zIndex = Number.isFinite(options.zIndex) ? options.zIndex : 10000;\n        const centerVerticalRatio = Number.isFinite(options.centerVerticalRatio) ? options.centerVerticalRatio : 0.5;\n        const bounds = getViewportBounds();\n        const centerOnMobile = shouldCenterPopup(bounds, options);\n\n        content.style.position = 'fixed';\n        content.style.transform = 'none';\n        content.style.left = '0px';\n        content.style.top = '0px';\n        content.style.visibility = 'hidden';\n        content.style.zIndex = `${zIndex}`;\n\n        const maxAllowedHeight = Math.max(minHeight, Math.floor(bounds.height - (margin * 2)));\n        const maxAllowedWidth = Math.max(minWidth, Math.floor(bounds.width - (margin * 2)));\n\n        content.style.maxHeight = `${maxAllowedHeight}px`;\n        content.style.width = '';\n\n        let popupRect = content.getBoundingClientRect();\n        if (popupRect.width > maxAllowedWidth) {\n            content.style.width = `${maxAllowedWidth}px`;\n            popupRect = content.getBoundingClientRect();\n        }\n\n        const popupWidth = popupRect.width;\n        const popupHeight = popupRect.height;\n\n        let left;\n        let top;\n\n        if (centerOnMobile) {\n            left = bounds.left + ((bounds.width - popupWidth) / 2);\n            top = bounds.top + ((bounds.height - popupHeight) * centerVerticalRatio);\n        } else {\n            left = anchorRect.right + gap;\n            if (left + popupWidth > bounds.right - margin) {\n                left = anchorRect.left - popupWidth - gap;\n            }\n            top = anchorRect.top;\n        }\n\n        const minLeft = bounds.left + margin;\n        const maxLeft = bounds.right - popupWidth - margin;\n        left = maxLeft < minLeft ? minLeft : clampValue(left, minLeft, maxLeft);\n\n        const minTop = bounds.top + margin;\n        const maxTop = bounds.bottom - popupHeight - margin;\n        top = maxTop < minTop ? minTop : clampValue(top, minTop, maxTop);\n\n        const availableHeight = Math.max(minHeight, Math.floor(bounds.bottom - top - margin));\n        const finalMaxHeight = Math.min(maxAllowedHeight, availableHeight);\n        content.style.maxHeight = `${finalMaxHeight}px`;\n\n        content.style.left = `${Math.round(left)}px`;\n        content.style.top = `${Math.round(top)}px`;\n        content.style.visibility = 'visible';\n    }\n\n    function addViewportListeners(key, updatePositionFn) {\n        window.addEventListener('resize', updatePositionFn);\n        window.addEventListener('scroll', updatePositionFn, true);\n\n        if (window.visualViewport) {\n            window.visualViewport.addEventListener('resize', updatePositionFn);\n            window.visualViewport.addEventListener('scroll', updatePositionFn);\n        }\n\n        viewportListeners.set(key, updatePositionFn);\n    }\n\n    function removeViewportListeners(key) {\n        const updatePositionFn = viewportListeners.get(key);\n        if (!updatePositionFn) return;\n\n        window.removeEventListener('resize', updatePositionFn);\n        window.removeEventListener('scroll', updatePositionFn, true);\n\n        if (window.visualViewport) {\n            window.visualViewport.removeEventListener('resize', updatePositionFn);\n            window.visualViewport.removeEventListener('scroll', updatePositionFn);\n        }\n\n        viewportListeners.delete(key);\n    }\n\n    function attachToPopup(config = {}) {\n        const {\n            key,\n            popupId,\n            anchorId,\n            options = {}\n        } = config;\n\n        if (!key || !popupId || !anchorId) return;\n\n        const updatePosition = function () {\n            const popup = document.getElementById(popupId);\n            const anchor = document.getElementById(anchorId);\n            if (!popup || !anchor) return;\n\n            const content = popup.firstElementChild;\n            if (!content) return;\n\n            positionAtAnchor(content, anchor.getBoundingClientRect(), options);\n        };\n\n        removeViewportListeners(key);\n        addViewportListeners(key, updatePosition);\n        updatePosition();\n    }\n\n    function detachFromPopup(key) {\n        removeViewportListeners(key);\n    }\n\n    return {\n        getViewportBounds,\n        shouldCenterPopup,\n        positionAtAnchor,\n        attachToPopup,\n        detachFromPopup\n    };\n})();\n\n// Convert from the game's coordinate system to our 8192 system\nfunction convertGameDistance(gameDistance) {\n    const gridSize = Math.pow(selectedMapGridZoom, 2);\n    const radius = Math.round(gameDistance / (gridSize * 50400 / MAP_SIZE));\n    return map.unproject([radius, 0], MAP_ZOOM).lng;\n}\n\n// Convert from the map's coordinate system to our 0 to 8192 system\nfunction cord_search() {\n    var lng = document.getElementById('lng').value;\n    var lat = document.getElementById('lat').value;\n\n    if (!lng || !lat) {\n        document.getElementById('results').innerHTML = 'Please enter game coordinates (Lng/Lat).';\n        return;\n    }\n\n    var gridSize = Math.pow(selectedMapGridZoom, 2);\n    x = (lng / (gridSize * 50400 / 8192)) + 4096;\n    y = (lat / (gridSize * 50400 / 8192)) + 4096;\n\n    marker.closePopup();\n    marker.setLatLng(map.unproject([x, y], MAP_ZOOM));\n    setTimeout(marker.openPopup);\n\n    // Pan to the location\n    const latlng = map.unproject([x, y], MAP_ZOOM);\n    map.panTo(latlng);\n\n    // Update or create navigation marker\n    updateNavMarker(latlng);\n\n    // Update coordinate fields to show current position\n    document.getElementById('navX').value = Math.round(x);\n    document.getElementById('navY').value = Math.round(y);\n\n    // Also update cave marker fields with map coordinates\n    updateCaveMarkerFields(Math.round(x), Math.round(y));\n\n    document.getElementById('results').innerHTML = 'Game coordinates (' + lng + ', ' + lat + ') > Map coordinates (' + Math.round(x) + ', ' + Math.round(y) + ')';\n}\n\nasync function paste_coords() {\n    try {\n        const text = await navigator.clipboard.readText();\n        const numbers = text.match(/-?\\d+(?:\\.\\d+)?/g);\n\n        if (numbers && numbers.length >= 2) {\n            const lng = parseFloat(numbers[0]);\n            const lat = parseFloat(numbers[1]);\n\n            if (!isNaN(lng) && !isNaN(lat)) {\n                document.getElementById('lng').value = lng;\n                document.getElementById('lat').value = lat;\n                cord_search();\n\n                // Supports \"X Y Z Rotation\" clipboard format by reading the 4th value as rotation.\n                if (numbers.length >= 4) {\n                    const rotation = parseFloat(numbers[3]);\n                    if (!isNaN(rotation)) {\n                        const adjustedRotation = rotation + PASTE_COORDS_ROTATION_OFFSET;\n                        updateCaveMarkerFields(undefined, undefined, adjustedRotation);\n                        if (typeof cave_search === 'function') {\n                            cave_search();\n                        }\n                    }\n                }\n            } else {\n                document.getElementById('results').innerHTML = 'Invalid coordinates in clipboard.';\n            }\n        } else {\n            document.getElementById('results').innerHTML = 'Clipboard does not contain valid coordinates.';\n        }\n    } catch (err) {\n        document.getElementById('results').innerHTML = 'Failed to read clipboard: ' + err.message;\n    }\n}\n\n// Generate cave code\nfunction cave_search() {\n    var x = document.getElementById('lngC').value || 0;\n    var y = document.getElementById('latC').value || 0;\n    var r = document.getElementById('rotC').value || 0;\n    var fo = document.getElementById('cfo') ? (document.getElementById('cfo').checked ? 1 : 0) : 0;\n    var hw = document.getElementById('cwr') ? (document.getElementById('cwr').checked ? 1 : 0) : 0;\n    var hws = document.getElementById('cwt') ? (document.getElementById('cwt').checked ? 1 : 0) : 0;\n    var hm = document.getElementById('cms') ? (document.getElementById('cms').checked ? 1 : 0) : 0;\n    var hg = document.getElementById('cuf') ? (document.getElementById('cuf').checked ? 1 : 0) : 0;\n    var hh = document.getElementById('chz') ? (document.getElementById('chz').checked ? 1 : 0) : 0;\n    var hs = document.getElementById('ctn') ? (document.getElementById('ctn').checked ? 1 : 0) : 0;\n    var hf = document.getElementById('cwf') ? (document.getElementById('cwf').checked ? 1 : 0) : 0;\n    var hfl = document.getElementById('cfl') ? (document.getElementById('cfl').checked ? 1 : 0) : 0;\n    var hu = document.getElementById('cuw') ? (document.getElementById('cuw').checked ? 1 : 0) : 0;\n    var hug = document.getElementById('cug') ? (document.getElementById('cug').checked ? 1 : 0) : 0;\n\n    markerC.closePopup();\n    markerC.setLatLng(map.unproject([x, y], MAP_ZOOM));\n    markerC.setRotationAngle(r);\n    setTimeout(markerC.openPopup);\n\n    // Get values for database INSERT statement\n    var caveId = document.getElementById('caveId') ? (document.getElementById('caveId').value || 'NULL') : 'NULL';\n    // Get current map name from the selected map or localStorage\n    var mapName = (typeof selectedMapParent !== 'undefined' && selectedMapParent)\n        ? selectedMapParent\n        : (localStorage.currentMap || 'olympus');\n    var size = document.getElementById('csz') ? (document.getElementById('csz').value || 'NULL') : 'NULL';\n    var oreCount = document.getElementById('cor') ? (document.getElementById('cor').value || 'NULL') : 'NULL';\n    var deepOreCount = document.getElementById('cdo') ? (document.getElementById('cdo').value || 0) : 0;\n    var hasFish = 0; // Not currently collected\n    var wormMin = document.getElementById('cwn') ? (document.getElementById('cwn').value || 'NULL') : 'NULL';\n    var wormMax = document.getElementById('cwx') ? (document.getElementById('cwx').value || 'NULL') : 'NULL';\n    var notes = document.getElementById('cnt') ? (document.getElementById('cnt').value || '') : '';\n    var gameId = ''; // Empty for now\n\n    // Check if this is an existing cave (being moved/updated) or a new cave\n    const isExistingCave = window.copiedCaveId && !window.isAddingNewCave;\n\n    let sql;\n    if (isExistingCave) {\n        // Generate UPDATE statement for existing cave\n        sql = `UPDATE caves SET<br>`;\n        sql += `&nbsp;&nbsp;map = '${mapName}',<br>`;\n        sql += `&nbsp;&nbsp;x = ${Math.round(x)},<br>`;\n        sql += `&nbsp;&nbsp;y = ${Math.round(y)},<br>`;\n        sql += `&nbsp;&nbsp;rotationAngle = ${r},<br>`;\n        sql += `&nbsp;&nbsp;size = '${size}',<br>`;\n        sql += `&nbsp;&nbsp;oreCount = ${oreCount},<br>`;\n        sql += `&nbsp;&nbsp;deepOreCount = ${deepOreCount},<br>`;\n        sql += `&nbsp;&nbsp;hasWorms = ${hw},<br>`;\n        sql += `&nbsp;&nbsp;wormsMin = ${wormMin},<br>`;\n        sql += `&nbsp;&nbsp;wormsMax = ${wormMax},<br>`;\n        sql += `&nbsp;&nbsp;hasWater = ${hws},<br>`;\n        sql += `&nbsp;&nbsp;hasFish = ${hasFish},<br>`;\n        sql += `&nbsp;&nbsp;hasMushrooms = ${hm},<br>`;\n        sql += `&nbsp;&nbsp;isUnfinished = ${hg},<br>`;\n        sql += `&nbsp;&nbsp;isHazardous = ${hh},<br>`;\n        sql += `&nbsp;&nbsp;isTunnel = ${hs},<br>`;\n        sql += `&nbsp;&nbsp;isWaterfall = ${hf},<br>`;\n        sql += `&nbsp;&nbsp;isFlooded = ${hfl},<br>`;\n        sql += `&nbsp;&nbsp;isUnderwater = ${hu},<br>`;\n        sql += `&nbsp;&nbsp;isUnderground = ${hug},<br>`;\n        sql += `&nbsp;&nbsp;notes = '${notes.replace(/'/g, \"''\")}'<br>`;\n        sql += `WHERE id = '${caveId}';`;\n    } else {\n        // Generate INSERT statement for new cave\n        sql = `INSERT INTO caves (id, map, x, y, rotationAngle, size, oreCount, deepOreCount, hasWorms, wormsMin, wormsMax, hasWater, hasFish, hasMushrooms, isUnfinished, isHazardous, isRemoved, isTunnel, isWaterfall, isFlooded, isUnderwater, notes, gameId, isUnderground) VALUES<br>`;\n        sql += `('${caveId}', '${mapName}', ${Math.round(x)}, ${Math.round(y)}, ${r}, '${size}', ${oreCount}, ${deepOreCount}, ${hw}, ${wormMin}, ${wormMax}, ${hws}, ${hasFish}, ${hm}, ${hg}, ${hh}, 0, ${hs}, ${hf}, ${hfl}, ${hu}, '${notes.replace(/'/g, \"''\")}', NULL, ${hug});`;\n    }\n\n    const resultsCDiv = document.getElementById('resultsC');\n    if (resultsCDiv) {\n        const sqlType = isExistingCave ? 'UPDATE' : 'INSERT';\n        resultsCDiv.innerHTML = '<div class=\"cave-sql-output\"><strong>' + sqlType + ' SQL:</strong><br><br>' + sql + '</div>';\n        resultsCDiv.style.display = 'block';\n    }\n}\n\n// Moves the cave marker used in DevTools\nfunction cave_update() {\n    var x2, y2;\n    var latlng = markerC.getLatLng();\n    x2 = latlng.lng * 32;\n    y2 = latlng.lat * -32;\n    updateCaveMarkerFields(x2, y2);\n\n    // Update the copied cave info display if it exists\n    updateCopiedCaveInfo();\n\n    // Regenerate SQL when marker is dragged\n    if (typeof cave_search === 'function') {\n        cave_search();\n    }\n}\n\n// Update the copied cave data display\nfunction updateCopiedCaveInfo() {\n    const copiedCaveInfo = document.getElementById('copiedCaveInfo');\n    if (copiedCaveInfo) {\n        if (!window.copiedCaveId && !window.isAddingNewCave) {\n            // Show instructions when no cave is copied\n            copiedCaveInfo.innerHTML = `\n                <div style=\"padding: 10px; background: rgba(200, 200, 200, 0.1); border-radius: 4px; margin-top: 10px; border: 1px dashed #999;\">\n                    <strong>How to Use:</strong><br>\n                    <ol style=\"margin: 8px 0 0 0; padding-left: 20px; font-size: 0.95em;\">\n                        <li><strong>To move a cave:</strong> Click on any cave on the map</li>\n                        <li><strong>To add a new cave:</strong> Enable the dev marker and position it on the map</li>\n                        <li>Adjust position, rotation, and metadata fields below</li>\n                        <li>Click the Copy button to copy the data and share it with us using the feedback form</li>\n                    </ol>\n                </div>\n            `;\n            return;\n        }\n\n        // Check if we're adding a new cave (must have isAddingNewCave=true AND no copiedCaveId)\n        const isNewCave = (window.isAddingNewCave === true) && !window.copiedCaveId;\n\n        const currentX = document.getElementById('lngC').value;\n        const currentY = document.getElementById('latC').value;\n        const currentRotation = document.getElementById('rotC').value;\n\n        const origX = window.copiedCaveOriginalX || currentX;\n        const origY = window.copiedCaveOriginalY || currentY;\n        const origRotation = window.copiedCaveOriginalRotation || currentRotation;\n\n        // Check if position or rotation has changed\n        const positionChanged = (currentX != origX || currentY != origY);\n        const rotationChanged = (currentRotation != origRotation);\n        const hasChanges = positionChanged || rotationChanged;\n\n        const bgColor = isNewCave ? 'rgba(76, 175, 80, 0.1)' : 'rgba(33, 150, 243, 0.1)';\n        const titleText = isNewCave ? 'New Cave Data:' : 'Copied Cave Data:';\n        const buttonText = isNewCave ? 'Copy new cave' : 'Copy changes';\n        const clearButtonText = isNewCave ? '<i class=\"material-symbols-outlined\">undo</i> Back to Move' : '<i class=\"material-symbols-outlined\">add</i> Add New';\n        const clearButtonTitle = isNewCave ? 'Switch back to moving existing cave mode' : 'Switch to adding new cave mode';\n\n        copiedCaveInfo.innerHTML = `\n            <div style=\"padding: 10px; background: ${bgColor}; border-radius: 4px; margin-top: 10px; position: relative;\">\n                <div style=\"margin-bottom: 10px;\">\n                    <strong>${titleText}</strong>\n                    <button id=\"showHelpBtn\" style=\"float: right; padding: 4px 8px; font-size: 11px; background: #9E9E9E; color: white; border: none; border-radius: 3px; cursor: pointer; margin-left: 5px;\" title=\"Show instructions\">\n                        <i class=\"material-symbols-outlined\">help</i> Help\n                    </button>\n                    <button id=\"clearCaveDataBtn\" style=\"float: right; padding: 4px 8px; font-size: 11px; background: ${isNewCave ? '#FF9800' : '#4CAF50'}; color: white; border: none; border-radius: 3px; cursor: pointer; margin-left: 5px;\" title=\"${clearButtonTitle}\">\n                        ${clearButtonText}\n                    </button>\n                </div>\n                <div style=\"clear: both;\"></div>\n                ${isNewCave ? `\n                    <strong style=\"color: #4CAF50;\">Adding New Cave</strong><br>\n                    <span style=\"margin-left: 10px;\">Position: X: ${currentX}, Y: ${currentY}</span><br>\n                    <span style=\"margin-left: 10px;\">Rotation: ${currentRotation}</span>\n                ` : `\n                    <strong>Cave ID:</strong> ${window.copiedCaveId}<br>\n                    <div style=\"margin-top: 8px;\">\n                        <strong>Original:</strong><br>\n                        <span style=\"margin-left: 10px;\">Position: X: ${origX}, Y: ${origY}</span><br>\n                        <span style=\"margin-left: 10px;\">Rotation: ${origRotation}</span>\n                    </div>\n                    ${hasChanges ? `\n                    <div style=\"margin-top: 8px; color: #2196F3;\">\n                        <strong>Current:</strong><br>\n                        <span style=\"margin-left: 10px;\">Position: X: ${currentX}, Y: ${currentY}</span><br>\n                        <span style=\"margin-left: 10px;\">Rotation: ${currentRotation}</span>\n                    </div>\n                    ` : ''}\n                `}\n                <em style=\"font-size: 0.9em; color: #999; display: block; margin-top: 8px;\">${isNewCave ? 'Position the marker, fill in the cave details, then copy the data to share with us.' : 'Drag the red cave marker or edit fields to reposition, then click \"Copy changes\" and send the information using the feedback form.'}</em>\n                <div style=\"text-align: center; margin-top: 10px; display: flex; gap: 8px; justify-content: center;\">\n                    <button id=\"copyCaveDataBtn\" style=\"padding: 6px 16px; font-size: 12px; background: #2196F3; color: white; border: none; border-radius: 3px; cursor: pointer;\" title=\"Copy cave data to clipboard\">\n                        <i class=\"material-symbols-outlined\">content_copy</i> ${buttonText}\n                    </button>\n                    <button id=\"copyCoordsBtn\" style=\"padding: 6px 16px; font-size: 12px; background: #9C27B0; color: white; border: none; border-radius: 3px; cursor: pointer;\" title=\"Copy coordinates only\">\n                        <i class=\"material-symbols-outlined\">location_on</i> Copy coordinates\n                    </button>\n                </div>\n            </div>\n        `;\n\n        // Add click event to help button (shows instructions popup)\n        const helpBtn = document.getElementById('showHelpBtn');\n        if (helpBtn) {\n            helpBtn.addEventListener('click', function (e) {\n                e.preventDefault();\n                e.stopPropagation();\n\n                // Show help popup\n                showCustomConfirm(\n                    \"Cave Editor Instructions\",\n                    `<div style=\"text-align: left;\">\n                        <strong>How to Use:</strong>\n                        <ol style=\"margin: 8px 0; padding-left: 20px;\">\n                            <li><strong>To move a cave:</strong> Click on any cave on the map</li>\n                            <li><strong>To add a new cave:</strong> Enable the dev marker and position the red cave marekr to the desired location on the map</li>\n                            <li>Adjust position, rotation, and metadata fields below</li>\n                            <li>Click the Copy button to copy the data and share it with us using the feedback form</li>\n                        </ol>\n                        <hr style=\"margin: 10px 0; border: none; border-top: 1px solid #ddd;\">\n                        <strong>Button Functions:</strong>\n                        <ul style=\"margin: 8px 0; padding-left: 20px;\">\n                            <li><strong>Copy:</strong> Copy cave data to clipboard, so you can paste it into the feedback form</li>\n                            <li><strong>${isNewCave ? 'Back to Move' : 'Add New'}:</strong> Switch between moving existing caves and adding new caves</li>\n                            <li><strong>Use Pin Icon:</strong> You can use this to change the cave marker icon to be more precise. This can be used for adding something else, not just caves.</li>\n                        </ul>\n                    </div>`,\n                    () => { }, // No action needed on confirm\n                    true, // Show only OK button\n                    \"Got it\",\n                    \"Cancel\",\n                    null,\n                    \"primary\"\n                );\n            });\n        }\n\n        // Add click event to clear button (now toggles between modes)\n        const clearBtn = document.getElementById('clearCaveDataBtn');\n        if (clearBtn) {\n            clearBtn.addEventListener('click', function (e) {\n                e.preventDefault();\n                e.stopPropagation();\n\n                if (isNewCave) {\n                    // Switch from \"add new\" back to \"move existing\" mode\n                    // Clear the adding flag and restore last clicked cave\n                    window.isAddingNewCave = false;\n\n                    // Restore the last clicked cave if available\n                    if (window.lastClickedCaveMarker && window.lastClickedCaveMarker.caveData) {\n                        const caveData = window.lastClickedCaveMarker.caveData;\n                        window.copiedCaveId = window.lastClickedCaveMarker.caveId;\n                        window.copiedCaveOriginalX = caveData.x;\n                        window.copiedCaveOriginalY = caveData.y;\n                        window.copiedCaveOriginalRotation = caveData.r || 0;\n\n                        // Update dev marker position to match the cave\n                        if (typeof markerC !== 'undefined') {\n                            markerC.setLatLng(map.unproject([caveData.x, caveData.y], MAP_ZOOM));\n                            markerC.setRotationAngle(caveData.r || 0);\n\n                            // Update form fields\n                            updateCaveMarkerFields(caveData.x, caveData.y, caveData.r || 0);\n                        }\n                    }\n                } else {\n                    // Switch from \"move existing\" to \"add new\" mode\n                    // Clear cave reference data\n                    window.copiedCaveId = null;\n                    window.copiedCaveOriginalX = null;\n                    window.copiedCaveOriginalY = null;\n                    window.copiedCaveOriginalRotation = null;\n                    window.isAddingNewCave = true;\n                }\n\n                // Update the display\n                updateCopiedCaveInfo();\n            });\n        }\n\n        // Add click event to copy button\n        const copyBtn = document.getElementById('copyCaveDataBtn');\n        if (copyBtn) {\n            copyBtn.addEventListener('click', function (e) {\n                e.preventDefault();\n                e.stopPropagation();\n\n                // Get all cave metadata\n                const size = document.getElementById('csz') ? document.getElementById('csz').value : '';\n                const oreCount = document.getElementById('cor') ? document.getElementById('cor').value : '';\n                const fuzzyOre = document.getElementById('cfo') ? (document.getElementById('cfo').checked ? '1' : '0') : '0';\n                const hasWorm = document.getElementById('cwr') ? (document.getElementById('cwr').checked ? '1' : '0') : '0';\n                const wormMin = document.getElementById('cwn') ? document.getElementById('cwn').value : '';\n                const wormMax = document.getElementById('cwx') ? document.getElementById('cwx').value : '';\n                const hasWater = document.getElementById('cwt') ? (document.getElementById('cwt').checked ? '1' : '0') : '0';\n                const hasMush = document.getElementById('cms') ? (document.getElementById('cms').checked ? '1' : '0') : '0';\n                const hasGlit = document.getElementById('cuf') ? (document.getElementById('cuf').checked ? '1' : '0') : '0';\n                const hasHaza = document.getElementById('chz') ? (document.getElementById('chz').checked ? '1' : '0') : '0';\n                const hasTunn = document.getElementById('ctn') ? (document.getElementById('ctn').checked ? '1' : '0') : '0';\n                const hasFall = document.getElementById('cwf') ? (document.getElementById('cwf').checked ? '1' : '0') : '0';\n                const hasFloo = document.getElementById('cfl') ? (document.getElementById('cfl').checked ? '1' : '0') : '0';\n                const hasUnde = document.getElementById('cuw') ? (document.getElementById('cuw').checked ? '1' : '0') : '0';\n                const notes = document.getElementById('cnt') ? document.getElementById('cnt').value : '';\n\n                // Create URL with dev cave parameters including metadata\n                const baseUrl = window.location.origin + window.location.pathname;\n                const hasUnderg = document.getElementById('cug') ? (document.getElementById('cug').checked ? '1' : '0') : '0';\n                const deepOre = document.getElementById('cdo') ? document.getElementById('cdo').value : '';\n                const params = new URLSearchParams({\n                    x: currentX,\n                    y: currentY,\n                    r: currentRotation,\n                    csz: size,\n                    cor: oreCount,\n                    cfo: fuzzyOre,\n                    cdo: deepOre,\n                    cwr: hasWorm,\n                    cwn: wormMin,\n                    cwx: wormMax,\n                    cwt: hasWater,\n                    cms: hasMush,\n                    cuf: hasGlit,\n                    chz: hasHaza,\n                    ctn: hasTunn,\n                    cwf: hasFall,\n                    cfl: hasFloo,\n                    cuw: hasUnde,\n                    cug: hasUnderg,\n                    cnt: notes\n                });\n\n                if (!isNewCave && window.copiedCaveId) {\n                    params.set('devCave', window.copiedCaveId);\n                    params.set('origX', origX);\n                    params.set('origY', origY);\n                    params.set('origR', origRotation);\n                }\n\n                const devUrl = `${baseUrl}#dev&${params.toString()}`;\n\n                // Get current map name\n                const currentMapName = (typeof selectedMapParent !== 'undefined' && selectedMapParent)\n                    ? selectedMapParent\n                    : (localStorage.currentMap || 'olympus');\n\n                let textToCopy = '';\n                if (isNewCave) {\n                    textToCopy = `NEW CAVE\nMap: ${currentMapName}\nPosition: X: ${currentX}, Y: ${currentY}\nRotation: ${currentRotation}\nSize: ${size}\nOre Count: ${oreCount}${fuzzyOre === '1' ? ' (estimated)' : ''}\n`;\n                } else {\n                    textToCopy = `Cave ID: ${window.copiedCaveId}\nMap: ${currentMapName}\nOriginal Position: X: ${origX}, Y: ${origY}\nOriginal Rotation: ${origRotation}${hasChanges ? `\nNew Position: X: ${currentX}, Y: ${currentY}\nNew Rotation: ${currentRotation}` : ''}\n`;\n                }\n\n                // Add metadata\n                textToCopy += `\\nMetadata:\n`;\n                if (hasWorm === '1') textToCopy += `- Worms: ${wormMin}-${wormMax}\\n`;\n                if (hasWater === '1') textToCopy += `- Has Water\\n`;\n                if (hasMush === '1') textToCopy += `- Has Mushrooms\\n`;\n                if (hasGlit === '1') textToCopy += `- Is Unfinished\\n`;\n                if (hasHaza === '1') textToCopy += `- Has Hazards\\n`;\n                if (hasTunn === '1') textToCopy += `- Is Tunnel\\n`;\n                if (hasFall === '1') textToCopy += `- Behind Waterfall\\n`;\n                if (hasFloo === '1') textToCopy += `- Is Flooded\\n`;\n                if (hasUnde === '1') textToCopy += `- Is Underwater\\n`;\n                if (hasUnderg === '1') textToCopy += `- Is Underground\\n`;\n                if (notes) textToCopy += `- Notes: ${notes}\\n`;\n\n                textToCopy += `\\nDev URL: ${devUrl}`;\n\n                navigator.clipboard.writeText(textToCopy).then(() => {\n                    // Show success feedback\n                    const originalText = copyBtn.innerHTML;\n                    copyBtn.innerHTML = '<i class=\"material-symbols-outlined\">check</i> Copied!';\n                    copyBtn.style.background = '#4CAF50';\n\n                    // Disable DevTools marker\n                    const marker = document.getElementById('marker');\n                    if (marker && marker.checked) {\n                        marker.checked = false;\n                        marker.onchange();\n                    }\n\n                    // Show notification\n                    showCaveDataNotification();\n\n                    // Hide DevTools and switch to feedback tab quickly\n                    setTimeout(() => {\n                        if (typeof devhide === 'function') {\n                            devhide();\n                        }\n                        if (typeof sidebar !== 'undefined') {\n                            sidebar.open('feedback');\n                        }\n                    }, 500);\n\n                    setTimeout(() => {\n                        copyBtn.innerHTML = originalText;\n                        copyBtn.style.background = '#2196F3';\n                    }, 2000);\n                }).catch(err => {\n                    console.error('Failed to copy:', err);\n                    alert('Failed to copy to clipboard');\n                });\n            });\n        }\n\n        // Add click event to copy coordinates button\n        const copyCoordsBtn = document.getElementById('copyCoordsBtn');\n        if (copyCoordsBtn) {\n            copyCoordsBtn.addEventListener('click', function (e) {\n                e.preventDefault();\n                e.stopPropagation();\n\n                // Get current map name\n                const currentMapName = (typeof selectedMapParent !== 'undefined' && selectedMapParent)\n                    ? selectedMapParent\n                    : (localStorage.currentMap || 'olympus');\n\n                // Create simple coordinates text\n                const coordsText = `Map: ${currentMapName}\nX: ${currentX}\nY: ${currentY}\nRotation: ${currentRotation}`;\n\n                navigator.clipboard.writeText(coordsText).then(() => {\n                    // Show success feedback\n                    const originalText = copyCoordsBtn.innerHTML;\n                    copyCoordsBtn.innerHTML = '<i class=\"material-symbols-outlined\">check</i> Copied!';\n                    copyCoordsBtn.style.background = '#4CAF50';\n\n                    setTimeout(() => {\n                        copyCoordsBtn.innerHTML = originalText;\n                        copyCoordsBtn.style.background = '#9C27B0';\n                    }, 2000);\n                }).catch(err => {\n                    console.error('Failed to copy:', err);\n                    alert('Failed to copy to clipboard');\n                });\n            });\n        }\n    }\n}\n\n// Show notification when cave data is copied\nfunction showCaveDataNotification() {\n    // Show notification using leaflet notification control\n    notificationControl.success('Cave Data Copied!', 'Please paste the copied data into the feedback form to submit your changes.', {\n        timeout: 4000\n    });\n}\n\n// Disable dev mode and hide dev tab\nfunction toggleDevMode() {\n    const marker = document.getElementById('marker');\n\n    if (marker && marker.checked) {\n        // Disable dev mode\n        marker.checked = false;\n        marker.onchange();\n    }\n\n    // Hide dev mode UI elements\n    devhide();\n\n    // Switch to feedback tab\n    setTimeout(() => {\n        if (typeof sidebar !== 'undefined') {\n            sidebar.open('feedback');\n        }\n    }, 300);\n}\n\n//Hide Devmode by default\nfunction devhide() {\n    const devMode = document.getElementById('devmode');\n    devMode.style.display = devMode.style.display === 'none' ? 'block' : 'none';\n\n    const devTab = document.getElementById('devtab');\n    devTab.style.display = devTab.style.display === 'none' ? 'block' : 'none';\n\n    // Show/hide generate code section based on URL hash\n    const generateCodeSection = document.querySelector('.generate-code-section');\n    if (generateCodeSection) {\n        generateCodeSection.style.display = window.location.hash.startsWith('#dev') ? 'block' : 'none';\n    }\n\n    // Show/hide resultsC section based on URL hash (independent of generate-code-section)\n    const resultsCSection = document.getElementById('resultsC');\n    if (resultsCSection) {\n        const shouldShow = window.location.hash.startsWith('#dev');\n        resultsCSection.style.display = shouldShow ? 'block' : 'none';\n    }\n\n    // When opening dev tab (not from URL), expand only cave marker section\n    if (devMode.style.display === 'block' && !window.location.hash.startsWith('#dev')) {\n        setTimeout(() => expandDevSections(false), 100);\n    }\n}\n\n// Dev Tooltip Settings\nfunction initDevTooltipSettings() {\n    const checkbox = document.getElementById('devTooltipInfo');\n    if (!checkbox) return;\n\n    // Add event listener to update tooltips when checkbox changes\n    checkbox.addEventListener('change', function () {\n        // Update tooltips if layers are loaded\n        if (typeof updateOreDepositState === 'function') {\n            updateOreDepositState();\n        }\n        if (typeof updateGeysersState === 'function') {\n            updateGeysersState();\n        }\n        if (typeof updateOilGeysersState === 'function') {\n            updateOilGeysersState();\n        }\n        if (typeof updateMetaDepositState === 'function') {\n            updateMetaDepositState();\n        }\n        if (typeof updateProspectExoticsPopups === 'function') {\n            updateProspectExoticsPopups();\n        }\n        if (typeof updateGeneralExoticsPopups === 'function') {\n            updateGeneralExoticsPopups();\n        }\n        if (typeof updateCaveDevTooltips === 'function') {\n            updateCaveDevTooltips();\n        }\n    });\n}\n\n/**\n * Clean up old/unnecessary localStorage items\n * Call this on page load to remove deprecated settings\n */\nfunction cleanupLocalStorage() {\n    const itemsToRemove = [\n        'caveHasOresColor',  // Removed feature - cave ore highlighting replaced with overlay/indicator\n        'oreHighlightColor',  // Migrated to displaySettings\n        'oreDimmedOpacity',   // Migrated to displaySettings\n        'caveShowOres'       // Removed filter - now controlled by Deep Ore Veins toggle\n    ];\n\n    itemsToRemove.forEach(item => {\n        if (localStorage.getItem(item) !== null) {\n            localStorage.removeItem(item);\n            debugLog('text', `Cleaned up localStorage item: ${item}`);\n        }\n    });\n}\n\n// Display Settings (consolidated storage)\nfunction getDisplaySettings() {\n    const defaults = {\n        showCaveOreOverlay: true,\n        highlightColor: '#2196F3',\n        dimmedOpacity: 30,\n        showMapCoordinates: false,\n        useGameCoordinates: false,\n        useThousandsSeparator: false\n    };\n\n    const stored = localStorage.getItem('displaySettings');\n    if (stored) {\n        try {\n            return { ...defaults, ...JSON.parse(stored) };\n        } catch (e) {\n            // Migrate old settings if they exist\n            const oldColor = localStorage.getItem('oreHighlightColor');\n            const oldOpacity = localStorage.getItem('oreDimmedOpacity');\n            if (oldColor || oldOpacity) {\n                return {\n                    ...defaults,\n                    highlightColor: oldColor || defaults.highlightColor,\n                    dimmedOpacity: parseInt(oldOpacity) || defaults.dimmedOpacity\n                };\n            }\n            return defaults;\n        }\n    }\n\n    // Migrate old settings if they exist\n    const oldColor = localStorage.getItem('oreHighlightColor');\n    const oldOpacity = localStorage.getItem('oreDimmedOpacity');\n    if (oldColor || oldOpacity) {\n        const migrated = {\n            ...defaults,\n            highlightColor: oldColor || defaults.highlightColor,\n            dimmedOpacity: parseInt(oldOpacity) || defaults.dimmedOpacity\n        };\n        saveDisplaySettings(migrated);\n        return migrated;\n    }\n\n    return defaults;\n}\n\nfunction saveDisplaySettings(settings) {\n    localStorage.setItem('displaySettings', JSON.stringify(settings));\n}\n\n// Ore Filter Highlight Settings\nfunction initHighlightSettings() {\n    // Load saved settings or use defaults\n    const settings = getDisplaySettings();\n\n    // Set UI elements\n    const colorInput = document.getElementById('highlightColor');\n    const opacityInput = document.getElementById('dimmedOpacity');\n    const opacityValue = document.getElementById('dimmedOpacityValue');\n    const overlayCheckbox = document.getElementById('showCaveOreOverlay');\n    const showCoordsCheckbox = document.getElementById('showMapCoordinates');\n    const useGameCoordsCheckbox = document.getElementById('useGameCoordinates');\n    const thousandsSeparatorCheckbox = document.getElementById('useThousandsSeparator');\n\n    if (colorInput) {\n        colorInput.value = settings.highlightColor;\n        colorInput.addEventListener('input', updateHighlightColor);\n    }\n\n    if (opacityInput) {\n        opacityInput.value = settings.dimmedOpacity;\n        opacityValue.textContent = settings.dimmedOpacity;\n        opacityInput.addEventListener('input', function () {\n            opacityValue.textContent = this.value;\n            updateDimmedOpacity(this.value);\n        });\n    }\n\n    if (overlayCheckbox) {\n        overlayCheckbox.checked = settings.showCaveOreOverlay;\n        overlayCheckbox.addEventListener('change', updateCaveOreOverlaySetting);\n    }\n\n    if (showCoordsCheckbox) {\n        showCoordsCheckbox.checked = settings.showMapCoordinates;\n        showCoordsCheckbox.addEventListener('change', updateShowMapCoordinatesSetting);\n        updateCoordinateDisplay();\n    }\n\n    if (useGameCoordsCheckbox) {\n        useGameCoordsCheckbox.checked = settings.useGameCoordinates;\n        useGameCoordsCheckbox.addEventListener('change', updateUseGameCoordinatesSetting);\n    }\n\n    if (thousandsSeparatorCheckbox) {\n        thousandsSeparatorCheckbox.checked = settings.useThousandsSeparator;\n        thousandsSeparatorCheckbox.addEventListener('change', updateUseThousandsSeparatorSetting);\n    }\n\n    // Apply settings\n    applyHighlightSettings(settings.highlightColor, settings.dimmedOpacity);\n}\n\nfunction updateHighlightColor() {\n    const color = document.getElementById('highlightColor').value;\n    const settings = getDisplaySettings();\n    settings.highlightColor = color;\n    saveDisplaySettings(settings);\n    applyHighlightColor(color);\n}\n\nfunction updateDimmedOpacity(opacity) {\n    const settings = getDisplaySettings();\n    settings.dimmedOpacity = parseInt(opacity);\n    saveDisplaySettings(settings);\n    applyDimmedOpacity(opacity);\n}\n\nfunction updateCaveOreOverlaySetting() {\n    const checkbox = document.getElementById('showCaveOreOverlay');\n    const settings = getDisplaySettings();\n    settings.showCaveOreOverlay = checkbox.checked;\n    saveDisplaySettings(settings);\n\n    // Refresh cave ore overlay if caves layer is active\n    if (typeof applyCaveOreOverlay === 'function') {\n        applyCaveOreOverlay();\n    }\n}\n\nfunction updateShowMapCoordinatesSetting() {\n    const checkbox = document.getElementById('showMapCoordinates');\n    const settings = getDisplaySettings();\n    settings.showMapCoordinates = checkbox.checked;\n    saveDisplaySettings(settings);\n    updateCoordinateDisplay();\n}\n\nfunction updateUseGameCoordinatesSetting() {\n    const checkbox = document.getElementById('useGameCoordinates');\n    const settings = getDisplaySettings();\n    settings.useGameCoordinates = checkbox.checked;\n    saveDisplaySettings(settings);\n}\n\nfunction updateUseThousandsSeparatorSetting() {\n    const checkbox = document.getElementById('useThousandsSeparator');\n    const settings = getDisplaySettings();\n    settings.useThousandsSeparator = checkbox.checked;\n    saveDisplaySettings(settings);\n}\n\nfunction updateCoordinateDisplay() {\n    const settings = getDisplaySettings();\n    const coordDisplay = document.getElementById('coordinateDisplay');\n\n    if (settings.showMapCoordinates) {\n        coordDisplay.style.display = 'block';\n        // Add mousemove listener to map if not already added\n        if (!map._coordinateListener) {\n            map._coordinateListener = true;\n            map.on('mousemove', function (e) {\n                updateCoordinateText(e.latlng);\n            });\n        }\n    } else {\n        coordDisplay.style.display = 'none';\n    }\n}\n\nfunction updateCoordinateText(latlng) {\n    const settings = getDisplaySettings();\n    const coordText = document.getElementById('coordinateText');\n\n    if (!settings.showMapCoordinates) {\n        return;\n    }\n\n    // Get map coordinates\n    const point = map.project(latlng, MAP_ZOOM);\n    const mapX = Math.round(point.x);\n    const mapY = Math.round(point.y);\n\n    if (settings.useGameCoordinates) {\n        // Convert to game coordinates using the same formula from cord_search\n        const gridSize = Math.pow(selectedMapGridZoom, 2);\n        const gameX = Math.round((mapX - 4096) * (gridSize * 50400 / 8192));\n        const gameY = Math.round((mapY - 4096) * (gridSize * 50400 / 8192));\n        coordText.textContent = settings.useThousandsSeparator\n            ? `${gameX.toLocaleString()} | ${gameY.toLocaleString()}`\n            : `${gameX} | ${gameY}`;\n    } else {\n        coordText.textContent = settings.useThousandsSeparator\n            ? `${mapX.toLocaleString()} | ${mapY.toLocaleString()}`\n            : `${mapX} | ${mapY}`;\n    }\n}\n\n\nfunction applyHighlightSettings(color, opacity) {\n    applyHighlightColor(color);\n    applyDimmedOpacity(opacity);\n}\n\nfunction applyHighlightColor(color) {\n    // Convert hex to RGB\n    const r = parseInt(color.substr(1, 2), 16);\n    const g = parseInt(color.substr(3, 2), 16);\n    const b = parseInt(color.substr(5, 2), 16);\n\n    // Create or update dynamic style\n    let styleEl = document.getElementById('dynamic-highlight-style');\n    if (!styleEl) {\n        styleEl = document.createElement('style');\n        styleEl.id = 'dynamic-highlight-style';\n        document.head.appendChild(styleEl);\n    }\n\n    styleEl.textContent = `\n        .leaflet-marker-icon.ore-highlighted {\n            filter: drop-shadow(0 0 8px rgba(${r}, ${g}, ${b}, 0.8)) drop-shadow(0 0 12px rgba(${r}, ${g}, ${b}, 0.6)) !important;\n            z-index: 1000 !important;\n        }\n        .leaflet-marker-icon.ore-highlighted.cave-has-ores {\n            filter: drop-shadow(0 0 8px rgba(${r}, ${g}, ${b}, 0.8)) drop-shadow(0 0 12px rgba(${r}, ${g}, ${b}, 0.6)) !important;\n            z-index: 1000 !important;\n        }\n    `;\n}\n\nfunction applyDimmedOpacity(opacity) {\n    // Create or update dynamic style\n    let styleEl = document.getElementById('dynamic-dimmed-style');\n    if (!styleEl) {\n        styleEl = document.createElement('style');\n        styleEl.id = 'dynamic-dimmed-style';\n        document.head.appendChild(styleEl);\n    }\n\n    const opacityValue = opacity / 100;\n    styleEl.textContent = `\n        .leaflet-marker-icon.ore-dimmed {\n            opacity: ${opacityValue} !important;\n            filter: grayscale(50%);\n        }\n    `;\n}\n\nfunction resetHighlightSettings() {\n    // Reset to defaults\n    const defaults = {\n        showCaveOreOverlay: true,\n        highlightColor: '#2196F3',\n        dimmedOpacity: 30\n    };\n\n    saveDisplaySettings(defaults);\n\n    // Update UI\n    document.getElementById('highlightColor').value = defaults.highlightColor;\n    document.getElementById('dimmedOpacity').value = defaults.dimmedOpacity;\n    document.getElementById('dimmedOpacityValue').textContent = defaults.dimmedOpacity;\n    const overlayCheckbox = document.getElementById('showCaveOreOverlay');\n    if (overlayCheckbox) {\n        overlayCheckbox.checked = defaults.showCaveOreOverlay;\n    }\n\n    // Apply settings\n    applyHighlightSettings(defaults.highlightColor, defaults.dimmedOpacity);\n\n    // Refresh cave ore overlay\n    if (typeof applyCaveOreOverlay === 'function') {\n        applyCaveOreOverlay();\n    }\n}\n\n// Initialize dev cave marker field listeners\nfunction initDevCaveFieldListeners() {\n    const lngCField = document.getElementById('lngC');\n    const latCField = document.getElementById('latC');\n    const rotCField = document.getElementById('rotC');\n\n    if (lngCField && latCField) {\n        // Update marker position when X field changes\n        lngCField.addEventListener('input', function () {\n            const x = parseFloat(this.value);\n            const y = parseFloat(latCField.value) || 0;\n            if (!isNaN(x)) {\n                markerC.setLatLng(map.unproject([x, y], MAP_ZOOM));\n                updateCopiedCaveInfo();\n                if (typeof cave_search === 'function') cave_search();\n            }\n        });\n\n        // Update marker position when Y field changes\n        latCField.addEventListener('input', function () {\n            const x = parseFloat(lngCField.value) || 0;\n            const y = parseFloat(this.value);\n            if (!isNaN(y)) {\n                markerC.setLatLng(map.unproject([x, y], MAP_ZOOM));\n                updateCopiedCaveInfo();\n                if (typeof cave_search === 'function') cave_search();\n            }\n        });\n    }\n\n    if (rotCField) {\n        // Update marker rotation when rotation field changes\n        rotCField.addEventListener('input', function () {\n            const rotation = parseFloat(this.value) || 0;\n            markerC.setRotationAngle(rotation);\n            updateCopiedCaveInfo();\n            if (typeof cave_search === 'function') cave_search();\n        });\n    }\n\n    // Add listeners for all cave property fields to regenerate SQL\n    const cavePropertyFields = [\n        'caveId', 'csz', 'cor', 'cfo', 'cdo', 'cwr', 'cwn', 'cwx',\n        'cwt', 'cms', 'cuf', 'chz', 'ctn', 'cwf', 'cfl', 'cuw', 'cug', 'cnt'\n    ];\n\n    cavePropertyFields.forEach(fieldId => {\n        const field = document.getElementById(fieldId);\n        if (field) {\n            const eventType = field.type === 'checkbox' ? 'change' : 'input';\n            field.addEventListener(eventType, function () {\n                if (typeof cave_search === 'function') cave_search();\n            });\n        }\n    });\n\n    // Show initial instructions\n    updateCopiedCaveInfo();\n}\n\n/**\n * Copy cave data to the dev cave marker for repositioning\n * @param {Object} marker - The cave marker to copy data from\n */\nfunction copyCaveToDevMarker(marker) {\n    if (!marker || !marker.caveData) return;\n\n    const caveData = marker.caveData;\n    const caveId = marker.caveId;\n\n    // Store cave ID and original position globally for updates\n    window.copiedCaveId = caveId;\n    window.copiedCaveOriginalX = caveData.x;\n    window.copiedCaveOriginalY = caveData.y;\n    window.copiedCaveOriginalRotation = caveData.r || 0;\n\n    // Store the last clicked cave marker for restoration\n    window.lastClickedCaveMarker = marker;\n\n    // Get the cave's current position\n    const x = caveData.x;\n    const y = caveData.y;\n    const rotation = caveData.r || 0;\n\n    // Update the dev cave marker position and rotation\n    if (typeof markerC !== 'undefined') {\n        markerC.setLatLng(map.unproject([x, y], MAP_ZOOM));\n        markerC.setRotationAngle(rotation);\n\n        // Update the form fields in the dev tab\n        updateCaveMarkerFields(x, y, rotation);\n\n        // Update the copied cave info display\n        updateCopiedCaveInfo();\n\n        // Add marker to map if not already visible\n        const markerCheckbox = document.getElementById('marker');\n        if (markerCheckbox && !markerCheckbox.checked) {\n            markerCheckbox.checked = true;\n            markerC.addTo(map);\n        }\n\n        // Pan to the marker\n        map.panTo(markerC.getLatLng());\n\n        // Open the dev tab\n        if (typeof sidebar !== 'undefined') {\n            sidebar.open('dev');\n        }\n    }\n}\n\nfunction devToolsLoad() {\n    (async () => {\n        if (window.importDevCavesFromCsv) {\n            console.log('devTools.js already loaded');\n            return;\n        }\n\n        await new Promise((resolve, reject) => {\n            const script = document.createElement('script');\n            script.src = new URL(`scripts/util/devTools.js`, location.href).href;\n            script.onload = resolve;\n            script.onerror = () => reject(new Error('Failed to load devTools.js'));\n            document.head.appendChild(script);\n        });\n\n        console.log('Loaded devTools.js');\n    })();\n}\n\n// Initialize on load\nif (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', cleanupLocalStorage);\n    document.addEventListener('DOMContentLoaded', initHighlightSettings);\n    document.addEventListener('DOMContentLoaded', initDevTooltipSettings);\n    document.addEventListener('DOMContentLoaded', initDevCaveFieldListeners);\n    document.addEventListener('DOMContentLoaded', () => {\n        setTimeout(loadDevCaveFromURL, 500);\n    });\n} else {\n    cleanupLocalStorage();\n    initHighlightSettings();\n    initDevTooltipSettings();\n    initDevCaveFieldListeners();\n    setTimeout(loadDevCaveFromURL, 500);\n}\n\n//Created by FinallyRage, CheevoSeeker, ENeMy_DaVe reach out to us on discord!\nfunction searchCave() {\n    const caveId = document.getElementById('caveId').value.trim();\n    if (!caveId) {\n        document.getElementById('caveResults').innerHTML = 'Please enter a cave ID.';\n        return;\n    }\n\n    const mapName = window.selectedMapParent;\n    const caves = window.cachedCavesData[mapName];\n    if (!caves) {\n        document.getElementById('caveResults').innerHTML = 'No cave data loaded for this map.';\n        return;\n    }\n\n    const cave = Object.values(caves).find(c => String(c.id).toLowerCase() === caveId.toLowerCase());\n    if (!cave) {\n        document.getElementById('caveResults').innerHTML = 'Cave not found.';\n        return;\n    }\n\n    // Pan to the cave\n    const latlng = map.unproject([cave.x, cave.y], MAP_ZOOM);\n    map.panTo(latlng);\n\n    // Highlight the cave marker for a few seconds\n    if (window.mapLayerCaves) {\n        // Add CSS for highlight if not present\n        let styleEl = document.getElementById('cave-search-highlight-style');\n        if (!styleEl) {\n            styleEl = document.createElement('style');\n            styleEl.id = 'cave-search-highlight-style';\n            styleEl.textContent = `\n                .leaflet-marker-icon.cave-search-highlight {\n                    filter: drop-shadow(0 0 10px rgba(255, 255, 0, 0.8)) drop-shadow(0 0 20px rgba(255, 255, 0, 0.6)) !important;\n                    z-index: 1000 !important;\n                }\n            `;\n            document.head.appendChild(styleEl);\n        }\n\n        window.mapLayerCaves.eachLayer(marker => {\n            if (marker.caveId == cave.id) {\n                const iconElement = marker.getElement();\n                if (iconElement) {\n                    iconElement.classList.add('cave-search-highlight');\n                    setTimeout(() => {\n                        iconElement.classList.remove('cave-search-highlight');\n                    }, 3000); // Highlight for 3 seconds\n                }\n            }\n        });\n    }\n\n    // Compute game coordinates from map coordinates\n    const gridSize = Math.pow(window.selectedMapGridZoom, 2);\n    const gameLng = (cave.x - 4096) * (gridSize * 50400 / 8192);\n    const gameLat = (cave.y - 4096) * (gridSize * 50400 / 8192);\n\n    document.getElementById('caveResults').innerHTML = `Found cave ${cave.id} at game coordinates (${gameLng.toFixed(2)}, ${gameLat.toFixed(2)}). Panned to location.`;\n}\n\n// Helper function to create or move the navigation marker\nfunction updateNavMarker(latlng) {\n    if (currentNavMarker) {\n        // Move existing marker to new position\n        currentNavMarker.setLatLng(latlng);\n    } else {\n        // Create new navigation marker\n        currentNavMarker = L.marker(latlng, { icon: target_nav, draggable: true }).addTo(map);\n\n        // Update coordinates when marker is dragged\n        currentNavMarker.on('dragend', function (e) {\n            const newLatLng = currentNavMarker.getLatLng();\n            const projected = map.project(newLatLng, MAP_ZOOM);\n            document.getElementById('navX').value = Math.round(projected.x);\n            document.getElementById('navY').value = Math.round(projected.y);\n            document.getElementById('caveResults').innerHTML = `Marker moved to coordinates (${Math.round(projected.x)}, ${Math.round(projected.y)}).`;\n        });\n\n        // Remove marker when clicked\n        currentNavMarker.on('click', function (e) {\n            map.removeLayer(currentNavMarker);\n            currentNavMarker = null;\n            document.getElementById('caveResults').innerHTML = 'Navigation marker removed.';\n        });\n    }\n\n    // Always update coordinate fields when marker position changes\n    const projected = map.project(latlng, MAP_ZOOM);\n    document.getElementById('navX').value = Math.round(projected.x);\n    document.getElementById('navY').value = Math.round(projected.y);\n\n    return currentNavMarker;\n}\n\nfunction navigateToCoords() {\n    const navX = parseFloat(document.getElementById('navX').value);\n    const navY = parseFloat(document.getElementById('navY').value);\n\n    if (isNaN(navX) || isNaN(navY)) {\n        document.getElementById('caveResults').innerHTML = 'Please enter valid coordinates.';\n        return;\n    }\n\n    // Use input coordinates directly as map coordinates\n    const x = navX;\n    const y = navY;\n\n    const latlng = map.unproject([x, y], MAP_ZOOM);\n    map.panTo(latlng);\n\n    // Update or create navigation marker\n    updateNavMarker(latlng);\n\n    document.getElementById('caveResults').innerHTML = `Navigated to coordinates (${navX}, ${navY}).`;\n}\n\n/**\n * Updates the visibility of the Prometheus NULL sector spoiler section\n * Shows the section only when Prometheus map is selected\n */\nfunction updatePrometheusNullSectionVisibility() {\n    const nullSection = document.getElementById('prometheusNullSection');\n    if (!nullSection) return;\n\n    if (typeof selectedMapParent !== 'undefined' && selectedMapParent === 'prometheus') {\n        nullSection.style.display = '';\n    } else {\n        nullSection.style.display = 'none';\n    }\n}\n\n// Prometheus NULL Sector - Caves toggle\ndocument.getElementById(filterPrometheusNullCaves).addEventListener(\"change\", function () {\n    const filterState = getFilterState();\n    if (!filterState.prometheusNull) {\n        filterState.prometheusNull = { caves: false, ore: false, map: false };\n    }\n    filterState.prometheusNull.caves = this.checked;\n    setFilterState(filterState);\n\n    // Apply NULL sector cave filtering dynamically\n    if (selectedMapParent === 'prometheus' && typeof applyCaveTierFiltering !== 'undefined') {\n        applyCaveTierFiltering();\n    }\n});\n\n// Prometheus NULL Sector - Ore nodes toggle\ndocument.getElementById(filterPrometheusNullOre).addEventListener(\"change\", function () {\n    const filterState = getFilterState();\n    if (!filterState.prometheusNull) {\n        filterState.prometheusNull = { caves: false, ore: false, map: false };\n    }\n    filterState.prometheusNull.ore = this.checked;\n    setFilterState(filterState);\n    // Apply ore deposit filtering to show/hide NULL sector ores\n    if (selectedMapParent === 'prometheus' && typeof applyOreDepositFiltering !== 'undefined') {\n        applyOreDepositFiltering();\n    }\n});\n\n// Prometheus NULL Sector - Map visibility toggle (with confirmation)\ndocument.getElementById(filterPrometheusNullMap).addEventListener(\"click\", function (e) {\n    if (this.checked) {\n        // User is trying to enable - show confirmation\n        e.preventDefault();\n\n        showCustomConfirm(\n            \"Uncover NULL Sector\",\n            \"You are trying to uncover the null sector fog. Game design covered it for a better game experience. Are you sure, you want to see map of null sector?\",\n            () => {\n                // User confirmed - enable the checkbox\n                this.checked = true;\n                const filterState = getFilterState();\n                if (!filterState.prometheusNull) {\n                    filterState.prometheusNull = { caves: false, ore: false, map: false };\n                }\n                filterState.prometheusNull.map = true;\n                setFilterState(filterState);\n\n                // Toggle to prometheus2 tiles\n                togglePrometheusNullMap(true);\n            },\n            false,\n            \"Show Map\",\n            \"Cancel\",\n            null,\n            \"primary\"\n        );\n    } else {\n        // User is disabling - allow without confirmation\n        const filterState = getFilterState();\n        if (!filterState.prometheusNull) {\n            filterState.prometheusNull = { caves: false, ore: false, map: false };\n        }\n        filterState.prometheusNull.map = false;\n        setFilterState(filterState);\n\n        // Toggle back to prometheus tiles\n        togglePrometheusNullMap(false);\n    }\n});\n\n/**\n * Toggle between prometheus and prometheus2 map tiles\n * @param {boolean} showNull - True to show prometheus2 (NULL sector), false for prometheus\n */\nfunction togglePrometheusNullMap(showNull) {\n    if (selectedMapParent !== 'prometheus') return;\n\n    const targetTilesPath = showNull ? 'prometheus2' : 'prometheus';\n\n    // Only switch if we're changing to a different tileset\n    if (_currentTilesPath === targetTilesPath) return;\n\n    // Get current map info for options\n    const mapInfo = _mapData.find(m => m.code === selectedMap);\n    if (!mapInfo) return;\n\n    // Create new tile layer if it doesn't exist\n    if (!_mapTileLayers[targetTilesPath]) {\n        let mapOptions = {\n            minZoom: 1,\n            maxZoom: mapInfo['gridZoom'] + 2,\n            maxNativeZoom: mapInfo['maxZoom'],\n            continuousWorld: false,\n            noWrap: true,\n            bounds: TILE_BOUNDS,\n            // attribution: mapAttribution,\n        };\n        _mapTileLayers[targetTilesPath] = L.tileLayer('maps/' + targetTilesPath + '/{z}/{x}/{y}.jpg', mapOptions);\n    }\n\n    // Remove old map, load new one\n    Object.values(_mapTileLayers).forEach(layer => map.removeLayer(layer));\n    _mapTileLayers[targetTilesPath].addTo(map);\n\n    _currentTilesPath = targetTilesPath;\n}\n\n// Connect rotation slider to input\ndocument.getElementById('rotSlider').addEventListener('input', function () {\n    document.getElementById('rotC').value = this.value;\n    cave_search();\n});\n\ndocument.getElementById('rotC').addEventListener('input', function () {\n    let val = parseInt(this.value) || 0;\n    val = ((val % 360) + 360) % 360;\n    if (val > 180) val -= 360;\n    this.value = val;\n    document.getElementById('rotSlider').value = val;\n    cave_search();\n});\n\n// Initialize slider value\nlet initVal = parseInt(document.getElementById('rotC').value) || 0;\ninitVal = ((initVal % 360) + 360) % 360;\nif (initVal > 180) initVal -= 360;\ndocument.getElementById('rotSlider').value = initVal;\n\n// Function to update cave marker fields consistently\nfunction updateCaveMarkerFields(x, y, r) {\n    if (x !== undefined) document.getElementById('lngC').value = x;\n    if (y !== undefined) document.getElementById('latC').value = y;\n    if (r !== undefined) {\n        let val = ((r % 360) + 360) % 360;\n        if (val > 180) val -= 360;\n        document.getElementById('rotC').value = val;\n        document.getElementById('rotSlider').value = val;\n    }\n}\n"
          },
