          "cookies": [],
          "content": {
            "size": 22624,
            "mimeType": "text/javascript",
            "text": "/**\n * Change Tracker Module\n * Tracks all user changes to map entities since last load/save.\n * Used for conflict resolution when multiple users edit the same map.\n * Debug logging controlled by global debugChanges flag in main.js\n */\n\nconst ChangeTracker = (function () {\n    'use strict';\n\n    // Private storage for changes\n    let changes = {\n        caves: {},          // {id: {icon, deepOres}}\n        deposits: {},       // {id: {icon, drill}}\n        exotics: {},        // {id: icon}\n        markers: {          // {id: marker_object}\n            added: {},\n            removed: {},\n            edited: {}\n        }\n    };\n\n    /**\n     * Initialize or reset the change tracker\n     */\n    function init() {\n        changes = {\n            caves: {},\n            deposits: {},\n            exotics: {},\n            markers: {\n                added: {},\n                removed: {},\n                edited: {}\n            }\n        };\n    }\n\n    /**\n     * Clear all tracked changes (called after successful save)\n     */\n    function clear() {\n        debugLog('changes', '[ChangeTracker] Clearing all tracked changes:', getChangesSummary());\n        debugLog('changes', '[ChangeTracker] Clearing all tracked changes');\n        init();\n    }\n\n    /**\n     * Check if there are any tracked changes\n     * @returns {boolean} True if there are changes\n     */\n    function hasChanges() {\n        return Object.keys(changes.caves).length > 0 ||\n            Object.keys(changes.deposits).length > 0 ||\n            Object.keys(changes.exotics).length > 0 ||\n            Object.keys(changes.markers.added).length > 0 ||\n            Object.keys(changes.markers.removed).length > 0 ||\n            Object.keys(changes.markers.edited).length > 0;\n    }\n\n    /**\n     * Track a cave icon change\n     * @param {string} id - Cave ID\n     * @param {string} icon - Icon state (i/m/p)\n     * @param {object} deepOres - Deep ore tracking data\n     * @param {array} drills - Drill status array for cave ores\n     */\n    function trackCaveChange(id, icon, deepOres, drills) {\n        changes.caves[id] = {\n            icon: icon,\n            deepOres: deepOres ? JSON.parse(JSON.stringify(deepOres)) : {},\n            drills: drills ? JSON.parse(JSON.stringify(drills)) : undefined\n        };\n        debugLog('changes', '[ChangeTracker] Tracked cave change:', {\n            id,\n            icon,\n            hasDeepOres: !!deepOres,\n            deepOres: deepOres,\n            hasDrills: !!drills,\n            drills: drills,\n            totalCaves: Object.keys(changes.caves).length\n        });\n    }\n\n    /**\n     * Track a deposit icon change\n     * @param {string} id - Deposit ID\n     * @param {string} icon - Icon state (m/x/?)\n     * @param {string} drill - Drill type (optional, undefined to clear)\n     */\n    function trackDepositChange(id, icon, drill) {\n        changes.deposits[id] = {\n            icon: icon,\n            drill: drill\n        };\n        debugLog('changes', '[ChangeTracker] Tracked deposit change:', {\n            id,\n            icon,\n            drill: drill === undefined ? 'none' : drill,\n            hasDrill: drill !== undefined && drill !== null,\n            totalDeposits: Object.keys(changes.deposits).length\n        });\n    }\n\n    /**\n     * Track an exotic deposit icon change\n     * @param {string} id - Exotic deposit ID\n     * @param {string} icon - Icon state (m/x/?)\n     */\n    function trackExoticChange(id, icon) {\n        changes.exotics[id] = icon;\n        debugLog('changes', '[ChangeTracker] Tracked exotic change:', { id, icon, totalExotics: Object.keys(changes.exotics).length });\n    }\n\n    /**\n     * Track a custom marker addition\n     * @param {string} id - Marker ID\n     * @param {object} marker - Marker data\n     */\n    function trackMarkerAdded(id, marker) {\n        // If this was previously marked for removal, check if it's the same marker (same position)\n        if (changes.markers.removed[id]) {\n            // Get the original marker that was removed\n            let removedMarkerPos = null;\n            if (typeof getMapState === 'function') {\n                const localState = getMapState();\n                const removedMarker = localState.custom_marker?.find(m => m.id == id);\n                if (removedMarker) {\n                    removedMarkerPos = removedMarker.pos;\n                }\n            }\n\n            // Check if positions match (same marker being re-added vs different marker reusing ID)\n            if (removedMarkerPos && marker.pos) {\n                const positionThreshold = 0.0001;\n                const removedLat = Array.isArray(removedMarkerPos) ? removedMarkerPos[0] : removedMarkerPos.lat;\n                const removedLng = Array.isArray(removedMarkerPos) ? removedMarkerPos[1] : removedMarkerPos.lng;\n                const newLat = Array.isArray(marker.pos) ? marker.pos[0] : marker.pos.lat;\n                const newLng = Array.isArray(marker.pos) ? marker.pos[1] : marker.pos.lng;\n\n                const latDiff = Math.abs(removedLat - newLat);\n                const lngDiff = Math.abs(removedLng - newLng);\n\n                if (latDiff < positionThreshold && lngDiff < positionThreshold) {\n                    // Same position - marker is being re-added, cancel the removal\n                    delete changes.markers.removed[id];\n                    debugLog('changes', '[ChangeTracker] Marker re-added (same position, removed from removal list):', { id });\n                    return;\n                }\n            }\n\n            // Different position or no position data - this is a different marker reusing the ID\n            // Keep the removal AND add the new marker\n            changes.markers.added[id] = JSON.parse(JSON.stringify(marker));\n            debugLog('changes', '[ChangeTracker] Marker added with reused ID (keeping removal of old marker):', { id });\n        } else {\n            changes.markers.added[id] = JSON.parse(JSON.stringify(marker));\n            debugLog('changes', '[ChangeTracker] Tracked marker added:', { id, totalMarkersAdded: Object.keys(changes.markers.added).length });\n        }\n    }\n\n    /**\n     * Track a custom marker removal\n     * @param {string} id - Marker ID\n     * @param {object} marker - Marker data (optional, for position validation during conflict resolution)\n     */\n    function trackMarkerRemoved(id, marker = null) {\n        // If this was just added, remove from added list\n        if (changes.markers.added[id]) {\n            delete changes.markers.added[id];\n            debugLog('changes', '[ChangeTracker] Marker removed (was just added):', { id });\n        } else if (changes.markers.edited[id]) {\n            // If this was edited, remove from edited list and mark as removed\n            const markerData = marker || changes.markers.edited[id];\n            delete changes.markers.edited[id];\n            changes.markers.removed[id] = markerData ? JSON.parse(JSON.stringify(markerData)) : true;\n            debugLog('changes', '[ChangeTracker] Marker removed (was edited):', { id });\n        } else {\n            // Store marker data for position validation during conflict resolution\n            changes.markers.removed[id] = marker ? JSON.parse(JSON.stringify(marker)) : true;\n            debugLog('changes', '[ChangeTracker] Tracked marker removed:', { id, hasPosition: !!marker?.pos, totalMarkersRemoved: Object.keys(changes.markers.removed).length });\n        }\n    }\n\n    /**\n     * Track a custom marker edit\n     * @param {string} id - Marker ID\n     * @param {object} marker - Updated marker data\n     */\n    function trackMarkerEdited(id, marker) {\n        // If this was just added in this session, update the added entry\n        if (changes.markers.added[id]) {\n            changes.markers.added[id] = JSON.parse(JSON.stringify(marker));\n            debugLog('changes', '[ChangeTracker] Marker edited (updating added entry):', { id });\n        } else if (changes.markers.removed[id]) {\n            // If this was removed, remove from removed list and track as edited\n            // This means the user removed and then re-added/edited the marker\n            delete changes.markers.removed[id];\n            changes.markers.edited[id] = JSON.parse(JSON.stringify(marker));\n            debugLog('changes', '[ChangeTracker] Marker edited (was removed, now edited):', { id });\n        } else {\n            // Track as edited\n            changes.markers.edited[id] = JSON.parse(JSON.stringify(marker));\n            debugLog('changes', '[ChangeTracker] Tracked marker edited:', { id, totalMarkersEdited: Object.keys(changes.markers.edited).length });\n        }\n    }\n\n    /**\n     * Find a marker in a state by ID and position\n     * @param {object} marker - The marker to find (must have id and pos properties)\n     * @param {object} state - The state object containing custom_marker array\n     * @returns {object|null} Returns {marker, index} if found, null if not found\n     */\n    function findMarkerInState(marker, state) {\n        if (!state.custom_marker || !Array.isArray(state.custom_marker)) {\n            return null;\n        }\n\n        const positionThreshold = 0.0001;\n        const markerId = marker.id;\n\n        // Helper to extract lat/lng from either array or object format\n        const getLatLng = (pos) => {\n            if (!pos) return null;\n            if (Array.isArray(pos)) {\n                return { lat: pos[0], lng: pos[1] };\n            }\n            return { lat: pos.lat, lng: pos.lng };\n        };\n\n        // Helper to compare positions\n        const positionsMatch = (pos1, pos2) => {\n            if (!pos1 || !pos2) return false;\n            const latLng1 = getLatLng(pos1);\n            const latLng2 = getLatLng(pos2);\n            if (!latLng1 || !latLng2) return false;\n            const latDiff = Math.abs(latLng1.lat - latLng2.lat);\n            const lngDiff = Math.abs(latLng1.lng - latLng2.lng);\n            return latDiff < positionThreshold && lngDiff < positionThreshold;\n        };\n\n        // First, try to find by ID\n        const indexById = state.custom_marker.findIndex(m => m.id == markerId);\n        if (indexById !== -1) {\n            const foundMarker = state.custom_marker[indexById];\n            // Check if positions match\n            if (positionsMatch(marker.pos, foundMarker.pos)) {\n                // Found by ID and position matches\n                return { marker: foundMarker, index: indexById };\n            }\n            // ID matches but position doesn't - continue searching by position\n        }\n\n        // If not found by ID+position, search by position only\n        if (marker.pos) {\n            const indexByPos = state.custom_marker.findIndex(m => positionsMatch(marker.pos, m.pos));\n            if (indexByPos !== -1) {\n                // Found by position (different ID, same location)\n                return { marker: state.custom_marker[indexByPos], index: indexByPos };\n            }\n        }\n\n        // Not found\n        return null;\n    }\n\n    /**\n     * Apply tracked changes to a given state object\n     * @param {object} state - State object to apply changes to\n     * @returns {object} Modified state with changes applied\n     */\n    function applyChangesToState(state) {\n        const modifiedState = JSON.parse(JSON.stringify(state));\n\n        // Apply cave changes\n        for (const caveId in changes.caves) {\n            const change = changes.caves[caveId];\n            let found = false;\n\n            // Find and update existing cave status\n            if (modifiedState.cave_status) {\n                for (let i = 0; i < modifiedState.cave_status.length; i++) {\n                    if (modifiedState.cave_status[i].id === caveId) {\n                        modifiedState.cave_status[i].icon = change.icon;\n                        if (change.deepOres) {\n                            modifiedState.cave_status[i].deepOres = change.deepOres;\n                        }\n                        // Handle drills: if explicitly set (even to undefined), use it; otherwise preserve existing\n                        if ('drills' in change) {\n                            if (change.drills) {\n                                modifiedState.cave_status[i].drills = change.drills;\n                            } else {\n                                // Explicitly cleared - remove drills property\n                                delete modifiedState.cave_status[i].drills;\n                            }\n                        }\n                        found = true;\n                        break;\n                    }\n                }\n            } else {\n                modifiedState.cave_status = [];\n            }\n\n            // If not found, add new entry\n            if (!found) {\n                const newEntry = {\n                    id: caveId,\n                    icon: change.icon\n                };\n                if (change.deepOres && Object.keys(change.deepOres).length > 0) {\n                    newEntry.deepOres = change.deepOres;\n                }\n                if (change.drills) {\n                    newEntry.drills = change.drills;\n                }\n                modifiedState.cave_status.push(newEntry);\n            }\n        }\n\n        // Apply deposit changes\n        for (const depositId in changes.deposits) {\n            const change = changes.deposits[depositId];\n            let found = false;\n\n            if (modifiedState.deposit_status) {\n                for (let i = 0; i < modifiedState.deposit_status.length; i++) {\n                    if (modifiedState.deposit_status[i].id === depositId) {\n                        modifiedState.deposit_status[i].icon = change.icon;\n                        // Handle drill: if explicitly set in change (even to undefined), use it\n                        if ('drill' in change) {\n                            if (change.drill) {\n                                modifiedState.deposit_status[i].drill = change.drill;\n                            } else {\n                                // Explicitly cleared - remove drill property\n                                delete modifiedState.deposit_status[i].drill;\n                            }\n                        }\n                        found = true;\n                        break;\n                    }\n                }\n            } else {\n                modifiedState.deposit_status = [];\n            }\n\n            if (!found) {\n                const newEntry = {\n                    id: depositId,\n                    icon: change.icon\n                };\n                if (change.drill) {\n                    newEntry.drill = change.drill;\n                }\n                modifiedState.deposit_status.push(newEntry);\n            }\n        }\n\n        // Apply exotic changes\n        for (const exoticId in changes.exotics) {\n            const icon = changes.exotics[exoticId];\n            let found = false;\n\n            if (modifiedState.exotics_status) {\n                for (let i = 0; i < modifiedState.exotics_status.length; i++) {\n                    if (modifiedState.exotics_status[i].id === exoticId) {\n                        modifiedState.exotics_status[i].icon = icon;\n                        found = true;\n                        break;\n                    }\n                }\n            } else {\n                modifiedState.exotics_status = [];\n            }\n\n            if (!found) {\n                modifiedState.exotics_status.push({\n                    id: exoticId,\n                    icon: icon\n                });\n            }\n        }\n\n        // Apply marker edits FIRST (before removals and additions)\n        if (!modifiedState.custom_marker) {\n            modifiedState.custom_marker = [];\n        }\n        for (const markerId in changes.markers.edited) {\n            const editedMarker = changes.markers.edited[markerId];\n            const found = findMarkerInState(editedMarker, modifiedState);\n\n            if (found) {\n                // Marker exists in server state, update it\n                modifiedState.custom_marker[found.index] = JSON.parse(JSON.stringify(editedMarker));\n                debugLog('changes', '[ChangeTracker] Marker edited (updated in place):', markerId, 'at index', found.index);\n            } else {\n                // Marker doesn't exist in server state (possibly deleted by another user)\n                // Treat the edit as an addition\n                modifiedState.custom_marker.push(JSON.parse(JSON.stringify(editedMarker)));\n                debugLog('changes', '[ChangeTracker] Marker edited but not found (adding as new):', markerId);\n            }\n        }\n\n        // Apply marker removals (do this AFTER edits, BEFORE additions)\n        for (const markerId in changes.markers.removed) {\n            // Get the marker information - might be stored directly in removed list\n            let markerToRemove = changes.markers.removed[markerId];\n\n            // If it's just 'true', try to find the marker data elsewhere\n            if (markerToRemove === true) {\n                markerToRemove = changes.markers.added[markerId];\n                if (!markerToRemove && typeof getMapState === 'function') {\n                    const localState = getMapState();\n                    markerToRemove = localState.custom_marker?.find(m => m.id == markerId);\n                }\n                if (!markerToRemove) {\n                    markerToRemove = modifiedState.custom_marker.find(m => m.id == markerId);\n                }\n            }\n\n            if (markerToRemove && typeof markerToRemove === 'object' && markerToRemove.id) {\n                const found = findMarkerInState(markerToRemove, modifiedState);\n                if (found) {\n                    // Found the marker, remove it\n                    modifiedState.custom_marker.splice(found.index, 1);\n                    debugLog('changes', '[ChangeTracker] Marker removed:', markerId, 'from index', found.index);\n                } else {\n                    // Not found - already removed by someone else, that's ok\n                    debugLog('changes', '[ChangeTracker] Marker already removed:', markerId);\n                }\n            } else {\n                // No marker info, try to remove by ID only\n                const index = modifiedState.custom_marker.findIndex(m => m.id == markerId);\n                if (index !== -1) {\n                    modifiedState.custom_marker.splice(index, 1);\n                    debugLog('changes', '[ChangeTracker] Marker removed by ID only:', markerId);\n                } else {\n                    debugLog('changes', '[ChangeTracker] Marker not found for removal:', markerId);\n                }\n            }\n        }\n\n        // Apply marker additions\n        for (const markerId in changes.markers.added) {\n            let marker = changes.markers.added[markerId];\n            let proposedId = parseInt(markerId);\n\n            // Check if ID already exists with different position\n            const found = findMarkerInState(marker, modifiedState);\n\n            if (found) {\n                // Found marker with same ID and position - replace it\n                modifiedState.custom_marker[found.index] = JSON.parse(JSON.stringify(marker));\n                debugLog('changes', '[ChangeTracker] Marker replaced (same ID and position):', proposedId);\n            } else {\n                // Check if the ID is used by a different marker (different position)\n                const idExists = modifiedState.custom_marker.some(m => m.id === proposedId);\n\n                if (idExists) {\n                    // ID exists with different position - find next available ID\n                    const maxId = 1000; // Safety limit\n                    const originalId = proposedId;\n                    while (proposedId < maxId && modifiedState.custom_marker.some(m => m.id === proposedId)) {\n                        proposedId++;\n                    }\n\n                    if (proposedId < maxId) {\n                        // Found available ID, update marker and add\n                        marker = { ...marker, id: proposedId };\n                        modifiedState.custom_marker.push(marker);\n                        debugLog('changes', '[ChangeTracker] Marker added with new ID:', originalId, '->', proposedId);\n                    } else {\n                        debugLog('changes', '[ChangeTracker] Could not find available ID for marker:', markerId);\n                    }\n                } else {\n                    // ID is free, add marker\n                    modifiedState.custom_marker.push(JSON.parse(JSON.stringify(marker)));\n                    debugLog('changes', '[ChangeTracker] Marker added:', proposedId);\n                }\n            }\n        }\n\n        return modifiedState;\n    }\n\n    /**\n     * Get a summary of changes for debugging\n     * @returns {object} Summary of all tracked changes\n     */\n    function getChangesSummary() {\n        return {\n            caves: Object.keys(changes.caves).length,\n            deposits: Object.keys(changes.deposits).length,\n            exotics: Object.keys(changes.exotics).length,\n            markersAdded: Object.keys(changes.markers.added).length,\n            markersRemoved: Object.keys(changes.markers.removed).length,\n            markersEdited: Object.keys(changes.markers.edited).length\n        };\n    }\n\n    /**\n     * Enable debug logging (deprecated - use global debugChanges flag in main.js)\n     */\n    function enableDebug() {\n        debugLog('changes', '[ChangeTracker] Debug logging controlled by global debugChanges flag');\n    }\n\n    /**\n     * Disable debug logging (deprecated - use global debugChanges flag in main.js)\n     */\n    function disableDebug() {\n        debugLog('changes', '[ChangeTracker] Debug logging controlled by global debugChanges flag');\n    }\n\n    /**\n     * Check if debug mode is enabled\n     * @returns {boolean} True if debug is enabled\n     */\n    function isDebugEnabled() {\n        return typeof DEBUG !== 'undefined' && DEBUG.debugChanges;\n    }\n\n    // Public API\n    return {\n        init: init,\n        clear: clear,\n        hasChanges: hasChanges,\n        trackCaveChange: trackCaveChange,\n        trackDepositChange: trackDepositChange,\n        trackExoticChange: trackExoticChange,\n        trackMarkerAdded: trackMarkerAdded,\n        trackMarkerRemoved: trackMarkerRemoved,\n        trackMarkerEdited: trackMarkerEdited,\n        applyChangesToState: applyChangesToState,\n        getChangesSummary: getChangesSummary,\n        enableDebug: enableDebug,\n        disableDebug: disableDebug,\n        isDebugEnabled: isDebugEnabled\n    };\n})();\n"
          },
