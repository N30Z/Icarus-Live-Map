              "value": "text/javascript"
            }
          ],
          "cookies": [],
          "content": {
            "size": 3869,
            "mimeType": "text/javascript",
            "text": "/**\n * Theme Management System\n * Handles light/dark mode toggling with localStorage persistence\n * Default: Dark mode\n */\n\nclass ThemeManager {\n    constructor() {\n        this.STORAGE_KEY = 'icarusMapTheme';\n        this.THEME_DARK = 'dark';\n        this.THEME_LIGHT = 'light';\n\n        // Initialize theme on page load\n        this.init();\n    }\n\n    /**\n     * Initialize the theme system\n     */\n    init() {\n        // Get saved theme preference, default to dark if not set\n        const savedTheme = localStorage.getItem(this.STORAGE_KEY);\n        const initialTheme = savedTheme || this.THEME_DARK;\n\n        // Apply the theme\n        this.applyTheme(initialTheme, false);\n\n        // Set up event listener for theme toggle button (if it exists)\n        this.setupToggleButton();\n    }\n\n    /**\n     * Get the current theme\n     */\n    getCurrentTheme() {\n        return document.body.classList.contains('light-mode') ? this.THEME_LIGHT : this.THEME_DARK;\n    }\n\n    /**\n     * Apply a specific theme\n     * @param {string} theme - 'light' or 'dark'\n     * @param {boolean} save - Whether to save to localStorage (default: true)\n     */\n    applyTheme(theme, save = true) {\n        if (theme === this.THEME_LIGHT) {\n            document.body.classList.add('light-mode');\n        } else {\n            document.body.classList.remove('light-mode');\n        }\n\n        // Save to localStorage (only save if light mode, dark is default)\n        if (save) {\n            if (theme === this.THEME_LIGHT) {\n                localStorage.setItem(this.STORAGE_KEY, this.THEME_LIGHT);\n            } else {\n                // Remove from storage if dark mode (since dark is default)\n                localStorage.removeItem(this.STORAGE_KEY);\n            }\n        }\n\n        // Update toggle button state if it exists\n        this.updateToggleButton();\n\n        // Dispatch custom event for other components that might need to react\n        window.dispatchEvent(new CustomEvent('themeChanged', { detail: { theme } }));\n    }\n\n    /**\n     * Toggle between light and dark themes\n     */\n    toggleTheme() {\n        const currentTheme = this.getCurrentTheme();\n        const newTheme = currentTheme === this.THEME_DARK ? this.THEME_LIGHT : this.THEME_DARK;\n        this.applyTheme(newTheme);\n    }\n\n    /**\n     * Set up the theme toggle button event listener\n     */\n    setupToggleButton() {\n        const toggleButton = document.getElementById('themeToggle');\n        if (toggleButton) {\n            toggleButton.addEventListener('click', () => this.toggleTheme());\n            this.updateToggleButton();\n        }\n    }\n\n    /**\n     * Update the theme toggle button appearance\n     */\n    updateToggleButton() {\n        const toggleButton = document.getElementById('themeToggle');\n        if (!toggleButton) return;\n\n        const currentTheme = this.getCurrentTheme();\n        const icon = toggleButton.querySelector('.material-symbols-outlined');\n        const label = toggleButton.querySelector('.theme-toggle-label');\n\n        if (currentTheme === this.THEME_DARK) {\n            if (icon) icon.textContent = 'light_mode';\n            if (label) label.textContent = 'Switch to Light Mode';\n            toggleButton.title = 'Switch to Light Mode';\n        } else {\n            if (icon) icon.textContent = 'dark_mode';\n            if (label) label.textContent = 'Switch to Dark Mode';\n            toggleButton.title = 'Switch to Dark Mode';\n        }\n    }\n\n    /**\n     * Check if system prefers dark mode (optional, for future use)\n     */\n    systemPrefersDark() {\n        return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;\n    }\n}\n\n// Create global instance\nwindow.themeManager = new ThemeManager();\n\n// Export for module usage if needed\nif (typeof module !== 'undefined' && module.exports) {\n    module.exports = ThemeManager;\n}\n"
          },
          "redirectURL": "",
          "headersSize": -1,
