          "content": {
            "size": 53856,
            "mimeType": "text/javascript",
            "text": "window.mapLayerCaves = null;\nlet mapLayerCavesName = '';\nwindow.cachedCavesData = {};\n\n// Cave tier thresholds\nconst CAVE_TIER1_MAX = 24;\nconst CAVE_TIER2_MAX = 34;\nconst CAVE_TIER3_MAX = 54;\n\n// Helper function to calculate cave tier from ore count\nfunction getCaveTier(oreCount) {\n    if (oreCount == null || oreCount <= 0) return null;\n    if (oreCount <= CAVE_TIER1_MAX) return 1;\n    if (oreCount <= CAVE_TIER2_MAX) return 2;\n    if (oreCount <= CAVE_TIER3_MAX) return 3;\n    return 5;\n}\n\n// Function to create custom stacked cave icon\nfunction createCaveIcon({ tier = 1, danger = false, removed = false, tunnel = false, ug = false, uw = false, mined = false, partiallyMined = false, rotation = 0 }) {\n    const rankSrc = (tier && !mined && !partiallyMined) ? (tier === 1 ? 'rank1.png' : tier === 2 ? 'rank2.png' : tier === 3 ? 'rank3.png' : 'rank5.png') : null;\n    let baseSrc = 'cave.png';\n    if (uw) baseSrc = 'cave_uw.png';\n    else if (ug) baseSrc = 'cave_ug.png';\n    const html = `\n        <div class=\"cave-icon-wrapper\" style=\"position: relative; width: 32px; height: 32px;\">\n            <img src=\"icon/${baseSrc}\" style=\"position: absolute; width: 32px; height: 32px;\" />\n            ${tunnel ? '<img src=\"icon/cave_tn.png\" style=\"position: absolute; width: 32px; height: 32px;\" />' : ''}\n            ${rankSrc ? `<img src=\"icon/${rankSrc}\" style=\"position: absolute; top: 0; left: 0; width: 20px; height: 20px; margin-top: 4px;\" />` : ''}\n            ${danger ? '<img src=\"icon/dang.png\" style=\"position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 12px; height: 12px;\" />' : ''}\n            ${removed ? '<img src=\"icon/cave_rm.png\" style=\"position: absolute; width: 32px; height: 32px;\" />' : ''}\n            ${partiallyMined ? '<img src=\"icon/cave_s_p.png\" style=\"position: absolute; width: 32px; height: 32px;\" />' : ''}\n            ${mined ? '<img src=\"icon/cave_s_m.png\" style=\"position: absolute; width: 32px; height: 32px;\" />' : ''}\n        </div>\n    `;\n\n    // Calculate popup anchor based on rotation\n    // Icon rotates around iconAnchor [16, 32] (bottom center of original icon)\n    // Icon center is at [16, 16] relative to iconAnchor\n    // We want popup to always appear ~30px above the visual center of the rotated icon\n    const radians = (rotation * Math.PI) / 180;\n\n    // First, find where the icon center is after rotation (relative to icon anchor)\n    const centerX = 0;  // Icon center is directly above the anchor horizontally\n    const centerY = -16; // Icon center is 16px above the anchor\n\n    // Rotate the center point\n    const rotatedCenterX = centerX * Math.cos(radians) - centerY * Math.sin(radians);\n    const rotatedCenterY = centerX * Math.sin(radians) + centerY * Math.cos(radians);\n\n    // Popup should be 30px above the rotated center in screen space (not rotated space)\n    // This means always offsetting by [0, -30] in screen coordinates\n    const popupX = rotatedCenterX + 0;\n    const popupY = rotatedCenterY - 30;\n\n    return L.divIcon({\n        className: 'custom-cave-icon',\n        html: html,\n        iconSize: [32, 32],\n        iconAnchor: [16, 32],\n        popupAnchor: [Math.round(popupX), Math.round(popupY)],\n    });\n}\n\n// Helper function to get cave icon\nfunction getCaveIcon(cave) {\n    const tier = getCaveTier(cave.oc);\n    const danger = cave.haz || false;\n    const removed = (cave.rem || cave.unf) || false;\n    const tunnel = cave.tun || false;\n    const ug = cave.ug || false;\n    const uw = cave.uw || false;\n    const state = getCaveState(cave.id) || 'i';\n    const mined = state === 'm';\n    const partiallyMined = state === 'p';\n    const rotation = cave.r || 0;\n\n    return createCaveIcon({ tier, danger, removed, tunnel, ug, uw, mined, partiallyMined, rotation });\n}\n\n// Helper function to get formatted deep ore count\nfunction getDeepOres(cave) {\n    if (cave.doc === null || cave.doc === undefined) return '???';\n    if (cave.doc === 0) return 'NONE';\n    return String(cave.doc);\n}\n\n// Helper function to get formatted ore count\nfunction getOres(cave) {\n    if (cave.oc === null || cave.oc === undefined) return '???';\n    if (cave.oc === 0) return 'N/A';\n\n    let str = String(cave.oc);\n    if (cave.foc) str += '+';\n    return str;\n}\n\n// Helper function to get cave properties array\nfunction getCaveProperties(cave) {\n    const properties = [];\n    if (cave.wat) properties.push('Water');\n    if (cave.fsh) properties.push('Fish');\n    if (cave.msh) properties.push('Mushrooms');\n    if (cave.unf) properties.push('Unfinished');\n    if (cave.haz) properties.push('Pit Hazard');\n    if (cave.rem) properties.push('Removed');\n    if (cave.tun) properties.push('Tunnel');\n    if (cave.wf) properties.push('Waterfall Cave');\n    if (cave.fld) properties.push('Flooded');\n    if (cave.uw) properties.push('Underwater');\n    if (cave.ug) properties.push('Underground');\n    if (properties.length === 0) properties.push('None');\n    return properties;\n}\n\n// Helper function to get formatted size\nfunction getCaveSize(cave) {\n    return cave.s === null || cave.s === undefined ? '???' : cave.s;\n}\n\n// Helper function to get formatted worms info\nfunction getCaveWorms(cave) {\n    if (cave.hw === null || cave.hw === undefined) return '???';\n    if (!cave.hw) return 'None';\n\n    const min = (cave.wmin === null || cave.wmin === undefined || Number(cave.wmin) === 0) ? 0 : Number(cave.wmin);\n    const max = (cave.wmax === null || cave.wmax === undefined || Number(cave.wmax) === 0) ? 'x' : Number(cave.wmax);\n\n    return \"Yes (\" + min + \"-\" + max + \")\";\n}\n\n// Helper function to get formatted bees info\nfunction getCaveBees(cave) {\n    if (cave.hb === null || cave.hb === undefined) return '???';\n    if (!cave.hb) return 'None';\n\n    const min = (cave.bmin === null || cave.bmin === undefined || Number(cave.bmin) === 0) ? 0 : Number(cave.bmin);\n    const max = (cave.bmax === null || cave.bmax === undefined || Number(cave.bmax) === 0) ? 'x' : Number(cave.bmax);\n\n    return \"Yes (\" + min + \"-\" + max + \")\";\n}\n\nfunction escapeTooltipHtml(value) {\n    return String(value)\n        .replace(/&/g, '&amp;')\n        .replace(/</g, '&lt;')\n        .replace(/>/g, '&gt;')\n        .replace(/\"/g, '&quot;')\n        .replace(/'/g, '&#39;');\n}\n\nfunction getCaveDisplayInfo(cave) {\n    const defaultInfo = {\n        displayId: cave && cave.id !== undefined && cave.id !== null ? cave.id : '',\n        isRenamed: false\n    };\n\n    if (typeof window.getDevCaveRenameState !== 'function') {\n        return defaultInfo;\n    }\n\n    const devInfo = window.getDevCaveRenameState(cave);\n    if (!devInfo || devInfo.displayId === undefined || devInfo.displayId === null) {\n        return defaultInfo;\n    }\n\n    return {\n        displayId: devInfo.displayId,\n        isRenamed: !!devInfo.isRenamed\n    };\n}\n\n// Helper function to build cave tooltip\nfunction buildCaveTooltip(cave) {\n    const caveDisplayInfo = getCaveDisplayInfo(cave);\n    const caveIdStyle = caveDisplayInfo.isRenamed ? ' style=\"color: #ffb74d; font-weight: 700;\"' : '';\n\n    let str = 'ID: <span' + caveIdStyle + '>' + escapeTooltipHtml(caveDisplayInfo.displayId) + '</span><br>' +\n        'PROPERTIES: ' + getCaveProperties(cave).join(', ').toUpperCase() + '<br>' +\n        'ORE #: ' + getOres(cave) + '<br>' +\n        'DEEP ORE #: ' + getDeepOres(cave) + '<br>' +\n        'SIZE: ' + getCaveSize(cave).toUpperCase() + '<br>' +\n        'WORMS: ' + getCaveWorms(cave).toUpperCase() + '<br>' +\n        'BEES: ' + getCaveBees(cave).toUpperCase();\n\n    if (cave.n) str += '<br>NOTES: ' + cave.n;\n\n    return str;\n}\n\nfunction toggleCavesLayer(state, isProgrammatic = false) {\n    if (!state) {\n        if (mapLayerCaves != null && map.hasLayer(mapLayerCaves)) {\n            map.removeLayer(mapLayerCaves);\n        }\n        // Reset cave tier filter ONLY when user manually turns off the layer\n        if (!isProgrammatic) {\n            const allTiers = ['rank1', 'rank2', 'rank3', 'rank5', 'partiallymined', 'mined'];\n            setCaveTierFilterSelection(allTiers);\n            updateCaveTierFilterButtonState();\n        }\n        return;\n    }\n\n    const mapName = selectedMapParent;\n\n    if (mapLayerCavesName !== mapName) {\n        //Load new map - requires data to be pre-loaded\n        if (cachedCavesData[mapName]) {\n            setCavesData(mapName, cachedCavesData[mapName], true);\n        }\n    } else {\n        if (mapLayerCaves != null && !map.hasLayer(mapLayerCaves)) {\n            // Listen for when layer is fully added and rendered\n            const onLayerAdd = function () {\n                // Update cave-has-ores indicator for each marker\n                mapLayerCaves.eachLayer(marker => {\n                    if (marker.caveId) {\n                        updateCaveOreIndicator(marker);\n                    }\n                });\n\n                // Reapply ore filtering after layer is in DOM\n                if (typeof applyCaveOreFiltering === 'function') {\n                    setTimeout(function () {\n                        applyCaveOreFiltering();\n                    }, 50);\n                }\n\n                // Apply cave tier filtering (including NULL sector caves) immediately when layer is added\n                if (typeof applyCaveTierFiltering === 'function') {\n                    applyCaveTierFiltering();\n                }\n\n                // Apply cave ore overlay if enabled\n                if (typeof applyCaveOreOverlay === 'function') {\n                    setTimeout(function () {\n                        applyCaveOreOverlay();\n                    }, 50);\n                }\n\n                mapLayerCaves.off('add', onLayerAdd);\n            };\n\n            mapLayerCaves.on('add', onLayerAdd);\n            mapLayerCaves.addTo(map);\n        }\n    }\n}\n\nfunction setCavesData(mapName, data, showInMap) {\n    //Remove\n    if (mapLayerCaves != null && map.hasLayer(mapLayerCaves)) {\n        map.removeLayer(mapLayerCaves);\n    }\n\n    // Check cache first\n    if (mapLayerCavesName === mapName && mapLayerCaves != null) {\n        if (showInMap) {\n            // Listen for when layer is fully added and rendered\n            const onLayerAdd = function () {\n                updateCavesState();\n\n                // Update tooltips and ore indicators for each marker\n                mapLayerCaves.eachLayer(marker => {\n                    if (marker.caveId) {\n                        // Update tooltip to reflect current ore state\n                        updateCaveTooltip(marker);\n                        updateCaveOreIndicator(marker);\n                    }\n                });\n\n                // Reapply ore filtering after layer is in DOM\n                if (typeof applyCaveOreFiltering === 'function') {\n                    setTimeout(function () {\n                        applyCaveOreFiltering();\n                    }, 50);\n                }\n\n                // Apply cave tier filtering (including NULL sector caves) after layer is in DOM\n                if (typeof applyCaveTierFiltering === 'function') {\n                    setTimeout(function () {\n                        applyCaveTierFiltering();\n                    }, 50);\n                }\n\n                // Apply cave ore overlay if enabled\n                if (typeof applyCaveOreOverlay === 'function') {\n                    setTimeout(function () {\n                        applyCaveOreOverlay();\n                    }, 50);\n                }\n\n                mapLayerCaves.off('add', onLayerAdd);\n            };\n\n            mapLayerCaves.on('add', onLayerAdd);\n            mapLayerCaves.addTo(map);\n        }\n        return;\n    }\n\n    mapLayerCavesName = mapName;\n    cachedCavesData[mapName] = data;\n\n    filterSetDisabledState(filterCaves, true);\n\n    let caveMarkers = [];\n\n    // Create cave groups\n    // let caveGroups = {};\n\n    Object.values(data).forEach(cave => {\n        // Get icon and create marker\n        const icon = getCaveIcon(cave);\n        const tooltip = buildCaveTooltip(cave);\n\n        var caveMarker = L.marker(map.unproject([cave.x, cave.y], MAP_ZOOM), {\n            rotationAngle: cave.r,\n            icon: icon\n        });\n\n        caveMarker.tempIcon = caveMarker.getIcon();\n        caveMarker.caveId = cave.id;\n        caveMarker.caveTooltip = tooltip;\n        caveMarker.caveData = cave;\n\n        // Mark NULL sector caves for Prometheus\n        caveMarker.isNullSectorCave = (mapName === 'prometheus' && cave.id && cave.id.toString().startsWith('PX'));\n\n        // Stop map zoom and map move when quickly clicking\n        caveMarker.on('dblclick', function (e) {\n            L.DomEvent.stopPropagation(e);\n        });\n\n        // Bind initial tooltip - same pattern as deep ore veins\n        updateCaveTooltip(caveMarker);\n\n        // Apply visual indicator if cave has ores specified\n        updateCaveOreIndicator(caveMarker);\n\n        // Marker event listeners - same as deep ore veins\n        caveMarker.on('mouseover', function (e) {\n            this.openPopup();\n        });\n\n        caveMarker.on('mouseout', function (e) {\n            this.closePopup();\n        });\n\n        caveMarker.on('click', function (e) {\n            if (typeof window.devCaveRenameHandleClick === 'function') {\n                const handledByCaveRenameTool = window.devCaveRenameHandleClick(this, e);\n                if (handledByCaveRenameTool) {\n                    return;\n                }\n            }\n\n            // Check if dev mode is active\n            const devModeElement = document.getElementById('devmode');\n            const isDevModeActive = devModeElement && devModeElement.style.display !== 'none';\n\n            // If dev mode is active, copy cave to dev marker\n            if (isDevModeActive) {\n                if (typeof copyCaveToDevMarker === 'function') {\n                    copyCaveToDevMarker(this);\n                }\n                // Show notification\n                if (typeof notificationControl !== 'undefined') {\n                    notificationControl.info('Cave Data Copied',\n                        `Cave ${this.caveId} data copied to dev marker. Check the DevTools to adjust position.`,\n                        { timeout: 5000 });\n                }\n                return;\n            }\n\n            // Normal click behavior\n            if (!window.mobileAndTabletCheck()) {\n                if (this.getPopup().isOpen()) {\n                    this.closePopup();\n                }\n            }\n\n            showCaveContextMenu(e, this);\n        });\n\n        // Stop map zoom and map move when quickly clicking on cave\n        caveMarker.on('dblclick', function (e) {\n            L.DomEvent.stopPropagation(e);\n        });\n\n        caveMarkers.push(caveMarker);\n    });\n\n\n    //Empty caves.\n    if (caveMarkers.length === 0) {\n        filterHideRow(filterCaves, true);\n        filterSetDisabledState(filterCaves, false);\n        return;\n    }\n\n    filterHideRow(filterCaves, false);\n\n    mapLayerCaves = L.layerGroup(caveMarkers);\n\n    if (showInMap) {\n        // Listen for when layer is fully added and rendered\n        const onLayerAdd = function () {\n            updateCavesState();\n\n            // Update cave-has-ores indicator for each marker\n            mapLayerCaves.eachLayer(marker => {\n                if (marker.caveId) {\n                    updateCaveOreIndicator(marker);\n                }\n            });\n\n            // Reapply ore filtering after layer is in DOM\n            if (typeof applyCaveOreFiltering === 'function') {\n                setTimeout(function () {\n                    applyCaveOreFiltering();\n                }, 50);\n            }\n\n            // Apply cave tier filtering (including NULL sector caves) immediately when layer is added\n            if (typeof applyCaveTierFiltering === 'function') {\n                applyCaveTierFiltering();\n            }\n\n            // Apply cave ore overlay if enabled\n            if (typeof applyCaveOreOverlay === 'function') {\n                setTimeout(function () {\n                    applyCaveOreOverlay();\n                }, 50);\n            }\n\n            mapLayerCaves.off('add', onLayerAdd);\n        };\n\n        mapLayerCaves.on('add', onLayerAdd);\n        mapLayerCaves.addTo(map);\n    }\n    filterSetDisabledState(filterCaves, false);\n}\n\nfunction updateCavesState() {\n    updateLayerState(mapLayerCaves, (layer) => {\n        // Store current ore filter highlighting classes before changing icon\n        const iconElement = layer.getElement();\n        const wasHighlighted = iconElement && iconElement.classList.contains('ore-highlighted');\n        const wasDimmed = iconElement && iconElement.classList.contains('ore-dimmed');\n\n        // Update ore indicator for existing caves\n        updateCaveOreIndicator(layer);\n\n        // Schedule restoration of filter classes after icon change\n        setTimeout(() => {\n            const newIconElement = layer.getElement();\n            if (newIconElement) {\n                if (wasHighlighted) {\n                    newIconElement.classList.add('ore-highlighted');\n                } else if (wasDimmed) {\n                    newIconElement.classList.add('ore-dimmed');\n                }\n            }\n\n            // Reapply cave ore overlay after icon change\n            if (typeof applyCaveOreOverlay === 'function') {\n                applyCaveOreOverlay();\n            }\n        }, 0);\n\n        // Return new icon based on current cave data and state\n        return {\n            icon: getCaveIcon(layer.caveData)\n        };\n    });\n}\n\nfunction updateCaveTooltip(marker) {\n    const savedOres = getCaveDeepOres(marker.caveId) || ['?', '?', '?'];\n\n    if (marker.caveData) {\n        marker.caveTooltip = buildCaveTooltip(marker.caveData);\n    }\n\n    let oreList = oreDepositTypesNoPrometheus;\n    if (mapselect === 'prometheus') {\n        oreList = oreDepositTypes;\n    }\n\n    // Get ore names\n    const oreNames = savedOres.map(stateId => {\n        const oreType = oreList.find(item => item.stateId === stateId);\n        return oreType ? oreType.text : 'UNKNOWN';\n    });\n\n    // Create compact tooltip with ore info - same as deep ore veins\n    let tooltipContent = `\n        ${marker.caveTooltip}\n        <div style=\"margin-top: 6px; padding-top: 6px; border-top: 1px solid rgba(255,255,255,0.2); font-size: 11px;\">\n            <strong>Ores:</strong> ${oreNames.join(', ')}\n        </div>\n    `;\n\n    // Add dev info if enabled\n    const devTooltipCheckbox = document.getElementById('devTooltipInfo');\n    const devTooltipEnabled = devTooltipCheckbox && devTooltipCheckbox.checked;\n    if (devTooltipEnabled && marker.caveData) {\n        const data = marker.caveData;\n        tooltipContent += `<br>Position: ${data.x}, ${data.y}<br>Rotation: ${data.r}`;\n\n        // Add gameid if present\n        if (data.gid) {\n            tooltipContent += `<br>GameID: ${data.gid}`;\n        }\n\n        // Add all other attributes\n        const excluded = ['id', 'x', 'y', 'r', 'gid', 'n', 's', 'oc', 'doc', 'hw', 'wmin', 'wmax', 'hb', 'bmin', 'bmax'];\n        for (const [key, value] of Object.entries(data)) {\n            if (!excluded.includes(key) && value !== null && value !== false && value !== '') {\n                tooltipContent += `<br>${key.toUpperCase()}: ${value}`;\n            }\n        }\n    }\n\n    marker.bindPopup(tooltipContent, {\n        className: 'cave-tooltip-popup',\n        autoPan: false,\n        maxWidth: 280\n    });\n}\n\nfunction updateCaveDevTooltips() {\n    if (!mapLayerCaves) return;\n    mapLayerCaves.eachLayer(marker => {\n        if (marker.caveId) {\n            updateCaveTooltip(marker);\n        }\n    });\n}\n\nfunction updateCaveOreIndicator(marker) {\n    // This function is now used only for search highlighting\n    // Regular ore indication is handled by applyCaveOreOverlay\n\n    // Update ore filter highlighting if ore filtering is active\n    if (typeof applyCaveOreFiltering === 'function') {\n        applyCaveOreFiltering();\n    }\n}\n\nfunction showCaveContextMenu(e, marker) {\n    const wrapper = document.createElement('div');\n    wrapper.className = 'cave-popup-wrapper';\n\n    // Check read-only mode\n    const isReadOnly = getMapState().rights === \"ro\";\n\n    // Get cave tooltip content\n    const tooltipContent = marker.getPopup()._content;\n\n    // Info section\n    const infoSection = document.createElement('div');\n    infoSection.className = 'cave-popup-info';\n    infoSection.innerHTML = tooltipContent;\n    wrapper.appendChild(infoSection);\n\n    // Cave status section - only show in edit mode\n    if (!isReadOnly) {\n        const caveStatusSection = document.createElement('div');\n        caveStatusSection.className = 'cave-popup-status';\n\n        const statusLabel = document.createElement('div');\n        statusLabel.className = 'cave-popup-label';\n        statusLabel.textContent = 'Cave Status:';\n        caveStatusSection.appendChild(statusLabel);\n\n        const statusButtons = document.createElement('div');\n        statusButtons.className = 'cave-popup-status-buttons';\n\n        const currentCaveState = getCaveState(marker.caveId) || 'i';\n\n        const statusOptions = [\n            { state: 'i', label: 'Intact' },\n            { state: 'p', label: 'Partially Mined' },\n            { state: 'm', label: 'Fully Mined' }\n        ];\n\n        statusOptions.forEach(option => {\n            const statusBtn = document.createElement('button');\n            statusBtn.className = 'cave-popup-status-btn' + (currentCaveState === option.state ? ' active' : '');\n            \n            // Create icon element based on state\n            const icon = document.createElement('img');\n            icon.className = 'cave-popup-status-icon';\n            \n            if (option.state === 'i') {\n                // Intact - no icon\n                icon.style.display = 'none';\n            } else if (option.state === 'p') {\n                // Partially Mined\n                icon.src = 'icon/cave_s_p.png';\n            } else if (option.state === 'm') {\n                // Fully Mined\n                icon.src = 'icon/cave_s_m.png';\n            }\n            \n            statusBtn.appendChild(icon);\n            \n            // Add label text\n            const label = document.createElement('span');\n            label.style.marginLeft = '4px';\n            label.textContent = option.label;\n            statusBtn.appendChild(label);\n\n            statusBtn.onclick = () => {\n                // Store current highlighting classes before changing icon\n                const oldIcon = marker.getElement();\n                const wasHighlighted = oldIcon && oldIcon.classList.contains('ore-highlighted');\n                const wasDimmed = oldIcon && oldIcon.classList.contains('ore-dimmed');\n                const hadOres = oldIcon && oldIcon.classList.contains('cave-has-ores');\n\n                setCaveState(marker.caveId, option.state);\n                marker.setIcon(getCaveIcon(marker.caveData));\n\n                // Restore highlighting classes after icon change\n                const newIcon = marker.getElement();\n                if (newIcon) {\n                    if (wasHighlighted) {\n                        newIcon.classList.add('ore-highlighted');\n                    } else if (wasDimmed) {\n                        newIcon.classList.add('ore-dimmed');\n                    }\n                    if (hadOres) {\n                        newIcon.classList.add('cave-has-ores');\n                    }\n                }\n\n                // Update button states\n                statusButtons.querySelectorAll('.cave-popup-status-btn').forEach(btn => {\n                    btn.classList.remove('active');\n                });\n                statusBtn.classList.add('active');\n\n                // Reapply cave ore overlay after status change\n                if (typeof applyCaveOreOverlay === 'function') {\n                    applyCaveOreOverlay();\n                }\n            };\n\n            statusButtons.appendChild(statusBtn);\n        });\n\n        caveStatusSection.appendChild(statusButtons);\n        wrapper.appendChild(caveStatusSection);\n    }\n\n    // Deep ore section\n    const deepOreSection = document.createElement('div');\n    deepOreSection.className = 'cave-popup-deep-ores';\n\n    const deepOreLabelContainer = document.createElement('div');\n    deepOreLabelContainer.style.display = 'flex';\n    deepOreLabelContainer.style.justifyContent = 'space-between';\n    deepOreLabelContainer.style.alignItems = 'center';\n\n    const deepOreLabel = document.createElement('div');\n    deepOreLabel.className = 'cave-popup-label';\n    deepOreLabel.textContent = 'Deep Ore Veins:';\n    deepOreLabelContainer.appendChild(deepOreLabel);\n\n    // Add clear button in write mode\n    if (!isReadOnly) {\n        const clearButton = document.createElement('button');\n        clearButton.className = 'cave-popup-clear-btn';\n        clearButton.innerHTML = '<i class=\"material-symbols-outlined\">delete</i>';\n        clearButton.title = 'Clear all ore veins';\n        clearButton.onclick = () => {\n            // Reset all ores to unknown\n            setCaveDeepOres(marker.caveId, ['?', '?', '?']);\n\n            // Clear all drill statuses\n            setCaveOreDrill(marker.caveId, 0, undefined);\n            setCaveOreDrill(marker.caveId, 1, undefined);\n            setCaveOreDrill(marker.caveId, 2, undefined);\n\n            // Update tooltip\n            updateCaveTooltip(marker);\n\n            // Update cave-has-ores indicator\n            updateCaveOreIndicator(marker);\n\n            // Refresh the cave ore overlay\n            if (typeof applyCaveOreOverlay === 'function') {\n                applyCaveOreOverlay();\n            }\n\n            // Close and reopen popup to refresh display\n            marker.closePopup();\n            setTimeout(() => {\n                marker.fire('click', { latlng: marker.getLatLng() });\n            }, 50);\n        };\n        deepOreLabelContainer.appendChild(clearButton);\n    }\n\n    deepOreSection.appendChild(deepOreLabelContainer);\n\n    const deepOreIcons = document.createElement('div');\n    deepOreIcons.className = 'cave-popup-ore-icons';\n\n    // Get saved deep ore states\n    const savedOres = getCaveDeepOres(marker.caveId) || ['?', '?', '?'];\n\n    let oreList = oreDepositTypesNoPrometheus;\n    if (mapselect === 'prometheus') {\n        oreList = oreDepositTypes;\n    }\n\n    // Create 3 ore circles with labels\n    for (let i = 0; i < 3; i++) {\n        const oreContainer = document.createElement('div');\n        oreContainer.className = 'cave-popup-ore-container';\n\n        const oreCircle = document.createElement('div');\n        oreCircle.className = 'cave-popup-ore-circle';\n\n        const currentStateId = savedOres[i];\n        const currentOreType = oreList.find(item => item.stateId === currentStateId) || oreList[0];\n        const currentDrill = getCaveOreDrill(marker.caveId, i);\n\n        // Store reference for click handler\n        let oreElement = null;\n\n        // Show + sign for unknown ore, otherwise show icon\n        if (currentStateId === '?') {\n            const plusSign = document.createElement('div');\n            plusSign.className = 'cave-popup-ore-plus';\n            plusSign.textContent = '+';\n            oreCircle.appendChild(plusSign);\n            oreElement = plusSign;\n        } else {\n            const oreImg = document.createElement('img');\n            oreImg.src = currentOreType.icon.options.iconUrl;\n            oreImg.alt = currentOreType.text;\n            oreImg.title = currentOreType.text;\n            oreCircle.appendChild(oreImg);\n            oreElement = oreImg;\n\n            // Add drill overlay icon if drill is installed\n            if (currentDrill) {\n                const drillOverlay = createDrillStatusIcon(currentDrill, 'cave-ore-drill-overlay');\n                if (drillOverlay) {\n                    oreCircle.appendChild(drillOverlay);\n                }\n            }\n        }\n\n        const oreLabel = document.createElement('div');\n        oreLabel.className = 'cave-popup-ore-name';\n        oreLabel.textContent = currentOreType.text;\n\n        // Left click handler to show context menu - only in edit mode\n        if (!isReadOnly) {\n            oreCircle.onclick = (clickEvent) => {\n                clickEvent.preventDefault();\n                clickEvent.stopPropagation();\n\n                // Get fresh current state\n                const freshSavedOres = getCaveDeepOres(marker.caveId) || ['?', '?', '?'];\n                const freshCurrentStateId = freshSavedOres[i];\n\n                showCaveOreContextMenu(clickEvent, oreCircle, oreList, i, savedOres, marker, oreElement, oreLabel, freshCurrentStateId);\n            };\n        } else {\n            // In read-only mode, remove pointer cursor\n            oreCircle.style.cursor = 'default';\n        }\n\n        oreContainer.appendChild(oreCircle);\n        oreContainer.appendChild(oreLabel);\n        deepOreIcons.appendChild(oreContainer);\n    }\n\n    deepOreSection.appendChild(deepOreIcons);\n    wrapper.appendChild(deepOreSection);\n\n    // Open popup with offset\n    const offset = marker.options.icon.options.popupAnchor || [0, 0];\n    const point = map.latLngToContainerPoint(e.latlng);\n\n    point.x += offset[0];\n    point.y += offset[1];\n\n    const shiftedLatLng = map.containerPointToLatLng(point);\n\n    const cavePopup = L.popup({\n        closeButton: true,\n        autoClose: true,\n        closeOnClick: true,\n        autoPan: true,\n        autoPanPadding: [20, 20]\n    })\n        .setLatLng(shiftedLatLng)\n        .setContent(wrapper)\n        .openOn(map);\n\n    // Close any ore selection popups when cave popup is closed\n    cavePopup.on('remove', function () {\n        closeAllOreSelectionPopups();\n    });\n}\n\nfunction closeAllOreSelectionPopups() {\n    const allPopups = document.querySelectorAll('.leaflet-popup-pane .leaflet-popup.cave-ore-context-popup');\n    allPopups.forEach(popup => {\n        const closeBtn = popup.querySelector('.leaflet-popup-close-button');\n        if (closeBtn) {\n            closeBtn.click();\n        }\n    });\n}\n\nfunction showCaveOreContextMenu(e, oreCircle, oreList, oreIndex, savedOres, marker, oreElement, oreLabel, currentStateId) {\n    // Close any existing ore selection popups first\n    closeAllOreSelectionPopups();\n\n    const currentDrill = getCaveOreDrill(marker.caveId, oreIndex);\n\n    const container = buildOreSelectionMenu({\n        oreList: oreList,\n        currentOreState: currentStateId,\n        currentDrillState: currentDrill,\n        showImages: true,\n        onOreSelect: (item, clickEvent) => {\n            clickEvent.stopPropagation();\n            clickEvent.preventDefault();\n\n            savedOres[oreIndex] = item.stateId;\n\n            // Clear drill if setting to empty or unknown\n            if (item.stateId === 'm' || item.stateId === '?') {\n                setCaveOreDrill(marker.caveId, oreIndex, undefined);\n            }\n\n            // Clear the ore circle and update display\n            oreCircle.innerHTML = '';\n\n            if (item.stateId === '?') {\n                // Show + sign for unknown ore\n                const plusSign = document.createElement('div');\n                plusSign.className = 'cave-popup-ore-plus';\n                plusSign.textContent = '+';\n                oreCircle.appendChild(plusSign);\n            } else {\n                // Show icon for known ore\n                const newOreImg = document.createElement('img');\n                newOreImg.src = item.icon.options.iconUrl;\n                newOreImg.alt = item.text;\n                newOreImg.title = item.text;\n                oreCircle.appendChild(newOreImg);\n\n                // Re-add drill overlay if still present and not cleared\n                if (item.stateId !== 'm' && item.stateId !== '?') {\n                    const freshDrill = getCaveOreDrill(marker.caveId, oreIndex);\n                    if (freshDrill) {\n                        const drillOverlay = createDrillStatusIcon(freshDrill, 'cave-ore-drill-overlay');\n                        if (drillOverlay) {\n                            oreCircle.appendChild(drillOverlay);\n                        }\n                    }\n                }\n            }\n\n            oreLabel.textContent = item.text;\n\n            setCaveDeepOres(marker.caveId, savedOres);\n\n            // Update the cave tooltip to reflect the new ore selection\n            updateCaveTooltip(marker);\n\n            // Update visual indicator for cave with ores\n            updateCaveOreIndicator(marker);\n\n            // Apply cave ore overlay to update icon overlay\n            if (typeof applyCaveOreOverlay === 'function') {\n                setTimeout(function () {\n                    applyCaveOreOverlay();\n                }, 50);\n            }\n\n            // Update the visible info section in the cave popup\n            const cavePopupInfo = document.querySelector('.cave-popup-info');\n            if (cavePopupInfo && marker.getPopup()) {\n                cavePopupInfo.innerHTML = marker.getPopup()._content;\n            }\n\n            // Find and close only the ore selection popup (the newest one)\n            const allPopups = document.querySelectorAll('.leaflet-popup-pane .leaflet-popup');\n            if (allPopups.length > 1) {\n                // Close the last popup (ore selection menu)\n                const orePopup = allPopups[allPopups.length - 1];\n                const closeBtn = orePopup.querySelector('.leaflet-popup-close-button');\n                if (closeBtn) {\n                    closeBtn.click();\n                }\n            }\n        },\n        onDrillSelect: (drillType) => {\n            setCaveOreDrill(marker.caveId, oreIndex, drillType.id);\n\n            // Update drill overlay in the ore circle\n            const existingOverlay = oreCircle.querySelector('.cave-ore-drill-overlay');\n            if (existingOverlay) {\n                existingOverlay.remove();\n            }\n\n            if (drillType.id && currentStateId !== '?' && currentStateId !== 'm') {\n                const drillOverlay = createDrillStatusIcon(drillType.id, 'cave-ore-drill-overlay');\n                if (drillOverlay) {\n                    oreCircle.appendChild(drillOverlay);\n                }\n            }\n\n            // Refresh the cave ore overlay to update drill status\n            if (typeof applyCaveOreOverlay === 'function') {\n                applyCaveOreOverlay();\n            }\n\n            // Close the popup\n            const allPopups = document.querySelectorAll('.leaflet-popup-pane .leaflet-popup');\n            if (allPopups.length > 1) {\n                const orePopup = allPopups[allPopups.length - 1];\n                const closeBtn = orePopup.querySelector('.leaflet-popup-close-button');\n                if (closeBtn) {\n                    closeBtn.click();\n                }\n            }\n        }\n    });\n\n    // Position the context menu near the ore circle\n    const rect = oreCircle.getBoundingClientRect();\n    const popupLatLng = map.containerPointToLatLng([rect.left + rect.width / 2, rect.top + rect.height / 2]);\n\n    // Create a new popup without affecting the existing cave popup\n    const oreSelectionPopup = L.popup({\n        closeButton: true,\n        autoClose: false,\n        closeOnClick: false,\n        className: 'cave-ore-context-popup',\n        offset: [0, 10],\n        autoPan: true,\n        autoPanPadding: [20, 20]\n    })\n        .setLatLng(popupLatLng)\n        .setContent(container);\n\n    // Open the popup without closing existing popups\n    map.addLayer(oreSelectionPopup);\n}\n\n// Cave Tier Filter Functionality\nlet caveTierFilterPopup = null;\n\nconst CAVE_TIER_FILTER_POPUP_LAYOUT_KEY = 'caveTierFilterPopupLayout';\n\n// Helper function to determine cave rank from icon name (from tempIcon - original rank)\nfunction getCaveRankFromIcon(iconName) {\n    if (!iconName) return null;\n\n    const iconStr = iconName.toString();\n\n    // Check for ranked caves (ignore 'd' suffix - it's just hazard variant, same rank)\n    if (iconStr.includes('icon_cave_1')) return 'rank1';\n    if (iconStr.includes('icon_cave_2')) return 'rank2';\n    if (iconStr.includes('icon_cave_3')) return 'rank3';\n    if (iconStr.includes('icon_cave_5')) return 'rank5';\n\n    return null;\n}\n\n// Helper function to determine cave status from current icon\nfunction getCaveStatusFromIcon(iconName) {\n    if (!iconName) return 'intact';\n\n    const iconStr = iconName.toString();\n\n    if (iconStr.includes('icon_cave_mine.png')) return 'mined';\n    if (iconStr.includes('icon_cave_mine_part.png')) return 'partiallymined';\n\n    return 'intact';\n}\n\nfunction initCaveTierFilter() {\n    const filterButton = document.getElementById('caveFilterButton');\n    if (!filterButton) return;\n\n    filterButton.addEventListener('click', (e) => {\n        e.stopPropagation();\n        e.preventDefault();\n        toggleCaveTierFilterPopup();\n    });\n\n    // Update button state on load\n    updateCaveTierFilterButtonState();\n}\n\nfunction toggleCaveTierFilterPopup() {\n    if (caveTierFilterPopup) {\n        closeCaveTierFilterPopup();\n        return;\n    }\n\n    showCaveTierFilterPopup();\n}\n\nfunction showCaveTierFilterPopup() {\n    // Close ore filter popup if it's open\n    if (typeof closeOreFilterPopup === 'function') {\n        closeOreFilterPopup();\n    }\n\n    const filterButton = document.getElementById('caveFilterButton');\n    if (!filterButton) return;\n\n    const content = createCaveTierFilterContent();\n\n    // Create custom popup div\n    const popupDiv = document.createElement('div');\n    popupDiv.id = 'caveTierFilterPopupDiv';\n    popupDiv.className = 'ore-filter-popup-overlay';\n\n    popupDiv.appendChild(content);\n    document.body.appendChild(popupDiv);\n\n    if (window.PopupOverlayManager && typeof window.PopupOverlayManager.attachToPopup === 'function') {\n        window.PopupOverlayManager.attachToPopup({\n            key: CAVE_TIER_FILTER_POPUP_LAYOUT_KEY,\n            popupId: 'caveTierFilterPopupDiv',\n            anchorId: 'caveFilterButton',\n            options: {\n                margin: 12,\n                gap: 10,\n                minHeight: 140,\n                minWidth: 160,\n                zIndex: 10000,\n                centerOnMobile: true,\n                centerViewportWidthThreshold: 600,\n                centerVerticalRatio: 0.5\n            }\n        });\n    }\n\n    // Close on clicking outside\n    setTimeout(() => {\n        document.addEventListener('click', closeCaveTierFilterOnClickOutside);\n    }, 100);\n\n    caveTierFilterPopup = popupDiv;\n}\n\nfunction closeCaveTierFilterOnClickOutside(e) {\n    const popup = document.getElementById('caveTierFilterPopupDiv');\n    const filterButton = document.getElementById('caveFilterButton');\n\n    if (popup && !popup.contains(e.target) && e.target !== filterButton && !filterButton.contains(e.target)) {\n        closeCaveTierFilterPopup();\n    }\n}\n\nfunction closeCaveTierFilterPopup() {\n    const popup = document.getElementById('caveTierFilterPopupDiv');\n    if (popup) {\n        popup.remove();\n        document.removeEventListener('click', closeCaveTierFilterOnClickOutside);\n    }\n\n    if (window.PopupOverlayManager && typeof window.PopupOverlayManager.detachFromPopup === 'function') {\n        window.PopupOverlayManager.detachFromPopup(CAVE_TIER_FILTER_POPUP_LAYOUT_KEY);\n    }\n\n    caveTierFilterPopup = null;\n}\n\nfunction createCaveTierFilterContent() {\n    const wrapper = document.createElement('div');\n    wrapper.className = 'ore-filter-popup';\n\n    // Header with close button\n    const header = document.createElement('div');\n    header.className = 'ore-filter-header';\n\n    const title = document.createElement('h3');\n    title.textContent = 'Filter Cave Tiers';\n    header.appendChild(title);\n\n    const closeBtn = document.createElement('button');\n    closeBtn.className = 'ore-filter-close';\n    closeBtn.innerHTML = '&times;';\n    closeBtn.onclick = () => closeCaveTierFilterPopup();\n    header.appendChild(closeBtn);\n\n    wrapper.appendChild(header);\n\n    // Tier list\n    const list = document.createElement('div');\n    list.className = 'ore-filter-list';\n    list.id = 'caveTierFilterList';\n\n    const selectedTiers = getCaveTierFilterSelection();\n    const allTiers = ['rank1', 'rank2', 'rank3', 'rank5', 'partiallymined', 'mined'];\n\n    // Add \"All\" checkbox at the top\n    const allItem = document.createElement('div');\n    allItem.className = 'ore-filter-item';\n\n    const allCheckbox = document.createElement('input');\n    allCheckbox.type = 'checkbox';\n    allCheckbox.id = 'cave-tier-filter-all';\n    allCheckbox.checked = selectedTiers.length === allTiers.length;\n\n    const allLabel = document.createElement('label');\n    allLabel.htmlFor = 'cave-tier-filter-all';\n    allLabel.textContent = 'All';\n    allLabel.style.fontWeight = 'bold';\n\n    allItem.appendChild(allCheckbox);\n    allItem.appendChild(allLabel);\n\n    // Handle \"All\" checkbox change\n    allCheckbox.addEventListener('change', (e) => {\n        e.stopPropagation();\n        const isChecked = allCheckbox.checked;\n\n        if (isChecked) {\n            selectAllCaveTiers();\n        } else {\n            clearAllCaveTiers();\n        }\n\n        // Update all checkboxes in the list\n        setTimeout(() => {\n            document.querySelectorAll('[id^=\"cave-tier-filter-\"]:not(#cave-tier-filter-all)').forEach(cb => {\n                cb.checked = isChecked;\n            });\n        }, 0);\n    });\n\n    // Make row clickable (trigger checkbox)\n    allItem.onclick = (e) => {\n        if (e.target !== allCheckbox) {\n            e.preventDefault();\n            allCheckbox.click();\n        }\n    };\n\n    list.appendChild(allItem);\n\n    const tierOptions = [\n        { id: 'rank1', label: 'Rank 1', icon: 'icon/icon_cave_1.png' },\n        { id: 'rank2', label: 'Rank 2', icon: 'icon/icon_cave_2.png' },\n        { id: 'rank3', label: 'Rank 3', icon: 'icon/icon_cave_3.png' },\n        { id: 'rank5', label: 'Rank Max', icon: 'icon/icon_cave_5.png' },\n        { id: 'partiallymined', label: 'Partially Mined', icon: 'icon/icon_cave_mine_part.png' },\n        { id: 'mined', label: 'Mined', icon: 'icon/icon_cave_mine.png' }\n    ];\n\n    tierOptions.forEach(tier => {\n        const item = document.createElement('div');\n        item.className = 'ore-filter-item';\n\n        const checkbox = document.createElement('input');\n        checkbox.type = 'checkbox';\n        checkbox.id = `cave-tier-filter-${tier.id}`;\n        checkbox.checked = selectedTiers.includes(tier.id);\n\n        const icon = document.createElement('img');\n        icon.src = tier.icon;\n        icon.alt = tier.label;\n\n        const label = document.createElement('label');\n        label.htmlFor = `cave-tier-filter-${tier.id}`;\n        label.textContent = tier.label;\n\n        item.appendChild(checkbox);\n        item.appendChild(icon);\n        item.appendChild(label);\n\n        // Handle checkbox change event\n        checkbox.addEventListener('change', (e) => {\n            e.stopPropagation();\n\n            // Build selection based on checkbox states directly\n            const newSelection = [];\n            allTiers.forEach(tierId => {\n                const cb = document.getElementById(`cave-tier-filter-${tierId}`);\n                if (cb && cb.checked) {\n                    newSelection.push(tierId);\n                }\n            });\n\n            setCaveTierFilterSelection(newSelection);\n            updateCaveTierFilterButtonState();\n            applyCaveTierFiltering();\n\n            // Update \"All\" checkbox state\n            const allCheckbox = document.getElementById('cave-tier-filter-all');\n            if (allCheckbox) {\n                allCheckbox.checked = (newSelection.length === allTiers.length);\n            }\n        });\n\n        // Make entire row clickable (trigger checkbox)\n        item.onclick = (e) => {\n            if (e.target !== checkbox) {\n                e.preventDefault();\n                checkbox.click();\n            }\n        };\n\n        list.appendChild(item);\n    });\n\n    wrapper.appendChild(list);\n    return wrapper;\n}\n\nfunction toggleCaveTierSelection(tierId) {\n    toggleCaveTierFilter(tierId);\n}\n\nfunction selectAllCaveTiers() {\n    const allTiers = ['rank1', 'rank2', 'rank3', 'rank5', 'partiallymined', 'mined'];\n\n    setCaveTierFilterSelection(allTiers);\n    updateCaveTierFilterButtonState();\n    applyCaveTierFiltering();\n\n    // Update checkboxes\n    allTiers.forEach(tier => {\n        const checkbox = document.getElementById(`cave-tier-filter-${tier}`);\n        if (checkbox) checkbox.checked = true;\n    });\n}\n\nfunction clearAllCaveTiers() {\n    setCaveTierFilterSelection([]);\n    updateCaveTierFilterButtonState();\n    applyCaveTierFiltering();\n\n    // Update checkboxes\n    const checkboxes = document.querySelectorAll('[id^=\"cave-tier-filter-\"]');\n    checkboxes.forEach(cb => cb.checked = false);\n}\n\nfunction toggleCaveTierFilter(tierId) {\n    let selectedTiers = getCaveTierFilterSelection();\n\n    if (selectedTiers.includes(tierId)) {\n        selectedTiers = selectedTiers.filter(id => id !== tierId);\n    } else {\n        selectedTiers.push(tierId);\n    }\n\n    setCaveTierFilterSelection(selectedTiers);\n    updateCaveTierFilterButtonState();\n    applyCaveTierFiltering();\n}\n\nfunction updateCaveTierFilterButtonState() {\n    const filterButton = document.getElementById('caveFilterButton');\n    if (!filterButton) return;\n\n    if (isCaveTierFilterActive()) {\n        filterButton.classList.add('active');\n    } else {\n        filterButton.classList.remove('active');\n    }\n}\n\nfunction applyCaveTierFiltering() {\n    if (!mapLayerCaves) return;\n\n    const selectedTiers = getCaveTierFilterSelection();\n    const isFilterActive = selectedTiers.length < 6; // Filter is active if not all 6 options are selected\n\n    // Check NULL sector filter state for Prometheus\n    const filterState = getFilterState();\n    const showNullSectorCaves = filterState.prometheusNull && filterState.prometheusNull.caves;\n\n    mapLayerCaves.eachLayer(layer => {\n        if (!layer || !layer.tempIcon) return;\n\n        const icon = layer.getElement();\n        if (!icon) return;\n\n        // Filter NULL sector caves for Prometheus\n        if (layer.isNullSectorCave && !showNullSectorCaves) {\n            icon.style.display = 'none';\n            return;\n        }\n\n        // Don't filter if ore filter is already hiding this cave\n        if (icon.classList.contains('ore-highlighted') || icon.classList.contains('ore-dimmed')) {\n            return;\n        }\n\n        if (isFilterActive) {\n            // Get cave rank from cave data\n            const caveRank = getCaveTier(layer.caveData.oc);\n            const rankKey = caveRank ? (caveRank === 1 ? 'rank1' : caveRank === 2 ? 'rank2' : caveRank === 3 ? 'rank3' : 'rank5') : 'rank1';\n\n            // Get cave status from current state\n            const caveState = getCaveState(layer.caveId) || 'i';\n            const caveStatus = caveState === 'm' ? 'mined' : caveState === 'p' ? 'partiallymined' : 'intact';\n\n            let shouldShow = false;\n\n            // Cave is visible if either its rank OR status is selected\n            // This allows filtering by rank (show all rank 1 regardless of status)\n            // or by status (show all mined caves regardless of rank)\n            const rankSelected = selectedTiers.includes(rankKey);\n            const statusSelected = (caveStatus === 'mined' && selectedTiers.includes('mined')) ||\n                (caveStatus === 'partiallymined' && selectedTiers.includes('partiallymined')) ||\n                (caveStatus === 'intact');\n\n            // Show if rank is selected AND status is selected (or intact)\n            // Show cave if:\n            // 1. Its rank is selected AND (it's intact OR its status is selected)\n            // 2. OR its status (mined/partially mined) is explicitly selected\n            if (rankSelected) {\n                // Rank is selected - show if intact or status is also selected\n                if (caveStatus === 'intact') {\n                    shouldShow = true;\n                } else if (caveStatus === 'mined' && selectedTiers.includes('mined')) {\n                    shouldShow = true;\n                } else if (caveStatus === 'partiallymined' && selectedTiers.includes('partiallymined')) {\n                    shouldShow = true;\n                }\n            } else {\n                // Rank not selected - only show if status is explicitly selected\n                if (caveStatus === 'mined' && selectedTiers.includes('mined')) {\n                    shouldShow = true;\n                } else if (caveStatus === 'partiallymined' && selectedTiers.includes('partiallymined')) {\n                    shouldShow = true;\n                }\n            }\n\n            icon.style.display = shouldShow ? '' : 'none';\n        } else {\n            icon.style.display = '';\n        }\n    });\n}\n\n// Initialize cave tier filter when DOM is ready\nif (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', initCaveTierFilter);\n} else {\n    initCaveTierFilter();\n}\n\n/**\n * Apply or remove ore icon overlays on cave markers based on the filter setting\n */\n// Get ingot icon path for cave ore overlay\nfunction getIngotIconForOre(stateId) {\n    const ingotIcons = {\n        'a': 'icon/ingot/aluminium_ingot_128.png',\n        'cl': 'icon/ingot/clay_128.png',\n        'c': 'icon/ingot/coal_ore_128.png',\n        'cu': 'icon/ingot/copper_ingot_128.png',\n        'g': 'icon/ingot/gold_ingot_128.png',\n        'i': 'icon/ingot/iron_ingot_128.png',\n        'o': 'icon/ingot/obsidian_128.png',\n        'ox': 'icon/ingot/oxite_128.png',\n        'p': 'icon/ingot/platinum_ingot_128.png',\n        'sa': 'icon/ingot/salt_128.png',\n        'sc': 'icon/ingot/scoria_128.png',\n        'si': 'icon/ingot/silica_ore_128.png',\n        'st': 'icon/ingot/stone_128.png',\n        'su': 'icon/ingot/sulfur_128.png',\n        't': 'icon/ingot/titanium_ingot_128.png',\n        '?': 'icon/dov_unknown_128.png'\n    };\n    return ingotIcons[stateId] || 'icon/dov_unknown.png';\n}\n\nfunction applyCaveOreOverlay() {\n    if (!mapLayerCaves) return;\n\n    // Check if deep ore veins layer is enabled\n    const filterState = getFilterState();\n    const deepOreLayerEnabled = filterState.deepOreDeposits || false;\n\n    // Check cave ore overlay setting\n    const displaySettings = typeof getDisplaySettings === 'function' ? getDisplaySettings() : { showCaveOreOverlay: true };\n    const showFullOverlay = displaySettings.showCaveOreOverlay;\n    const showOres = deepOreLayerEnabled && showFullOverlay;\n\n    mapLayerCaves.eachLayer(layer => {\n        if (!layer || !layer.caveId) return;\n\n        const iconElement = layer.getElement();\n        if (!iconElement) return;\n\n        // Remove existing overlay if present\n        const existingOverlay = iconElement.querySelector('.cave-ore-overlay-container');\n        if (existingOverlay) {\n            existingOverlay.remove();\n        }\n\n        // Remove existing indicator if present\n        const existingIndicator = iconElement.querySelector('.cave-ore-indicator');\n        if (existingIndicator) {\n            existingIndicator.remove();\n        }\n\n        // Get the saved ores for this cave\n        const savedOres = getCaveDeepOres(layer.caveId) || ['?', '?', '?'];\n\n        // Filter out unknown ('?') and empty ('m') ores\n        const validOres = [];\n        savedOres.forEach((ore, idx) => {\n            if (ore !== '?' && ore !== 'm') {\n                validOres.push({ stateId: ore, index: idx });\n            }\n        });\n\n        // If no valid ores, don't show anything\n        if (validOres.length === 0) return;\n\n        // Only show overlay or indicator if ore layer is enabled\n        if (!deepOreLayerEnabled) return;\n\n        // If showCaveOreOverlay is enabled, show full overlay\n        if (showFullOverlay) {\n            // Get the ore list based on map\n            let oreList = oreDepositTypesNoPrometheus;\n            if (mapselect === 'prometheus') {\n                oreList = oreDepositTypes;\n            }\n\n            // Create overlay container\n            const overlayContainer = document.createElement('div');\n            overlayContainer.className = 'cave-ore-overlay-container';\n\n            // Add ore icons to container (CSS handles positioning and layout)\n            validOres.forEach((oreData, displayIndex) => {\n                const oreType = oreList.find(item => item.stateId === oreData.stateId);\n                if (!oreType) return;\n\n                // Create wrapper for ore icon\n                const oreWrapper = document.createElement('div');\n                oreWrapper.className = 'cave-ore-overlay-wrapper';\n\n                const oreIcon = document.createElement('img');\n                oreIcon.src = getIngotIconForOre(oreData.stateId);\n                oreIcon.alt = oreType.text;\n                oreIcon.title = oreType.text;\n                oreIcon.className = 'cave-ore-overlay-icon';\n\n                oreWrapper.appendChild(oreIcon);\n\n                // Add drill overlay if drill is installed\n                const drillType = getCaveOreDrill(layer.caveId, oreData.index);\n                const drillOverlay = createDrillStatusIcon(drillType, 'cave-ore-overlay-drill');\n                if (drillOverlay) {\n                    oreWrapper.appendChild(drillOverlay);\n                }\n\n                overlayContainer.appendChild(oreWrapper);\n            });\n\n            iconElement.appendChild(overlayContainer);\n        } else {\n            // Ore layer is enabled but showCaveOreOverlay is disabled - show small indicator icon\n            const indicator = document.createElement('i');\n            indicator.className = 'material-symbols-outlined cave-ore-indicator';\n            indicator.textContent = 'diamond';\n            indicator.title = `${validOres.length} ore vein${validOres.length > 1 ? 's' : ''} specified`;\n            iconElement.appendChild(indicator);\n        }\n    });\n}\n"
          },
