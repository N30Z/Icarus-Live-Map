            "size": 2278,
            "mimeType": "text/javascript",
            "text": "let mapLayerOilGeysers = null;\nlet mapLayerOilGeysersName = '';\nlet cachedOilGeysersData = {};\n\nfunction toggleOilGeysersLayer(state) {\n    if (!state) {\n        if (mapLayerOilGeysers != null && map.hasLayer(mapLayerOilGeysers)) {\n            map.removeLayer(mapLayerOilGeysers);\n        }\n        return;\n    }\n\n    const mapName = selectedMapParent;\n\n    if (mapLayerOilGeysersName !== mapName) {\n        //Load new map - requires data to be pre-loaded\n        if (cachedOilGeysersData[mapName]) {\n            setOilGeysersData(mapName, cachedOilGeysersData[mapName], true);\n        }\n    } else {\n        if (mapLayerOilGeysers != null && !map.hasLayer(mapLayerOilGeysers)) {\n            mapLayerOilGeysers.addTo(map);\n        }\n    }\n}\n\nfunction setOilGeysersData(mapName, data, showInMap) {\n    //Remove\n    if (mapLayerOilGeysers != null && map.hasLayer(mapLayerOilGeysers)) {\n        map.removeLayer(mapLayerOilGeysers);\n    }\n\n    // Check cache first\n    if (mapLayerOilGeysersName === mapName && mapLayerOilGeysers != null) {\n        if (showInMap) {\n            mapLayerOilGeysers.addTo(map);\n        }\n        return;\n    }\n\n    mapLayerOilGeysersName = mapName;\n    cachedOilGeysersData[mapName] = data;\n    filterSetDisabledState(filterOilGeysers, true);\n\n    let oilGeyserMarkers = [];\n\n    Object.values(data).forEach(oilGeyser => {\n        let popupText = addDevTooltip('OIL GEYSER', oilGeyser);\n\n        let oilGeyserMarker = L.marker(map.unproject([oilGeyser.x, oilGeyser.y], MAP_ZOOM), { icon: geyser_oil });\n        oilGeyserMarker.bindPopup(popupText, { autoPan: false });\n        oilGeyserMarker.geyserData = oilGeyser;\n        oilGeyserMarkers.push(oilGeyserMarker);\n    });\n\n\n    //Empty Geysers.\n    if (oilGeyserMarkers.length === 0) {\n        filterHideRow(filterOilGeysers, true);\n        filterSetDisabledState(filterOilGeysers, false);\n        return;\n    }\n\n    filterHideRow(filterOilGeysers, false);\n\n    mapLayerOilGeysers = L.layerGroup(oilGeyserMarkers);\n\n    if (showInMap) {\n        mapLayerOilGeysers.addTo(map);\n    }\n    filterSetDisabledState(filterOilGeysers, false);\n}\n\nfunction updateOilGeysersState() {\n    updateLayerState(mapLayerOilGeysers, (layer) => ({\n        popup: addDevTooltip('OIL GEYSER', layer.geyserData)\n    }));\n}\n"
