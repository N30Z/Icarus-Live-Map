            "size": 23388,
            "mimeType": "text/javascript",
            "text": "let _mapData = [];\n\nlet _gridLayers = {};\nlet _mapTileLayers = {};\nlet _currentTilesPath = ''; // Track current tiles path for toggling\n\nwindow.selectedMap = '';\nwindow.selectedMapParent = '';\nwindow.selectedMapGridZoom = 4;\nlet isInitialMapLoad = true; // Track if this is the first map load\n\nfunction setControlInteractivityState(control, enabled, enabledTitle = '', disabledTitle = '') {\n    if (!control) return;\n\n    control.disabled = !enabled;\n    control.title = enabled ? enabledTitle : disabledTitle;\n    control.style.cursor = enabled ? '' : 'not-allowed';\n    control.style.opacity = enabled ? '' : '0.6';\n}\n\n(function () {\n    // Check if we're loading from a shared link and need to preload the map state\n    const params = new URLSearchParams(window.location.search);\n    const sharedGuid = params.get('m');\n    let initialMapLoaded = false;\n\n    const initializeMapDropdown = function () {\n        fetch(`/mapdata`)\n            .then(res => res.json())\n            .then(data => {\n                _mapData = data;\n\n                // Run migration after map data is loaded\n                if (typeof migrateMapStorage !== 'undefined') {\n                    migrateMapStorage(_mapData);\n                }\n\n                const mapDropdown = document.getElementById('mapSelector');\n                mapDropdown.innerHTML = '';\n\n                Object.entries(_mapData).forEach(([key, map]) => {\n                    const option = document.createElement('option');\n                    option.value = map.code;\n                    option.textContent = map.title;\n                    // Store tips data as a data attribute for easy access\n                    if (map.tips) {\n                        option.setAttribute('data-tips', map.tips);\n                    }\n                    mapDropdown.appendChild(option);\n                });\n\n                mapDropdown.addEventListener('change', (event) => {\n                    const selectedMap = event.target.value;\n                    switchMap(selectedMap);\n                    updateMapTipsIcon();\n                });\n\n                if (localStorage.currentMap) {\n                    mapDropdown.value = localStorage.currentMap;\n                    mapDropdown.dispatchEvent(new Event('change'));\n                } else {\n                    mapDropdown.value = mapselect;\n                    mapDropdown.dispatchEvent(new Event('change'));\n                }\n\n                // If this is a shared link (read-only or shared state), disable map and mission switching\n                if (sharedGuid) {\n                    // Use setTimeout to ensure DOM is fully ready and we're targeting the right element\n                    setTimeout(() => {\n                        const mapSelectorElement = document.getElementById('mapSelector');\n                        const missionSelectorElement = document.getElementById('mission');\n                        const mapManageBtn = document.getElementById('openSavedMapsDialogBtn');\n                        const sharedMapOverlay = document.getElementById('sharedMapOverlay');\n\n                        setControlInteractivityState(\n                            mapSelectorElement,\n                            false,\n                            'Select a map',\n                            'Map selection is locked when viewing a shared link'\n                        );\n\n                        setControlInteractivityState(\n                            mapManageBtn,\n                            false,\n                            'Manage saved maps',\n                            'Map management is disabled for shared maps'\n                        );\n\n                        if (sharedMapOverlay) {\n                            sharedMapOverlay.style.display = 'flex';\n                        }\n                    }, 10);\n                }\n            });\n    };\n\n    // If loading from shared link, preload the map state to get the correct map\n    if (sharedGuid) {\n        // Set global flag to prevent savedMaps updates\n        window.isViewingSharedMap = true;\n\n        const xhr = new XMLHttpRequest();\n        xhr.open('POST', 'map/load/' + sharedGuid + '/new', false);\n        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');\n        if (typeof appendClientVersionToFormBody === 'function') {\n            xhr.send(appendClientVersionToFormBody(''));\n        } else {\n            xhr.send('');\n        }\n        if (xhr.status === 200) {\n            const data = JSON.parse(xhr.responseText);\n            if (data != \"false\") {\n                // Check for map property in new location (data.map) or old location (data.filters.map)\n                const mapName = data.map || (data.filters && data.filters.map);\n                if (mapName) {\n                    // Update localStorage.currentMap BEFORE dropdown initializes\n                    localStorage.currentMap = mapName;\n                }\n                // Also set the map state so custom markers are available\n                if (typeof setMapState !== 'undefined') {\n                    setMapState(data);\n                }\n                // Don't update GUID or metadata for shared maps - they should remain read-only\n                // and not affect the user's saved maps list or selected state\n            }\n        } else if (xhr.status === 426 || xhr.status === 409) {\n            try {\n                const mismatchPayload = JSON.parse(xhr.responseText || '{}');\n                if (typeof handleClientVersionMismatch === 'function') {\n                    handleClientVersionMismatch(mismatchPayload);\n                }\n            } catch (e) {\n                // Ignore JSON parse issues here; normal app flow will continue with defaults\n            }\n        }\n    }\n\n    initializeMapDropdown();\n})\n    ();\n\nfunction switchMap(mapCode) {\n    // Capture the current map BEFORE switching\n    const previousMap = localStorage.currentMap || 'olympus';\n    const suppressMapSwitchNotification = (typeof window !== 'undefined' && window.__suppressNextMapSwitchLoadNotification === true);\n\n    // Clean up any unsaved map entries before switching maps\n    if (typeof cleanupUnsavedMapEntries !== 'undefined') {\n        cleanupUnsavedMapEntries();\n    }\n\n    // Save current map view (zoom and center) before switching\n    if (typeof map !== 'undefined' && typeof saveMapView !== 'undefined') {\n        const zoom = map.getZoom();\n        const center = map.getCenter();\n        saveMapView(zoom, { lat: center.lat, lng: center.lng });\n    }\n\n    // Save current map state before switching (pass the previous map ID)\n    if (typeof saveBeforeMapSwitch !== 'undefined') {\n        saveBeforeMapSwitch(previousMap);\n    }\n\n    // Now set the new map\n    localStorage.currentMap = mapCode;\n    mapselect = mapCode;\n\n    // Update lastOpenedIndex in savedMaps to point to the entry that will be loaded\n    // Don't update if viewing a shared map\n    if (typeof getSavedMaps !== 'undefined' && typeof setSavedMaps !== 'undefined' && !window.isViewingSharedMap) {\n        const savedMapsData = getSavedMaps();\n        // Find the entry with selected=true for this mapCode (the one that will be loaded)\n        let index = savedMapsData.savedMaps.findIndex(m => m.mapCode === mapCode && m.selected === true);\n        // Fallback to first entry with this mapCode if no selected flag set\n        if (index === -1) {\n            index = savedMapsData.savedMaps.findIndex(m => m.mapCode === mapCode);\n        }\n        if (index !== -1) {\n            savedMapsData.lastOpenedIndex = index;\n            setSavedMaps(savedMapsData);\n\n            const selectedEntry = savedMapsData.savedMaps[index];\n            const shouldQueueMapSwitchNotification =\n                !isInitialMapLoad &&\n                previousMap !== mapCode &&\n                !suppressMapSwitchNotification &&\n                selectedEntry &&\n                selectedEntry.guid &&\n                selectedEntry.guid !== 'new';\n\n            if (shouldQueueMapSwitchNotification) {\n                window.__pendingMapSwitchNotification = {\n                    mapCode,\n                    expectedGuid: selectedEntry.guid,\n                    timestamp: Date.now()\n                };\n            } else if (typeof window !== 'undefined') {\n                window.__pendingMapSwitchNotification = null;\n            }\n        } else if (typeof window !== 'undefined') {\n            window.__pendingMapSwitchNotification = null;\n        }\n    }\n\n    // Show loading overlay only if this is not the initial map load\n    if (typeof showMapLoading !== 'undefined' && !isInitialMapLoad) {\n        showMapLoading();\n    } else if (isInitialMapLoad && typeof hideMapLoading !== 'undefined') {\n        // Ensure loading overlay is hidden during initial load\n        hideMapLoading();\n    }\n\n    // Mark that initial load is complete\n    if (isInitialMapLoad) {\n        isInitialMapLoad = false;\n    }\n\n    // Remove layers\n    _mapRemoveLayers();\n\n    // Load user map data\n    _mapLoadUserData(mapCode);\n\n    // Change map\n    _mapLoadTiles(mapCode);\n\n    // Apply saved filters and states\n    const reloadPromise = mapReloadSavedState();\n\n    // Update saved map name display\n    if (typeof updateCurrentMapNameDisplay !== 'undefined') {\n        setTimeout(updateCurrentMapNameDisplay, 100);\n    }\n\n    return reloadPromise;\n}\n\nfunction _mapLoadTiles(mapCode) {\n    // const mapId = _mapData.findIndex(m => m.code === mapCode);\n    const mapInfo = _mapData.find(m => m.code === mapCode);\n\n    //Save map changed info\n    selectedMapParent = mapInfo['parentMap'];\n    selectedMapGridZoom = mapInfo['gridZoom'];\n    selectedMap = mapCode;\n\n    // Calculate dynamic maxZoom: gridZoom + 2 virtual levels\n    const dynamicMaxZoom = selectedMapGridZoom + 2;\n\n    let tilesPath = mapInfo['tilesPath'];\n\n    // Check if NULL sector map should be shown for Prometheus\n    if (selectedMapParent === 'prometheus') {\n        const filterState = getFilterState();\n        if (filterState.prometheusNull && filterState.prometheusNull.map) {\n            tilesPath = 'prometheus2';\n        }\n    }\n\n    _currentTilesPath = tilesPath;\n\n    //Create map layer\n    if (!_mapTileLayers[tilesPath]) {\n        let mapOptions = {\n            minZoom: 1,\n            maxZoom: dynamicMaxZoom,  // gridZoom + 2 for virtual zoom levels\n            maxNativeZoom: mapInfo['maxZoom'],\n            continuousWorld: false,\n            noWrap: true,\n            bounds: TILE_BOUNDS,\n            reuseTiles: true,\n            keepBuffer: 6,\n            // attribution: mapAttribution,\n        };\n        _mapTileLayers[tilesPath] = L.tileLayer('maps/' + tilesPath + '/{z}/{x}/{y}.jpg', mapOptions);\n    }\n\n    // Remove old map, load new one.\n    Object.values(_mapTileLayers).forEach(layer => map.removeLayer(layer));\n    _mapTileLayers[tilesPath].addTo(map);\n\n    // Update map's maxZoom to match tile layer (gridZoom + 2)\n    map.setMaxZoom(dynamicMaxZoom);\n\n    //Create grid layer\n    if (!_gridLayers[selectedMapGridZoom]) {\n        let gridOptions = {\n            bounds: TILE_BOUNDS,\n            className: 'icarus-grid-native-zoom-' + selectedMapGridZoom,\n            minZoom: 1,\n            minNativeZoom: selectedMapGridZoom,\n            maxNativeZoom: selectedMapGridZoom,\n            zIndex: 100,\n        };\n        _gridLayers[selectedMapGridZoom] = L.gridLayer.icarusGrid(gridOptions);\n    }\n\n    // Remove old grid lines, load new ones.\n    Object.values(_gridLayers).forEach(layer => map.removeLayer(layer));\n    _gridLayers[selectedMapGridZoom].addTo(map);\n}\n\nfunction mapToggleGridLayer(state) {\n    if (state) {\n        _gridLayers[selectedMapGridZoom].addTo(map);\n    } else {\n        Object.values(_gridLayers).forEach(gridLayer => {\n            map.removeLayer(gridLayer);\n        });\n    }\n}\n\nfunction _mapRemoveLayers() {\n    toggleGeysersLayer(false);\n    toggleOilGeysersLayer(false);\n    toggleOreDepositLayer(false, true); // isProgrammatic=true during map switch\n    toggleCavesLayer(false, true); // isProgrammatic=true during map switch\n    toggleMetaDepositsLayer(false);\n\n    toggleCustomMarkerLayer(false);\n    customMarkersClear();\n\n    // Clear mission-related layers (don't restore general deposits during map switch)\n    if (typeof clearProspect !== 'undefined') {\n        clearProspect(false);\n    }\n}\n\nfunction _mapLoadUserData(mapCode) {\n    setTimeout(() => {\n        load_persistent();\n        // Initialize saved maps UI after persistent data is loaded\n        if (typeof initSavedMapsUI !== 'undefined') {\n            initSavedMapsUI();\n        }\n    }, 50);\n}\n\nfunction mapReloadSavedState() {\n    const mapState = getMapState();\n\n    // Disable map selector during loading\n    const mapSelector = document.getElementById('mapSelector');\n    if (mapSelector) {\n        setControlInteractivityState(mapSelector, false, 'Select a map', 'Loading map data...');\n    }\n\n    // Fetch all layer data in a single request\n    const layersUrl = typeof appendClientVersionToUrl === 'function'\n        ? appendClientVersionToUrl(`/map/layers/${encodeURIComponent(selectedMapParent)}`)\n        : `/map/layers/${encodeURIComponent(selectedMapParent)}`;\n\n    return fetch(layersUrl)\n        .then(res => {\n            if (res.status === 426 || res.status === 409) {\n                return res.json().then(payload => {\n                    if (typeof handleClientVersionMismatch === 'function') {\n                        handleClientVersionMismatch(payload);\n                    }\n                    const mismatchError = new Error('Client version mismatch');\n                    mismatchError.isClientVersionMismatch = true;\n                    throw mismatchError;\n                });\n            }\n            return res.json();\n        })\n        .then(layerData => {\n\n            // Cache and set all layer data\n            if (typeof cachedCavesData !== 'undefined') {\n                cachedCavesData[selectedMapParent] = layerData.caves;\n            }\n            if (typeof cachedOresData !== 'undefined') {\n                cachedOresData[selectedMapParent] = layerData.ores;\n            }\n            if (typeof cachedGeysersData !== 'undefined') {\n                cachedGeysersData[selectedMapParent] = layerData.geysers;\n            }\n            if (typeof cachedOilGeysersData !== 'undefined') {\n                cachedOilGeysersData[selectedMapParent] = layerData.oilGeysers;\n            }\n            if (typeof cachedMissionsListData !== 'undefined' && layerData.missions) {\n                cachedMissionsListData[selectedMapParent] = layerData.missions;\n            }\n\n            // Load layers based on saved state from localStorage\n            const filterState = getFilterState();\n\n            if (typeof setCavesData !== 'undefined') {\n                setCavesData(selectedMapParent, layerData.caves, filterState.caves.all);\n            }\n            if (typeof setOreDepositsData !== 'undefined') {\n                setOreDepositsData(selectedMapParent, layerData.ores, filterState.deepOreDeposits);\n            }\n            if (typeof setGeysersData !== 'undefined') {\n                setGeysersData(selectedMapParent, layerData.geysers, filterState.enzymeGeysers);\n            }\n            if (typeof setOilGeysersData !== 'undefined') {\n                setOilGeysersData(selectedMapParent, layerData.oilGeysers, filterState.oilGeysers);\n            }\n\n            // Load missions data\n            if (typeof setMissionsData !== 'undefined' && layerData.missions) {\n                setMissionsData(selectedMapParent, layerData.missions);\n            }\n\n            // Load meta deposits (exotic deposits)\n            if (typeof loadMetaDepositsForMap !== 'undefined' && layerData.metaDeposits) {\n                loadMetaDepositsForMap(selectedMapParent, layerData.metaDeposits, filterState.metaDeposits);\n            }\n\n            // Load custom markers (from user state, not server)\n            if (typeof loadCustomMarkers !== 'undefined') {\n                loadCustomMarkers(filterState.markers);\n            }\n\n            // Restore saved map view (zoom and center position)\n            if (typeof getSavedMapView !== 'undefined' && typeof map !== 'undefined') {\n                const savedView = getSavedMapView();\n                if (savedView && savedView.zoom !== null && savedView.center !== null) {\n                    // Temporarily disable saving while we restore the view\n                    if (typeof shouldSaveMapView !== 'undefined') {\n                        shouldSaveMapView = false;\n                    }\n                    map.setView([savedView.center.lat, savedView.center.lng], savedView.zoom);\n                }\n            }\n\n            // Enable map view saving after restoration is complete\n            // Only register the event listener once (on first map load)\n            if (typeof shouldSaveMapView !== 'undefined' && !map._mapViewListenerRegistered) {\n                map._mapViewListenerRegistered = true;\n                // Small delay to ensure the view restoration moveend event completes first\n                setTimeout(function () {\n                    shouldSaveMapView = true;\n                    map.on('moveend', function () {\n                        if (shouldSaveMapView && typeof saveMapView !== 'undefined') {\n                            const zoom = map.getZoom();\n                            const center = map.getCenter();\n                            saveMapView(zoom, { lat: center.lat, lng: center.lng });\n                        }\n                    });\n                }, 100);\n            } else if (typeof shouldSaveMapView !== 'undefined') {\n                // Re-enable saving for subsequent map switches\n                setTimeout(function () {\n                    shouldSaveMapView = true;\n                }, 100);\n            }\n\n            // Re-enable map and mission selectors (unless it's a shared link)\n            const params = new URLSearchParams(window.location.search);\n            const isSharedLink = params.get('m');\n            if (mapSelector) {\n                if (!isSharedLink) {\n                    setControlInteractivityState(mapSelector, true, 'Select a map');\n                }\n            }\n\n            // Mission selector is now allowed for shared links\n            // Mission selection is stored locally, not in shared map state\n\n            // Update Prometheus NULL sector section visibility\n            updatePrometheusNullSectionVisibility();\n\n            // Update map tips icon visibility\n            updateMapTipsIcon();\n\n            // Hide loading overlay\n            if (typeof hideMapLoading !== 'undefined') {\n                hideMapLoading();\n            }\n\n            window.dispatchEvent(new CustomEvent('mapReloadComplete', {\n                detail: {\n                    success: true,\n                    mapCode: selectedMapParent\n                }\n            }));\n        })\n        .catch(error => {\n            if (error && error.isClientVersionMismatch) {\n                return;\n            }\n\n            console.error('Error loading map layers:', error);\n\n            // Re-enable map selector even on error\n            if (mapSelector) {\n                setControlInteractivityState(mapSelector, true, 'Select a map');\n            }\n\n            // Hide loading overlay\n            if (typeof hideMapLoading !== 'undefined') {\n                hideMapLoading();\n            }\n\n            // Show error notification if available\n            if (typeof notificationControl !== 'undefined') {\n                notificationControl.danger('Error loading map layers', 'Failed to load map data. Please try again.');\n            }\n\n            window.dispatchEvent(new CustomEvent('mapReloadComplete', {\n                detail: {\n                    success: false,\n                    mapCode: selectedMapParent,\n                    error: error?.message || 'Unknown error'\n                }\n            }));\n        });\n}\n\n/**\n * Updates the map tips icon visibility and tooltip based on selected map\n */\nfunction updateMapTipsIcon() {\n    const mapSelector = document.getElementById('mapSelector');\n    const tipsIcon = document.getElementById('mapTipsIcon');\n\n    if (!mapSelector || !tipsIcon) return;\n\n    const selectedOption = mapSelector.options[mapSelector.selectedIndex];\n    const tips = selectedOption ? selectedOption.getAttribute('data-tips') : null;\n\n    if (tips && tips.trim() !== '') {\n        tipsIcon.style.display = 'flex';\n\n        // Remove any existing event listeners by cloning and replacing\n        const newTipsIcon = tipsIcon.cloneNode(true);\n        tipsIcon.parentNode.replaceChild(newTipsIcon, tipsIcon);\n\n        // Show tips on click\n        newTipsIcon.addEventListener('click', (e) => {\n            e.preventDefault();\n            e.stopPropagation();\n            showMapTipsPopup(tips, newTipsIcon);\n        });\n\n        // if (typeof setIconTooltip === 'function') {\n        //     setIconTooltip(newTipsIcon, 'Click to view map tips');\n        // } else {\n        //     newTipsIcon.setAttribute('data-tooltip', 'Click to view map tips');\n        //     newTipsIcon.removeAttribute('title');\n        // }\n    } else {\n        tipsIcon.style.display = 'none';\n    }\n}\n\n/**\n * Shows a popup with map tips\n */\nfunction showMapTipsPopup(tips, iconElement) {\n    // Check if there's already a tips popup and close it\n    const existingPopup = document.getElementById('mapTipsPopup');\n    if (existingPopup) {\n        existingPopup.remove();\n        return; // Toggle behavior - close if already open\n    }\n\n    // Create popup element\n    const popup = document.createElement('div');\n    popup.id = 'mapTipsPopup';\n    popup.className = 'map-tips-popup';\n\n    // Create popup content\n    const content = document.createElement('div');\n    content.className = 'map-tips-content';\n\n    const header = document.createElement('div');\n    header.className = 'map-tips-header';\n    header.innerHTML = '<strong>Map Tips:</strong>';\n\n    const closeBtn = document.createElement('button');\n    closeBtn.className = 'map-tips-close';\n    closeBtn.innerHTML = '&times;';\n    closeBtn.onclick = () => popup.remove();\n\n    header.appendChild(closeBtn);\n\n    const body = document.createElement('div');\n    body.className = 'map-tips-body';\n    body.innerHTML = tips;\n\n    content.appendChild(header);\n    content.appendChild(body);\n    popup.appendChild(content);\n\n    popup.style.position = 'fixed';\n    popup.style.zIndex = '10000';\n\n    const isMobileLayout = window.matchMedia('(max-width: 767px)').matches;\n\n    if (isMobileLayout) {\n        popup.style.left = '50%';\n        popup.style.top = '50%';\n        popup.style.transform = 'translate(-50%, -50%)';\n    } else {\n        const rect = iconElement.getBoundingClientRect();\n        popup.style.left = (rect.right + 10) + 'px';\n        popup.style.top = rect.top + 'px';\n    }\n\n    document.body.appendChild(popup);\n\n    // Close popup when clicking outside\n    setTimeout(() => {\n        const closeOnClickOutside = (e) => {\n            if (!popup.contains(e.target) && e.target !== iconElement) {\n                popup.remove();\n                document.removeEventListener('click', closeOnClickOutside);\n            }\n        };\n        document.addEventListener('click', closeOnClickOutside);\n    }, 100);\n}\n"
