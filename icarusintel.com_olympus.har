          "content": {
            "size": 73604,
            "mimeType": "text/javascript",
            "text": "/*\n    Author : Ecaps79\n    Created : January 2022\n\n    This file is made exclusively for icarusintel.com site.\n\n    Map state persistence using sessionStorage and localStorage.\n    Filter states are stored in localStorage per map.\n    Cave/deposit/marker states are stored in the database.\n\n*/\n\nconst secondsBetweenUpdate = 60; //seconds\nconst secondsBetweenChangeUpdate = 10; //seconds\nconst secondsTick = 1000;\nconst requestTimeout = 20000;\nconst permittedIdleTime = 30 * 60 * 1 * 1000 // 30 minutes\nvar _int = undefined;\nvar _autoSaveTimer = undefined;\nvar _stateIconHideTimer = undefined;\nvar lastErrorFound;\n\n// ============================================================================\n// WWW TO NON-WWW MIGRATION CODE - TEMPORARY\n// TODO: Remove this entire section after migration period (Added: Feb 2026)\n// This code handles migration of savedMaps from www subdomain to main domain\n// Note: Must capture www legacy data before redirect as localStorage is domain-specific\n// ============================================================================\n(function () {\n    'use strict';\n\n    const MIGRATION_KEY = 'savedMapsMigrationData';\n\n    // Check if we're on www subdomain\n    const isWWW = window.location.hostname.startsWith('www.');\n    const isNonWWW = !isWWW;\n\n    if (isWWW) {\n        // STEP 1 & 2: On WWW domain - extract savedMaps and redirect to non-www\n        console.log('[WWW Migration] Detected www subdomain, initiating migration...');\n\n        // Check if already migrated - fast forward to redirect\n        if (localStorage.getItem('migratedFromWWW')) {\n            console.log('[WWW Migration] Already migrated previously, redirecting...');\n            const nonWWWUrl = window.location.href.replace('://www.', '://');\n            window.location.replace(nonWWWUrl);\n            return;\n        }\n\n        try {\n            let savedMapsData = localStorage.getItem('savedMaps');\n\n            // If no savedMaps, check for legacy format - MUST capture before redirect!\n            // (www localStorage becomes inaccessible after redirect to non-www)\n            if (!savedMapsData) {\n                console.log('[WWW Migration] No savedMaps, checking for legacy format...');\n                const legacyMaps = ['olympus', 'styx', 'prometheus', 'elysium', 'outpost1', 'outpost2', 'outpost3',\n                    'outpost4', 'outpost6', 'outpost7', 'outpost8', 'outpost9', 'outpost12'];\n\n\n                const migratedMaps = [];\n\n                legacyMaps.forEach(mapCode => {\n                    const guid = localStorage.getItem(mapCode);\n                    if (guid && guid !== 'new' && guid !== 'undefined') {\n                        migratedMaps.push({\n                            mapCode: mapCode,\n                            guid: guid,\n                            name: \"\",\n                            selected: false,\n                            created: null,\n                            lastAccess: new Date().toISOString()\n                        });\n                    }\n                });\n\n                if (migratedMaps.length > 0) {\n                    const currentMap = localStorage.getItem('currentMap') || 'olympus';\n                    const currentMapEntry = migratedMaps.find(m => m.mapCode === currentMap);\n                    if (currentMapEntry) {\n                        currentMapEntry.selected = true;\n                    } else {\n                        migratedMaps[0].selected = true;\n                    }\n\n                    savedMapsData = JSON.stringify({\n                        savedMaps: migratedMaps,\n                        lastOpenedIndex: migratedMaps.findIndex(m => m.selected) || 0\n                    });\n                    console.log(`[WWW Migration] Built savedMaps from ${migratedMaps.length} legacy entries`);\n                }\n            }\n\n            if (savedMapsData) {\n                console.log('[WWW Migration] Transferring savedMaps data for migration...');\n\n                // Compress and encode data for URL transfer (sessionStorage doesn't work across subdomains)\n                const encodedData = encodeURIComponent(btoa(savedMapsData));\n                localStorage.removeItem('savedMaps');\n\n                // Mark migration as completed to skip next time\n                localStorage.setItem('migratedFromWWW', 'true');\n\n                // Redirect to non-www version with migration data in URL\n                const nonWWWUrl = window.location.href.replace('://www.', '://');\n                const separator = nonWWWUrl.includes('?') ? '&' : '?';\n                const redirectUrl = `${nonWWWUrl}${separator}${MIGRATION_KEY}=${encodedData}`;\n\n                console.log('[WWW Migration] Redirecting with migration data...');\n                window.location.replace(redirectUrl);\n            } else {\n                console.log('[WWW Migration] No data to migrate from www');\n\n                // Mark migration as completed to skip next time\n                localStorage.setItem('migratedFromWWW', 'true');\n\n                // Redirect to non-www version\n                const nonWWWUrl = window.location.href.replace('://www.', '://');\n                console.log('[WWW Migration] Redirecting to:', nonWWWUrl);\n                window.location.replace(nonWWWUrl);\n            }\n\n        } catch (e) {\n            console.error('[WWW Migration] Error during www migration:', e);\n            // Mark as migrated even on error to prevent infinite loops\n            localStorage.setItem('migratedFromWWW', 'true');\n            const nonWWWUrl = window.location.href.replace('://www.', '://');\n            window.location.replace(nonWWWUrl);\n        }\n    }\n    else if (isNonWWW) {\n        // STEP 3 & 4: On non-WWW domain - merge savedMaps if migration data exists\n        // Note: Local legacy format (if any) will be handled by migrateMapStorage() in load_persistent.js\n        try {\n            // Get migration data from URL parameters (sessionStorage doesn't work across subdomains)\n            const params = new URLSearchParams(window.location.search);\n            const encodedData = params.get(MIGRATION_KEY);\n            const migrationData = encodedData ? atob(decodeURIComponent(encodedData)) : null;\n\n            // Clean URL by removing migration parameter\n            if (encodedData) {\n                params.delete(MIGRATION_KEY);\n                const cleanUrl = window.location.pathname + (params.toString() ? '?' + params.toString() : '');\n                window.history.replaceState({}, '', cleanUrl);\n            }\n\n            if (migrationData) {\n                console.log('[WWW Migration] Found migration data on non-www domain, processing...');\n\n                const wwwSavedMaps = JSON.parse(migrationData);\n                console.log('[WWW Migration] Retrieved savedMaps from migration data:', wwwSavedMaps);\n\n                const existingSavedMaps = localStorage.getItem('savedMaps');\n\n                let finalSavedMaps;\n                let hadMerge = false;\n\n                if (existingSavedMaps) {\n                    // Both www and non-www have savedMaps data - merge them\n                    console.log('[WWW Migration] Merging savedMaps from both domains...');\n\n                    const existing = JSON.parse(existingSavedMaps);\n                    const wwwMaps = wwwSavedMaps.savedMaps || [];\n                    const existingMaps = existing.savedMaps || [];\n\n                    // Create a map of existing GUIDs to avoid duplicates\n                    const existingGuids = new Set(existingMaps.map(m => m.guid));\n\n                    // Add www maps that don't already exist\n                    const newMaps = wwwMaps.filter(m => !existingGuids.has(m.guid));\n\n                    finalSavedMaps = {\n                        savedMaps: [...existingMaps, ...newMaps],\n                        lastOpenedIndex: existing.lastOpenedIndex || wwwSavedMaps.lastOpenedIndex || -1\n                    };\n\n                    hadMerge = newMaps.length > 0;\n\n                    if (hadMerge) {\n                        console.log(`[WWW Migration] Merged ${newMaps.length} new maps from www domain`);\n                    } else {\n                        console.log('[WWW Migration] No new maps to merge (all GUIDs already present)');\n                    }\n                } else {\n                    // Only www had savedMaps data - use it directly\n                    // Note: If both had legacy format, migrateMapStorage() will handle the merge later\n                    console.log('[WWW Migration] No existing savedMaps on non-www, using www data...');\n                    finalSavedMaps = wwwSavedMaps;\n                    hadMerge = (wwwSavedMaps.savedMaps && wwwSavedMaps.savedMaps.length > 0);\n                }\n\n                // Save merged data\n                localStorage.setItem('savedMaps', JSON.stringify(finalSavedMaps));\n                console.log('[WWW Migration] Migration complete, saved merged data');\n\n                // Show notification to user if data was merged\n                if (hadMerge) {\n                    // Wait for NotificationSystem to be available\n                    const showMigrationNotification = function () {\n                        if (typeof NotificationSystem !== 'undefined') {\n                            NotificationSystem.info(\n                                'Your saved maps have been migrated from the www version of the site. All your data is now consolidated.',\n                                8000\n                            );\n                            console.log('[WWW Migration] Notification shown to user');\n                        } else {\n                            // Retry after delay if NotificationSystem not yet loaded\n                            setTimeout(showMigrationNotification, 500);\n                        }\n                    };\n\n                    // Delay notification slightly to ensure page is loaded\n                    setTimeout(showMigrationNotification, 1000);\n                }\n            } else {\n                console.log('[WWW Migration] No migration data found (normal page load)');\n            }\n        } catch (e) {\n            console.error('[WWW Migration] Error processing migration on non-www:', e);\n        }\n    }\n})();\n// ============================================================================\n// END OF WWW TO NON-WWW MIGRATION CODE\n// ============================================================================\n\n/**\n * Detect mobile/tablet device.\n * @returns boolean\n */\nwindow.mobileAndTabletCheck = function () {\n    let check = false;\n    (function (a) { if (/(android|bb\\d+|meego).+mobile|avantgo|bada\\/|blackberry|blazer|compal|elaine|fennec|hiptop|iemobile|ip(hone|od)|iris|kindle|lge |maemo|midp|mmp|mobile.+firefox|netfront|opera m(ob|in)i|palm( os)?|phone|p(ixi|re)\\/|plucker|pocket|psp|series(4|6)0|symbian|treo|up\\.(browser|link)|vodafone|wap|windows ce|xda|xiino|android|ipad|playbook|silk/i.test(a) || /1207|6310|6590|3gso|4thp|50[1-6]i|770s|802s|a wa|abac|ac(er|oo|s\\-)|ai(ko|rn)|al(av|ca|co)|amoi|an(ex|ny|yw)|aptu|ar(ch|go)|as(te|us)|attw|au(di|\\-m|r |s )|avan|be(ck|ll|nq)|bi(lb|rd)|bl(ac|az)|br(e|v)w|bumb|bw\\-(n|u)|c55\\/|capi|ccwa|cdm\\-|cell|chtm|cldc|cmd\\-|co(mp|nd)|craw|da(it|ll|ng)|dbte|dc\\-s|devi|dica|dmob|do(c|p)o|ds(12|\\-d)|el(49|ai)|em(l2|ul)|er(ic|k0)|esl8|ez([4-7]0|os|wa|ze)|fetc|fly(\\-|_)|g1 u|g560|gene|gf\\-5|g\\-mo|go(\\.w|od)|gr(ad|un)|haie|hcit|hd\\-(m|p|t)|hei\\-|hi(pt|ta)|hp( i|ip)|hs\\-c|ht(c(\\-| |_|a|g|p|s|t)|tp)|hu(aw|tc)|i\\-(20|go|ma)|i230|iac( |\\-|\\/)|ibro|idea|ig01|ikom|im1k|inno|ipaq|iris|ja(t|v)a|jbro|jemu|jigs|kddi|keji|kgt( |\\/)|klon|kpt |kwc\\-|kyo(c|k)|le(no|xi)|lg( g|\\/(k|l|u)|50|54|\\-[a-w])|libw|lynx|m1\\-w|m3ga|m50\\/|ma(te|ui|xo)|mc(01|21|ca)|m\\-cr|me(rc|ri)|mi(o8|oa|ts)|mmef|mo(01|02|bi|de|do|t(\\-| |o|v)|zz)|mt(50|p1|v )|mwbp|mywa|n10[0-2]|n20[2-3]|n30(0|2)|n50(0|2|5)|n7(0(0|1)|10)|ne((c|m)\\-|on|tf|wf|wg|wt)|nok(6|i)|nzph|o2im|op(ti|wv)|oran|owg1|p800|pan(a|d|t)|pdxg|pg(13|\\-([1-8]|c))|phil|pire|pl(ay|uc)|pn\\-2|po(ck|rt|se)|prox|psio|pt\\-g|qa\\-a|qc(07|12|21|32|60|\\-[2-7]|i\\-)|qtek|r380|r600|raks|rim9|ro(ve|zo)|s55\\/|sa(ge|ma|mm|ms|ny|va)|sc(01|h\\-|oo|p\\-)|sdk\\/|se(c(\\-|0|1)|47|mc|nd|ri)|sgh\\-|shar|sie(\\-|m)|sk\\-0|sl(45|id)|sm(al|ar|b3|it|t5)|so(ft|ny)|sp(01|h\\-|v\\-|v )|sy(01|mb)|t2(18|50)|t6(00|10|18)|ta(gt|lk)|tcl\\-|tdg\\-|tel(i|m)|tim\\-|t\\-mo|to(pl|sh)|ts(70|m\\-|m3|m5)|tx\\-9|up(\\.b|g1|si)|utst|v400|v750|veri|vi(rg|te)|vk(40|5[0-3]|\\-v)|vm40|voda|vulc|vx(52|53|60|61|70|80|81|83|85|98)|w3c(\\-| )|webc|whit|wi(g |nc|nw)|wmlb|wonu|x700|yas\\-|your|zeto|zte\\-/i.test(a.substr(0, 4))) check = true; })(navigator.userAgent || navigator.vendor || window.opera);\n    return check;\n};\n\n\nfunction setMapState(mapState) {\n    debugLog('text', \"Map state changed:\", mapState);\n    if (mapState != undefined) {\n        sessionStorage.mapState = JSON.stringify(mapState);\n\n        // Trigger auto-save timer if there are changes\n        if (mapState.change === \"new\") {\n            scheduleAutoSave();\n            updateMapState('changed');\n        }\n    } else {\n        clearMapStateSession();\n    }\n}\n\nfunction getMapState() {\n    if (!sessionStorage.mapState) {\n        const xhr = new XMLHttpRequest();\n        xhr.open('GET', 'scripts/default-map-state.json', false);\n        xhr.send();\n        if (xhr.status === 200) {\n            const data = JSON.parse(xhr.responseText);\n            if (!localStorage.currentMap)\n                localStorage.currentMap = 'olympus';\n            // Set directly to avoid recursive call\n            // Don't mark as \"new\" until there are actual changes\n            data.change = undefined;\n            // Set map name if available\n            if (typeof selectedMapParent !== 'undefined' && selectedMapParent) {\n                data.map = selectedMapParent;\n            }\n            sessionStorage.mapState = JSON.stringify(data);\n        }\n    }\n\n    let mapState = JSON.parse(sessionStorage.mapState);\n    // Ensure map name is set\n    if (typeof selectedMapParent !== 'undefined' && selectedMapParent && !mapState.map) {\n        mapState.map = selectedMapParent;\n    }\n    return mapState;\n}\n\n/**\n * Clear the map state from session storage\n * This does not delete from database - only clears the local session\n */\nfunction clearMapStateSession() {\n    sessionStorage.removeItem('mapState');\n}\n\n/**\n * Convert old format deposit ID to new compact format\n * Old: \"dov-prometheus-81_5\" -> New: \"P81\"\n * Old: \"dov-prometheus-_2\" -> New: \"P1\"\n * @param {string} oldId - The old format deposit ID\n * @returns {string} The new compact format deposit ID\n */\nfunction convertDepositId(oldId) {\n    // Parse old format: \"dov-mapname-code\"\n    const parts = oldId.split('-');\n    if (parts.length !== 3 || parts[0] !== 'dov') {\n        // If not in expected format, return as-is\n        return oldId;\n    }\n\n    const mapName = parts[1];\n    const code = parts[2];\n\n    // Get map letter code using reverse lookup of MAP_CODE_TO_NAME (defined in main.js)\n    let mapCode = null;\n    if (typeof MAP_CODE_TO_NAME !== 'undefined') {\n        // Reverse lookup: find the code whose value matches mapName\n        mapCode = Object.keys(MAP_CODE_TO_NAME).find(key => MAP_CODE_TO_NAME[key] === mapName);\n    }\n\n    if (!mapCode) {\n        // Unknown map, return as-is\n        return oldId;\n    }\n\n    // Extract first number before underscore\n    const underscoreIndex = code.indexOf('_');\n    let firstNumber;\n\n    if (underscoreIndex === 0) {\n        // Edge case: \"_2\" or \"_352\" -> use \"1\"\n        firstNumber = '1';\n    } else if (underscoreIndex > 0) {\n        // Normal case: \"81_5\" -> use \"81\"\n        firstNumber = code.substring(0, underscoreIndex);\n    } else {\n        // No underscore: use entire code\n        firstNumber = code;\n    }\n\n    return mapCode + firstNumber;\n}\n\n/**\n * Clean loaded map state by removing filter data (except map name)\n * This ensures old data with filters gets cleaned up on next save\n * @param {*} data The loaded map state from DB\n * @returns Cleaned map state\n */\nfunction cleanLoadedMapState(data) {\n    let hadOldFilterData = false;\n\n    if (data && data.filters) {\n        hadOldFilterData = true;\n        // Preserve map name if it exists in filters AND currentMap is not set\n        // This prevents overwriting during map switches\n        if (data.filters.map && !localStorage.currentMap) {\n            localStorage.currentMap = data.filters.map;\n        }\n        // Remove all filter data from the state\n        delete data.filters;\n    }\n    // Ensure map name is set\n    if (typeof selectedMapParent !== 'undefined' && selectedMapParent && !data.map) {\n        data.map = selectedMapParent;\n    }\n\n    // Convert deposit IDs from old format to new compact format\n    // AND separate exotics deposits into their own array\n    // Only when loading old data with filters (one-time migration)\n    let depositStatus = data.deposit_status || [];\n    let exoticsStatus = data.exotics_status || [];\n\n    if (hadOldFilterData && depositStatus.length > 0) {\n        const deepOreDeposits = [];\n        const exoticsDeposits = [];\n\n        depositStatus.forEach(deposit => {\n            if (deposit.id && deposit.id.startsWith('dov-')) {\n                // Deep ore deposit - convert ID format\n                deepOreDeposits.push({\n                    ...deposit,\n                    id: convertDepositId(deposit.id)\n                });\n            } else if (deposit.id) {\n                // Exotic deposit - numeric ID format (e.g., \"57_11\"), move to exotics_status\n                exoticsDeposits.push(deposit);\n            }\n        });\n\n        depositStatus = deepOreDeposits;\n        exoticsStatus = exoticsDeposits;\n    }\n\n    // Reconstruct object with map at first position\n    const cleanedData = {\n        map: data.map || '',\n        cave_status: data.cave_status || [],\n        deposit_status: depositStatus,\n        exotics_status: exoticsStatus,\n        custom_marker: data.custom_marker || [],\n        guid: data.guid,\n        change: data.change,\n        rights: data.rights,\n        guidro: data.guidro,\n        version: data.version || 1\n    };\n\n    // Add created date if available\n    if (data.created) {\n        cleanedData.created = data.created;\n    }\n\n    // Add deleted flag if true\n    if (data.deleted) {\n        cleanedData.deleted = true;\n    }\n\n    return cleanedData;\n}\n\n/**\n * Update the map state icon in the top right corner\n * @param {string} state - One of: 'loaded', 'changed', 'saving', 'saved', 'error'\n * @param {string} message - Optional tooltip message\n */\nfunction updateMapState(state, message = '') {\n    const stateIcon = document.getElementById('mapStateIcon');\n    if (!stateIcon) return;\n\n    const iconMap = {\n        'loaded': { icon: 'check_circle', color: '#4CAF50', tooltip: 'Loaded from database' },\n        'changed': { icon: 'edit', color: '#FF9800', tooltip: 'Unsaved changes' },\n        'saving': { icon: 'progress_activity', color: '#2196F3', tooltip: 'Saving to database...' },\n        'saved': { icon: 'check_circle', color: '#4CAF50', tooltip: 'Saved to database' },\n        'error': { icon: 'error', color: '#F44336', tooltip: 'Error' }\n    };\n\n    const stateConfig = iconMap[state] || iconMap['loaded'];\n    const tooltipText = message || stateConfig.tooltip;\n\n    const spinClass = state === 'saving' ? ' spinning' : '';\n    stateIcon.innerHTML = `<i class=\"material-symbols-outlined${spinClass}\">${stateConfig.icon}</i>`;\n    stateIcon.style.color = stateConfig.color;\n    if (typeof setIconTooltip === 'function') {\n        setIconTooltip(stateIcon, tooltipText);\n    } else {\n        stateIcon.setAttribute('data-tooltip', tooltipText);\n        stateIcon.removeAttribute('title');\n    }\n\n    // Disable reload button when there are unsaved changes\n    const reloadBtn = document.getElementById('reloadMapButton');\n    const reloadBtnSidebarLi = document.getElementById('reloadMapButtonSidebar');\n    const reloadBtnSidebar = reloadBtnSidebarLi ? reloadBtnSidebarLi.querySelector('a') : null;\n\n    if (reloadBtn) {\n        if (state === 'changed' || state === 'saving') {\n            reloadBtn.classList.add('disabled');\n            // if (typeof setIconTooltip === 'function') {\n            //     setIconTooltip(reloadBtn, 'Cannot reload while there are unsaved changes');\n            // } else {\n            //     reloadBtn.setAttribute('data-tooltip', 'Cannot reload while there are unsaved changes');\n            //     reloadBtn.removeAttribute('title');\n            // }\n        } else {\n            reloadBtn.classList.remove('disabled');\n            // if (typeof setIconTooltip === 'function') {\n            //     // setIconTooltip(reloadBtn, 'Reload map from server');\n            // } else {\n            //     // reloadBtn.setAttribute('data-tooltip', 'Reload map from server');\n            //     reloadBtn.removeAttribute('title');\n            // }\n        }\n    }\n    if (reloadBtnSidebar) {\n        if (state === 'changed' || state === 'saving') {\n            reloadBtnSidebar.classList.add('disabled');\n        } else {\n            reloadBtnSidebar.classList.remove('disabled');\n        }\n    }\n\n    // Clear any existing hide timer\n    if (_stateIconHideTimer) {\n        clearTimeout(_stateIconHideTimer);\n        _stateIconHideTimer = undefined;\n    }\n\n    // Show the icon\n    stateIcon.style.display = 'flex';\n\n    // Auto-hide after 10 seconds only if saved or loaded\n    if (state === 'saved' || state === 'loaded') {\n        _stateIconHideTimer = setTimeout(() => {\n            stateIcon.style.display = 'none';\n            _stateIconHideTimer = undefined;\n        }, 10000);\n    }\n\n    sessionStorage.lastMapState = state;\n}\n\nfunction scheduleAutoSave() {\n    // Clear existing timer\n    if (_autoSaveTimer) {\n        clearTimeout(_autoSaveTimer);\n    }\n\n    // Schedule save in 10 seconds\n    _autoSaveTimer = setTimeout(() => {\n        updateUserAndMap(true);\n        _autoSaveTimer = undefined;\n    }, secondsBetweenChangeUpdate * 1000);\n\n    // Update message to show countdown\n    updateSaveCountdown();\n}\n\nfunction updateSaveCountdown() {\n    const mapState = getMapState();\n    if (mapState && mapState.change === \"new\" && _autoSaveTimer) {\n        updateMapState('changed', 'Saving in 10 seconds...');\n    }\n}\n\nfunction cancelAutoSave() {\n    if (_autoSaveTimer) {\n        clearTimeout(_autoSaveTimer);\n        _autoSaveTimer = undefined;\n    }\n}\n\nfunction updateUserAndMap(forceSave = false) {\n    if (!sessionStorage.lastUpdate)\n        sessionStorage.lastUpdate = Date.now();\n\n    let secondElapse = Math.floor((Date.now() - sessionStorage.lastUpdate) / 1000);\n\n    mapState = getMapState();\n\n    // Don't save if viewing a shared read-only map\n    if (mapState && mapState.rights === 'ro') {\n        updateMapState('loaded', 'Map is read-only');\n        return;\n    }\n\n    if (mapState && mapState.change == \"new\" && (secondElapse % secondsBetweenChangeUpdate == 0 || forceSave)) {\n        const currentMap = localStorage.currentMap || 'olympus';\n        debugLog('saving', 'Saving map to DB:', { map: currentMap, guid: getGuid(), forceSave });\n        updateMapState('saving');\n\n        // Clean the map state before saving (remove filters, ensure map name is set)\n        const stateToSave = cleanLoadedMapState({ ...mapState });\n\n        // Use two-stage save with conflict resolution\n        saveToDatabase(stateToSave, 0);\n    } else if (secondElapse > secondsBetweenUpdate) {\n        loadMapFromDb(false);\n    } else {\n        if (mapState && mapState.change == \"new\") {\n            const secondsLeft = secondsBetweenChangeUpdate - (secondElapse % secondsBetweenChangeUpdate);\n            updateMapState('changed', `Saving in ${secondsLeft}s`);\n        } else {\n            updateMapState('loaded');\n        }\n    }\n}\n\n/**\n * Get saved maps structure from localStorage\n * @returns {Object} {savedMaps: Array<{mapCode, guid, name, selected, created, lastAccess}>, lastOpenedIndex: number}\n */\nfunction getSavedMaps() {\n    try {\n        const data = localStorage.getItem('savedMaps');\n        if (data) {\n            const parsed = JSON.parse(data);\n            const savedMaps = Array.isArray(parsed.savedMaps)\n                ? parsed.savedMaps.map(entry => ({\n                    ...entry,\n                    markedForDeletion: entry?.markedForDeletion === true\n                }))\n                : [];\n\n            const lastOpenedIndex = Number.isInteger(parsed.lastOpenedIndex)\n                ? parsed.lastOpenedIndex\n                : -1;\n\n            return { savedMaps, lastOpenedIndex };\n        }\n    } catch (e) {\n        console.error('Error parsing savedMaps:', e);\n    }\n    return { savedMaps: [], lastOpenedIndex: -1 };\n}\n\n/**\n * Save the savedMaps structure to localStorage\n * @param {Object} data - {savedMaps: Array, lastOpenedIndex: number}\n */\nfunction setSavedMaps(data) {\n    // Don't update savedMaps when viewing a shared map\n    if (window.isViewingSharedMap) {\n        return;\n    }\n    localStorage.setItem('savedMaps', JSON.stringify(data));\n}\n\n/**\n * Update saved map metadata (created date and last access time)\n * @param {string} guid - The map GUID\n * @param {string|null} created - The created date from server (null if not available)\n * @param {boolean} updateAccess - Whether to update the lastAccess timestamp\n */\nfunction updateSavedMapMetadata(guid, created = null, updateAccess = false) {\n    if (!guid || guid === 'new') return;\n\n    const params = new URLSearchParams(window.location.search);\n    if (params.get('m')) return; // Don't update for shared URLs\n\n    // Don't update metadata when viewing a shared map\n    if (window.isViewingSharedMap) {\n        return;\n    }\n\n    const savedMapsData = getSavedMaps();\n    const entry = savedMapsData.savedMaps.find(m => m.guid === guid);\n\n    if (entry) {\n        // Update created date only if it's not already set and we have a value\n        if (created && !entry.created) {\n            entry.created = created;\n            debugLog('text', 'Set created date for map:', { guid, created });\n        }\n\n        // Update last access time if requested\n        if (updateAccess) {\n            entry.lastAccess = new Date().toISOString();\n            debugLog('text', 'Updated lastAccess for map:', { guid, lastAccess: entry.lastAccess });\n        }\n\n        setSavedMaps(savedMapsData);\n    }\n}\n\n/**\n * Update whether a saved map is marked for deletion\n * @param {string} guid - The map GUID\n * @param {boolean} markedForDeletion - Deletion flag from server\n */\nfunction setSavedMapDeletionFlag(guid, markedForDeletion = false) {\n    if (!guid || guid === 'new') return;\n\n    const params = new URLSearchParams(window.location.search);\n    if (params.get('m')) return; // Don't update for shared URLs\n\n    // Don't update metadata when viewing a shared map\n    if (window.isViewingSharedMap) {\n        return;\n    }\n\n    const savedMapsData = getSavedMaps();\n    const entry = savedMapsData.savedMaps.find(m => m.guid === guid);\n\n    if (entry) {\n        entry.markedForDeletion = markedForDeletion === true;\n        setSavedMaps(savedMapsData);\n    }\n}\n\nfunction getSavedMapAccessTimestamp(entry) {\n    if (!entry || !entry.lastAccess) return 0;\n\n    const timestamp = new Date(entry.lastAccess).getTime();\n    return Number.isFinite(timestamp) ? timestamp : 0;\n}\n\n/**\n * Mark a map as missing (404) while keeping the local entry for user visibility.\n * The missing entry is deselected to avoid auto-loading it in the background.\n * @param {string} guid - The missing map GUID\n * @returns {boolean} True when the entry was found and updated\n */\nfunction markSavedMapAsMissing(guid) {\n    if (!guid || guid === 'new') return false;\n\n    const params = new URLSearchParams(window.location.search);\n    if (params.get('m')) return false; // Don't update for shared URLs\n\n    if (window.isViewingSharedMap) {\n        return false;\n    }\n\n    const savedMapsData = getSavedMaps();\n    const entryIndex = savedMapsData.savedMaps.findIndex(m => m.guid === guid);\n    if (entryIndex === -1) {\n        return false;\n    }\n\n    const entry = savedMapsData.savedMaps[entryIndex];\n    entry.markedForDeletion = true;\n\n    if (entry.selected === true) {\n        entry.selected = false;\n\n        const fallbackCandidates = savedMapsData.savedMaps\n            .map((mapEntry, index) => ({ mapEntry, index }))\n            .filter(({ mapEntry }) =>\n                mapEntry.mapCode === entry.mapCode\n                && mapEntry.guid !== guid\n                && mapEntry.markedForDeletion !== true\n            )\n            .sort((a, b) => getSavedMapAccessTimestamp(b.mapEntry) - getSavedMapAccessTimestamp(a.mapEntry));\n\n        if (fallbackCandidates.length > 0) {\n            const fallback = fallbackCandidates[0];\n            fallback.mapEntry.selected = true;\n            savedMapsData.lastOpenedIndex = fallback.index;\n        } else {\n            savedMapsData.lastOpenedIndex = -1;\n        }\n    }\n\n    setSavedMaps(savedMapsData);\n    return true;\n}\n\nfunction getGuid() {\n    const params = new URLSearchParams(window.location.search);\n    if (params.get('m')) { // Loaded map\n        return params.get('m')\n    }\n\n    // Try new savedMaps structure first\n    const savedMapsData = getSavedMaps();\n    const currentMapCode = localStorage.currentMap;\n    if (savedMapsData.savedMaps && savedMapsData.savedMaps.length > 0) {\n        // Find the last opened entry for this map code\n        let entry = savedMapsData.savedMaps.find(m => m.mapCode === currentMapCode && m.selected === true);\n\n        // If no entry is marked as selected, find the most recently accessed one\n        if (!entry) {\n            const entriesForMap = savedMapsData.savedMaps.filter(\n                m => m.mapCode === currentMapCode && m.markedForDeletion !== true\n            );\n\n            if (entriesForMap.length > 0) {\n                // Sort by lastAccess (most recent first)\n                entriesForMap.sort((a, b) => {\n                    const dateA = a.lastAccess ? new Date(a.lastAccess).getTime() : 0;\n                    const dateB = b.lastAccess ? new Date(b.lastAccess).getTime() : 0;\n                    return dateB - dateA;\n                });\n\n                entry = entriesForMap[0];\n                debugLog('saving', 'No selected entry found, using most recent:', {\n                    mapCode: currentMapCode,\n                    guid: entry.guid,\n                    lastAccess: entry.lastAccess\n                });\n            } else {\n                // No entries for this map at all, return 'new'\n                debugLog('saving', 'No entries found for current map code:', currentMapCode);\n                return 'new';\n            }\n        } else {\n            debugLog('saving', 'Found selected entry for current map:', { guid: entry.guid, mapCode: currentMapCode });\n        }\n\n        if (entry && entry.guid) {\n            return entry.guid;\n        }\n    }\n\n    // Fallback to legacy localStorage[mapCode] structure\n    let guid = localStorage[currentMapCode];\n    if (guid) {\n        return guid\n    } else {\n        return 'new'\n    }\n}\n\nfunction setGuid(guid) {\n    const params = new URLSearchParams(window.location.search);\n    if (params.get('m')) // this is a loaded url, no need to save GUID\n        return;\n\n    // Don't update GUID when viewing a shared map\n    if (window.isViewingSharedMap) {\n        return;\n    }\n\n    const currentMapCode = localStorage.currentMap;\n    const savedMapsData = getSavedMaps();\n\n    if (guid) {\n        // Check if there's an entry with guid: 'new' for this map code (unsaved map being saved)\n        const newEntry = savedMapsData.savedMaps.find(m => m.mapCode === currentMapCode && m.guid === 'new');\n        if (newEntry) {\n            // Update the 'new' entry with the actual GUID from server\n            debugLog('saving', 'Updating new entry with actual GUID:', {\n                oldGuid: 'new',\n                newGuid: guid,\n                preservedName: newEntry.name,\n                mapCode: currentMapCode\n            });\n\n            newEntry.guid = guid;\n            newEntry.selected = true;\n\n            // Clear selected from other entries for this map code\n            savedMapsData.savedMaps.forEach(m => {\n                if (m.mapCode === currentMapCode && m.guid !== guid) {\n                    m.selected = false;\n                }\n            });\n\n            // Update global lastOpenedIndex\n            const newIndex = savedMapsData.savedMaps.findIndex(m => m.guid === guid);\n            if (newIndex !== -1) {\n                savedMapsData.lastOpenedIndex = newIndex;\n            }\n\n            setSavedMaps(savedMapsData);\n            debugLog('saving', 'Entry updated successfully, name preserved');\n            return;\n        }\n\n        // Check if this GUID already exists\n        const existingByGuid = savedMapsData.savedMaps.find(m => m.guid === guid);\n        if (existingByGuid) {\n            // GUID already exists, mark it as last opened for this map code\n            debugLog('saving', 'GUID already exists, marking as last opened:', { guid, mapCode: existingByGuid.mapCode, currentMapCode });\n\n            // Clear selected flag from other entries with same mapCode\n            savedMapsData.savedMaps.forEach(m => {\n                if (m.mapCode === currentMapCode) {\n                    m.selected = (m.guid === guid);\n                }\n            });\n\n            // Update global lastOpenedIndex\n            const newIndex = savedMapsData.savedMaps.findIndex(m => m.guid === guid);\n            if (newIndex !== -1) {\n                savedMapsData.lastOpenedIndex = newIndex;\n            }\n\n            setSavedMaps(savedMapsData);\n            debugLog('saving', 'Marked existing GUID as last opened', { guid, mapCode: currentMapCode, index: newIndex });\n            // console.log('setGuid: Marked GUID as selected:', { guid, mapCode: currentMapCode, index: newIndex });\n            return;\n        }\n\n        // Clear selected flag from all other entries for this mapCode\n        savedMapsData.savedMaps.forEach(m => {\n            if (m.mapCode === currentMapCode) {\n                m.selected = false;\n            }\n        });\n\n        // Add new entry and mark as last opened\n        savedMapsData.savedMaps.push({\n            mapCode: currentMapCode,\n            guid: guid,\n            name: \"\",\n            selected: true,\n            created: null,\n            lastAccess: new Date().toISOString(),\n            markedForDeletion: false\n        });\n\n        // Update global lastOpenedIndex\n        const newIndex = savedMapsData.savedMaps.length - 1;\n        savedMapsData.lastOpenedIndex = newIndex;\n\n        setSavedMaps(savedMapsData);\n    } else {\n        // Remove entry if guid is null/empty - only remove the last opened one\n        const indexToRemove = savedMapsData.savedMaps.findIndex(m => m.mapCode === currentMapCode && m.selected === true);\n        if (indexToRemove !== -1) {\n            savedMapsData.savedMaps.splice(indexToRemove, 1);\n\n            // Adjust global lastOpenedIndex\n            if (savedMapsData.lastOpenedIndex === indexToRemove) {\n                savedMapsData.lastOpenedIndex = -1;\n            } else if (savedMapsData.lastOpenedIndex > indexToRemove) {\n                savedMapsData.lastOpenedIndex--;\n            }\n        }\n        setSavedMaps(savedMapsData);\n\n        // Also remove legacy storage\n        localStorage.removeItem(currentMapCode);\n    }\n\n    // Update the current map name display in UI\n    if (typeof updateCurrentMapNameDisplay !== 'undefined') {\n        setTimeout(updateCurrentMapNameDisplay, 50);\n    }\n}\n\nfunction debugMapState() {\n\n    debugLog('text', '************ L O C A L ***************');\n    debugLog('text', 'Current map : ' + localStorage.currentMap);\n    debugLog('text', 'Olympus GUID : ' + localStorage.olympus);\n    debugLog('text', 'Styx GUID : ' + localStorage.styx);\n    debugLog('text', 'Elysium GUID : ' + localStorage.elysium);\n    debugLog('text', 'Outpost 1 GUID ' + localStorage.outpost1);\n    debugLog('text', 'Outpost 2 GUID ' + localStorage.outpost2);\n    debugLog('text', 'Outpost 3 GUID ' + localStorage.outpost3);\n    debugLog('text', '*********** S E S S I O N ************');\n    debugLog('text', 'Last update : ' + sessionStorage.lastUpdate);\n    debugLog('text', 'Current map state : ' + sessionStorage.lastMapState);\n    debugLog('text', 'Current map state : \\n' + JSON.stringify(getMapState(), null, 2));\n    debugLog('text', '*************************************');\n}\n\nfunction setMapRights() {\n    let mapState = getMapState();\n\n    // Disable map data management for both read-only maps and shared maps\n    if (mapState.rights == 'ro' || window.isViewingSharedMap) {\n        // Disable map selector\n        const mapSelector = document.getElementById('mapSelector');\n        if (mapSelector) mapSelector.disabled = true;\n\n        // Disable reset buttons (these modify map state)\n        const resetCaves = document.getElementById('resetCaves');\n        if (resetCaves) resetCaves.disabled = true;\n        const resetOreVeins = document.getElementById('resetOreVeins');\n        if (resetOreVeins) resetOreVeins.disabled = true;\n        const resetMarkers = document.getElementById('resetMarkers');\n        if (resetMarkers) resetMarkers.disabled = true;\n        const resetAll = document.getElementById('resetAll');\n        if (resetAll) resetAll.disabled = true;\n\n        // Disable import/export from file\n        const importFile = document.getElementById('importFile');\n        if (importFile) importFile.disabled = true;\n        const exportFile = document.getElementById('exportFile');\n        if (exportFile) exportFile.disabled = true;\n\n        // Mission selection and all filters are now allowed in read-only mode\n        // They're stored per-map in localStorage, not in the shared map state\n        const mission = document.getElementById('mission');\n        if (mission) mission.disabled = false;\n    }\n}\n\n/**\n * Reload all map icons from current state\n * Called after conflict resolution or manual reload\n */\nfunction reloadMapIcons() {\n    debugLog('saving', 'Reloading all map icons');\n    if (typeof updateGeysersState === 'function') {\n        updateGeysersState();\n    }\n    if (typeof updateCavesState === 'function') {\n        updateCavesState();\n    }\n    if (typeof updateOreDepositState === 'function') {\n        updateOreDepositState();\n    }\n    if (typeof updateMetaDepositState === 'function') {\n        updateMetaDepositState();\n    }\n    if (typeof loadCustomMarkers === 'function') {\n        // Clear existing custom markers first to ensure deletions and updates are reflected\n        if (typeof customMarkersClear === 'function') {\n            customMarkersClear();\n        }\n        const filterState = getFilterState();\n        loadCustomMarkers(filterState.markers);\n    }\n}\n\n/**\n * Setup reload map button\n * Checks if version is current, if not loads server state and reloads icons\n */\nlet lastReloadTime = 0;\nconst RELOAD_COOLDOWN = 10000; // 10 seconds cooldown\n\nfunction handleReloadMapClick(clickedBtn) {\n    // Check if button is disabled (unsaved changes)\n    const reloadBtn = document.getElementById('reloadMapButton');\n    const reloadBtnSidebarLi = document.getElementById('reloadMapButtonSidebar');\n    const reloadBtnSidebar = reloadBtnSidebarLi ? reloadBtnSidebarLi.querySelector('a') : null;\n\n    if ((reloadBtn && reloadBtn.classList.contains('disabled')) ||\n        (reloadBtnSidebar && reloadBtnSidebar.classList.contains('disabled'))) {\n        if (typeof NotificationSystem !== 'undefined') {\n            NotificationSystem.info('Cannot reload while there are unsaved changes', 3000);\n        }\n        return;\n    }\n\n    // Check cooldown\n    const now = Date.now();\n    if (now - lastReloadTime < RELOAD_COOLDOWN) {\n        const remainingTime = Math.ceil((RELOAD_COOLDOWN - (now - lastReloadTime)) / 1000);\n        if (typeof NotificationSystem !== 'undefined') {\n            NotificationSystem.info('Please wait ' + remainingTime + ' second' + (remainingTime > 1 ? 's' : '') + ' before reloading again', 2000);\n        }\n        return;\n    }\n    lastReloadTime = now;\n\n    const mapState = getMapState();\n    if (!mapState || !mapState.guid || mapState.guid === 'new') {\n        if (typeof NotificationSystem !== 'undefined') {\n            NotificationSystem.info('No saved map to reload', 3000);\n        }\n        return;\n    }\n\n    updateMapState('saving', 'Checking for updates...');\n\n    // Check version first\n    const currentVersion = mapState.version || 1;\n    const guid = mapState.guid;\n\n    fetch('map/save', {\n        method: 'POST',\n        headers: {\n            'Content-Type': 'application/x-www-form-urlencoded',\n        },\n        body: (typeof appendClientVersionToFormBody === 'function'\n            ? appendClientVersionToFormBody('checkVersion=true&guid=' + encodeURIComponent(guid) + '&version=' + currentVersion)\n            : 'checkVersion=true&guid=' + encodeURIComponent(guid) + '&version=' + currentVersion)\n    })\n        .then(response => {\n            if (response.status === 426) {\n                return response.json().then(payload => {\n                    if (typeof handleClientVersionMismatch === 'function') {\n                        handleClientVersionMismatch(payload);\n                    }\n                });\n            } else if (response.status === 409) {\n                // Version mismatch - load server state\n                return response.json().then(serverState => {\n                    if (typeof handleClientVersionMismatch === 'function' && handleClientVersionMismatch(serverState)) {\n                        return;\n                    }\n\n                    debugLog('saving', 'Server has newer version, reloading...', {\n                        localVersion: currentVersion,\n                        serverVersion: serverState.version\n                    });\n\n                    // Update local state with server state\n                    const cleanedData = cleanLoadedMapState(serverState);\n                    setMapState(cleanedData);\n\n                    // Update metadata: created date and last access\n                    updateSavedMapMetadata(cleanedData.guid, cleanedData.created, true);\n\n                    // Update UI\n                    updateMapState('loaded', 'Reloaded from server');\n                    setGuid(cleanedData.guid);\n\n                    // Reload all icons\n                    sessionStorage.lastUpdate = Date.now();\n                    updateMapToState(false);\n                    reloadMapIcons();\n\n                    // Clear change tracker since we just loaded server state\n                    if (typeof ChangeTracker !== 'undefined') {\n                        ChangeTracker.clear();\n                    }\n\n                    shareLink();\n\n                    if (typeof NotificationSystem !== 'undefined') {\n                        NotificationSystem.success('Map reloaded from server', 3000);\n                    }\n                });\n            } else if (response.status === 204) {\n                // Version matches - already up to date\n                updateMapState('loaded', 'Already up to date');\n                if (typeof NotificationSystem !== 'undefined') {\n                    NotificationSystem.info('Map is already up to date', 3000);\n                }\n            } else if (!response.ok) {\n                throw new Error(response.status + ' ' + response.statusText);\n            }\n        })\n        .catch(error => {\n            console.error('Reload error:', error);\n            updateMapState('error', 'Failed to reload');\n            if (typeof NotificationSystem !== 'undefined') {\n                NotificationSystem.error('Failed to reload map: ' + error.message, 5000);\n            }\n        });\n\n    return false;\n}\n\nfunction setupReloadButton() {\n    const reloadBtn = document.getElementById('reloadMapButton');\n    const reloadBtnSidebarLi = document.getElementById('reloadMapButtonSidebar');\n    const reloadBtnSidebar = reloadBtnSidebarLi ? reloadBtnSidebarLi.querySelector('a') : null;\n\n    if (reloadBtn) {\n        reloadBtn.onclick = function () {\n            return handleReloadMapClick(this);\n        };\n    }\n\n    if (reloadBtnSidebar) {\n        reloadBtnSidebar.onclick = function () {\n            return handleReloadMapClick(this);\n        };\n    }\n}\n\nfunction copyTextToClipboard(text) {\n    if (!text) {\n        return Promise.resolve(false);\n    }\n\n    if (typeof navigator !== 'undefined' && navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {\n        return navigator.clipboard.writeText(text).then(() => true).catch(() => false);\n    }\n\n    return new Promise(resolve => {\n        const textArea = document.createElement('textarea');\n        textArea.value = text;\n        textArea.setAttribute('readonly', '');\n        textArea.style.position = 'fixed';\n        textArea.style.left = '-9999px';\n        textArea.style.top = '0';\n        textArea.style.opacity = '0';\n\n        document.body.appendChild(textArea);\n        textArea.focus();\n        textArea.select();\n\n        let copied = false;\n        try {\n            copied = document.execCommand('copy');\n        } catch (error) {\n            copied = false;\n        }\n\n        document.body.removeChild(textArea);\n        resolve(copied);\n    });\n}\n\nfunction escapeHtml(text) {\n    return String(text)\n        .replace(/&/g, '&amp;')\n        .replace(/</g, '&lt;')\n        .replace(/>/g, '&gt;')\n        .replace(/\"/g, '&quot;')\n        .replace(/'/g, '&#39;');\n}\n\nfunction closeCustomConfirmDialogManually() {\n    const overlay = document.getElementById('customConfirmDialog');\n    const dialogEl = overlay ? overlay.querySelector('.custom-confirm-dialog') : null;\n    const messageEl = document.getElementById('customConfirmMessage');\n    const okBtn = document.getElementById('customConfirmOk');\n    const cancelBtn = document.getElementById('customConfirmCancel');\n    const closeBtn = document.getElementById('customConfirmClose');\n\n    if (overlay) {\n        overlay.style.display = 'none';\n        overlay.onclick = null;\n    }\n\n    if (okBtn) {\n        okBtn.onclick = null;\n        okBtn.className = 'popup-button';\n    }\n\n    if (cancelBtn) {\n        cancelBtn.onclick = null;\n        cancelBtn.className = 'popup-button';\n    }\n\n    if (closeBtn) {\n        closeBtn.onclick = null;\n    }\n\n    if (messageEl) {\n        messageEl.innerHTML = '';\n    }\n\n    if (dialogEl) {\n        dialogEl.classList.remove('custom-confirm-dialog--wide');\n    }\n}\n\nfunction showShareUrlInDialog(absoluteUrl, copied, linkLabel = 'Share') {\n    const overlay = document.getElementById('customConfirmDialog');\n    const titleEl = document.getElementById('customConfirmTitle');\n    const messageEl = document.getElementById('customConfirmMessage');\n    const okBtn = document.getElementById('customConfirmOk');\n    const cancelBtn = document.getElementById('customConfirmCancel');\n    const closeBtn = document.getElementById('customConfirmClose');\n    const escapedUrl = escapeHtml(absoluteUrl);\n    const statusText = copied\n        ? 'Link copied to clipboard. You can also use this URL:'\n        : 'Automatic copy failed. Please use this URL:';\n\n    if (!overlay || !titleEl || !messageEl || !okBtn || !cancelBtn) {\n        showCustomConfirm(\n            linkLabel + ' Link',\n            statusText + '<br><br><a href=\"' + escapedUrl + '\" target=\"_blank\" rel=\"noopener noreferrer\">' + escapedUrl + '</a>',\n            () => { },\n            true,\n            'OK'\n        );\n        return;\n    }\n\n    overlay.style.display = 'flex';\n    titleEl.textContent = linkLabel + ' Link';\n    messageEl.innerHTML = '<strong>' + statusText + '</strong><br><br><a href=\"' + escapedUrl + '\" target=\"_blank\" rel=\"noopener noreferrer\">' + escapedUrl + '</a>';\n\n    okBtn.textContent = 'Copy Again';\n    cancelBtn.textContent = 'Close';\n    cancelBtn.style.display = 'inline-block';\n    okBtn.className = 'popup-button success';\n    cancelBtn.className = 'popup-button';\n\n    okBtn.onclick = () => {\n        copySharedUrlWithFeedback(absoluteUrl, { keepDialogOpen: true, linkLabel: linkLabel });\n    };\n\n    cancelBtn.onclick = closeCustomConfirmDialogManually;\n    if (closeBtn) {\n        closeBtn.onclick = closeCustomConfirmDialogManually;\n    }\n\n    overlay.onclick = (e) => {\n        if (e.target === overlay) {\n            closeCustomConfirmDialogManually();\n        }\n    };\n}\n\nfunction showShareCopyFallbackDialog(absoluteUrl) {\n    const escapedUrl = escapeHtml(absoluteUrl);\n\n    showCustomConfirm(\n        \"Copy Link Failed\",\n        \"Couldn't copy the share link automatically.<br><br>Use this link:<br><a href=\\\"\" + escapedUrl + \"\\\" target=\\\"_blank\\\" rel=\\\"noopener noreferrer\\\">\" + escapedUrl + \"</a>\",\n        () => {\n            window.location.href = absoluteUrl;\n        },\n        false,\n        \"Open Link\",\n        \"Close\"\n    );\n}\n\nfunction copySharedUrlWithFeedback(url, options = {}) {\n    const keepDialogOpen = !!(options && options.keepDialogOpen);\n    const linkLabel = options && options.linkLabel ? options.linkLabel : 'Share';\n    const absoluteUrl = new URL(url, window.location.origin).href;\n\n    copyTextToClipboard(absoluteUrl)\n        .then((copied) => {\n            if (copied) {\n                if (typeof NotificationSystem !== 'undefined') {\n                    NotificationSystem.success('Share link copied: ' + absoluteUrl, 3500);\n                } else {\n                    showCustomConfirm(\n                        \"Share Link Copied\",\n                        \"The share link has been copied to your clipboard.\",\n                        () => { },\n                        true,\n                        \"OK\"\n                    );\n                }\n\n                if (keepDialogOpen) {\n                    showShareUrlInDialog(absoluteUrl, true, linkLabel);\n                }\n                return;\n            }\n\n            if (keepDialogOpen) {\n                if (typeof NotificationSystem !== 'undefined') {\n                    NotificationSystem.warning('Could not copy automatically. Use the link in the dialog.', 4500);\n                }\n                showShareUrlInDialog(absoluteUrl, false, linkLabel);\n                return;\n            }\n\n            showShareCopyFallbackDialog(absoluteUrl);\n        })\n        .catch(() => {\n            if (keepDialogOpen) {\n                if (typeof NotificationSystem !== 'undefined') {\n                    NotificationSystem.warning('Could not copy automatically. Use the link in the dialog.', 4500);\n                }\n                showShareUrlInDialog(absoluteUrl, false, linkLabel);\n                return;\n            }\n\n            showShareCopyFallbackDialog(absoluteUrl);\n        });\n}\n\nfunction shareLink() {\n    const shareLinkEl = document.getElementById('shareLink');\n    const reloadBtn = document.getElementById('reloadMapButton');\n    const reloadBtnSidebarLi = document.getElementById('reloadMapButtonSidebar');\n    const mapState = getMapState();\n    const hasUID = mapState.guid && mapState.guid !== 'new';\n\n    if (shareLinkEl) {\n        if (mapState.rights === 'ro') {\n            // Read-only map: hide share link but show reload button if map has UID\n            shareLinkEl.style.display = 'none';\n            if (reloadBtn) {\n                reloadBtn.style.display = hasUID ? 'flex' : 'none';\n            }\n            if (reloadBtnSidebarLi) {\n                reloadBtnSidebarLi.style.display = hasUID ? 'flex' : 'none';\n            }\n            return;\n        }\n        if (hasUID) {\n            shareLinkEl.onclick = function () {\n                const guidro = mapState.guidro;\n                if (guidro) {\n                    showCustomConfirm(\n                        \"Share Map\",\n                        \"Choose how to share your map.\",\n                        () => { },\n                        false,\n                        \"Read-Only\",\n                        \"Editable\",\n                        \"<strong>Share map with edit access?</strong><br><br>Anyone with this link can edit your map.<br>This feature is <strong>experimental</strong> and may still have issues.<br><ul><li>Changes from multiple users are automatically merged when saving. Combined state will show after saving.</li><li>If the same item (cave, ore, marker,...) is edited by multiple users, the <strong>most recent save wins.</strong></li><li>Users with this link can <strong>modify or delete</strong> your map.</li></ul>Share editable links <strong>only with people you trust</strong>.<br>You can create a backup using <strong>Export to file in the Settings tab.</strong>\",\n                        \"success\",\n                        \"danger\"\n                    );\n\n                    const okBtn = document.getElementById('customConfirmOk');\n                    const cancelBtn = document.getElementById('customConfirmCancel');\n\n                    if (okBtn) {\n                        okBtn.onclick = () => {\n                            const url = '/?m=' + guidro;\n                            copySharedUrlWithFeedback(url, { keepDialogOpen: true, linkLabel: 'Read-Only' });\n                        };\n                    }\n\n                    if (cancelBtn) {\n                        cancelBtn.onclick = () => {\n                            const url = '/?m=' + mapState.guid;\n                            copySharedUrlWithFeedback(url, { keepDialogOpen: true, linkLabel: 'Editable' });\n                        };\n                    }\n                } else {\n                    const url = '/?m=' + mapState.guid;\n                    copySharedUrlWithFeedback(url);\n                }\n                return false;\n            };\n            shareLinkEl.style.display = 'flex';\n            if (reloadBtn) reloadBtn.style.display = 'flex';\n            if (reloadBtnSidebarLi) reloadBtnSidebarLi.style.display = 'flex';\n        } else {\n            // New map without UID: hide both buttons\n            shareLinkEl.style.display = 'none';\n            if (reloadBtn) reloadBtn.style.display = 'none';\n            if (reloadBtnSidebarLi) reloadBtnSidebarLi.style.display = 'none';\n        }\n    }\n}\n\nfunction saveBeforeMapSwitch(previousMap) {\n    if (typeof isSiteUpdateBlocked === 'function' && isSiteUpdateBlocked()) {\n        return Promise.resolve();\n    }\n\n    const mapState = getMapState();\n    if (mapState && mapState.change === \"new\") {\n        // Use the passed previousMap parameter, or fall back to current if not provided\n        const mapToSave = previousMap || localStorage.currentMap || 'olympus';\n        cancelAutoSave();\n        debugLog('saving', 'Saving map before switch:', { map: mapToSave, guid: getGuid() });\n        updateMapState('saving', 'Saving before map switch...');\n\n        // Synchronous save\n        const xhr = new XMLHttpRequest();\n        xhr.open('POST', 'map/save', false);\n        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');\n        const saveBody = 'state=' + encodeURIComponent(JSON.stringify(mapState));\n        xhr.send(typeof appendClientVersionToFormBody === 'function' ? appendClientVersionToFormBody(saveBody) : saveBody);\n\n        if (xhr.status === 200) {\n            const data = JSON.parse(xhr.responseText);\n            debugLog('saving', 'Map saved before switch:', { guid: data.guid, rights: data.rights, map: mapToSave });\n            if (data.rights == 'rw') {\n                updateMapState('saved');\n                setGuid(data.guid);\n            } else {\n                updateMapState('loaded', 'Map is read-only');\n            }\n            // Clean any old filter data from loaded state\n            const cleanedData = cleanLoadedMapState(data);\n            setMapState(cleanedData);\n\n            // Update metadata: created date from save\n            updateSavedMapMetadata(cleanedData.guid, cleanedData.created, false);\n        } else if (xhr.status === 426 || xhr.status === 409) {\n            let payload = null;\n            try {\n                payload = JSON.parse(xhr.responseText || '{}');\n            } catch (e) {\n                payload = null;\n            }\n\n            if (typeof handleClientVersionMismatch === 'function' && handleClientVersionMismatch(payload)) {\n                return Promise.resolve();\n            }\n        } else {\n            updateMapState('error', 'Error saving changes');\n            console.error('Save error:', xhr.statusText);\n        }\n    }\n    return Promise.resolve();\n}\n\nfunction showRONotification() {\n    if (getMapState().rights == 'ro') {\n        if (!sessionStorage.sicreadonly) {\n            sessionStorage.sicreadonly = true;\n\n            notificationControl.info('Map is Read Only', 'This shared map is read-only.<br\\><br\\>You can use filters, but you cannot modify the map.', {\n                timeout: 30000,\n                closable: true,\n                dismissable: true,\n                icon: 'info',\n                className: 'important-info',\n            });\n        }\n    }\n}\n\n//this prevents ppl from closing their browser and losing changes not saved to database.\nwindow.addEventListener('beforeunload', function (e) {\n    if (typeof window !== 'undefined' && window.__suppressBeforeUnloadPrompt) {\n        return;\n    }\n\n    let mapState = getMapState();\n\n    if (mapState.change == \"new\") { //Map has still pending saved changes.\n        e.preventDefault();\n        e.returnValue = '';\n    }\n})\n\n/**\n * Two-stage save with conflict resolution\n * @param {object} stateToSave - The state to save\n * @param {number} retryCount - Current retry attempt (0-3)\n * @param {boolean} forceOverwrite - Force overwrite without version check\n */\nfunction saveToDatabase(stateToSave, retryCount = 0, forceOverwrite = false) {\n    const MAX_RETRIES = 3;\n\n    debugLog('saving', '[Save] Starting save attempt', {\n        retryCount,\n        forceOverwrite,\n        version: stateToSave.version,\n        hasChanges: typeof ChangeTracker !== 'undefined' ? ChangeTracker.hasChanges() : 'undefined',\n        changesSummary: typeof ChangeTracker !== 'undefined' ? ChangeTracker.getChangesSummary() : null\n    });\n\n    if (retryCount > MAX_RETRIES) {\n        // After max retries, give user a choice\n        updateMapState('error', 'Failed to save after ' + MAX_RETRIES + ' attempts');\n        if (typeof NotificationSystem !== 'undefined') {\n            NotificationSystem.showConflictChoice(\n                'Failed to save changes after multiple concurrent edits.',\n                () => {\n                    // Force save - overwrite server state\n                    saveToDatabase(stateToSave, 0, true);\n                },\n                () => {\n                    // Refresh page\n                    location.reload();\n                }\n            );\n        }\n        return;\n    }\n\n    // If forcing overwrite, skip version check\n    if (forceOverwrite) {\n        performSave(stateToSave, null, true);\n        return;\n    }\n\n    const guid = stateToSave.guid;\n    const currentVersion = stateToSave.version || 1;\n\n    // For new maps, skip version check and save directly (no need for 2-step save)\n    if (guid === 'new') {\n        performSave(stateToSave, null, false);\n        return;\n    }\n\n    // Step 1: Check version first without sending full state\n    fetch('map/save', {\n        method: 'POST',\n        headers: {\n            'Content-Type': 'application/x-www-form-urlencoded',\n        },\n        body: (typeof appendClientVersionToFormBody === 'function'\n            ? appendClientVersionToFormBody('checkVersion=true&guid=' + encodeURIComponent(guid) + '&version=' + currentVersion)\n            : 'checkVersion=true&guid=' + encodeURIComponent(guid) + '&version=' + currentVersion)\n    })\n        .then(response => {\n            if (response.status === 426) {\n                return response.json().then(payload => {\n                    if (typeof handleClientVersionMismatch === 'function') {\n                        handleClientVersionMismatch(payload);\n                    }\n                });\n            } else if (response.status === 409) {\n                // Version conflict - server returned current state\n                return response.json().then(serverState => {\n                    if (typeof handleClientVersionMismatch === 'function' && handleClientVersionMismatch(serverState)) {\n                        return;\n                    }\n                    handleVersionConflict(stateToSave, serverState, retryCount);\n                });\n            } else if (response.status === 204) {\n                // Version matches (204 No Content), proceed with full save\n                performSave(stateToSave, currentVersion, false);\n            } else if (response.ok) {\n                // Other success response\n                performSave(stateToSave, currentVersion, false);\n            } else {\n                throw new Error(response.status + ' ' + response.statusText);\n            }\n        })\n        .catch(error => {\n            console.error('Version check error:', error);\n            updateMapState('error', 'Failed to check version');\n            if (typeof NotificationSystem !== 'undefined') {\n                NotificationSystem.error('Connection error. Changes not saved.', 5000);\n            }\n        });\n}\n/**\n * Handle version conflict by merging local changes with server state\n * @param {object} localState - Local state with changes\n * @param {object} serverState - Current server state\n * @param {number} retryCount - Current retry attempt\n */\nfunction handleVersionConflict(localState, serverState, retryCount) {\n    debugLog('base', 'Version conflict detected. Merging changes...', {\n        localVersion: localState.version,\n        serverVersion: serverState.version,\n        retryCount: retryCount\n    });\n\n    // Check if we have tracked changes\n    const hasChanges = typeof ChangeTracker !== 'undefined' && ChangeTracker.hasChanges();\n    const changesSummary = typeof ChangeTracker !== 'undefined' ? ChangeTracker.getChangesSummary() : null;\n\n    debugLog('saving', 'Change tracker status:', {\n        trackerDefined: typeof ChangeTracker !== 'undefined',\n        hasChanges: hasChanges,\n        changes: changesSummary\n    });\n\n    if (!hasChanges) {\n        // No changes tracked, accept server state as-is\n        debugLog('saving', 'No tracked changes found, accepting server state');\n\n        // Update local state with server state\n        const cleanedData = cleanLoadedMapState(serverState);\n        setMapState(cleanedData);\n\n        // Update metadata: created date and last access (conflict resolution loads from server)\n        updateSavedMapMetadata(cleanedData.guid, cleanedData.created, true);\n\n        // Update UI to show loaded state\n        updateMapState('saved');\n        setGuid(cleanedData.guid);\n\n        // Refresh all map icons to reflect server state\n        sessionStorage.lastUpdate = Date.now();\n        updateMapToState(false);\n\n        if (typeof reloadMapIcons === 'function') {\n            reloadMapIcons();\n        }\n\n        shareLink();\n        return;\n    }\n\n    // Apply our tracked changes to the server state\n    const mergedState = ChangeTracker.applyChangesToState(serverState);\n\n    // Show notification about merge\n    if (typeof NotificationSystem !== 'undefined') {\n        const summary = ChangeTracker.getChangesSummary();\n        const totalChanges = summary.caves + summary.deposits + summary.exotics +\n            summary.markersAdded + summary.markersRemoved;\n        NotificationSystem.changesMerged(totalChanges);\n    }\n\n    // Immediately save merged state without version check (we just got the latest state)\n    debugLog('saving', 'Saving merged state immediately (attempt ' + (retryCount + 1) + ')');\n    updateMapState('saving', 'Saving merged changes...');\n\n    // Clean and save directly\n    const cleanedMergedState = cleanLoadedMapState(mergedState);\n    const mergedVersion = cleanedMergedState.version || 1;\n\n    // Update local state with merged state BEFORE saving\n    // This ensures reloadMapIcons() will use the correct merged data\n    setMapState(cleanedMergedState);\n\n    // Update metadata with created date from merged state\n    updateSavedMapMetadata(cleanedMergedState.guid, cleanedMergedState.created, false);\n    debugLog('saving', 'Updated local state with merged data:', {\n        version: cleanedMergedState.version,\n        caves: cleanedMergedState.cave_status?.length,\n        deposits: cleanedMergedState.deposit_status?.length,\n        exotics: cleanedMergedState.exotics_status?.length,\n        markers: cleanedMergedState.custom_marker?.length\n    });\n\n    // Check if we've exceeded retry limit before attempting save\n    if (retryCount >= 3) {\n        // Max retries reached, give user choice\n        updateMapState('error', 'Failed to save after multiple merge attempts');\n        if (typeof NotificationSystem !== 'undefined') {\n            NotificationSystem.showConflictChoice(\n                'Failed to save changes after multiple concurrent edits.',\n                () => {\n                    // Force save - overwrite server state\n                    performSave(cleanedMergedState, null, true);\n                },\n                () => {\n                    // Refresh page\n                    location.reload();\n                }\n            );\n        }\n        return;\n    }\n\n    // Perform save directly with merged state\n    performSaveWithConflictRetry(cleanedMergedState, mergedVersion, retryCount + 1);\n}\n\n/**\n * Perform the actual save operation\n * @param {object} stateToSave - State to save\n * @param {number|null} version - Expected version (null to skip check)\n * @param {boolean} skipVersionCheck - Skip version check on server (for force save)\n */\nfunction performSave(stateToSave, version, skipVersionCheck = false) {\n    // Add version to state if provided\n    if (version !== null && !skipVersionCheck) {\n        stateToSave.version = version;\n    }\n\n    fetch('map/save', {\n        method: 'POST',\n        headers: {\n            'Content-Type': 'application/x-www-form-urlencoded',\n        },\n        body: (typeof appendClientVersionToFormBody === 'function'\n            ? appendClientVersionToFormBody('state=' + encodeURIComponent(JSON.stringify(stateToSave)))\n            : 'state=' + encodeURIComponent(JSON.stringify(stateToSave)))\n    })\n        .then(response => {\n            if (response.status === 426) {\n                return response.json().then(payload => {\n                    if (typeof handleClientVersionMismatch === 'function') {\n                        handleClientVersionMismatch(payload);\n                    }\n                });\n            }\n\n            if (response.status === 409 && !skipVersionCheck) {\n                // Conflict during save - server state changed between check and save (race condition)\n                return response.json().then(serverState => {\n                    if (typeof handleClientVersionMismatch === 'function' && handleClientVersionMismatch(serverState)) {\n                        return;\n                    }\n                    // Recursive conflict resolution\n                    handleVersionConflict(stateToSave, serverState, 0);\n                });\n            } else if (!response.ok) {\n                throw new Error(response.status + ' ' + response.statusText);\n            }\n            return response.json();\n        })\n        .then(data => {\n            if (data) {\n                handleSuccessfulSave(data);\n            }\n        })\n        .catch(error => {\n            updateMapState('error', 'Invalid map ID, using default');\n            if (error.message.includes('Not Found') || error.message.includes('404')) {\n                lastErrorFound = 'Loaded map could not be found. Loading default map.';\n                const params = new URLSearchParams(window.location.search);\n                if (params.get('m')) {\n                    alert(lastErrorFound);\n                    let myUrl = 'http://' + window.location.hostname;\n                    if (window.location.port && window.location.port != '80' && window.location.port != '443') {\n                        myUrl += ':' + window.location.port;\n                    }\n                    window.location.replace(myUrl);\n                }\n                updateMapState('error', lastErrorFound);\n                clearMapStateSession();\n                setGuid(undefined);\n                lastErrorFound = undefined;\n            } else {\n                lastErrorFound = 'Could not save map. Halting updates.';\n                updateMapState('error', lastErrorFound);\n                return;\n            }\n        });\n}\n\n/**\n * Perform save with conflict retry handling (for merged states)\n * @param {object} stateToSave - State to save\n * @param {number} version - Expected version\n * @param {number} retryCount - Current retry count\n */\nfunction performSaveWithConflictRetry(stateToSave, version, retryCount) {\n    // Add version to state\n    stateToSave.version = version;\n\n    fetch('map/save', {\n        method: 'POST',\n        headers: {\n            'Content-Type': 'application/x-www-form-urlencoded',\n        },\n        body: (typeof appendClientVersionToFormBody === 'function'\n            ? appendClientVersionToFormBody('state=' + encodeURIComponent(JSON.stringify(stateToSave)))\n            : 'state=' + encodeURIComponent(JSON.stringify(stateToSave)))\n    })\n        .then(response => {\n            if (response.status === 426) {\n                return response.json().then(payload => {\n                    if (typeof handleClientVersionMismatch === 'function') {\n                        handleClientVersionMismatch(payload);\n                    }\n                });\n            } else if (response.status === 409) {\n                // Another conflict occurred during save - merge again\n                return response.json().then(serverState => {\n                    if (typeof handleClientVersionMismatch === 'function' && handleClientVersionMismatch(serverState)) {\n                        return;\n                    }\n                    handleVersionConflict(stateToSave, serverState, retryCount);\n                });\n            } else if (!response.ok) {\n                throw new Error(response.status + ' ' + response.statusText);\n            }\n            return response.json();\n        })\n        .then(data => {\n            if (data) {\n                handleSuccessfulSave(data, true); // true = was conflict resolution\n            }\n        })\n        .catch(error => {\n            updateMapState('error', 'Save failed');\n            console.error('Save error:', error);\n            if (typeof NotificationSystem !== 'undefined') {\n                NotificationSystem.error('Failed to save changes: ' + error.message, 5000);\n            }\n        });\n}\n\n/**\n * Handle successful save - update local state and clear change tracker\n * @param {object} data - Response data from server (minimal: guid, guidro, rights, version, updated)\n * @param {boolean} wasConflictResolution - Whether this save was after resolving a 409 conflict\n */\nfunction handleSuccessfulSave(data, wasConflictResolution = false) {\n    const currentMap = localStorage.currentMap || 'olympus';\n    debugLog('base', 'Map saved successfully to DB:', {\n        guid: data.guid,\n        rights: data.rights,\n        version: data.version,\n        map: currentMap,\n        wasConflictResolution: wasConflictResolution\n    });\n\n    // Check if this was a new map being saved for the first time\n    let mapState = getMapState();\n    const wasNewMap = !mapState.guid || mapState.guid === 'new';\n\n    if (data.rights == 'rw') {\n        updateMapState('saved');\n        setGuid(data.guid);\n    } else {\n        updateMapState('loaded', 'Map is read-only');\n    }\n\n    // Update local state with new version and metadata\n    mapState.guid = data.guid;\n    mapState.guidro = data.guidro;\n    mapState.rights = data.rights;\n    mapState.version = data.version;\n    mapState.change = data.updated;\n\n    // Store created date if available from server\n    if (data.created) {\n        mapState.created = data.created;\n    }\n\n    setMapState(mapState);\n\n    // Update metadata: created date from server response\n    updateSavedMapMetadata(data.guid, data.created, false);\n\n    // Update the current map name display in UI\n    if (typeof updateCurrentMapNameDisplay !== 'undefined') {\n        setTimeout(updateCurrentMapNameDisplay, 100);\n    }\n\n    debugLog('saving', mapState);\n\n    // Clear change tracker on successful save\n    if (typeof ChangeTracker !== 'undefined') {\n        debugLog('saving', 'Clearing change tracker after successful save');\n        ChangeTracker.clear();\n    }\n\n    // Update timestamp and UI\n    sessionStorage.lastUpdate = Date.now();\n    updateMapToState(false);\n\n    // Refresh all map icons ONLY if this was after conflict resolution (409)\n    // Normal saves don't need icon reload since local state is already correct\n    if (wasConflictResolution) {\n        debugLog('saving', 'Reloading icons after conflict resolution');\n        reloadMapIcons();\n    }\n\n    shareLink();\n\n    // Notify user if this was a new map being saved for the first time\n    if (wasNewMap && data.guid && data.guid !== 'new') {\n        if (typeof NotificationSystem !== 'undefined') {\n            NotificationSystem.success('Map saved! You can now use the share button to share your map with others.', 6000);\n        }\n    }\n}\n"
          },
