          "content": {
            "size": 86995,
            "mimeType": "text/javascript",
            "text": "function showCustomConfirm(title, message, onConfirm, hideCancel = false, okText = \"OK\", cancelText = \"Cancel\", note = null, okClass = \"\", cancelClass = \"\") {\n    const overlay = document.getElementById('customConfirmDialog');\n    const dialogEl = overlay ? overlay.querySelector('.custom-confirm-dialog') : null;\n    const titleEl = document.getElementById('customConfirmTitle');\n    const messageEl = document.getElementById('customConfirmMessage');\n    const okBtn = document.getElementById('customConfirmOk');\n    const cancelBtn = document.getElementById('customConfirmCancel');\n    const closeBtn = document.getElementById('customConfirmClose');\n\n    if (dialogEl) {\n        dialogEl.classList.remove('custom-confirm-dialog--wide');\n    }\n\n    titleEl.textContent = title;\n    // Use innerHTML if message contains HTML tags, otherwise use textContent\n    if (message.includes('<')) {\n        messageEl.innerHTML = message;\n    } else {\n        messageEl.textContent = message;\n    }\n\n    // Add note if provided\n    if (note) {\n        const noteEl = document.createElement('div');\n        noteEl.className = 'custom-confirm-note';\n        noteEl.innerHTML = note;\n        messageEl.appendChild(noteEl);\n    }\n\n    // Hide cancel button if requested (for info-only dialogs)\n    cancelBtn.style.display = hideCancel ? 'none' : 'inline-block';\n\n    // Set button texts\n    okBtn.textContent = okText;\n    cancelBtn.textContent = cancelText;\n\n    // Reset button classes to base\n    okBtn.className = 'popup-button';\n    cancelBtn.className = 'popup-button';\n\n    // Apply button classes\n    if (okClass) okBtn.classList.add(okClass);\n    if (cancelClass) cancelBtn.classList.add(cancelClass);\n\n    overlay.style.display = 'flex';\n\n    const cleanup = () => {\n        overlay.style.display = 'none';\n        okBtn.onclick = null;\n        cancelBtn.onclick = null;\n        if (closeBtn) {\n            closeBtn.onclick = null;\n        }\n        if (dialogEl) {\n            dialogEl.classList.remove('custom-confirm-dialog--wide');\n        }\n        // Clear message content to remove note\n        messageEl.innerHTML = '';\n        // Reset button classes to base\n        okBtn.className = 'popup-button';\n        cancelBtn.className = 'popup-button';\n    };\n\n    okBtn.onclick = () => {\n        cleanup();\n        onConfirm();\n    };\n\n    cancelBtn.onclick = cleanup;\n    if (closeBtn) {\n        closeBtn.onclick = cleanup;\n    }\n\n    overlay.onclick = (e) => {\n        if (e.target === overlay) {\n            cleanup();\n        }\n    };\n}\n\n/**\n * Show a custom prompt dialog with text input\n * @param {string} title - Dialog title\n * @param {string} message - Dialog message\n * @param {function} onConfirm - Callback with input value (null if cancelled)\n * @param {string} defaultValue - Default input value\n * @param {string} placeholder - Input placeholder text\n * @param {string} okText - OK button text\n * @param {string} cancelText - Cancel button text\n * @param {Object} options - Optional dialog settings ({ wide: boolean })\n */\nfunction showCustomPrompt(title, message, onConfirm, defaultValue = '', placeholder = '', okText = \"OK\", cancelText = \"Cancel\", options = {}) {\n    const overlay = document.getElementById('customConfirmDialog');\n    const dialogEl = overlay ? overlay.querySelector('.custom-confirm-dialog') : null;\n    const titleEl = document.getElementById('customConfirmTitle');\n    const messageEl = document.getElementById('customConfirmMessage');\n    const okBtn = document.getElementById('customConfirmOk');\n    const cancelBtn = document.getElementById('customConfirmCancel');\n    const closeBtn = document.getElementById('customConfirmClose');\n\n    const useWideDialog = !!(options && options.wide);\n    if (dialogEl) {\n        dialogEl.classList.toggle('custom-confirm-dialog--wide', useWideDialog);\n    }\n\n    titleEl.textContent = title;\n\n    // Create input field\n    const inputWrapper = document.createElement('div');\n    inputWrapper.style.marginTop = '16px';\n\n    const input = document.createElement('input');\n    input.type = 'text';\n    input.value = defaultValue;\n    input.placeholder = placeholder;\n    input.maxLength = 30;\n    input.style.width = '100%';\n    input.style.padding = '8px 12px';\n    input.style.border = '1px solid #d0d0d0';\n    input.style.borderRadius = '4px';\n    input.style.fontSize = '14px';\n    input.style.boxSizing = 'border-box';\n\n    inputWrapper.appendChild(input);\n\n    // Set message and append input\n    if (typeof message === 'string' && message.includes('<')) {\n        messageEl.innerHTML = message;\n    } else {\n        messageEl.textContent = message;\n    }\n    messageEl.appendChild(inputWrapper);\n\n    // Show cancel button\n    cancelBtn.style.display = 'inline-block';\n\n    // Set button texts\n    okBtn.textContent = okText;\n    cancelBtn.textContent = cancelText;\n\n    // Reset button classes\n    okBtn.className = 'popup-button primary';\n    cancelBtn.className = 'popup-button';\n\n    overlay.style.display = 'flex';\n\n    // Focus input after a short delay\n    setTimeout(() => input.focus(), 100);\n\n    const cleanup = () => {\n        overlay.style.display = 'none';\n        okBtn.onclick = null;\n        cancelBtn.onclick = null;\n        if (closeBtn) {\n            closeBtn.onclick = null;\n        }\n        input.onkeydown = null;\n        messageEl.innerHTML = '';\n        if (dialogEl) {\n            dialogEl.classList.remove('custom-confirm-dialog--wide');\n        }\n        okBtn.className = 'popup-button';\n        cancelBtn.className = 'popup-button';\n    };\n\n    const handleConfirm = () => {\n        const value = input.value.trim();\n        cleanup();\n        onConfirm(value);\n    };\n\n    okBtn.onclick = handleConfirm;\n    cancelBtn.onclick = () => {\n        cleanup();\n        onConfirm(null);\n    };\n    if (closeBtn) {\n        closeBtn.onclick = () => {\n            cleanup();\n            onConfirm(null);\n        };\n    }\n\n    // Handle Enter key\n    input.onkeydown = (e) => {\n        if (e.key === 'Enter') {\n            e.preventDefault();\n            handleConfirm();\n        } else if (e.key === 'Escape') {\n            e.preventDefault();\n            cleanup();\n            onConfirm(null);\n        }\n    };\n\n    overlay.onclick = (e) => {\n        if (e.target === overlay) {\n            cleanup();\n            onConfirm(null);\n        }\n    };\n}\n\nfunction getMapDisplayNameFromCode(mapCode) {\n    if (!mapCode) return 'Unknown Map';\n\n    const mapSelector = document.getElementById('mapSelector');\n    if (mapSelector && mapSelector.options) {\n        for (let i = 0; i < mapSelector.options.length; i++) {\n            const option = mapSelector.options[i];\n            if (option.value === mapCode) {\n                return option.textContent || mapCode;\n            }\n        }\n    }\n\n    return mapCode;\n}\n\nfunction resetFiltersToDefault() {\n    showCustomConfirm(\n        \"Reset Filters\",\n        \"Are you sure you want to reset all filters to default settings? This will reset visibility, ore filters, and cave filters.\",\n        () => {\n            // Get default filter state\n            const defaultState = getDefaultFilterState();\n\n            // Override defaults: grid, caves, and markers ON by default\n            defaultState.grid = true;\n            defaultState.caves.all = true;\n            defaultState.enzymeGeysers = false;\n            defaultState.oilGeysers = false;\n            defaultState.markers = true;\n            defaultState.metaDeposits = false;\n            defaultState.deepOreDeposits = false;\n            defaultState.selectedMission = '0';  // Clear mission selection\n\n            // Clear saved map view so map resets to default zoom\n            defaultState.mapView = {\n                zoom: null,\n                center: null\n            };\n\n            // Save to localStorage\n            setFilterState(defaultState);\n\n            // Clear mission selection in dropdown\n            const missionDropdown = document.getElementById('mission');\n            if (missionDropdown) {\n                missionDropdown.value = '0';\n            }\n\n            // Hide mission div\n            const missDiv = document.getElementById('miss');\n            if (missDiv) {\n                missDiv.style.display = 'none';\n            }\n\n            // Clear mission from map\n            if (typeof clearProspect === 'function') {\n                clearProspect();\n            }\n\n            // Reset map view to default (zoomed out, centered)\n            if (typeof map !== 'undefined') {\n                // Temporarily disable saving while we reset the view\n                if (typeof shouldSaveMapView !== 'undefined') {\n                    shouldSaveMapView = false;\n                }\n                // Reset to default zoom level and center at 0,0\n                const defaultZoom = 2; // Zoomed out view\n                map.setView([0, 0], defaultZoom);\n\n                map.fitBounds(TILE_BOUNDS, {\n                    animate: true,\n                    padding: [0, 0]\n                });\n\n                // Re-enable saving after a short delay\n                setTimeout(() => {\n                    if (typeof shouldSaveMapView !== 'undefined') {\n                        shouldSaveMapView = true;\n                    }\n                }, 200);\n            }\n\n            // Update UI to reflect changes\n            updateMapToState(false);\n\n            notificationControl.success(\"Filters reset\", \"All filters have been reset to default settings.\");\n        },\n        false,\n        \"Reset\",\n        \"Cancel\",\n        null,\n        \"danger\"\n    );\n}\n\nfunction resetAllMapData() {\n    let mapState = getMapState();\n    const hasData = mapState.cave_status?.length > 0 ||\n        mapState.deposit_status?.length > 0 ||\n        mapState.exotics_status?.length > 0 ||\n        mapState.custom_marker?.length > 0;\n\n    if (!hasData) {\n        notificationControl.info(\"Nothing to reset\", \"No map data to reset.\");\n        return;\n    }\n\n    showCustomConfirm(\n        \"Reset All Map Data\",\n        \"Are you sure you want to reset ALL map data for the current map? This will clear all caves, ore veins, exotics, and custom markers on this map only. This action cannot be undone!\",\n        () => {\n            mapState.cave_status = [];\n            mapState.deposit_status = [];\n            mapState.exotics_status = [];\n            mapState.custom_marker = [];\n            mapState.change = \"new\";\n            setMapState(mapState);\n\n            // Clear custom markers from map\n            if (typeof customMarkersClear !== 'undefined') {\n                customMarkersClear();\n            }\n\n            // Reload layers from cache instead of fetching from server\n            if (typeof cachedCavesData !== 'undefined' && cachedCavesData[selectedMapParent]) {\n                const isCavesVisible = filterGetState(filterCaves);\n                toggleCavesLayer(false, true); // isProgrammatic=true during reset\n                setCavesData(selectedMapParent, cachedCavesData[selectedMapParent], isCavesVisible);\n            }\n\n            if (typeof cachedOresData !== 'undefined' && cachedOresData[selectedMapParent]) {\n                const isOresVisible = filterGetState(filterOreDeposits);\n                toggleOreDepositLayer(false, true); // isProgrammatic=true during reset\n                setOreDepositsData(selectedMapParent, cachedOresData[selectedMapParent], isOresVisible);\n            }\n\n            // Update exotics to reflect cleared state\n            if (typeof updateMetaDepositState === 'function') {\n                updateMetaDepositState();\n            }\n\n            notificationControl.success(\"All map data reset\", \"Caves, ore veins, exotics, and custom markers have been cleared.\");\n        },\n        false,\n        \"Reset All\",\n        \"Cancel\",\n        null,\n        \"danger\"\n    );\n}\n\nfunction deleteAllCustomMarkers() {\n    let mapState = getMapState();\n\n    if (mapState.custom_marker.length === 0) {\n        notificationControl.info(\"Nothing to delete\", \"No custom markers to delete.\");\n        return;\n    }\n\n    showCustomConfirm(\n        \"Delete All Custom Markers\",\n        \"Are you sure you want to delete all custom markers on the current map? This action cannot be undone.\",\n        () => {\n            mapState.custom_marker = [];\n            mapState.change = \"new\"\n            setMapState(mapState);\n\n            if (typeof customMarkersClear !== 'undefined') {\n                customMarkersClear();\n            }\n\n            notificationControl.success(\"Custom markers deleted\", \"\");\n        },\n        false,\n        \"Delete Markers\",\n        \"Cancel\",\n        null,\n        \"danger\"\n    );\n}\n\nfunction restoreCavesStates() {\n    let mapState = getMapState();\n\n    if (mapState.cave_status.length > 0) {\n        showCustomConfirm(\n            \"Reset Caves\",\n            \"Are you sure you want to reset all caves state on the current map? This will mark all caves as unexplored on this map only.\",\n            () => {\n                mapState.cave_status = [];\n                mapState.change = \"new\"\n                setMapState(mapState);\n\n                // Reload caves from cache instead of fetching from server\n                if (typeof toggleCavesLayer !== 'undefined' && typeof cachedCavesData !== 'undefined') {\n                    const isVisible = filterGetState(filterCaves);\n                    toggleCavesLayer(false, true); // isProgrammatic=true during reset\n                    if (cachedCavesData[selectedMapParent]) {\n                        setCavesData(selectedMapParent, cachedCavesData[selectedMapParent], isVisible);\n                    }\n                }\n\n                notificationControl.success(\"Caves restored\", ``);\n            },\n            false,\n            \"Reset Caves\",\n            \"Cancel\",\n            null,\n            \"danger\"\n        );\n    } else {\n        notificationControl.info(\"Nothing to reset\", \"No cave states to restore.\");\n    }\n}\n\nfunction restoreDepositStates() {\n    let mapState = getMapState();\n\n    if (mapState.deposit_status.length > 0) {\n        showCustomConfirm(\n            \"Reset Ore Veins\",\n            \"Are you sure you want to reset all ore vein states on the current map? This will mark all deposits as unmined on this map only.\",\n            () => {\n                mapState.deposit_status = [];\n                mapState.change = \"new\";\n                setMapState(mapState);\n\n                // Reload ore deposits from cache instead of fetching from server\n                if (typeof toggleOreDepositLayer !== 'undefined' && typeof cachedOresData !== 'undefined') {\n                    const isVisible = filterGetState(filterOreDeposits);\n                    toggleOreDepositLayer(false, true); // isProgrammatic=true during reset\n                    if (cachedOresData[selectedMapParent]) {\n                        setOreDepositsData(selectedMapParent, cachedOresData[selectedMapParent], isVisible);\n                    }\n                }\n\n                notificationControl.success(\"Deep ore deposits restored\", ``);\n            },\n            false,\n            \"Reset Ore Veins\",\n            \"Cancel\",\n            null,\n            \"danger\"\n        );\n    } else {\n        notificationControl.info(\"Nothing to reset\", \"No deposit states to restore.\");\n    }\n}\n\n/**\n * Reset all exotic deposit states to default (used in saved maps dialog to reset exotics)\n */\nfunction restoreExoticsStates() {\n    let mapState = getMapState();\n\n    if (mapState.exotics_status && mapState.exotics_status.length > 0) {\n        showCustomConfirm(\n            \"Reset Exotics\",\n            \"Are you sure you want to reset all exotic states on the current map? This will mark all exotics as unexplored on this map only.\",\n            () => {\n                mapState.exotics_status = [];\n                mapState.change = \"new\";\n                setMapState(mapState);\n\n                // Update exotics to reflect cleared state and refresh icons\n                if (typeof updateMetaDepositState === 'function') {\n                    updateMetaDepositState();\n                }\n\n                notificationControl.success(\"Exotics restored\", ``);\n            },\n            false,\n            \"Reset Exotics\",\n            \"Cancel\",\n            null,\n            \"danger\"\n        );\n    } else {\n        notificationControl.info(\"Nothing to reset\", \"No exotic deposit states to restore.\");\n    }\n}\n\nfunction getCurrentSavedMapNameForExport() {\n    if (typeof getSavedMaps !== 'function' || typeof getGuid !== 'function') {\n        return '';\n    }\n\n    const savedMapsData = getSavedMaps();\n    const currentMapCode = localStorage.currentMap || 'olympus';\n    const currentGuid = getGuid();\n\n    if (!savedMapsData || !Array.isArray(savedMapsData.savedMaps)) {\n        return '';\n    }\n\n    const currentEntry = savedMapsData.savedMaps.find(m => m.guid === currentGuid && m.mapCode === currentMapCode);\n    if (!currentEntry || !currentEntry.name) {\n        return '';\n    }\n\n    return String(currentEntry.name).trim();\n}\n\nfunction sanitizeFilenamePart(value) {\n    if (!value) return '';\n\n    return String(value)\n        .replace(/[<>:\"/\\\\|?*\\x00-\\x1f]/g, '-')\n        .replace(/\\s+/g, '-')\n        .replace(/-+/g, '-')\n        .replace(/^[\\-.\\s]+|[\\-.\\s]+$/g, '');\n}\n\nfunction downloadMapStateFile(exportState, filename) {\n    const blob = new Blob([JSON.stringify(exportState, null, 2)], { type: 'application/json' });\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement('a');\n    a.href = url;\n    a.download = filename;\n    document.body.appendChild(a);\n    a.click();\n    document.body.removeChild(a);\n    URL.revokeObjectURL(url);\n}\n\nfunction saveMapStateToFile() {\n    let mapState = getMapState();\n    const currentMap = localStorage.currentMap || 'olympus';\n    const savedMapName = sanitizeFilenamePart(getCurrentSavedMapNameForExport());\n\n    // Prompt user for filename with timestamp\n    const now = new Date();\n    const timestamp = now.toISOString().replace(/[:.]/g, '-').slice(0, 19); // Format: YYYY-MM-DDTHH-MM-SS\n    const defaultFilename = savedMapName\n        ? `icarusintel-${currentMap}_${savedMapName}_${timestamp}`\n        : `icarusintel-${currentMap}_${timestamp}`;\n\n    // Create a clean copy without sensitive data, including map name\n    const exportState = {\n        map: currentMap,\n        cave_status: mapState.cave_status,\n        deposit_status: mapState.deposit_status,\n        custom_marker: mapState.custom_marker\n    };\n\n    const mapDisplayName = getMapDisplayNameFromCode(currentMap);\n    const caveCount = Array.isArray(exportState?.cave_status) ? exportState.cave_status.length : 0;\n    const oreCount = Array.isArray(exportState?.deposit_status) ? exportState.deposit_status.length : 0;\n    const markerCount = Array.isArray(exportState?.custom_marker) ? exportState.custom_marker.length : 0;\n\n    const promptMessage =\n        `<div style=\"line-height:1.5; margin-bottom:10px;\">` +\n        `Export current map state for <strong>${mapDisplayName}</strong>:` +\n        `</div>` +\n        `<div style=\"display:flex; gap:14px; flex-wrap:wrap; font-size:13px; color:#666;\">` +\n        `<span><strong>Caves:</strong> ${caveCount}</span>` +\n        `<span><strong>Ores:</strong> ${oreCount}</span>` +\n        `<span><strong>Markers:</strong> ${markerCount}</span>` +\n        `</div>`;\n\n    const finalizeExport = (userFilename) => {\n        // If user cancelled, don't save\n        if (userFilename === null) {\n            return;\n        }\n\n        // Clean filename and ensure it has .json extension\n        let filename = userFilename.trim() || defaultFilename;\n        if (!filename.toLowerCase().endsWith('.json')) {\n            filename += '.json';\n        }\n\n        downloadMapStateFile(exportState, filename);\n        notificationControl.success(\"Saved to file\", `Saved as ${filename}`);\n    };\n\n    if (typeof showCustomPrompt === 'function') {\n        showCustomPrompt(\n            \"Export Map State\",\n            promptMessage,\n            finalizeExport,\n            defaultFilename,\n            \"e.g., week-300-olympus.json\",\n            \"Export\",\n            \"Cancel\",\n            { wide: true }\n        );\n        return;\n    }\n\n    // Fallback without browser prompt: export with default filename.\n    finalizeExport(defaultFilename);\n}\n\n/**\n * Step 1: Load map state from file with validation\n * Asks user for file, validates it's a proper map state, then proceeds with import logic\n */\nfunction loadMapStateFromFile() {\n    loadMapStateFile()\n        .then(loadedState => {\n            // Validate that it's a proper map state\n            if (!loadedState || typeof loadedState !== 'object') {\n                notificationControl.alert(\"Invalid file\", \"The selected file is not a valid map state file.\");\n                return;\n            }\n\n            // Validate basic structure\n            if (!loadedState.hasOwnProperty('cave_status') &&\n                !loadedState.hasOwnProperty('deposit_status') &&\n                !loadedState.hasOwnProperty('custom_marker')) {\n                notificationControl.alert(\"Invalid map state\", \"The file does not contain valid map state data.\");\n                return;\n            }\n\n            // Step 2: Find map code in loaded state\n            const currentMapCode = localStorage.currentMap || 'olympus';\n            const loadedMapCode = loadedState.map || currentMapCode;\n            const mapDisplayName = getMapDisplayNameFromCode(loadedMapCode);\n            const caveCount = Array.isArray(loadedState?.cave_status) ? loadedState.cave_status.length : 0;\n            const oreCount = Array.isArray(loadedState?.deposit_status) ? loadedState.deposit_status.length : 0;\n            const markerCount = Array.isArray(loadedState?.custom_marker) ? loadedState.custom_marker.length : 0;\n\n            const importSummaryHtml =\n                `<div style='line-height:1.5; margin-bottom:10px;'>` +\n                `Loaded map: <strong>${mapDisplayName}</strong>` +\n                `</div>` +\n                `<div style='display:flex; gap:14px; flex-wrap:wrap; font-size:13px; color:#666; margin-bottom:12px;'>` +\n                `<span><strong>Caves:</strong> ${caveCount}</span>` +\n                `<span><strong>Ores:</strong> ${oreCount}</span>` +\n                `<span><strong>Markers:</strong> ${markerCount}</span>` +\n                `</div>`;\n\n            // Check if same map or different\n            if (currentMapCode === loadedMapCode) {\n                // Same map: Ask user whether to override or save as new\n                showCustomConfirm(\n                    \"Import Map State\",\n                    importSummaryHtml +\n                    \"<div style='line-height: 1.6; margin-bottom: 12px;'>The file is for the same map you're currently viewing.</div>\" +\n                    \"<div style='margin-left: 12px;'>\" +\n                    \"<div style='margin-bottom: 10px;'><strong>• Save as New Map:</strong> Create a new saved map from the file (keeps your current map intact)</div>\" +\n                    \"<div><strong>• Override Current Map:</strong> Replace all data in your current map</div>\" +\n                    \"</div>\",\n                    () => {\n                        // User chose \"Save as New Map\"\n                        promptForNameAndSaveAsNew(loadedState, loadedMapCode);\n                    },\n                    false,\n                    \"Save as New Map\",\n                    \"Override Current\",\n                    null,\n                    \"primary\",\n                    \"\"\n                );\n\n                // Override the cancel button to trigger the override flow\n                setTimeout(() => {\n                    const overlay = document.getElementById('customConfirmDialog');\n                    const cancelBtn = document.getElementById('customConfirmCancel');\n                    if (cancelBtn) {\n                        cancelBtn.onclick = () => {\n                            overlay.style.display = 'none';\n                            // Show override confirmation\n                            confirmAndOverrideMap(loadedState, loadedMapCode);\n                        };\n                    }\n                }, 50);\n            } else {\n                // Different map: Automatically save as new (ask for name)\n                promptForNameAndSaveAsNew(loadedState, loadedMapCode);\n            }\n        })\n        .catch(err => {\n            if (err.message !== 'No file selected') {\n                notificationControl.alert(\"Error loading map state\", err.message);\n            }\n        });\n}\n\n/**\n * Open file picker and load map state from JSON file\n * @returns {Promise<Object>} Promise that resolves with the loaded map state object\n */\nfunction loadMapStateFile() {\n    return new Promise((resolve, reject) => {\n        const input = document.createElement('input');\n        input.type = 'file';\n        input.accept = '.json,application/json';\n\n        input.onchange = e => {\n            const file = e.target.files[0];\n            if (!file) {\n                reject(new Error('No file selected'));\n                return;\n            }\n\n            const reader = new FileReader();\n            reader.onload = event => {\n                try {\n                    const loadedState = JSON.parse(event.target.result);\n                    resolve(loadedState);\n                } catch (err) {\n                    reject(err);\n                }\n            };\n            reader.onerror = () => {\n                reject(new Error('Failed to read file'));\n            };\n            reader.readAsText(file);\n        };\n\n        // If user cancels file picker, nothing happens (reject is not called)\n        input.click();\n    });\n}\n\n/**\n * Step 3a: Prompt for map name and save the loaded state as a new map\n * @param {Object} loadedState - The loaded map state from file\n * @param {string} loadedMapCode - The map code from the loaded state\n */\nfunction promptForNameAndSaveAsNew(loadedState, loadedMapCode) {\n    const now = new Date();\n    const dateStr = now.toLocaleDateString(undefined, {\n        year: 'numeric',\n        month: 'short',\n        day: 'numeric'\n    });\n    const defaultName = `Imported Map ${dateStr}`;\n\n    const mapDisplayName = getMapDisplayNameFromCode(loadedMapCode);\n    const caveCount = Array.isArray(loadedState?.cave_status) ? loadedState.cave_status.length : 0;\n    const oreCount = Array.isArray(loadedState?.deposit_status) ? loadedState.deposit_status.length : 0;\n    const markerCount = Array.isArray(loadedState?.custom_marker) ? loadedState.custom_marker.length : 0;\n\n    const promptMessage =\n        `<div style=\"line-height:1.5; margin-bottom:10px;\">` +\n        `Save imported map as new save for <strong>${mapDisplayName}</strong>:` +\n        `</div>` +\n        `<div style=\"display:flex; gap:14px; flex-wrap:wrap; font-size:13px; color:#666;\">` +\n        `<span><strong>Caves:</strong> ${caveCount}</span>` +\n        `<span><strong>Ores:</strong> ${oreCount}</span>` +\n        `<span><strong>Markers:</strong> ${markerCount}</span>` +\n        `</div>`;\n\n    showCustomPrompt(\n        \"Save Imported Map As\",\n        promptMessage,\n        (mapName) => {\n            if (mapName === null) {\n                return; // User cancelled\n            }\n\n            const finalName = mapName.trim() || defaultName;\n            applyLoadedMapStateAsNew(loadedState, loadedMapCode, finalName);\n        },\n        defaultName,\n        \"e.g., Week 300 Imported\",\n        \"Import\",\n        \"Cancel\",\n        { wide: true }\n    );\n}\n\n/**\n * Step 3b: Show confirmation and override current map with loaded state\n * @param {Object} loadedState - The loaded map state from file\n * @param {string} loadedMapCode - The map code from the loaded state\n */\nfunction confirmAndOverrideMap(loadedState, loadedMapCode) {\n    showCustomConfirm(\n        \"Override Current Map\",\n        \"This will DELETE all data in your current map including all markers, cave states, and ore deposits. This action cannot be undone!\",\n        () => {\n            applyLoadedMapState(loadedState, loadedMapCode);\n        },\n        false,\n        \"Override\",\n        \"Cancel\",\n        null,\n        \"danger\"\n    );\n}\n\n/**\n * Override current map with loaded state\n * @param {Object} loadedState - The loaded map state from file\n * @param {string} loadedMapCode - The map code from loaded state\n */\nfunction applyLoadedMapState(loadedState, loadedMapCode) {\n    const currentMapCode = localStorage.currentMap || 'olympus';\n\n    // Check if we need to switch maps\n    if (loadedMapCode !== currentMapCode) {\n        // Switch to the correct map first\n        if (typeof switchMap !== 'undefined') {\n            localStorage.currentMap = loadedMapCode;\n\n            // Update map dropdown if it exists\n            const mapDropdown = document.getElementById('mapSelector');\n            if (mapDropdown) {\n                mapDropdown.value = loadedMapCode;\n            }\n\n            // Switch map and then load the state\n            switchMap(loadedMapCode);\n\n            // Wait for map to load before applying state\n            setTimeout(() => {\n                overrideCurrentMapData(loadedState);\n                forceImmediateMapSave();\n            }, 500);\n            return;\n        }\n    }\n\n    // If same map or switchMap not available, apply directly\n    overrideCurrentMapData(loadedState);\n    forceImmediateMapSave();\n}\n\nfunction clearImportFlowFlags() {\n    if (typeof window.skipCleanupDuringImport !== 'undefined') {\n        window.skipCleanupDuringImport = false;\n    }\n    if (typeof window.skipLoadDuringImport !== 'undefined') {\n        window.skipLoadDuringImport = false;\n    }\n}\n\nfunction forceImmediateMapSave() {\n    if (typeof getMapState !== 'function' || typeof setMapState !== 'function') return;\n\n    const mapState = getMapState();\n    if (!mapState) return;\n\n    if (mapState.change !== 'new') {\n        mapState.change = 'new';\n        setMapState(mapState);\n    }\n\n    if (typeof updateUserAndMap === 'function') {\n        updateUserAndMap(true);\n    }\n}\n\nfunction updateImportedMapUi() {\n    if (typeof hideMapLoading !== 'undefined') {\n        hideMapLoading();\n    }\n\n    if (typeof updateCurrentMapNameDisplay !== 'undefined') {\n        updateCurrentMapNameDisplay();\n    }\n}\n\n/**\n * Helper function to override current map data with loaded state\n * @param {Object} loadedState - The loaded map state\n */\nfunction overrideCurrentMapData(loadedState) {\n    // Get current map state\n    let mapState = getMapState();\n\n    // Update with loaded data\n    mapState.cave_status = loadedState.cave_status || [];\n    mapState.deposit_status = loadedState.deposit_status || [];\n    mapState.exotics_status = loadedState.exotics_status || [];\n    mapState.custom_marker = loadedState.custom_marker || [];\n    mapState.change = \"new\";\n\n    // Clear existing custom markers before loading new state\n    if (typeof customMarkersClear !== 'undefined') {\n        customMarkersClear();\n    }\n\n    setMapState(mapState);\n    updateMapToState(false);\n    mapReloadSavedState();\n}\n\n/**\n * Step 3: Apply loaded map state as a new saved map\n * Creates a new map entry with the imported data and triggers save\n * @param {Object} loadedState - The loaded map state\n * @param {string} loadedMapCode - The map code from loaded state\n * @param {string} mapName - The name for the new map\n */\nfunction applyLoadedMapStateAsNew(loadedState, loadedMapCode, mapName) {\n    const currentMapCode = localStorage.currentMap || 'olympus';\n\n    debugLog('saving', 'Creating new map from imported file:', { loadedMapCode, mapName });\n\n    // Set flags to prevent cleanup and DB loading during import\n    if (typeof window.skipCleanupDuringImport !== 'undefined') {\n        window.skipCleanupDuringImport = true;\n    }\n    if (typeof window.skipLoadDuringImport !== 'undefined') {\n        window.skipLoadDuringImport = true;\n    }\n\n    // Save current map if there are unsaved changes\n    const currentMapState = getMapState();\n    if (currentMapState && currentMapState.change === \"new\") {\n        debugLog('saving', 'Saving current map before importing as new');\n        if (typeof saveBeforeMapSwitch !== 'undefined') {\n            saveBeforeMapSwitch(currentMapCode);\n        }\n    }\n\n    // Clean up any unsaved map entries\n    if (typeof cleanupUnsavedMapEntries !== 'undefined') {\n        cleanupUnsavedMapEntries();\n    }\n\n    // Create savedMaps entry with the specified name\n    if (typeof getSavedMaps !== 'undefined' && typeof setSavedMaps !== 'undefined') {\n        const savedMapsData = getSavedMaps();\n\n        // Clear selected for all maps of this type\n        savedMapsData.savedMaps.forEach(m => {\n            if (m.mapCode === loadedMapCode) {\n                m.selected = false;\n            }\n        });\n\n        // Create new entry\n        const newEntry = {\n            mapCode: loadedMapCode,\n            guid: 'new',\n            name: mapName,\n            selected: true,\n            created: null,\n            lastAccess: new Date().toISOString()\n        };\n\n        savedMapsData.savedMaps.push(newEntry);\n        savedMapsData.lastOpenedIndex = savedMapsData.savedMaps.length - 1;\n\n        setSavedMaps(savedMapsData);\n        debugLog('saving', 'Created new map entry for imported data:', newEntry);\n    }\n\n    // Create new map state with imported data\n    const newMapState = {\n        map: loadedMapCode,\n        cave_status: loadedState.cave_status || [],\n        deposit_status: loadedState.deposit_status || [],\n        exotics_status: loadedState.exotics_status || [],\n        custom_marker: loadedState.custom_marker || [],\n        guid: 'new',\n        change: 'new', // Mark as changed so it will be saved\n        rights: 'rw',\n        version: loadedState.version || 1\n    };\n\n    // Set the new state\n    if (typeof setMapState !== 'undefined') {\n        setMapState(newMapState);\n    }\n\n    // Set GUID to 'new'\n    if (typeof setGuid !== 'undefined') {\n        setGuid('new');\n    }\n\n    // Clear existing custom markers\n    if (typeof customMarkersClear !== 'undefined') {\n        customMarkersClear();\n    }\n\n    // Switch maps if needed (DON'T set localStorage.currentMap before this - let switchMap handle it)\n    if (currentMapCode !== loadedMapCode) {\n        // Update map selector dropdown BEFORE switching\n        const mapDropdown = document.getElementById('mapSelector');\n        if (mapDropdown) {\n            mapDropdown.value = loadedMapCode;\n        }\n\n        const waitForReload = new Promise((resolve) => {\n            let handled = false;\n\n            const cleanup = () => {\n                window.removeEventListener('mapReloadComplete', onComplete);\n            };\n\n            const onComplete = () => {\n                if (handled) return;\n                handled = true;\n                cleanup();\n                resolve();\n            };\n\n            window.addEventListener('mapReloadComplete', onComplete);\n\n            setTimeout(() => {\n                if (handled) return;\n                handled = true;\n                cleanup();\n                resolve();\n            }, 8000);\n        });\n\n        if (typeof switchMap !== 'undefined') {\n            switchMap(loadedMapCode);\n        }\n\n        waitForReload.then(() => {\n            updateImportedMapUi();\n            forceImmediateMapSave();\n            clearImportFlowFlags();\n        });\n    } else {\n        // Same map, reload display\n        updateMapToState(false);\n        mapReloadSavedState();\n\n        updateImportedMapUi();\n        forceImmediateMapSave();\n        clearImportFlowFlags();\n    }\n\n    debugLog('saving', 'Import as new map complete');\n}\n\nfunction getDepositState(depositId) {\n    let mapState = getMapState().deposit_status;\n\n    if (mapState) {\n        for (let i = 0; i < mapState.length; i++) {\n            if (mapState[i].id == depositId) {\n                return mapState[i].icon\n            }\n        }\n    }\n}\n\nfunction getDepositDrill(depositId) {\n    let mapState = getMapState().deposit_status;\n\n    if (mapState) {\n        for (let i = 0; i < mapState.length; i++) {\n            if (mapState[i].id == depositId) {\n                return mapState[i].drill\n            }\n        }\n    }\n}\n\n/**\n * Get the state of an exotics deposit\n * @param {string} exoticsId - ID of the exotics deposit (e.g., \"57_11\")\n * @returns {string} State icon ('?', 'x', 'm')\n */\nfunction getExoticsState(exoticsId) {\n    let mapState = getMapState().exotics_status;\n\n    if (mapState) {\n        for (let i = 0; i < mapState.length; i++) {\n            if (mapState[i].id == exoticsId) {\n                return mapState[i].icon;\n            }\n        }\n    }\n    return '?'; // Default to unknown\n}\n\n/**\n * ============================================================================\n * CENTRALIZED STATE UPDATE FUNCTION\n * ============================================================================\n * This function handles ALL user changes to the map state.\n * It updates both the local state (sessionStorage) and the change tracker.\n * This ensures changes are always tracked and never missed.\n */\n\n/**\n * Record a user change to the map state\n * @param {string} type - Type of change: 'cave', 'cave_ores', 'deposit', 'exotic', 'marker_add', 'marker_remove'\n * @param {object} data - Change data specific to the type\n */\nfunction recordUserChange(type, data) {\n    const mapState = getMapState();\n\n    switch (type) {\n        case 'cave': {\n            // data: complete cave object { id, icon?, deepOres?, drills? }\n            const caveId = data.id;\n\n            // Find existing cave to merge with\n            let caveFound = -1;\n            let existingCave = null;\n\n            for (let i = 0; i < mapState.cave_status.length; i++) {\n                if (mapState.cave_status[i].id == caveId) {\n                    caveFound = i;\n                    existingCave = mapState.cave_status[i];\n                    break;\n                }\n            }\n\n            // Build complete cave entry by merging new data with existing\n            const caveEntry = {\n                id: caveId,\n                icon: data.icon !== undefined ? data.icon : (existingCave?.icon || 'i'),\n                // If deepOres is explicitly provided (even as undefined), use it; otherwise keep existing\n                ...('deepOres' in data ? (data.deepOres ? { deepOres: data.deepOres } : {}) : (existingCave?.deepOres ? { deepOres: existingCave.deepOres } : {})),\n                // If drills is explicitly provided (even as undefined), use it; otherwise keep existing\n                ...('drills' in data ? (data.drills ? { drills: data.drills } : {}) : (existingCave?.drills ? { drills: existingCave.drills } : {}))\n            };\n\n            // Remove existing entry\n            if (caveFound >= 0) {\n                mapState.cave_status.splice(caveFound, 1);\n            }\n\n            // Only add if not default state (icon='i' with no ores/drills)\n            const hasData = caveEntry.icon !== 'i' || caveEntry.deepOres || caveEntry.drills;\n            if (hasData) {\n                mapState.cave_status.push(caveEntry);\n            }\n\n            // Track the complete cave state\n            if (typeof ChangeTracker !== 'undefined') {\n                ChangeTracker.trackCaveChange(caveId, caveEntry.icon, caveEntry.deepOres, caveEntry.drills);\n            }\n            break;\n        }\n\n        case 'deposit': {\n            // data: complete deposit object { id, icon?, drill? }\n            const depositId = data.id;\n\n            if (!mapState.deposit_status) {\n                mapState.deposit_status = [];\n            }\n\n            // Find existing deposit to merge with\n            let depositFound = -1;\n            let existingDeposit = null;\n\n            for (let i = 0; i < mapState.deposit_status.length; i++) {\n                if (mapState.deposit_status[i].id == depositId) {\n                    depositFound = i;\n                    existingDeposit = mapState.deposit_status[i];\n                    break;\n                }\n            }\n\n            // Build complete deposit entry\n            const depositEntry = {\n                id: depositId,\n                icon: data.icon !== undefined ? data.icon : (existingDeposit?.icon || '?'),\n                // If drill is explicitly provided (even as undefined), use it; otherwise keep existing\n                ...('drill' in data ? (data.drill ? { drill: data.drill } : {}) : (existingDeposit?.drill ? { drill: existingDeposit.drill } : {}))\n            };\n\n            // Remove existing entry\n            if (depositFound >= 0) {\n                mapState.deposit_status.splice(depositFound, 1);\n            }\n\n            // Only add if not unknown state\n            if (depositEntry.icon !== '?') {\n                mapState.deposit_status.push(depositEntry);\n            }\n\n            // Track the complete deposit state\n            if (typeof ChangeTracker !== 'undefined') {\n                ChangeTracker.trackDepositChange(depositId, depositEntry.icon, depositEntry.drill);\n            }\n            break;\n        }\n\n        case 'exotic': {\n            // data: { id, icon }\n            const { id: exoticsId, icon: exoticsState } = data;\n\n            if (!mapState.exotics_status) {\n                mapState.exotics_status = [];\n            }\n\n            let depositFound = -1;\n            for (let i = 0; i < mapState.exotics_status.length; i++) {\n                if (mapState.exotics_status[i].id == exoticsId) {\n                    depositFound = i;\n                    break;\n                }\n            }\n\n            if (depositFound >= 0) {\n                mapState.exotics_status.splice(depositFound, 1);\n            }\n\n            if (exoticsState != '?') {\n                mapState.exotics_status.push({\n                    'id': exoticsId,\n                    'icon': exoticsState\n                });\n            }\n\n            // Track the change\n            if (typeof ChangeTracker !== 'undefined') {\n                ChangeTracker.trackExoticChange(exoticsId, exoticsState);\n            }\n            break;\n        }\n\n        case 'marker_add': {\n            // data: { id, pos, icon, color, desc }\n            const { id, pos, icon, color, desc } = data;\n\n            if (mapState.custom_marker === undefined) {\n                mapState.custom_marker = [];\n            }\n\n            const marker = { 'id': id, 'pos': pos, 'icon': icon, 'color': color, 'desc': desc };\n            mapState.custom_marker.push(marker);\n\n            // Track the change\n            if (typeof ChangeTracker !== 'undefined') {\n                ChangeTracker.trackMarkerAdded(id, marker);\n            }\n            break;\n        }\n\n        case 'marker_remove': {\n            // data: { id }\n            const { id } = data;\n\n            if (mapState.custom_marker === undefined) {\n                return;\n            }\n\n            const markerIndex = mapState.custom_marker.findIndex(m => m.id === id);\n            let removedMarker = null;\n            if (markerIndex !== -1) {\n                // Store marker data before removing for conflict resolution\n                removedMarker = mapState.custom_marker[markerIndex];\n                mapState.custom_marker.splice(markerIndex, 1);\n            }\n\n            // Track the change with marker data\n            if (typeof ChangeTracker !== 'undefined') {\n                ChangeTracker.trackMarkerRemoved(id, removedMarker);\n            }\n            break;\n        }\n\n        case 'marker_edit': {\n            // data: { id, pos, icon, color, desc }\n            const { id, pos, icon, color, desc } = data;\n\n            if (mapState.custom_marker === undefined) {\n                return;\n            }\n\n            const markerIndex = mapState.custom_marker.findIndex(m => m.id === id);\n            if (markerIndex !== -1) {\n                // Update existing marker\n                mapState.custom_marker[markerIndex] = { 'id': id, 'pos': pos, 'icon': icon, 'color': color, 'desc': desc };\n\n                // Track the change\n                if (typeof ChangeTracker !== 'undefined') {\n                    ChangeTracker.trackMarkerEdited(id, mapState.custom_marker[markerIndex]);\n                }\n            }\n            break;\n        }\n    }\n\n    // Mark state as changed and save\n    mapState.change = \"new\";\n    setMapState(mapState);\n}\n\n/**\n * ============================================================================\n * LEGACY STATE FUNCTIONS (now use recordUserChange internally)\n * ============================================================================\n */\n\n/**\n * Set the state of an exotics deposit\n * @param {string} exoticsId - ID of the exotics deposit\n * @param {string} exoticsState - State: 'x' = invalid, 'm' = mined, '?' = unknown\n */\nfunction setExoticsState(exoticsId, exoticsState) {\n    recordUserChange('exotic', { id: exoticsId, icon: exoticsState });\n}\n\n/**\n * From the list of all saved cave state, return the state of the given cave\n * @param {*} caveId id of the cave extrated from the cave.js bindpopup\n * @returns i = Icon/m = Mined\n */\nfunction getCaveState(caveId) {\n\n    let mapState = getMapState().cave_status;\n\n    for (let i = 0; i < mapState.length; i++) {\n        if (mapState[i].id == caveId) {\n            return mapState[i].icon\n        }\n    }\n}\n\n/**\n * Get the deep ore vein states for a cave\n * @param {*} caveId id of the cave\n * @returns Array of 3 ore state IDs (e.g. ['?', 'i', 'g'])\n */\nfunction getCaveDeepOres(caveId) {\n    let mapState = getMapState().cave_status;\n\n    if (mapState) {\n        for (let i = 0; i < mapState.length; i++) {\n            if (mapState[i].id == caveId) {\n                const deepOres = mapState[i].deepOres;\n                // Ensure deepOres is an array (handle legacy object format)\n                if (deepOres) {\n                    if (Array.isArray(deepOres)) {\n                        return deepOres;\n                    } else if (typeof deepOres === 'object') {\n                        // Convert object format {0: '?', 1: 'i', 2: 'g'} to array\n                        return [deepOres[0] || '?', deepOres[1] || '?', deepOres[2] || '?'];\n                    }\n                }\n                return ['?', '?', '?'];\n            }\n        }\n    }\n    return ['?', '?', '?'];\n}\n\n/**\n * Save the deep ore vein states for a cave\n * @param {*} caveId id of the cave\n * @param {*} deepOres Array of 3 ore state IDs\n */\nfunction setCaveDeepOres(caveId, deepOres) {\n    recordUserChange('cave', { id: caveId, deepOres });\n}\n\n/**\n * Get drill status for a specific cave ore slot\n * @param {*} caveId id of the cave\n * @param {*} oreIndex ore slot index (0, 1, or 2)\n * @returns {string|undefined} drill status ('b', 'e', 'o', or undefined)\n */\nfunction getCaveOreDrill(caveId, oreIndex) {\n    let mapState = getMapState().cave_status;\n\n    if (mapState) {\n        for (let i = 0; i < mapState.length; i++) {\n            if (mapState[i].id == caveId) {\n                const drills = mapState[i].drills;\n                return drills ? drills[oreIndex] : undefined;\n            }\n        }\n    }\n    return undefined;\n}\n\n/**\n * Set drill status for a specific cave ore slot\n * @param {*} caveId id of the cave\n * @param {*} oreIndex ore slot index (0, 1, or 2)\n * @param {*} drill drill status ('b', 'e', 'o', or undefined)\n */\nfunction setCaveOreDrill(caveId, oreIndex, drill) {\n    // Get current cave state to merge with\n    let mapState = getMapState();\n    let existingCave = mapState.cave_status.find(c => c.id == caveId);\n\n    // Build or update drills array\n    let drills = existingCave?.drills ? [...existingCave.drills] : [undefined, undefined, undefined];\n    drills[oreIndex] = drill;\n\n    // Clean up: if all drills are undefined, don't include drills\n    const allUndefined = drills.every(d => !d);\n\n    recordUserChange('cave', {\n        id: caveId,\n        drills: allUndefined ? undefined : drills\n    });\n}\n\n/**\n * Save the state of a given deposit id\n * @param {*} depositId id of the deposit being modified\n * @param {*} depositState m = mined, ? = unknown, x = invalid\n * @param {*} drill b = biofuel, e = electric, o = oil, undefined = none\n */\nfunction setOreDepositState(depositId, depositState, drill) {\n    recordUserChange('deposit', { id: depositId, icon: depositState, drill });\n}\n\nfunction setDepositDrill(depositId, drill) {\n    recordUserChange('deposit', {\n        id: depositId,\n        drill: drill\n    });\n}\n\n/**\n * Save the state of the given cave\n * @param {*} caveId id of the cave extrated from the cave.js bindpopup\n * @param {*} caveState i = Icon/m = Mined/p = partially mined\n */\nfunction setCaveState(caveId, caveState) {\n    recordUserChange('cave', { id: caveId, icon: caveState });\n}\n\n/**\n * Save custom icon\n */\nfunction addCustomMarkerState(id, latlen, iconText, color, description) {\n    recordUserChange('marker_add', { id, pos: latlen, icon: iconText, color, desc: description });\n}\n\n/**\n * Save custom icon\n */\nfunction deleteCustomMarker(id) {\n    recordUserChange('marker_remove', { id });\n    scheduleAutoSave();\n}\n\n/**\n * Edit custom marker\n */\nfunction editCustomMarkerState(id, latlen, iconText, color, description) {\n    recordUserChange('marker_edit', { id, pos: latlen, icon: iconText, color, desc: description });\n    scheduleAutoSave();\n}\n\nfunction updateMapToState(loadMap = true) {\n\n    let filterState = getFilterState();\n\n    // Set flag to prevent filter reset during state restoration\n    window.isRestoringMapState = true;\n\n    filterSetCheckedState(filterGrid, filterState.grid);\n    filterSetCheckedState(filterExotics, filterState.metaDeposits);\n    filterSetCheckedState(filterGeysers, filterState.enzymeGeysers);\n    filterSetCheckedState(filterOilGeysers, filterState.oilGeysers);\n    filterSetCheckedState(filterOreDeposits, filterState.deepOreDeposits);\n    filterSetCheckedState(filterCaves, filterState.caves.all);\n    filterSetCheckedState(filterCustomMarkers, filterState.markers);\n\n    // Restore Prometheus NULL sector filter states\n    if (filterState.prometheusNull) {\n        filterSetCheckedState(filterPrometheusNullCaves, filterState.prometheusNull.caves);\n        filterSetCheckedState(filterPrometheusNullOre, filterState.prometheusNull.ore);\n        filterSetCheckedState(filterPrometheusNullMap, filterState.prometheusNull.map);\n    }\n\n    // Restore map view (zoom and center position) if available\n    if (filterState.mapView && filterState.mapView.zoom !== null && filterState.mapView.center !== null && typeof map !== 'undefined') {\n        // Temporarily disable saving while we restore the view\n        if (typeof shouldSaveMapView !== 'undefined') {\n            shouldSaveMapView = false;\n        }\n        map.setView([filterState.mapView.center.lat, filterState.mapView.center.lng], filterState.mapView.zoom);\n        // Re-enable saving after a short delay\n        setTimeout(() => {\n            if (typeof shouldSaveMapView !== 'undefined') {\n                shouldSaveMapView = true;\n            }\n        }, 100);\n    }\n\n    // Apply filters immediately using requestAnimationFrame for better performance\n    requestAnimationFrame(() => {\n        mapToggleGridLayer(filterState.grid);\n        if (typeof applyOreFiltering === 'function') {\n            applyOreFiltering();\n        }\n        if (typeof applyCaveTierFiltering === 'function') {\n            applyCaveTierFiltering();\n        }\n\n        // Update filter button states to reflect the applied filters\n        if (typeof updateOreFilterButtonState === 'function') {\n            updateOreFilterButtonState();\n        }\n        if (typeof updateCaveTierFilterButtonState === 'function') {\n            updateCaveTierFilterButtonState();\n        }\n\n        // Clear flag after filters are applied\n        window.isRestoringMapState = false;\n    });\n}\n\nfunction scheduleMapNameDisplayUpdate(delay = 100) {\n    if (typeof updateCurrentMapNameDisplay !== 'undefined') {\n        setTimeout(updateCurrentMapNameDisplay, delay);\n    }\n}\n\nfunction finalizeMapUiAfterStateUpdate({\n    loadMap = true,\n    showRONotify = false,\n    refreshIcons = true,\n    hideLoading = false,\n    mapStateUpdate = null\n} = {}) {\n    sessionStorage.lastUpdate = Date.now();\n    updateMapToState(loadMap);\n    debugMapState();\n    setMapRights();\n    shareLink();\n    setupReloadButton();\n\n    if (showRONotify) {\n        showRONotification();\n    }\n\n    if (mapStateUpdate) {\n        updateMapState(mapStateUpdate);\n    }\n\n    if (refreshIcons && typeof reloadMapIcons !== 'undefined') {\n        reloadMapIcons();\n    }\n\n    if (hideLoading && typeof hideMapLoading !== 'undefined') {\n        setTimeout(() => hideMapLoading(), 100);\n    }\n\n    scheduleMapNameDisplayUpdate(100);\n}\n\nlet _siteUpdateDetected = false;\nlet _siteUpdatePromptShown = false;\n\nfunction getClientAppVersion() {\n    return typeof icarusIntelVersion !== 'undefined'\n        ? String(icarusIntelVersion)\n        : '';\n}\n\nfunction appendClientVersionToFormBody(body = '') {\n    const baseBody = body ? String(body) : '';\n    const versionPart = 'clientVersion=' + encodeURIComponent(getClientAppVersion());\n    return baseBody ? `${baseBody}&${versionPart}` : versionPart;\n}\n\nfunction appendClientVersionToUrl(url) {\n    const separator = url.includes('?') ? '&' : '?';\n    return `${url}${separator}clientVersion=${encodeURIComponent(getClientAppVersion())}`;\n}\n\nfunction isClientVersionMismatchPayload(payload) {\n    return !!(payload && payload.error === 'client_version_mismatch');\n}\n\nfunction handleClientVersionMismatch(payload) {\n    if (!isClientVersionMismatchPayload(payload)) return false;\n    triggerReloadForSiteUpdate(payload.serverVersion || null);\n    return true;\n}\n\nfunction triggerSafePageReloadForUpdate() {\n    if (typeof window !== 'undefined') {\n        window.__suppressBeforeUnloadPrompt = true;\n    }\n    window.location.reload();\n}\n\nfunction triggerReloadForSiteUpdate(newVersion) {\n    if (_siteUpdateDetected) return;\n\n    _siteUpdateDetected = true;\n\n    const mapState = typeof getMapState === 'function' ? getMapState() : null;\n    const hasUnsavedChanges = !!(mapState && mapState.change === 'new');\n\n    if (typeof updateMapState === 'function') {\n        updateMapState('error', 'Site updated. Reload required.');\n    }\n\n    if (hasUnsavedChanges) {\n        if (_siteUpdatePromptShown) return;\n        _siteUpdatePromptShown = true;\n\n        if (typeof showCustomConfirm === 'function') {\n            showCustomConfirm(\n                'Site Updated',\n                'A new version of Icarus Intel was deployed while you were editing. Reload now to prevent save/load issues.',\n                () => {\n                    triggerSafePageReloadForUpdate();\n                },\n                true,\n                'Reload Now'\n            );\n        } else {\n            alert('A new version was deployed. Please reload now to avoid data loss.');\n        }\n\n        return;\n    }\n\n    if (typeof NotificationSystem !== 'undefined') {\n        NotificationSystem.info('Site updated. Reloading to keep your session safe...', 2500);\n    }\n\n    setTimeout(() => {\n        triggerSafePageReloadForUpdate();\n    }, 1500);\n}\n\nfunction isSiteUpdateBlocked() {\n    if (!_siteUpdateDetected) return false;\n\n    if (typeof updateMapState === 'function') {\n        updateMapState('error', 'Site updated. Please reload page.');\n    }\n\n    return true;\n}\n\nfunction loadMapFromDb(loadMap = true) {\n    if (isSiteUpdateBlocked()) {\n        return;\n    }\n\n    const guidToLoad = getGuid();\n\n    if (guidToLoad != 'new') {\n        let mapState = getMapState();\n        const currentMap = localStorage.currentMap || 'olympus';\n        let myUrl = 'map/load/' + guidToLoad + '/' + mapState.change\n        debugLog('saving', 'Loading map from DB:', { guid: guidToLoad, map: currentMap, change: mapState.change });\n\n        const xhr = new XMLHttpRequest();\n        xhr.open('POST', myUrl, false);\n        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');\n        xhr.send(appendClientVersionToFormBody(''));\n\n        if (xhr.status === 200) {\n            let data = JSON.parse(xhr.responseText);\n            const currentMap = localStorage.currentMap || 'olympus';\n            debugLog('base', 'Map loaded successfully from DB:', { guid: data.guid, map: currentMap, rights: data.rights, version: data.version });\n            updateMapState('loaded');\n            debugLog('saving', 'Loaded map data:', data);\n            if (data != \"false\") {\n                console.log('Map data loaded from database:', data);\n\n\n                // Clean any old filter data from loaded state, if map version in not present and is smaller than 2\n                if (!data.version || data.version < 2) {\n                    const cleanedData = cleanLoadedMapState(data);\n                    data = cleanedData;\n                    debugLog('saving', 'Cleaned loaded map state:', cleanedData);\n                }\n\n                setMapState(data);\n                setGuid(data.guid);\n\n                // Update metadata: created date and last access (user is opening this map)\n                updateSavedMapMetadata(data.guid, data.created, true);\n\n                // Persist deletion flag in local savedMaps for dialog display\n                if (typeof setSavedMapDeletionFlag === 'function') {\n                    setSavedMapDeletionFlag(data.guid, data.deleted === true);\n                }\n\n                // Show one-time notification when user changed map and we loaded its last opened saved state\n                const pendingSwitchNotification = (typeof window !== 'undefined') ? window.__pendingMapSwitchNotification : null;\n                if (pendingSwitchNotification\n                    && pendingSwitchNotification.mapCode === currentMap\n                    && (!pendingSwitchNotification.expectedGuid || pendingSwitchNotification.expectedGuid === data.guid)) {\n                    const savedMapsData = getSavedMaps();\n                    const selectedEntry = savedMapsData.savedMaps.find(m => m.guid === data.guid) || { name: '' };\n                    showMapStateSwitchSuccessNotification(selectedEntry, currentMap);\n                    window.__pendingMapSwitchNotification = null;\n                }\n\n                // Show notification if map is marked as deleted\n                if (data.deleted && typeof NotificationSystem !== 'undefined') {\n                    NotificationSystem.warning('This map has been marked as deleted.', 5000);\n                }\n\n                // Clear change tracker on fresh load\n                if (typeof ChangeTracker !== 'undefined') {\n                    ChangeTracker.clear();\n                }\n            }\n        } else if (xhr.status === 426 || xhr.status === 409) {\n            let mismatchPayload = null;\n            try {\n                mismatchPayload = JSON.parse(xhr.responseText || '{}');\n            } catch (e) {\n                mismatchPayload = null;\n            }\n\n            if (handleClientVersionMismatch(mismatchPayload)) {\n                return;\n            }\n        } else {\n            if (xhr.status === 404) {\n                lastErrorFound = 'Map does not exist in the database. Redirecting to default map.';\n                const params = new URLSearchParams(window.location.search);\n                if (params.get('m')) {\n                    alert(lastErrorFound);\n                    let myUrl = 'http://' + window.location.hostname;\n                    if (window.location.port && window.location.port != '80' && window.location.port != '443') {\n                        myUrl += ':' + window.location.port;\n                    }\n                    window.location.replace(myUrl);\n                }\n\n                if (typeof markSavedMapAsMissing === 'function') {\n                    markSavedMapAsMissing(guidToLoad);\n                } else if (typeof setSavedMapDeletionFlag === 'function') {\n                    setSavedMapDeletionFlag(guidToLoad, true);\n                }\n\n                lastErrorFound += \". Need a new one.\"\n                updateMapState('error', lastErrorFound);\n                clearMapStateSession();\n                lastErrorFound = undefined;\n            } else {\n                lastErrorFound = 'Could not load map. Halting updates.';\n                updateMapState('error', lastErrorFound);\n                // endUpdate();\n                return;\n            }\n        }\n\n        // Complete\n        if (!lastErrorFound) {\n            finalizeMapUiAfterStateUpdate({\n                loadMap,\n                showRONotify: true,\n                refreshIcons: true\n            });\n            // startUpdate();\n        }\n    } else {\n        if (typeof window !== 'undefined') {\n            window.__pendingMapSwitchNotification = null;\n        }\n        setMapState(undefined)\n        finalizeMapUiAfterStateUpdate({\n            loadMap,\n            refreshIcons: true,\n            hideLoading: true,\n            mapStateUpdate: 'loaded'\n        });\n        // startUpdate();\n    }\n}\n\nfunction load_persistent() {\n    if (isSiteUpdateBlocked()) {\n        return;\n    }\n\n    // Skip loading from DB if we're in the middle of an import operation\n    // The imported state is already set in sessionStorage\n    if (typeof window !== 'undefined' && window.skipLoadDuringImport) {\n        console.log('[Load] Skipping DB load during import - using existing imported state');\n        // Still need to update UI to reflect the already-set state\n        mapReloadSavedState();\n        finalizeMapUiAfterStateUpdate({\n            loadMap: false,\n            refreshIcons: true,\n            hideLoading: true,\n            mapStateUpdate: 'loaded'\n        });\n        return;\n    }\n\n    const params = new URLSearchParams(window.location.search);\n    const c = params.get('c'); // URL parameter\n\n    switch (c) {\n        case 's':\n            sessionStorage.clear();\n            break;\n        case 'l':\n            localStorage.clear();\n            break;\n        case 'sl':\n            sessionStorage.clear();\n            localStorage.clear();\n            break;\n        default:\n            sessionStorage.clear();\n            if (localStorage.mapstate) {\n                localStorage.clear();\n            }\n    }\n\n    // Clear session storage if this is a new/unsaved map state\n    // (Don't try to delete from database - there's nothing to delete)\n    if (getGuid() === \"new\") {\n        sessionStorage.removeItem('mapState');\n    }\n\n    loadMapFromDb(true);\n}\n\n/**\n * Migrate legacy localStorage map GUIDs to new savedMaps structure\n * Runs once on page load after map data is fetched from server\n * Merges with existing savedMaps if www migration already added entries\n * @param {Array} mapData - Array of map objects from /mapdata endpoint\n */\nfunction migrateMapStorage(mapData) {\n    // Check if legacy migration already completed\n    if (localStorage.getItem('legacyMigrationCompleted')) {\n        console.log('[Legacy Migration] Already completed, skipping...');\n        return;\n    }\n\n    console.log('[Legacy Migration] Migrating map storage to new savedMaps structure...');\n\n    // Get existing savedMaps (might be from www migration)\n    let existingSavedMapsData = localStorage.getItem('savedMaps');\n    let savedMaps = [];\n    let lastOpenedIndex = -1;\n\n    if (existingSavedMapsData) {\n        try {\n            const parsed = JSON.parse(existingSavedMapsData);\n            savedMaps = parsed.savedMaps || [];\n            lastOpenedIndex = parsed.lastOpenedIndex || -1;\n            console.log(`[Legacy Migration] Found existing savedMaps with ${savedMaps.length} entries`);\n        } catch (e) {\n            console.error('[Legacy Migration] Error parsing existing savedMaps:', e);\n            savedMaps = [];\n        }\n    }\n\n    // Build set of existing GUIDs to avoid duplicates\n    const seenGuids = new Set(savedMaps.map(m => m.guid));\n    const currentMapCode = localStorage.currentMap;\n    const mapCodeCounts = {}; // Track how many entries per map code\n\n    // Count existing entries per map code\n    savedMaps.forEach(m => {\n        mapCodeCounts[m.mapCode] = (mapCodeCounts[m.mapCode] || 0) + 1;\n    });\n\n    let newMapsAdded = 0;\n\n    // Scan all valid map codes from server data\n    mapData.forEach(map => {\n        const mapCode = map.code;\n        const guid = localStorage.getItem(mapCode);\n\n        if (guid && guid !== 'new' && guid !== 'undefined') {\n            // Check for duplicate GUIDs\n            if (!seenGuids.has(guid)) {\n                seenGuids.add(guid);\n\n                // Track if this is the first entry for this mapCode\n                const isFirstForMap = !mapCodeCounts[mapCode];\n                mapCodeCounts[mapCode] = (mapCodeCounts[mapCode] || 0) + 1;\n\n                // Mark as selected if it's first for this map\n                const isLastOpened = isFirstForMap;\n\n                savedMaps.push({\n                    mapCode: mapCode,\n                    guid: guid,\n                    name: \"\",\n                    selected: isLastOpened,\n                    created: null,\n                    lastAccess: new Date().toISOString()\n                });\n\n                // Track if this is the current map for global lastOpenedIndex\n                if (mapCode === currentMapCode && isLastOpened) {\n                    lastOpenedIndex = savedMaps.length - 1;\n                }\n\n                newMapsAdded++;\n            } else {\n                console.log(`[Legacy Migration] Skipping duplicate GUID: ${guid} for map: ${mapCode}`);\n            }\n\n            // Remove legacy localStorage key\n            localStorage.removeItem(mapCode);\n        }\n    });\n\n    // Save merged structure\n    const savedMapsData = {\n        savedMaps: savedMaps,\n        lastOpenedIndex: lastOpenedIndex\n    };\n    localStorage.setItem('savedMaps', JSON.stringify(savedMapsData));\n\n    // Mark legacy migration as completed\n    localStorage.setItem('legacyMigrationCompleted', 'true');\n\n    console.log(`[Legacy Migration] Complete: ${newMapsAdded} new maps added (total: ${savedMaps.length})`);\n}\n\n/**\n * Get the current map's filter state from localStorage\n * @returns Object containing all filter states for the current map\n */\nfunction getFilterState() {\n    const currentMap = localStorage.currentMap || 'olympus';\n    const key = `filterState_${currentMap}`;\n    const stored = localStorage.getItem(key);\n\n    if (stored) {\n        try {\n            return JSON.parse(stored);\n        } catch (e) {\n            // Return default filter state if parsing fails\n            return getDefaultFilterState();\n        }\n    }\n    return getDefaultFilterState();\n}\n\n/**\n * Get the default filter state\n * @returns Object containing default filter states\n */\nfunction getDefaultFilterState() {\n    return {\n        grid: true,\n        metaDeposits: false,\n        enzymeGeysers: false,\n        oilGeysers: false,\n        deepOreDeposits: false,\n        caves: {\n            all: true,\n            rank1: true,\n            rank2: true,\n            rank3: true,\n            rankmax: true,\n            unfinished: true\n        },\n        markers: true,\n        // Ore filtering options\n        oreFilter: {\n            selectedOres: [],\n            includeCaves: true  // Keep filter caves selected by default\n        },\n        // Cave tier filtering options\n        caveTierFilter: {\n            selectedTiers: ['rank1', 'rank2', 'rank3', 'rank5', 'partiallymined', 'mined']\n        },\n        // Selected mission\n        selectedMission: '0',\n        // Prometheus NULL sector features (Spoilers)\n        prometheusNull: {\n            caves: false,\n            ore: false,\n            map: false\n        },\n        // Map view position and zoom\n        mapView: {\n            zoom: null,\n            center: null\n        },\n        // Open world setting\n        isOpenWorld: true\n    };\n}\n\n/**\n * Set the current map's filter state in localStorage\n * @param {Object} filterState The filter state object to save\n */\nfunction setFilterState(filterState) {\n    const currentMap = localStorage.currentMap || 'olympus';\n    const key = `filterState_${currentMap}`;\n    localStorage.setItem(key, JSON.stringify(filterState));\n}\n\n/**\n * Get the selected ore filter types\n * @returns Array of ore state IDs that are currently selected for filtering (e.g. ['i', 'g', 'cu'])\n */\nfunction getOreFilterSelection() {\n    const filterState = getFilterState();\n    return filterState.oreFilter?.selectedOres || [];\n}\n\n/**\n * Save the selected ore filter types\n * @param {Array} selectedOres Array of ore state IDs to filter by\n */\nfunction setOreFilterSelection(selectedOres) {\n    const filterState = getFilterState();\n    if (!filterState.oreFilter) {\n        filterState.oreFilter = { selectedOres: [], includeCaves: true };\n    }\n    filterState.oreFilter.selectedOres = selectedOres;\n    setFilterState(filterState);\n}\n\n/**\n * Check if ore filtering is currently active\n * @returns {boolean} True if any ore types or drills are selected for filtering\n */\nfunction isOreFilterActive() {\n    const selection = getOreFilterSelection();\n    const drills = getOreFilterDrills();\n    return (selection && selection.length > 0) || (drills && drills.length > 0);\n}\n\n/**\n * Get whether cave filtering is enabled\n * @returns {boolean} Whether to filter caves by ore content\n */\nfunction getOreFilterIncludeCaves() {\n    const filterState = getFilterState();\n    return filterState.oreFilter?.includeCaves ?? true;\n}\n\n/**\n * Get the selected drill filter types\n * @returns {Array} Array of drill type IDs ('none', 'b', 'e', 'o')\n */\nfunction getOreFilterDrills() {\n    const filterState = getFilterState();\n    return filterState.oreFilter?.selectedDrills || [];\n}\n\n/**\n * Save the selected drill filter types\n * @param {Array} selectedDrills Array of drill type IDs to filter by\n */\nfunction setOreFilterDrills(selectedDrills) {\n    const filterState = getFilterState();\n    if (!filterState.oreFilter) {\n        filterState.oreFilter = { selectedOres: [], includeCaves: true, selectedDrills: [] };\n    }\n    filterState.oreFilter.selectedDrills = selectedDrills;\n    setFilterState(filterState);\n}\n\n/**\n * Save the current map view (zoom and center position)\n * @param {number} zoom The zoom level\n * @param {Object} center The center position {lat, lng}\n */\nfunction saveMapView(zoom, center) {\n    const filterState = getFilterState();\n    if (!filterState.mapView) {\n        filterState.mapView = {};\n    }\n    filterState.mapView.zoom = zoom;\n    filterState.mapView.center = center;\n    setFilterState(filterState);\n}\n\n/**\n * Get the saved map view for the current map\n * @returns {Object|null} Object with {zoom, center} or null if not saved\n */\nfunction getSavedMapView() {\n    const filterState = getFilterState();\n    return filterState.mapView?.zoom !== null && filterState.mapView?.center !== null\n        ? filterState.mapView\n        : null;\n}\n\n/**\n * Set whether cave filtering is enabled\n * @param {boolean} enabled Whether to filter caves by ore content\n */\nfunction setOreFilterIncludeCaves(enabled) {\n    const filterState = getFilterState();\n    if (!filterState.oreFilter) {\n        filterState.oreFilter = { selectedOres: [], includeCaves: true };\n    }\n    filterState.oreFilter.includeCaves = enabled;\n    setFilterState(filterState);\n}\n\n/**\n * Get the selected cave tier filters\n * @returns Array of cave tier types that are currently selected for filtering (e.g. ['rank1', 'rank2', 'rank3', 'rankmax', 'unfinished'])\n */\nfunction getCaveTierFilterSelection() {\n    const filterState = getFilterState();\n    return filterState.caveTierFilter?.selectedTiers || ['rank1', 'rank2', 'rank3', 'rank5', 'partiallymined', 'mined'];\n}\n\n/**\n * Save the selected cave tier filters\n * @param {Array} selectedTiers Array of cave tier types to filter by\n */\nfunction setCaveTierFilterSelection(selectedTiers) {\n    const filterState = getFilterState();\n    if (!filterState.caveTierFilter) {\n        filterState.caveTierFilter = { selectedTiers: [] };\n    }\n    filterState.caveTierFilter.selectedTiers = selectedTiers;\n    setFilterState(filterState);\n}\n\n/**\n * Check if cave tier filtering is currently active (not all selected)\n * @returns {boolean} True if not all cave tiers are selected\n */\nfunction isCaveTierFilterActive() {\n    const selection = getCaveTierFilterSelection();\n    // Filter is active when NOT all 6 options are selected\n    return selection.length < 6;\n}\n\n/**\n * Delete a map state from the database\n * Marks the map as deleted if the guidrw matches\n * @param {string} guid - The guidrw of the map to delete\n * @returns {Promise} Promise that resolves when the delete is complete\n */\nfunction deleteMapState(guid) {\n    return new Promise((resolve, reject) => {\n        if (!guid || guid === 'new') {\n            resolve(new Error('Invalid GUID'));\n            return;\n        }\n\n        fetch('map/delete/' + encodeURIComponent(guid), {\n            method: 'POST',\n            headers: {\n                'Content-Type': 'application/x-www-form-urlencoded',\n            }\n        })\n            .then(response => {\n                if (!response.ok) {\n                    throw new Error(response.status + ' ' + response.statusText);\n                }\n                return response.json();\n            })\n            .then(data => {\n                debugLog('saving', 'Map deleted successfully:', data);\n                resolve(data);\n            })\n            .catch(error => {\n                console.error('Delete error:', error);\n                reject(error);\n            });\n    });\n}\n\n/**\n * Create a new empty map state for the specified map code\n * Saves current map if there are unsaved changes, then creates a fresh empty state\n * @param {string} mapCode - The map code to create a new state for (e.g., 'olympus', 'styx')\n * @param {Object} options - Optional behavior flags\n * @param {boolean} options.suppressNotification - Skip \"new map created\" success toast\n */\nfunction createNewMapState(mapCode, options = {}) {\n    if (!mapCode) {\n        console.error('Map code is required to create new map state');\n        return;\n    }\n\n    const suppressNotification = options.suppressNotification === true;\n\n    debugLog('saving', 'Creating new map state for:', mapCode);\n\n    // Get current state to check for changes\n    const currentMapState = getMapState();\n    const currentMapCode = localStorage.currentMap || 'olympus';\n\n    // Save current map if there are unsaved changes\n    if (currentMapState && currentMapState.change === \"new\") {\n        debugLog('saving', 'Saving current map before creating new state');\n        if (typeof saveBeforeMapSwitch !== 'undefined') {\n            saveBeforeMapSwitch(currentMapCode);\n        }\n    }\n\n    // Create empty map state\n    const newMapState = {\n        map: mapCode,\n        cave_status: [],\n        deposit_status: [],\n        exotics_status: [],\n        custom_marker: [],\n        guid: 'new',\n        change: undefined, // Don't mark as changed until user makes actual changes\n        rights: 'rw',\n        version: 1\n    };\n\n    // Switch to the new map context first\n    localStorage.currentMap = mapCode;\n\n    // Clear the selected flag from all entries for this map code\n    // and create a new entry for the unsaved map state\n    if (typeof getSavedMaps !== 'undefined' && typeof setSavedMaps !== 'undefined') {\n        const savedMapsData = getSavedMaps();\n        savedMapsData.savedMaps.forEach(m => {\n            if (m.mapCode === mapCode) {\n                m.selected = false;\n            }\n        });\n\n        // Create new entry for the unsaved map (guid: 'new')\n        // This allows user to edit the name before saving\n        const newEntry = {\n            mapCode: mapCode,\n            guid: 'new',\n            name: '',\n            selected: true,\n            created: null,\n            lastAccess: new Date().toISOString(),\n            markedForDeletion: false\n        };\n\n        savedMapsData.savedMaps.push(newEntry);\n        savedMapsData.lastOpenedIndex = savedMapsData.savedMaps.length - 1;\n\n        setSavedMaps(savedMapsData);\n        debugLog('saving', 'Created new map entry with guid: new for map:', mapCode);\n    }\n\n    // Set the new empty state\n    if (typeof setMapState !== 'undefined') {\n        setMapState(newMapState);\n    }\n\n    // Clear all existing map elements\n    if (typeof customMarkersClear !== 'undefined') {\n        customMarkersClear();\n    }\n\n    // Update the map state icon\n    if (typeof updateMapState !== 'undefined') {\n        updateMapState('loaded', 'New map created');\n    }\n\n    // If we're on a different map, trigger a map switch\n    if (currentMapCode !== mapCode) {\n        if (typeof switchMap !== 'undefined') {\n            switchMap(mapCode);\n        }\n    } else {\n        // Same map, just reload the display with empty state\n        // Update all layer states to reflect empty state\n        if (typeof updateCavesState === 'function') {\n            updateCavesState();\n        }\n        if (typeof updateOreDepositState === 'function') {\n            updateOreDepositState();\n        }\n        if (typeof updateMetaDepositState === 'function') {\n            updateMetaDepositState();\n        }\n\n        // Ensure custom markers are loaded (should be empty)\n        const filterState = getFilterState();\n        if (typeof loadCustomMarkers === 'function') {\n            loadCustomMarkers(filterState.markers);\n        }\n    }\n\n    // Show notification\n    if (!suppressNotification && typeof NotificationSystem !== 'undefined') {\n        NotificationSystem.success('New map created. Make changes and save to generate a shareable link.', 5000);\n    }\n\n    debugLog('saving', 'New map state created:', newMapState);\n}\n\nfunction formatMapSwitchDisplayName(mapCode) {\n    if (!mapCode) return 'Unknown map';\n\n    const mapSelector = document.getElementById('mapSelector');\n    if (mapSelector) {\n        const option = mapSelector.querySelector(`option[value=\"${mapCode}\"]`);\n        if (option && option.textContent) {\n            return option.textContent.trim();\n        }\n    }\n\n    return mapCode\n        .replace(/([a-z])([0-9])/gi, '$1 $2')\n        .replace(/_/g, ' ')\n        .replace(/\\b\\w/g, (c) => c.toUpperCase());\n}\n\nfunction showMapStateSwitchSuccessNotification(entry, targetMapCode) {\n    if (typeof NotificationSystem === 'undefined') return;\n\n    const mapSaveName = entry && entry.name ? entry.name : 'Unnamed Map';\n    const mapDisplayName = formatMapSwitchDisplayName(targetMapCode);\n    NotificationSystem.success(`Map save changed to \"${mapSaveName}\" on ${mapDisplayName}.`, 3500);\n}\n\n/**\n * Switch to a specific saved map state by GUID (for dev console use)\n * Usage in console: switchToMapStateByGuid('your-guid-here')\n * To list all saved maps: getSavedMaps()\n * @param {string} guid - The GUID of the map state to load\n * @param {string} mapCode - Optional map code, will be detected from saved maps if not provided\n */\nfunction switchToMapStateByGuid(guid, mapCode = null) {\n    return new Promise((resolve, reject) => {\n        try {\n            if (isSiteUpdateBlocked()) {\n                reject(new Error('Site updated, reload required'));\n                return;\n            }\n\n            if (!guid || guid === 'new') {\n                console.error('Please provide a valid GUID');\n                console.log('Available saved maps:', getSavedMaps());\n                reject(new Error('Invalid GUID'));\n                return;\n            }\n\n            // Find the map entry\n            const savedMapsData = getSavedMaps();\n            const entry = savedMapsData.savedMaps.find(m => m.guid === guid);\n\n            if (!entry) {\n                console.error('GUID not found in saved maps:', guid);\n                console.log('Available saved maps:', savedMapsData);\n                reject(new Error('GUID not found'));\n                return;\n            }\n\n            const targetMapCode = mapCode || entry.mapCode;\n            const currentMapCode = localStorage.currentMap || 'olympus';\n\n            console.log('Switching to map state:', {\n                guid: guid,\n                mapCode: targetMapCode,\n                name: entry.name || 'No name',\n                created: entry.created || 'Unknown',\n                lastAccess: entry.lastAccess || 'Never'\n            });\n\n            // Clean up any unsaved map entries before switching\n            if (typeof cleanupUnsavedMapEntries !== 'undefined') {\n                cleanupUnsavedMapEntries();\n            }\n\n            // Save current map if there are unsaved changes\n            const currentMapState = getMapState();\n            if (currentMapState && currentMapState.change === \"new\") {\n                debugLog('saving', 'Unsaved changes detected. Saving current map before switching.');\n                if (typeof saveBeforeMapSwitch !== 'undefined') {\n                    saveBeforeMapSwitch(currentMapCode);\n                }\n            }\n\n            // Set the new GUID as active\n            const previousMap = localStorage.currentMap;\n            localStorage.currentMap = targetMapCode;\n\n            if (typeof setGuid !== 'undefined') {\n                debugLog('saving', 'Setting GUID before loading map:', guid);\n                setGuid(guid);\n                // Verify the GUID was set correctly\n                const verifyGuid = typeof getGuid !== 'undefined' ? getGuid() : null;\n                debugLog('saving', 'GUID after setGuid:', verifyGuid);\n            } else {\n                console.error('setGuid function not available');\n            }\n\n            if (typeof updateCurrentMapNameDisplay !== 'undefined') {\n                updateCurrentMapNameDisplay({\n                    name: entry.name,\n                    isUnsaved: guid === 'new'\n                });\n            }\n\n            // Update map selector if switching to a different map\n            if (currentMapCode !== targetMapCode) {\n                const mapSelector = document.getElementById('mapSelector');\n                if (mapSelector && mapSelector.value !== targetMapCode) {\n                    mapSelector.value = targetMapCode;\n                    // Don't dispatch change event - switchMap will handle it\n                }\n            }\n\n            // If switching to a different map, trigger map switch\n            if (currentMapCode !== targetMapCode) {\n                debugLog('saving', `Current map (${currentMapCode}) is different from target map (${targetMapCode}). Triggering map switch.`);\n\n                const waitForMapReload = new Promise((resolveReload) => {\n                    let resolved = false;\n\n                    const cleanup = () => {\n                        window.removeEventListener('mapReloadComplete', onMapReloadComplete);\n                    };\n\n                    const onMapReloadComplete = (event) => {\n                        if (!event || !event.detail) return;\n                        const reloadedMapCode = event.detail.mapCode;\n                        if (reloadedMapCode !== targetMapCode && reloadedMapCode !== selectedMapParent) {\n                            return;\n                        }\n\n                        if (!resolved) {\n                            resolved = true;\n                            cleanup();\n                            resolveReload(event.detail);\n                        }\n                    };\n\n                    window.addEventListener('mapReloadComplete', onMapReloadComplete);\n\n                    setTimeout(() => {\n                        if (!resolved) {\n                            resolved = true;\n                            cleanup();\n                            resolveReload({ success: false, timeout: true });\n                        }\n                    }, 8000);\n                });\n\n                if (typeof switchMap !== 'undefined') {\n                    if (typeof window !== 'undefined') {\n                        window.__suppressNextMapSwitchLoadNotification = true;\n                    }\n                    try {\n                        switchMap(targetMapCode);\n                    } finally {\n                        if (typeof window !== 'undefined') {\n                            window.__suppressNextMapSwitchLoadNotification = false;\n                        }\n                    }\n                }\n\n                waitForMapReload.then((result) => {\n                    if (result && result.timeout) {\n                        debugLog('saving', 'Map reload completion timed out, proceeding with fallback resolution');\n                    }\n\n                    debugLog('saving', 'Map state switch complete');\n                    showMapStateSwitchSuccessNotification(entry, targetMapCode);\n                    resolve();\n                });\n            } else {\n                // Same map, just load the new state\n                debugLog('saving', 'Loading map state for current map...');\n                if (typeof loadMapFromDb !== 'undefined') {\n                    loadMapFromDb(true);\n                }\n\n                debugLog('saving', 'Map state switch complete');\n                showMapStateSwitchSuccessNotification(entry, targetMapCode);\n                resolve();\n            }\n        } catch (error) {\n            console.error('Error switching map state:', error);\n            reject(error);\n        }\n    });\n}\n\n/**\n * Switch to a saved map by its index in the savedMaps array (for dev console use)\n * Usage in console: switchToMapByIndex(0)  // Opens the first saved map\n * To list all saved maps with indices: getSavedMaps().savedMaps.forEach((m, i) => console.log(i, m.mapCode, m.guid, m.name))\n * @param {number} index - The index in the savedMaps array\n */\nfunction switchToMapByIndex(index) {\n    const savedMapsData = getSavedMaps();\n\n    if (!savedMapsData.savedMaps || savedMapsData.savedMaps.length === 0) {\n        console.error('No saved maps found');\n        return;\n    }\n\n    if (index < 0 || index >= savedMapsData.savedMaps.length) {\n        console.error('Invalid index. Valid range: 0 to', savedMapsData.savedMaps.length - 1);\n        console.log('Available maps:');\n        savedMapsData.savedMaps.forEach((m, i) => {\n            console.log(`  [${i}] ${m.mapCode} - ${m.name || 'No name'} - GUID: ${m.guid}`);\n        });\n        return;\n    }\n\n    const mapEntry = savedMapsData.savedMaps[index];\n    console.log(`Switching to map [${index}]:`, mapEntry);\n\n    // Use the existing switchToMapStateByGuid function\n    if (typeof switchToMapStateByGuid !== 'undefined') {\n        switchToMapStateByGuid(mapEntry.guid, mapEntry.mapCode);\n    } else {\n        console.error('switchToMapStateByGuid function not available');\n    }\n}\n\n// Initialize change tracker on script load\nif (typeof ChangeTracker !== 'undefined') {\n    ChangeTracker.init();\n}\n"
          },
