          "content": {
            "size": 16335,
            "mimeType": "text/javascript",
            "text": "//Custom icons => Material Symbols\nconst customIconNames = [\n    'location_on',\n    'home',\n    'fort',\n    'camping',\n    'mode_heat',\n    'favorite',\n    'star',\n\n    'bed',\n    'search',\n    'lock',\n    'pets',\n    'skull',\n    'warning_amber',\n    'chess_knight',\n\n    'water_medium',\n    'yakitori',\n    'forest',\n    'volcano',\n    'visibility',\n    'explore',\n    'phishing',\n];\n\nlet customMarkersLayer = L.layerGroup();\n\nlet _defaultColor = '#f5ea6e';\nconst MAX_CUSTOM_MARKERS = 75; // Limit to prevent excessive markers that could impact performance\n\n// customMarkersLayer.addTo(map);\n\nfunction customMarkerShowMenu(latlng) {\n    customMarkerLastLatLng = latlng;\n    customMarkerChangeMenu(null); // null = create new marker\n}\n\nfunction customMarkerChangeMenu(existingMarker = null) {\n    const isEditMode = existingMarker !== null;\n\n    const wrapper = document.createElement('div');\n    wrapper.id = 'customMarkerWrapper';\n    wrapper.className = 'custom-marker-popup';\n\n    // Header\n    const header = document.createElement('h3');\n    header.className = 'popup-title';\n    header.textContent = isEditMode ? 'Edit Custom Marker' : 'Create Custom Marker';\n    wrapper.appendChild(header);\n\n    // Icon selection section\n    const iconSection = document.createElement('div');\n    iconSection.className = 'popup-section';\n    const iconLabel = document.createElement('label');\n    iconLabel.className = 'popup-label';\n    iconLabel.textContent = 'Select Icon';\n    iconSection.appendChild(iconLabel);\n\n    // Store selected color and icon\n    let selectedColor = isEditMode ? existingMarker.color : _defaultColor;\n    if (isEditMode) {\n        selectedIconValue = existingMarker.icon;\n    } else {\n        selectedIconValue = null; // Reset to null for create mode\n    }\n\n    const iconGrid = createIconGrid(isEditMode ? existingMarker.icon : null, selectedColor);\n    iconSection.appendChild(iconGrid);\n    wrapper.appendChild(iconSection);\n\n    // Color selection section\n    const colorSection = document.createElement('div');\n    colorSection.className = 'popup-section';\n    const colorLabel = document.createElement('label');\n    colorLabel.className = 'popup-label';\n    colorLabel.textContent = 'Choose Color';\n    colorSection.appendChild(colorLabel);\n\n    // Color swatches grid\n    const colorGrid = document.createElement('div');\n    colorGrid.className = 'color-grid';\n    const colors = [\n        '#fdfdfd', '#abb4bb', '#424242', '#1c1c1c',\n        '#3db159',\n        '#2E7D32',\n        '#28ff00',\n        '#f5ea6e',\n        '#FBC02D',\n        '#fe7320',\n        '#f63200',\n        '#C62828',\n        '#fd7cd5',\n        '#fd00ae',\n        '#38fefe',\n        '#00ACC1',\n        '#1E88E5',\n        '#1565C0',\n        '#8d3dda',\n        '#8E24AA',\n    ];\n\n    colors.forEach(color => {\n        const colorSwatch = document.createElement('div');\n        colorSwatch.className = 'color-swatch';\n        if (color === selectedColor) {\n            colorSwatch.classList.add('selected');\n        }\n        colorSwatch.style.backgroundColor = color;\n        colorSwatch.title = color;\n\n        colorSwatch.addEventListener('click', () => {\n            // Remove previous selection\n            colorGrid.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));\n            colorSwatch.classList.add('selected');\n            selectedColor = color;\n\n            // Update icon preview color\n            iconGrid.querySelectorAll('.mi').forEach(icon => {\n                icon.style.setProperty('--mi-color', color);\n            });\n        });\n\n        colorGrid.appendChild(colorSwatch);\n    });\n\n    // Add custom color picker swatch\n    const customSwatch = document.createElement('div');\n    customSwatch.className = 'color-swatch custom';\n    customSwatch.title = 'Custom color';\n\n    const customColorInput = document.createElement('input');\n    customColorInput.type = 'color';\n    customColorInput.value = selectedColor;\n    customColorInput.className = 'custom-color-input';\n    customSwatch.appendChild(customColorInput);\n\n    customSwatch.addEventListener('click', () => {\n        customColorInput.click();\n    });\n\n    customColorInput.addEventListener('input', (e) => {\n        const customColor = e.target.value;\n        colorGrid.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));\n        customSwatch.classList.add('selected');\n        selectedColor = customColor;\n\n        // Update icon preview color\n        iconGrid.querySelectorAll('.mi').forEach(icon => {\n            icon.style.setProperty('--mi-color', customColor);\n        });\n    });\n\n    colorGrid.appendChild(customSwatch);\n\n    colorSection.appendChild(colorGrid);\n    wrapper.appendChild(colorSection);\n\n    // Label input section\n    const labelSection = document.createElement('div');\n    labelSection.className = 'popup-section';\n    const labelLabel = document.createElement('label');\n    labelLabel.className = 'popup-label';\n    labelLabel.textContent = 'Label (optional)';\n    labelSection.appendChild(labelLabel);\n\n    const labelInput = document.createElement('input');\n    labelInput.id = 'markerLabel';\n    labelInput.type = 'text';\n    labelInput.maxLength = 25;\n    labelInput.placeholder = 'Enter marker description';\n    labelInput.className = 'popup-input';\n    if (isEditMode) {\n        labelInput.value = existingMarker.text || '';\n    }\n    labelSection.appendChild(labelInput);\n    wrapper.appendChild(labelSection);\n\n    // Button section\n    const buttonSection = document.createElement('div');\n    buttonSection.className = 'popup-buttons';\n\n    if (isEditMode) {\n        const saveBtn = document.createElement('button');\n        saveBtn.textContent = 'Save Changes';\n        saveBtn.id = 'saveMarkerBtn';\n        saveBtn.className = 'popup-button primary';\n        buttonSection.appendChild(saveBtn);\n\n        const removeBtn = document.createElement('button');\n        removeBtn.textContent = 'Remove Marker';\n        removeBtn.id = 'removeMarkerBtn';\n        removeBtn.className = 'popup-button danger';\n        buttonSection.appendChild(removeBtn);\n    } else {\n        const addBtn = document.createElement('button');\n        addBtn.textContent = 'Add Marker';\n        addBtn.id = 'addMarkerBtn';\n        addBtn.className = 'popup-button primary';\n        buttonSection.appendChild(addBtn);\n\n        const cancelBtn = document.createElement('button');\n        cancelBtn.textContent = 'Cancel';\n        cancelBtn.id = 'cancelBtn';\n        cancelBtn.className = 'popup-button';\n        buttonSection.appendChild(cancelBtn);\n    }\n\n    wrapper.appendChild(buttonSection);\n\n    customMarkerPopup.setLatLng(isEditMode ? existingMarker.position : customMarkerLastLatLng);\n    customMarkerPopup.setContent(wrapper);\n    customMarkerPopup.openOn(map);\n\n    setTimeout(() => {\n        if (isEditMode) {\n            document.getElementById('saveMarkerBtn').addEventListener('click', () => {\n                if (selectedIconValue == null) {\n                    notificationControl.alert(\"Please select an icon for the marker.\");\n                    return;\n                }\n\n                const label = document.getElementById('markerLabel').value.trim();\n\n                // Find the existing marker\n                const marker = Object.values(customMarkersLayer._layers)\n                    .find(layer => layer.customId === existingMarker.id);\n\n                if (marker) {\n                    // Update the marker's icon\n                    const newIcon = materialIconMarker(existingMarker.position, {\n                        icon: selectedIconValue,\n                        color: selectedColor,\n                        size: 32\n                    }).getIcon();\n                    marker.setIcon(newIcon);\n\n                    // Update the marker's popup\n                    marker.bindPopup(label, { autoPan: false });\n                }\n\n                // Update the marker state (tracks as edited, not delete+add)\n                editCustomMarkerState(existingMarker.id, existingMarker.position, selectedIconValue, selectedColor, label);\n\n                customMarkerCloseMenu();\n            });\n\n            document.getElementById('removeMarkerBtn').addEventListener('click', () => {\n                const marker = Object.values(customMarkersLayer._layers)\n                    .find(layer => layer.customId === existingMarker.id);\n                if (marker) {\n                    customMarkersLayer.removeLayer(marker);\n                }\n                deleteCustomMarker(existingMarker.id);\n                customMarkerCloseMenu();\n            });\n        } else {\n            document.getElementById('addMarkerBtn').addEventListener('click', () => {\n                if (selectedIconValue == null) {\n                    notificationControl.alert(\"Please select an icon for the marker.\");\n                    return;\n                }\n\n                const label = document.getElementById('markerLabel').value.trim();\n                customMarkerAddMarker(customMarkerLastLatLng, selectedIconValue, selectedColor, label);\n            });\n\n            document.getElementById('cancelBtn').addEventListener('click', () => {\n                customMarkerCloseMenu();\n            });\n        }\n    }, 0);\n}\n\nlet selectedIconValue = null;\n\nfunction createIconGrid(selectedIcon = null, selectedColor = _defaultColor) {\n    const container = document.createElement('div');\n    container.className = 'icon-grid-container';\n\n    customIconNames.forEach(item => {\n        const iconWrapper = document.createElement('div');\n        iconWrapper.className = 'icon-grid-item';\n\n        // Pre-select icon if provided\n        if (selectedIcon === item) {\n            iconWrapper.classList.add('selected');\n        }\n\n        const img = document.createElement('span');\n        img.className = 'mi';\n        img.textContent = item;\n        img.style = `--mi-color: ${selectedColor}; --mi-size: 22px;`;\n\n        iconWrapper.appendChild(img);\n\n        iconWrapper.addEventListener('click', () => {\n            selectedIconValue = item;\n\n            // Remove selection from all icons\n            container.querySelectorAll('.icon-grid-item').forEach(div => {\n                div.classList.remove('selected');\n            });\n\n            // Mark selected icon\n            iconWrapper.classList.add('selected');\n        });\n\n        container.appendChild(iconWrapper);\n    });\n\n    return container;\n}\n\nfunction customMarkerCloseMenu() {\n    map.closePopup(customMarkerPopup);\n}\n\nfunction materialIconMarker(latlng, opts) {\n    const {\n        icon,\n        color = '#1976d2',\n        size = 36,\n        fill = true,\n        weight = 400,\n        grad = 0,\n        title = ''\n    } = opts || {};\n\n    const style = `--mi-color:${color}; --mi-size:${size}px;`;\n    const fvs = `'OPSZ' ${Math.max(20, Math.min(48, size))}, 'wght' ${weight}, 'FILL' ${fill ? '1' : '0'}, 'GRAD' ${grad}`;\n\n\n    const html = `\n        <div class=\"mi-wrapper\" aria-hidden=\"true\">\n          <span class=\"mi\" style=\"${style}; font-variation-settings:${fvs}\">${icon}</span>\n        </div>\n      `;\n\n    const iconSize = [size, size];\n    const iconAnchor = [size / 2, size / 2];\n\n    const divIcon = L.divIcon({\n        className: 'mi-divicon',\n        html,\n        iconSize,\n        iconAnchor,\n    });\n\n    const marker = L.marker(latlng, { icon: divIcon, title });\n    return marker;\n}\n\nfunction loadCustomMarkers(showInMap) {\n    let mapState = getMapState();\n\n    if (mapState.custom_marker === undefined || mapState.custom_marker.length < 1) {\n        return;\n    }\n\n    mapState.custom_marker.forEach(function (marker) {\n        // Use correct parameter order: position, icon, color, text, id, save\n        customMarkerAddMarker(marker.pos, marker.icon, marker.color || _defaultColor, marker.desc, marker.id, false);\n    });\n\n    if (showInMap) {\n        toggleCustomMarkerLayer(true);\n    }\n}\n\nfunction getNextCustomMarkerId() {\n    const mapState = getMapState();\n    if (!mapState.custom_marker || mapState.custom_marker.length === 0) {\n        return 1;\n    }\n\n    // Get all existing IDs\n    const existingIds = mapState.custom_marker.map(m => m.id).sort((a, b) => a - b);\n\n    // Find first gap in sequence (reuse deleted IDs)\n    for (let i = 1; i <= MAX_CUSTOM_MARKERS; i++) {\n        if (!existingIds.includes(i)) {\n            return i;\n        }\n    }\n\n    // No gaps found, return next sequential ID if under limit\n    return existingIds.length < MAX_CUSTOM_MARKERS ? existingIds[existingIds.length - 1] + 1 : null;\n}\n\nfunction customMarkerAddMarker(position, icon, color, text, id = 0, save = true) {\n    // Check marker limit\n    const mapState = getMapState();\n    if (save && mapState.custom_marker && mapState.custom_marker.length >= MAX_CUSTOM_MARKERS) {\n        if (typeof notificationControl !== 'undefined') {\n            notificationControl.warning('Marker Limit Reached', `Maximum of ${MAX_CUSTOM_MARKERS} custom markers allowed.`);\n        }\n        return;\n    }\n\n    if (id === 0) {\n        id = getNextCustomMarkerId();\n        if (id === null) {\n            if (typeof notificationControl !== 'undefined') {\n                notificationControl.warning('Marker Limit Reached', `Maximum of ${MAX_CUSTOM_MARKERS} custom markers allowed.`);\n            }\n            return;\n        }\n    } else {\n        const exists = Object.values(customMarkersLayer._layers)\n            .some(layer => layer.customId === id);\n\n        if (exists) {\n            return;\n        }\n    }\n\n    let marker = materialIconMarker(position, {\n        icon: icon,\n        color: color,\n        size: 32\n    })\n\n    // let marker = L.marker(position, {icon: iconN});\n    marker.customId = id;\n\n    marker.bindPopup(text, { autoPan: false });\n    marker.addTo(customMarkersLayer);\n\n    marker.on('mouseover', function (e) {\n        if (text.length > 0) {\n            this.openPopup();\n        }\n    });\n\n    marker.on('mouseout', function (e) {\n        this.closePopup();\n    });\n\n    marker.on('click', function (e) {\n        let mapState = getMapState().rights;\n        if (mapState == \"ro\") return;\n\n        if (!window.mobileAndTabletCheck()) {\n            if (this.getPopup().isOpen()) {\n                this.closePopup();\n            }\n        }\n\n        // Get marker data from state\n        const markerState = getMapState().custom_marker?.find(m => m.id === id);\n        if (markerState) {\n            customMarkerChangeMenu({\n                id: id,\n                position: position,\n                icon: icon,\n                color: color,\n                text: text\n            });\n        }\n    });\n\n    // Stop map zoom and map move when quickly clicking on marker\n    marker.on('dblclick', function (e) {\n        L.DomEvent.stopPropagation(e);\n    });\n\n    customMarkerCloseMenu();\n\n    if (save) {\n        addCustomMarkerState(id, position, icon, color, text);\n        // Ensure the custom markers layer is visible on the map\n        if (!map.hasLayer(customMarkersLayer)) {\n            customMarkersLayer.addTo(map);\n            // Update filter state to reflect the layer is now visible\n            const filterState = getFilterState();\n            filterState.markers = true;\n            setFilterState(filterState);\n            // Update the filter checkbox\n            if (typeof filterCustomMarkers !== 'undefined') {\n                const checkbox = document.getElementById(filterCustomMarkers);\n                if (checkbox) {\n                    checkbox.checked = true;\n                }\n            }\n        }\n    }\n}\n\nmap.on('contextmenu', function (e) {\n    let mapState = getMapState().rights;\n    if (mapState == \"ro\") return;\n\n    if (filterGetState(filterCustomMarkers)) {\n        customMarkerShowMenu(e.latlng);\n    }\n});\n\nmap.on('click', function (e) {\n    customMarkerCloseMenu();\n});\n\nfunction toggleCustomMarkerLayer(state) {\n    if (!state) {\n        if (customMarkersLayer != null && map.hasLayer(customMarkersLayer)) {\n            map.removeLayer(customMarkersLayer);\n        }\n\n        return;\n    }\n\n    if (customMarkersLayer != null && !map.hasLayer(customMarkersLayer)) {\n        customMarkersLayer.addTo(map);\n    }\n}\n\nfunction customMarkersClear() {\n    if (customMarkersLayer != null) {\n        customMarkersLayer.clearLayers();\n    }\n}\n"
          },
          "redirectURL": "",
          "headersSize": -1,
          "bodySize": 0,
          "_transferSize": 0,
          "_error": null,
          "_fetchedViaServiceWorker": false
        },
