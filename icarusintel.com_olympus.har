            "mimeType": "text/javascript",
            "text": "let cachedMissionsListData = {};\nlet cachedMissionDetailsData = {};\nlet currentMissionsMap = '';\nlet currentDisplayedProspect = null; // Store current prospect to update bounds on toggle change\nlet isProspectBoundsVisible = true; // Track bounds visibility state\n\n// General exotic deposits layer (for all deposits on map, not mission-specific)\nlet lg_metaDeposits = L.layerGroup();\n\n// Layer groups\nlet prospectBoundsGroup = L.featureGroup();\nlet prospectExoticsGroup = L.layerGroup();\nlet prospectMarkersGroup = L.layerGroup();\n\nlet cachedMetaDepositsData = {};\n\n// Prospect difficulties display\nconst prospectDifficulties = {\n    'EASY': '<img class=\"icon\" src=\"icon/d1.png\"> <img class=\"icon\" src=\"icon/d0.png\"> <img class=\"icon\" src=\"icon/d0.png\"> <img class=\"icon\" src=\"icon/d0.png\">',\n    'NORMAL': '<img class=\"icon\" src=\"icon/d2.png\"> <img class=\"icon\" src=\"icon/d2.png\"> <img class=\"icon\" src=\"icon/d0.png\"> <img class=\"icon\" src=\"icon/d0.png\">',\n    'HARD': '<img class=\"icon\" src=\"icon/d3.png\"> <img class=\"icon\" src=\"icon/d3.png\"> <img class=\"icon\" src=\"icon/d3.png\"> <img class=\"icon\" src=\"icon/d0.png\">',\n    'EXTREME': '<img class=\"icon\" src=\"icon/d4.png\"> <img class=\"icon\" src=\"icon/d4.png\"> <img class=\"icon\" src=\"icon/d4.png\"> <img class=\"icon\" src=\"icon/d4.png\">',\n};\n\nfunction setMissionsData(mapName, missionsList) {\n    // Cache the mission list (only id, code, title)\n    cachedMissionsListData[mapName] = missionsList;\n    currentMissionsMap = mapName;\n\n    // Clear any previously displayed mission when map changes\n    clearProspect();\n\n    // Populate mission dropdown\n    populateMissionDropdown(missionsList);\n    \n    // Initialize and sync open world toggle\n    initializeOpenWorldToggle();\n\n    // Note: General exotic deposits will be loaded separately when needed\n}\n\nfunction populateMissionDropdown(missionsList) {\n    const missionDropdown = document.getElementById('mission');\n    if (!missionDropdown) return;\n\n    // Clear existing options except the first one\n    while (missionDropdown.options.length > 1) {\n        missionDropdown.remove(1);\n    }\n\n    // Add missions for current map\n    missionsList.forEach(mission => {\n        const option = document.createElement('option');\n        option.value = mission.code;\n        option.textContent = mission.title;\n        missionDropdown.appendChild(option);\n    });\n\n    // Restore saved mission selection from filter state\n    const filterState = getFilterState();\n    const savedMission = filterState.selectedMission || '0';\n    missionDropdown.value = savedMission;\n\n    // Set mission div visibility based on selection\n    const missDiv = document.getElementById('miss');\n    if (missDiv) {\n        missDiv.style.display = (savedMission && savedMission !== '0') ? '' : 'none';\n    }\n\n    // Show/hide clear button based on selection\n    const clearBtn = document.getElementById('clearMissionBtn');\n    if (clearBtn) {\n        clearBtn.style.display = (savedMission && savedMission !== '0') ? 'block' : 'none';\n    }\n\n    // Load the mission if one was selected\n    if (savedMission && savedMission !== '0') {\n        loadSelectedProspect(savedMission);\n    }\n}\n\nfunction selectProspect(event) {\n    const prospectCode = event ? event.target.value : document.getElementById('mission').value;\n\n    // Save mission selection to filter state\n    const filterState = getFilterState();\n    filterState.selectedMission = prospectCode || '0';\n    setFilterState(filterState);\n\n    // Toggle mission div visibility\n    const missDiv = document.getElementById('miss');\n    if (missDiv) {\n        missDiv.style.display = (prospectCode && prospectCode !== '0') ? '' : 'none';\n    }\n\n    // Show/hide clear button based on selection\n    const clearBtn = document.getElementById('clearMissionBtn');\n    if (clearBtn) {\n        clearBtn.style.display = (prospectCode && prospectCode !== '0') ? 'block' : 'none';\n    }\n\n    if (!prospectCode || prospectCode === '0') {\n        clearProspect();\n        return;\n    }\n\n    loadSelectedProspect(prospectCode);\n}\n\nfunction loadSelectedProspect(prospectCode) {\n    // Show loading indicator\n    const missElement = document.getElementById('miss');\n    if (missElement) {\n        missElement.innerHTML = '<p style=\"text-align: center; padding: 20px;\">Loading mission details...</p>';\n    }\n\n    // Check cache first\n    const cacheKey = `${currentMissionsMap}_${prospectCode}`;\n    if (cachedMissionDetailsData[cacheKey]) {\n        displayMissionDetails(cachedMissionDetailsData[cacheKey], prospectCode);\n        return;\n    }\n\n    // Fetch full mission data\n    fetch(`/map/mission/${currentMissionsMap}/${prospectCode}`)\n        .then(response => {\n            if (!response.ok) {\n                throw new Error(`HTTP error! status: ${response.status}`);\n            }\n            return response.json();\n        })\n        .then(data => {\n            // Cache the mission details\n            cachedMissionDetailsData[cacheKey] = data;\n\n            // Display the mission\n            displayMissionDetails(data, prospectCode);\n\n            // Hide loading overlay\n            if (typeof hideMapLoading !== 'undefined') {\n                hideMapLoading();\n            }\n        })\n        .catch(error => {\n            console.error('Error loading mission details:', error);\n\n            // Hide loading overlay\n            if (typeof hideMapLoading !== 'undefined') {\n                hideMapLoading();\n            }\n\n            if (missElement) {\n                missElement.innerHTML = '<p style=\"color: red;\">Failed to load mission details. Please try again.</p>';\n            }\n        });\n}\n\nfunction displayMissionDetails(missionData, prospectCode) {\n    const prospect = missionData.prospect;\n\n    // Clear previous prospect display\n    clearProspect();\n\n    // Always show bounds by default when new mission is selected\n    isProspectBoundsVisible = true;\n\n    // Store current prospect for bounds updates\n    currentDisplayedProspect = prospect;\n    // Store full mission data for open world toggle refresh\n    window.currentMissionData = missionData;\n\n    // Display prospect information including objectives\n    displayProspectInfo(prospect, missionData.prospectQuests);\n\n    // Always show prospect bounds (use Bounds_Full as default if no bounds specified)\n    showProspectBounds(prospect);\n\n    // Show prospect markers\n    showProspectMarkers(missionData);\n\n    // Show exotic deposits\n    showProspectExotics(prospect, missionData);\n}\n\nfunction displayProspectInfo(prospect, quests) {\n    const missElement = document.getElementById('miss');\n    if (!missElement) return;\n\n    // Build mission title with optional bounds toggle\n    let titleHtml = `<h3 class=\"mission-title\" style=\"margin: 0;\">${prospect.title}</h3>`;\n    \n    // Add bounds toggle on same line only if custom bounds exist (not Bounds_Full)\n    const hasCustomBounds = prospect.bounds && prospect.bounds !== 'null' && prospect.bounds !== 'Bounds_Full';\n    if (hasCustomBounds) {\n        titleHtml = `<div style=\"display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 12px;\"><div style=\"flex: 1;\">${titleHtml}</div><div style=\"display: flex; align-items: center; gap: 4px; white-space: nowrap;\"><span style=\"font-size: 12px; color: var(--text-secondary);\">Show bounds</span><label class=\"compact-toggle\" data-tooltip=\"Show/hide mission bounds\" data-tooltip-position=\"left\"><input type=\"checkbox\" id=\"boundVisibilityToggle\" ${isProspectBoundsVisible ? 'checked' : ''}><span class=\"toggle-slider-compact\"></span></label></div></div>`;\n    }\n    \n    let html = titleHtml;\n\n    // Description directly under title (no label)\n    if (prospect.description) {\n        html += `<p style=\"margin: 4px 0 8px 0; font-style: italic;\">${prospect.description}</p>`;\n    }\n\n    // Difficulty, Reward, Insurance on one row\n    let infoRow1 = [];\n    if (prospect.difficulty) {\n        infoRow1.push(`<b>Difficulty:</b> ${prospectDifficulties[prospect.difficulty] || prospect.difficulty}`);\n    }\n\n    // Rewards\n    let rewardParts = [];\n    if (prospect.creditsReward > 0) {\n        rewardParts.push(`${prospect.creditsReward} <img class=\"icon\" src=\"icon/ren.png\">`);\n    }\n    if (prospect.exoticsReward > 0) {\n        rewardParts.push(`${prospect.exoticsReward} <img class=\"icon\" src=\"icon/exotic.png\">`);\n    }\n    if (prospect.redExoticsReward > 0) {\n        rewardParts.push(`${prospect.redExoticsReward} <img class=\"icon\" src=\"icon/exotic_red.png\">`);\n    }\n    if (prospect.uraniumExoticsReward > 0) {\n        rewardParts.push(`${prospect.uraniumExoticsReward} <img class=\"icon\" src=\"icon/exotic_uranium.png\">`);\n    }\n    if (rewardParts.length > 0) {\n        infoRow1.push(`<b>Reward:</b> ${rewardParts.join(' ')}`);\n    }\n\n    if (prospect.insurance !== undefined) {\n        infoRow1.push(`<b>Insured:</b> ${prospect.insurance ? 'YES' : 'NO'}`);\n    }\n\n    if (infoRow1.length > 0) {\n        html += `<p style=\"margin: 4px 0;\">${infoRow1.join(' | ')}</p>`;\n    }\n\n    // Exotics deposits and potential deposits on one row\n    if (prospect.exoticsDeposits > 0 || prospect.exoticsDepositsMax > 0) {\n        const depositCount = prospect.exoticsDeposits || 0;\n        const maxDeposits = prospect.exoticsDepositsMax || depositCount;\n        html += `<p style=\"margin: 4px 0;\"><b>Exotics:</b> ${depositCount} | <b>Potential:</b> ${maxDeposits}</p>`;\n    }\n\n    // Duration, Clock (faction), Weather on one row\n    let infoRow2 = [];\n    if (prospect.duration) {\n        infoRow2.push(`<b>Duration:</b> ${prospect.duration}`);\n    }\n    if (prospect.startingTime) {\n        infoRow2.push(`<b>Clock:</b> ${prospect.startingTime}:00`);\n    }\n    if (prospect.weather) {\n        infoRow2.push(`<b>Weather:</b> ${prospect.weather}`);\n    }\n    if (prospect.faction) {\n        infoRow2.push(`<b>Faction:</b> ${prospect.faction}`);\n    }\n    if (infoRow2.length > 0) {\n        html += `<p style=\"margin: 4px 0;\">${infoRow2.join(' | ')}</p>`;\n    }\n\n    // Show quest objectives if available\n    if (quests && quests.length > 0) {\n        html += '<p style=\"margin: 6px 0; font-size: 12px; color: #888;\"><b>Note:</b> Delivery objective amounts are shown for <b>Normal</b> difficulty. Easy usually needs a little less, while Hard usually needs more.</p>';\n        questTitle = quests[0];\n        questSteps = quests.slice(1);\n        html += `<h3 class=\"mission-title\" style=\"margin: 8px 0 4px\">${questTitle.description}</h3><ul style=\"margin: 0 0 8px 0; padding-left: 20px;\">`;\n        questSteps.forEach(quest => {\n            const indent = (quest.depth || 0) * 16;\n            const questTips = quest.infoText ? `<br><span class=\"quest-tips\">${quest.infoText}</span>` : '';\n            html += `<li style=\"margin: 2px 0 2px ${indent}px\">${quest.description}${questTips}</li>`;\n        });\n        html += '</ul>';\n    }\n\n    if (prospect.tips) {\n        html += `<p style=\"margin: 8px 0 0 0\"><b>Tips:</b><br>${prospect.tips}</p>`;\n    }\n\n    missElement.innerHTML = html;\n\n    // Setup bounds toggle listener only if custom bounds exist\n    if (hasCustomBounds) {\n        const boundsToggle = document.getElementById('boundVisibilityToggle');\n        if (boundsToggle) {\n            boundsToggle.removeEventListener('change', handleBoundsToggleChange);\n            boundsToggle.addEventListener('change', handleBoundsToggleChange);\n        }\n    }\n}\n\nfunction showProspectBounds(prospect) {\n    // Use Bounds_Full as default if no bounds specified\n    let boundsValue = prospect.bounds && prospect.bounds !== 'null' ? prospect.bounds : 'Bounds_Full';\n    \n    // Check if bounds is valid\n    if (!boundsValue || boundsValue.trim() === '') {\n        return;\n    }\n\n    // Get open world state to determine transparency\n    const filterState = getFilterState();\n    const isOpenWorld = filterState.isOpenWorld !== false;\n    \n    // Set opacity based on open world state\n    const imageOpacity = isOpenWorld ? 0.8 : 0.90;\n    const rectOpacity = isOpenWorld ? 0.05 : 0.1;\n\n    // Check if bounds is a reference to an image overlay (e.g., \"T1_ForestExploration\" or \"Bounds_Full\")\n    if (!boundsValue.trim().startsWith('[')) {\n        // It's an image overlay reference\n        const boundsImagePath = 'bounds/' + boundsValue + '.png';\n\n        const imageBounds = [\n            map.unproject([0, 0], MAP_ZOOM),\n            map.unproject([8192, 8192], MAP_ZOOM)\n        ];\n\n        const imageOverlay = L.imageOverlay(boundsImagePath, imageBounds, {\n            opacity: imageOpacity,\n            zIndex: 1000,\n            interactive: false\n        });\n\n        prospectBoundsGroup.addLayer(imageOverlay);\n        prospectBoundsGroup.addTo(map);\n\n        return;\n    }\n\n    // Otherwise, try to parse as JSON coordinates\n    try {\n        const bounds = JSON.parse(boundsValue);\n        if (bounds && Array.isArray(bounds) && bounds.length === 2) {\n            const latLngBounds = L.latLngBounds(\n                map.unproject([bounds[0][0], bounds[0][1]], MAP_ZOOM),\n                map.unproject([bounds[1][0], bounds[1][1]], MAP_ZOOM)\n            );\n\n            const rectangle = L.rectangle(latLngBounds, {\n                color: '#ff7800',\n                weight: 2,\n                fillOpacity: rectOpacity\n            });\n\n            prospectBoundsGroup.addLayer(rectangle);\n            prospectBoundsGroup.addTo(map);\n        }\n    } catch (e) {\n        console.warn('Could not parse prospect bounds:', boundsValue, e);\n    }\n}\n\nfunction ensureLandingZonePane() {\n    let landingZonePane = map.getPane('landingZonePane');\n\n    if (!landingZonePane) {\n        landingZonePane = map.createPane('landingZonePane');\n        landingZonePane.style.zIndex = 350;\n    }\n\n    return landingZonePane;\n}\n\n// function ensureProspectMarkersPane() {\n//     let markersPane = map.getPane('prospectMarkersPane');\n\n//     if (!markersPane) {\n//         markersPane = map.createPane('prospectMarkersPane');\n//         markersPane.style.zIndex = 4000; // Higher than landing zone pane (350) to appear on top\n//     }\n\n//     return markersPane;\n// }\n\nfunction showProspectMarkers(missionData) {\n    // Add player spawns (dropship locations)\n    const prospectPlayerSpawns = missionData.prospectPlayerSpawns;\n    const playerSpawns = missionData.playerSpawns;\n\n    // Show a single landing zone circle centered on the average of the mission's linked player spawns.\n    if (prospectPlayerSpawns && prospectPlayerSpawns.length > 0 && playerSpawns && playerSpawns.length > 0) {\n        const linkedPlayerSpawns = prospectPlayerSpawns.map(prospectPlayerSpawn => playerSpawns.find(ps => ps.code === prospectPlayerSpawn.playerSpawnId));\n        if (linkedPlayerSpawns.length > 0) {\n            const landingZoneCenter = linkedPlayerSpawns.reduce((center, playerSpawn) => ({\n                x: center.x + Number(playerSpawn.x),\n                y: center.y + Number(playerSpawn.y)\n            }), { x: 0, y: 0 });\n\n            landingZoneCenter.x /= linkedPlayerSpawns.length;\n            landingZoneCenter.y /= linkedPlayerSpawns.length;\n\n            const landingZoneMarker = L.circle(\n                map.unproject([landingZoneCenter.x, landingZoneCenter.y], MAP_ZOOM),\n                {\n                    pane: ensureLandingZonePane() ? 'landingZonePane' : undefined,\n                    radius: convertGameDistance(26000),\n                    color: '#FFBC00',\n                    weight: 3,\n                    fillColor: '#FFBC00',\n                    fillOpacity: 0.25\n                }\n            );\n\n            landingZoneMarker.bindPopup('Drop Ship Landing Zone', { autoPan: false });\n            prospectMarkersGroup.addLayer(landingZoneMarker);\n        }\n    }\n\n    // Show prospect markers\n    const markers = missionData.prospectMarkers;\n    if (markers && markers.length > 0) {\n        markers.forEach(markerData => {\n            // Use the icon type from the marker data if available, otherwise use default\n            let markerIcon;\n            if (markerData.type && typeof window[markerData.type] !== 'undefined') {\n                markerIcon = window[markerData.type];\n            } else {\n                markerIcon = L.icon({\n                    iconUrl: 'icon/marker.png',\n                    iconSize: [25, 41],\n                    iconAnchor: [12, 41],\n                    popupAnchor: [0, -20]\n                });\n            }\n\n            const marker = L.marker(\n                map.unproject([markerData.x, markerData.y], MAP_ZOOM),\n                {\n                    rotationAngle: 0,\n                    icon: markerIcon\n                }\n            );\n\n            let popupText = markerData.description || '';\n            if (markerData.tips) {\n                popupText += (popupText ? '<br>' : '') + markerData.tips;\n            }\n            if (popupText) {\n                marker.bindPopup(popupText);\n            }\n\n            prospectMarkersGroup.addLayer(marker);\n        });\n    }\n\n    // Add markers to map if any exist\n    const layerCount = prospectMarkersGroup.getLayers().length;\n    if (layerCount > 0) {\n        // // Set pane to ensure markers are on top\n        // prospectMarkersGroup.eachLayer(layer => {\n        //     if (layer.setPane) {\n        //         layer.setPane(ensureProspectMarkersPane());\n        //     }\n        // });\n        prospectMarkersGroup.addTo(map);\n    } else {\n        // Show info message if mission has no map markers\n        const missElement = document.getElementById('miss');\n        if (missElement && missionData.prospect) {\n            let html = missElement.innerHTML;\n            html += '<p style=\"color: #888; font-style: italic;\"><br>No map markers available for this mission.</p>';\n            missElement.innerHTML = html;\n        }\n    }\n}\n\nfunction showProspectExotics(prospect, missionData) {\n    prospectExoticsGroup.clearLayers();\n\n    // Hide the general deposits layer when showing mission-specific deposits\n    if (lg_metaDeposits && map.hasLayer(lg_metaDeposits)) {\n        map.removeLayer(lg_metaDeposits);\n    }\n\n    // Get open world state\n    const filterState = getFilterState();\n    const isOpenWorld = filterState.isOpenWorld !== false;\n\n    const metaDeposits = missionData.metaDeposits || [];\n    const prospectMetaDeposits = missionData.prospectMetaDeposits || [];\n\n    // Get the list of deposits to display\n    let depositsToDisplay = [];\n\n    if (isOpenWorld) {\n        // Open world mode: show ALL map deposits\n        metaDeposits.forEach(metaDeposit => {\n            if (metaDeposit.variant !== 'Plant') {\n                depositsToDisplay.push({\n                    deposit: metaDeposit,\n                    min: 0,\n                    max: 0,\n                    isAllDeposits: true // Flag to indicate showing all deposits\n                });\n            }\n        });\n    } else {\n        // Standalone mission mode: show only prospect-specific deposits\n        // If no prospect-specific deposits but mission has exotics capacity, show all map deposits\n        if (prospectMetaDeposits.length === 0 && prospect.exoticsDepositsMax > 0) {\n            metaDeposits.forEach(metaDeposit => {\n                if (metaDeposit.variant !== 'Plant') {\n                    depositsToDisplay.push({\n                        deposit: metaDeposit,\n                        min: prospect.exoticsAmountMin || 0,\n                        max: prospect.exoticsAmountMax || 0\n                    });\n                }\n            });\n        } else {\n            // Show only prospect-specific deposits\n            prospectMetaDeposits.forEach(prospectMetaDeposit => {\n                // Find the matching meta deposit by identifier\n                const metaDeposit = metaDeposits.find(md => md.identifier === prospectMetaDeposit.metaDepositId);\n\n                if (metaDeposit) {\n                    depositsToDisplay.push({\n                        deposit: metaDeposit,\n                        min: prospectMetaDeposit.min || 0,\n                        max: prospectMetaDeposit.max || 0\n                    });\n                }\n            });\n        }\n    }\n\n    // Create markers for each deposit\n    depositsToDisplay.forEach(item => {\n        const metaDeposit = item.deposit;\n\n        // Get the saved exotic state\n        const savedState = getExoticsState(metaDeposit.code);\n        \n        // Choose icon based on mode and saved state:\n        // - In standalone mission mode: use saved state (will be '?' if never marked)\n        // - In open world mode: use saved state if exists, otherwise '?' (shows all deposits with their marked state or default)\n        const depositState = savedState; // Always use saved state, whether in open world or standalone\n        const markerIcon = getExoticsIconByVariantAndState(metaDeposit.variant, depositState, isOpenWorld);\n\n        const marker = L.marker(\n            map.unproject([metaDeposit.x, metaDeposit.y], MAP_ZOOM),\n            {\n                rotationAngle: 0,\n                icon: markerIcon\n            }\n        );\n\n        // Store deposit ID and variant for click handling\n        marker.depositId = metaDeposit.code;\n        marker.depositVariant = metaDeposit.variant;\n\n        // Create popup text\n        let popupText;\n        if (metaDeposit.variant === 'Volcanic') {\n            if (item.isAllDeposits) {\n                popupText = `RED EXOTICS DEPOSIT<br>1 HARVESTER`;\n            } else {\n                popupText = `RED EXOTICS DEPOSIT<br>${item.min} TO ${item.max} ORE<br>1 HARVESTER`;\n            }\n        } else {\n            if (item.isAllDeposits) {\n                popupText = `EXOTICS DEPOSIT<br>${metaDeposit.extractorCount} EXTRACTORS`;\n            } else {\n                popupText = `EXOTICS DEPOSIT<br>${item.min} TO ${item.max} ORE<br>${metaDeposit.extractorCount} EXTRACTORS`;\n            }\n        }\n\n        marker.bindPopup(popupText, { autoPan: false });\n\n        // Store data for dev tooltips\n        marker.basePopupText = popupText;\n        marker.depositData = metaDeposit;\n\n        // Add event handlers\n        marker.on('click', function (e) {\n            if (!window.mobileAndTabletCheck()) {\n                if (this.getPopup().isOpen()) {\n                    this.closePopup();\n                }\n            }\n            showExoticsContextMenu(e, this);\n        });\n        marker.on('mouseover', metaDepositMarkerOnMouseOver);\n        marker.on('mouseout', metaDepositMarkerOnMouseOut);\n\n        prospectExoticsGroup.addLayer(marker);\n    });\n\n    // Add red exotic plants (always shown for all missions)\n    metaDeposits.forEach(metaDeposit => {\n        if (metaDeposit.variant === 'Plant') {\n            const marker = L.marker(\n                map.unproject([metaDeposit.x, metaDeposit.y], MAP_ZOOM),\n                {\n                    rotationAngle: 0,\n                    icon: red_exotics_plant\n                }\n            );\n\n            const popupText = 'STRANGE PLANT<br>20% CHANCE TO SPAWN';\n            marker.bindPopup(popupText, { autoPan: false });\n\n            // Store data for dev tooltips\n            marker.basePopupText = popupText;\n            marker.depositData = metaDeposit;\n\n            marker.on('mouseover', metaDepositMarkerOnMouseOver);\n            marker.on('mouseout', metaDepositMarkerOnMouseOut);\n\n            prospectExoticsGroup.addLayer(marker);\n        }\n    });\n\n    // Add to map if filter is enabled\n    if (prospectExoticsGroup.getLayers().length > 0 && filterGetState(filterExotics)) {\n        prospectExoticsGroup.addTo(map);\n    }\n}\n\n\nfunction metaDepositMarkerOnMouseOver(e) {\n    const marker = e.target;\n    if (!window.mobileAndTabletCheck && marker.getPopup() && !marker._contextMenuOpen) {\n        marker.openPopup();\n    }\n}\n\nfunction metaDepositMarkerOnMouseOut(e) {\n    const marker = e.target;\n    if (marker.getPopup() && !marker._contextMenuOpen) {\n        marker.closePopup();\n    }\n}\n\nfunction setDepositState(depositId, depositState) {\n    let mapState = getMapState();\n\n    let depositFound;\n\n    if (mapState.deposit_status) {\n        for (let i = 0; i < mapState.deposit_status.length; i++) {\n            if (mapState.deposit_status[i].id == depositId) {\n                depositFound = i;\n                break;\n            }\n        }\n    } else {\n        mapState.deposit_status = [];\n    }\n\n    if (depositFound >= 0) {\n        mapState.deposit_status.splice(depositFound, 1);\n    }\n\n    if (depositState != '?') {\n        mapState.deposit_status.push({\n            'id': depositId,\n            'icon': depositState\n        });\n    }\n\n    mapState.change = \"new\";\n\n    setMapState(mapState);\n    scheduleAutoSave();\n}\n\nfunction clearProspect(restoreGeneralDeposits = true) {\n    // Clear info display\n    const missElement = document.getElementById('miss');\n    if (missElement) {\n        missElement.innerHTML = '';\n    }\n\n    // Clear bounds\n    prospectBoundsGroup.clearLayers();\n\n    // Clear markers\n    prospectMarkersGroup.clearLayers();\n\n    // Clear mission-specific exotics\n    prospectExoticsGroup.clearLayers();\n\n    // Clear stored prospect to prevent bounds from showing when toggling open world\n    currentDisplayedProspect = null;\n\n    // Restore general deposits layer if filter is enabled (but not during map switch)\n    if (restoreGeneralDeposits && lg_metaDeposits && lg_metaDeposits.getLayers().length > 0 && filterGetState(filterExotics)) {\n        if (!map.hasLayer(lg_metaDeposits)) {\n            lg_metaDeposits.addTo(map);\n            // Update icons to reflect current saved state (in case state changed while mission was displayed)\n            updateMetaDepositState();\n        }\n    }\n}\n\n// General exotic deposits functions (for showing all deposits on map)\nfunction loadMetaDepositsForMap(mapName, metaDeposits, showInMap) {\n    // Clear existing layer\n    lg_metaDeposits.clearLayers();\n\n    if (!metaDeposits || metaDeposits.length === 0) {\n        filterHideRow(filterExotics, true);\n        return;\n    }\n\n    // Cache the data\n    cachedMetaDepositsData[mapName] = metaDeposits;\n\n    // Create markers for all deposits\n    metaDeposits.forEach(metaDeposit => {\n        // Choose icon based on variant and saved state\n        let markerIcon;\n        const depositState = getExoticsState(metaDeposit.code);\n\n        if (metaDeposit.variant === 'Plant') {\n            // Red exotic plants - always the same icon\n            markerIcon = red_exotics_plant;\n        } else if (metaDeposit.variant === 'Volcanic') {\n            // Red exotics deposits - show state icons (always use true for general deposits)\n            markerIcon = getExoticsIconByVariantAndState(metaDeposit.variant, depositState, true);\n        } else if (metaDeposit.variant === 'Uranium') {\n            // Uranium exotics deposits - show state icons (always use true for general deposits)\n            markerIcon = getExoticsIconByVariantAndState(metaDeposit.variant, depositState, true);\n        } else {\n            // Standard exotics deposits - show state icons (always use true for general deposits)\n            markerIcon = getExoticsIconByVariantAndState(metaDeposit.variant, depositState, true);\n        }\n\n        const marker = L.marker(\n            map.unproject([metaDeposit.x, metaDeposit.y], MAP_ZOOM),\n            {\n                rotationAngle: 0,\n                icon: markerIcon\n            }\n        );\n\n        // Create popup text\n        let popupText;\n        if (metaDeposit.variant === 'Plant') {\n            popupText = 'STRANGE PLANT<br>20% CHANCE TO SPAWN';\n        } else if (metaDeposit.variant === 'Volcanic') {\n            popupText = `RED EXOTICS DEPOSIT<br>${metaDeposit.extractorCount || 1} HARVESTER`;\n        } else {\n            popupText = `EXOTICS DEPOSIT<br>${metaDeposit.extractorCount} EXTRACTORS`;\n        }\n\n        marker.bindPopup(popupText, { autoPan: false });\n\n        // Store data for dev tooltips and state management\n        marker.basePopupText = popupText;\n        marker.depositData = metaDeposit;\n        marker.depositId = metaDeposit.code;\n        marker.depositVariant = metaDeposit.variant;\n\n        // Add event handlers for mouseover and click\n        marker.on('mouseover', metaDepositMarkerOnMouseOver);\n        marker.on('mouseout', metaDepositMarkerOnMouseOut);\n        marker.on('click', function (e) {\n            if (!window.mobileAndTabletCheck()) {\n                if (this.getPopup().isOpen()) {\n                    this.closePopup();\n                }\n            }\n            showExoticsContextMenu(e, this);\n        });\n\n        lg_metaDeposits.addLayer(marker);\n    });\n\n    filterHideRow(filterExotics, false);\n\n    // Add to map if requested (showInMap should indicate if filter is enabled)\n    if (showInMap) {\n        lg_metaDeposits.addTo(map);\n    }\n}\n\nfunction toggleMetaDepositsLayer(state) {\n    if (!state) {\n        if (lg_metaDeposits && map.hasLayer(lg_metaDeposits)) {\n            map.removeLayer(lg_metaDeposits);\n        }\n        return;\n    }\n\n    // Check if a mission is currently active (has mission-specific exotics)\n    const missionActive = prospectExoticsGroup && prospectExoticsGroup.getLayers().length > 0;\n\n    // Don't show general deposits if a mission is active\n    if (missionActive) {\n        if (lg_metaDeposits && map.hasLayer(lg_metaDeposits)) {\n            map.removeLayer(lg_metaDeposits);\n        }\n        return;\n    }\n\n    // Add to map if it has layers and no mission is active\n    if (lg_metaDeposits && lg_metaDeposits.getLayers().length > 0) {\n        if (!map.hasLayer(lg_metaDeposits)) {\n            lg_metaDeposits.addTo(map);\n        }\n    }\n}\n\nfunction updateProspectExoticsPopups() {\n    if (!prospectExoticsGroup) return;\n\n    prospectExoticsGroup.eachLayer(marker => {\n        if (!marker.basePopupText || !marker.depositData) return;\n\n        let popupText = addDevTooltip(marker.basePopupText, marker.depositData);\n\n        marker.bindPopup(popupText, { autoPan: false });\n    });\n}\n\nfunction updateGeneralExoticsPopups() {\n    if (!lg_metaDeposits) return;\n\n    lg_metaDeposits.eachLayer(marker => {\n        if (!marker.basePopupText || !marker.depositData) return;\n\n        let popupText = addDevTooltip(marker.basePopupText, marker.depositData);\n\n        marker.bindPopup(popupText, { autoPan: false });\n    });\n}\n\n/**\n * Update exotic deposit icons based on saved state\n * Called after reload or conflict resolution\n */\nfunction updateMetaDepositState() {\n    const filterState = getFilterState();\n    const isOpenWorld = filterState.isOpenWorld !== false;\n\n    // Update prospect-specific exotics (shown during missions)\n    if (prospectExoticsGroup) {\n        prospectExoticsGroup.eachLayer(marker => {\n            if (!marker.depositId) return;\n\n            const depositState = getExoticsState(marker.depositId);\n            const isVolcanic = marker.depositVariant === 'Volcanic';\n            const isUranium = marker.depositVariant === 'Uranium';\n\n            let newIcon = getExoticsIconByVariantAndState(marker.depositVariant, depositState, isOpenWorld);\n            marker.setIcon(newIcon);\n        });\n    }\n\n    // Update general exotics (lg_metaDeposits) - show state indication\n    if (lg_metaDeposits) {\n        lg_metaDeposits.eachLayer(marker => {\n            if (!marker.depositId || marker.depositVariant === 'Plant') return;\n\n            const depositState = getExoticsState(marker.depositId);\n            // General deposits always show normal icons regardless of open world state\n            let newIcon = getExoticsIconByVariantAndState(marker.depositVariant, depositState);\n            marker.setIcon(newIcon);\n        });\n    }\n}\n\n/**\n * Helper function to get the appropriate icon based on variant and state\n */\nfunction getExoticsIconByVariantAndState(variant, state, isOpenWorld = true) {\n    const isVolcanic = variant === 'Volcanic';\n    const isUranium = variant === 'Uranium';\n\n    if (isVolcanic) {\n        if (state === '?') {\n            // In standalone mission (not open world): show unknown icon\n            // In open world: show normal icon\n            return isOpenWorld ? red_exotics : red_exotics_unknown;\n        }\n        else if (state === 'x') return red_exotics_invalid;\n        else if (state === 'k') return red_exotics_marked;\n        else if (state === 'm') return red_exotics_mined;\n        else return red_exotics;\n    } else if (isUranium) {\n        if (state === '?') {\n            // In standalone mission (not open world): show unknown icon\n            // In open world: show normal icon\n            return isOpenWorld ? uranium_exotics : uranium_exotics_unknown;\n        }\n        else if (state === 'x') return uranium_exotics_invalid;\n        else if (state === 'k') return uranium_exotics_marked;\n        else if (state === 'm') return uranium_exotics_mined;\n        else return uranium_exotics;\n    } else {\n        if (state === '?') {\n            // In standalone mission (not open world): show unknown icon\n            // In open world: show normal icon\n            return isOpenWorld ? deposit : deposit_unknown;\n        }\n        else if (state === 'x') return deposit_invalid;\n        else if (state === 'k') return deposit_marked;\n        else if (state === 'm') return deposit_mined;\n        else return deposit;\n    }\n}\n\n/**\n * Show context menu for exotic deposits (similar to caves)\n * Displays deposit info and status buttons for marking state\n */\nfunction showExoticsContextMenu(e, marker) {\n    const wrapper = document.createElement('div');\n    wrapper.className = 'cave-popup-wrapper'; // Reuse cave styling\n\n    // Check read-only mode\n    const isReadOnly = getMapState().rights === \"ro\";\n\n    // Get exotic deposit tooltip content\n    const tooltipContent = marker.getPopup()._content;\n\n    // Info section\n    const infoSection = document.createElement('div');\n    infoSection.className = 'cave-popup-info';\n    infoSection.innerHTML = tooltipContent;\n    wrapper.appendChild(infoSection);\n\n    // Exotics status section - only show in edit mode\n    if (!isReadOnly && marker.depositVariant !== 'Plant') {\n        const exoticsStatusSection = document.createElement('div');\n        exoticsStatusSection.className = 'cave-popup-status';\n\n        const statusLabel = document.createElement('div');\n        statusLabel.className = 'cave-popup-label';\n        statusLabel.textContent = 'Exotic Status:';\n        exoticsStatusSection.appendChild(statusLabel);\n\n        const statusButtons = document.createElement('div');\n        statusButtons.className = 'cave-popup-status-buttons';\n\n        const currentState = getExoticsState(marker.depositId) || '?';\n\n        const statusOptions = [\n            { state: '?', label: 'Unknown' },\n            { state: 'x', label: 'Empty' },\n            { state: 'k', label: 'Marked' },\n            { state: 'm', label: 'Mining' }\n        ];\n\n        statusOptions.forEach(option => {\n            const statusBtn = document.createElement('button');\n            statusBtn.className = 'cave-popup-status-btn' + (currentState === option.state ? ' active' : '');\n            \n            // Create icon element based on state\n            const icon = document.createElement('img');\n            icon.className = 'cave-popup-status-icon';\n            \n            if (option.state === '?') {\n                // Unknown - no icon or question mark\n                icon.style.display = 'none';\n                // icon.src = 'icon/question.png';\n            } else if (option.state === 'x') {\n                // Empty\n                icon.src = 'icon/cave_rm.png';\n            } else if (option.state === 'k') {\n                // Marked\n                icon.src = 'icon/cave_s_p.png';\n            } else if (option.state === 'm') {\n                // Mining/Mined\n                icon.src = 'icon/cave_s_m.png';\n            }\n            \n            statusBtn.appendChild(icon);\n            \n            // Add label text\n            const label = document.createElement('span');\n            label.style.marginLeft = '4px';\n            label.textContent = option.label;\n            statusBtn.appendChild(label);\n\n            statusBtn.onclick = () => {\n                setExoticsState(marker.depositId, option.state);\n\n                // Update marker icon based on new state\n                const filterState = getFilterState();\n                const isOpenWorld = filterState.isOpenWorld !== false;\n                let newIcon = getExoticsIconByVariantAndState(marker.depositVariant, option.state, isOpenWorld);\n                marker.setIcon(newIcon);\n\n                // Update button states\n                statusButtons.querySelectorAll('.cave-popup-status-btn').forEach(btn => {\n                    btn.classList.remove('active');\n                });\n                statusBtn.classList.add('active');\n            };\n\n            statusButtons.appendChild(statusBtn);\n        });\n\n        exoticsStatusSection.appendChild(statusButtons);\n        wrapper.appendChild(exoticsStatusSection);\n    }\n\n    // Mark that context menu is open\n    marker._contextMenuOpen = true;\n\n    // Prevent event propagation on wrapper to keep popup open\n    L.DomEvent.disableClickPropagation(wrapper);\n\n    // Handle mouseenter/mouseleave on wrapper to keep popup open\n    wrapper.addEventListener('mouseenter', (e) => {\n        L.DomEvent.stopPropagation(e);\n    });\n\n    wrapper.addEventListener('mouseleave', (e) => {\n        L.DomEvent.stopPropagation(e);\n    });\n\n    marker.unbindPopup();\n    marker.bindPopup(wrapper, { autoPan: false });\n    marker.openPopup();\n\n    // Clear flag when popup closes\n    marker.on('popupclose', function handler() {\n        marker._contextMenuOpen = false;\n        marker.off('popupclose', handler);\n    });\n}\n\n/**\n * Toggle open world state for the current mission\n */\nfunction toggleOpenWorldState(isOpenWorld) {\n    let filterState = getFilterState();\n    filterState.isOpenWorld = isOpenWorld;\n    setFilterState(filterState);\n}\n\n/**\n * Initialize open world toggle listeners and restore state from filter\n */\nfunction initializeOpenWorldToggle() {\n    const sidebarToggle = document.getElementById('openWorldToggleSidebar');\n    if (sidebarToggle) {\n        // Restore state from filter state\n        const filterState = getFilterState();\n        const isOpenWorld = filterState.isOpenWorld !== false;\n        sidebarToggle.checked = isOpenWorld;\n        \n        // Remove existing listener to avoid duplicates\n        sidebarToggle.removeEventListener('change', handleOpenWorldToggleChange);\n        \n        // Add event listener\n        sidebarToggle.addEventListener('change', handleOpenWorldToggleChange);\n    }\n}\n\n/**\n * Handle open world toggle change event\n */\nfunction handleOpenWorldToggleChange(e) {\n    toggleOpenWorldState(e.target.checked);\n    // Redraw bounds with updated opacity based on new toggle state\n    redrawProspectBounds();\n    // Refresh exotics display to show all deposits (open world) or mission-specific (standalone)\n    refreshProspectExotics();\n}\n\n/**\n * Redraw prospect bounds with current open world state (used when toggle changes)\n */\nfunction redrawProspectBounds() {\n    if (currentDisplayedProspect && currentDisplayedProspect.bounds && currentDisplayedProspect.bounds !== 'null') {\n        // Clear existing bounds\n        prospectBoundsGroup.clearLayers();\n        // Redraw bounds with updated opacity\n        showProspectBounds(currentDisplayedProspect);\n    }\n}\n\n/**\n * Handle bounds visibility toggle change\n */\nfunction handleBoundsToggleChange(e) {\n    toggleBoundsVisibility(e.target.checked);\n}\n\n/**\n * Toggle mission bounds visibility\n */\nfunction toggleBoundsVisibility(isVisible) {\n    isProspectBoundsVisible = isVisible;\n    \n    if (isVisible) {\n        // Show bounds\n        if (prospectBoundsGroup && !map.hasLayer(prospectBoundsGroup)) {\n            prospectBoundsGroup.addTo(map);\n        }\n    } else {\n        // Hide bounds\n        if (prospectBoundsGroup && map.hasLayer(prospectBoundsGroup)) {\n            map.removeLayer(prospectBoundsGroup);\n        }\n    }\n}\n\n/**\n * Refresh prospect exotics display based on current open world state\n * Called when open world toggle changes to update what exotics are visible\n */\nfunction refreshProspectExotics() {\n    // Only refresh if a prospect is currently displayed\n    if (currentDisplayedProspect) {\n        // We need to re-get the mission data to refresh the exotics layer\n        // For now, we'll just clear and rebuild using the stored prospect\n        const missElement = document.getElementById('miss');\n        if (missElement && missElement.innerHTML) {\n            // Prospect is displayed, we need to refresh exotics for it\n            // This will be handled by re-calling showProspectExotics with current data\n            // We store the current mission data when displaying it\n            if (window.currentMissionData) {\n                showProspectExotics(window.currentMissionData.prospect, window.currentMissionData);\n            }\n        }\n    }\n}\n"
          },
