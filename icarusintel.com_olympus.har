          "content": {
            "size": 42913,
            "mimeType": "text/javascript",
            "text": "/**\n * ============================================================================\n * SAVED MAPS MANAGEMENT DIALOG\n * ============================================================================\n * This module handles the UI for managing multiple saved map states per map.\n * Users can view, rename, switch between, and delete saved map states.\n */\n\nlet savedMapsMenuListenersInitialized = false;\nlet activeSavedMapMenuGuid = null;\n\n/**\n * Clean up any unsaved map entries (guid === 'new')\n * These are entries that were created but never saved to the server\n * IMPORTANT: Never delete the 'new' entry for the currently active map\n */\nfunction cleanupUnsavedMapEntries() {\n    // Skip cleanup if we're in the middle of an import\n    if (typeof window !== 'undefined' && window.skipCleanupDuringImport) {\n        console.log('[Cleanup] Skipping cleanup during import operation');\n        return;\n    }\n\n    // Skip cleanup if viewing a shared map\n    if (typeof window !== 'undefined' && window.isViewingSharedMap) {\n        console.log('[Cleanup] Skipping cleanup when viewing shared map');\n        return;\n    }\n\n    const savedMapsData = getSavedMaps();\n    const originalLength = savedMapsData.savedMaps.length;\n    const currentMapCode = localStorage.currentMap || 'olympus';\n\n    // Remove 'new' entries, BUT keep the one for the current map (if it exists)\n    // This prevents deleting an actively-being-created map during import or creation\n    savedMapsData.savedMaps = savedMapsData.savedMaps.filter(m => {\n        // Keep entries that are NOT 'new'\n        if (m.guid !== 'new') return true;\n\n        // Keep 'new' entries that match the current map\n        if (m.mapCode === currentMapCode) {\n            console.log('[Cleanup] Keeping active unsaved entry for current map:', m.mapCode);\n            return true;\n        }\n\n        // Remove other 'new' entries\n        console.log('[Cleanup] Removing inactive unsaved entry for:', m.mapCode);\n        return false;\n    });\n\n    // If we removed any entries, update localStorage\n    if (savedMapsData.savedMaps.length < originalLength) {\n        // Adjust lastOpenedIndex if needed\n        if (savedMapsData.lastOpenedIndex >= savedMapsData.savedMaps.length) {\n            savedMapsData.lastOpenedIndex = savedMapsData.savedMaps.length - 1;\n        }\n\n        setSavedMaps(savedMapsData);\n        debugLog('base', `Cleaned up ${originalLength - savedMapsData.savedMaps.length} unsaved map entries`);\n    }\n}\n\n/**\n * Initialize the saved maps UI\n * Called on page load after load_persistent()\n */\nfunction initSavedMapsUI() {\n    // Clean up any unsaved entries from previous session\n    cleanupUnsavedMapEntries();\n\n    // Update the current map name display\n    updateCurrentMapNameDisplay();\n\n    // Setup event listeners\n    const openDialogBtn = document.getElementById('openSavedMapsDialogBtn');\n    if (openDialogBtn) {\n        openDialogBtn.addEventListener('click', openSavedMapsDialog);\n    }\n\n    const closeDialogBtn = document.getElementById('closeSavedMapsDialog');\n    if (closeDialogBtn) {\n        closeDialogBtn.addEventListener('click', closeSavedMapsDialog);\n    }\n\n    const addNewBtn = document.getElementById('addNewMapBtn');\n    if (addNewBtn) {\n        addNewBtn.addEventListener('click', handleAddNewMap);\n    }\n\n    const addFromFileBtn = document.getElementById('addFromFileBtn');\n    if (addFromFileBtn) {\n        addFromFileBtn.addEventListener('click', handleAddFromFile);\n    }\n\n    const addFromLinkBtn = document.getElementById('addFromLinkBtn');\n    if (addFromLinkBtn) {\n        addFromLinkBtn.disabled = true;\n        addFromLinkBtn.title = 'Coming soon';\n    }\n\n    // Close dialog when clicking overlay\n    const dialogOverlay = document.getElementById('savedMapsDialog');\n    if (dialogOverlay) {\n        dialogOverlay.addEventListener('click', (e) => {\n            if (e.target === dialogOverlay) {\n                closeSavedMapsDialog();\n            }\n        });\n    }\n\n    // Setup \"Return to My Maps\" button for shared maps\n    const returnToMyMapsBtn = document.getElementById('returnToMyMapsBtn');\n    if (returnToMyMapsBtn) {\n        returnToMyMapsBtn.addEventListener('click', handleReturnToMyMaps);\n    }\n\n    debugLog('base', 'Saved maps UI initialized');\n}\n\n/**\n * Update the current map name display in the row under map selector\n */\nfunction updateCurrentMapNameDisplay(override = null) {\n    const displayElement = document.getElementById('currentMapNameDisplay');\n    if (!displayElement) return;\n\n    if (override && typeof override === 'object') {\n        const overrideName = override.name && String(override.name).trim()\n            ? String(override.name).trim()\n            : 'Unnamed Map';\n        const overrideUnsaved = !!override.isUnsaved;\n\n        displayElement.textContent = overrideUnsaved ? `${overrideName} (unsaved)` : overrideName;\n        displayElement.style.fontStyle = overrideUnsaved ? 'italic' : 'normal';\n        displayElement.style.color = overrideUnsaved ? '#666' : '';\n        return;\n    }\n\n    const currentMapCode = localStorage.currentMap || 'olympus';\n    const currentGuid = getGuid();\n\n    // Find the current map entry\n    const savedMapsData = getSavedMaps();\n    const entry = savedMapsData.savedMaps.find(m => m.guid === currentGuid && m.mapCode === currentMapCode);\n\n    if (currentGuid === 'new') {\n        const mapName = entry && entry.name && entry.name.trim() ? entry.name : 'Unnamed Map';\n        displayElement.textContent = `${mapName} (unsaved)`;\n        displayElement.style.fontStyle = 'italic';\n        displayElement.style.color = '#666';\n        return;\n    }\n\n    if (entry && entry.name && entry.name.trim()) {\n        displayElement.textContent = entry.name;\n        displayElement.style.fontStyle = 'normal';\n        displayElement.style.color = '';\n    } else {\n        displayElement.textContent = 'Unnamed Map';\n        displayElement.style.fontStyle = 'italic';\n        displayElement.style.color = '#666';\n    }\n}\n\nfunction setControlInteractivity(control, enabled, enabledTitle, disabledTitle) {\n    if (!control) return;\n\n    control.disabled = !enabled;\n    control.title = enabled ? (enabledTitle || '') : (disabledTitle || '');\n    control.style.cursor = enabled ? '' : 'not-allowed';\n    control.style.opacity = enabled ? '' : '0.6';\n}\n\nfunction canRunCurrentMapDataActions() {\n    if (typeof window !== 'undefined' && window.isViewingSharedMap) {\n        return false;\n    }\n\n    if (typeof getMapState === 'function') {\n        const mapState = getMapState();\n        if (mapState && mapState.rights === 'ro') {\n            return false;\n        }\n    }\n\n    return true;\n}\n\nfunction getCurrentMapDataActionsDisabledReason(isActive = true) {\n    if (!isActive) {\n        return 'This action is enabled only for the active map.';\n    }\n\n    if (!canRunCurrentMapDataActions()) {\n        return 'This action is unavailable in read-only mode.';\n    }\n\n    return '';\n}\n\nfunction getCurrentMapShareDisabledReason(isActive = true) {\n    const baseDisabledReason = getCurrentMapDataActionsDisabledReason(isActive);\n    if (baseDisabledReason) {\n        return baseDisabledReason;\n    }\n\n    if (typeof getMapState !== 'function') {\n        return 'Share is currently unavailable.';\n    }\n\n    const mapState = getMapState();\n    if (!mapState || !mapState.guid || mapState.guid === 'new') {\n        return 'Save the current map before sharing.';\n    }\n\n    return '';\n}\n\nfunction openCurrentMapShareDialog() {\n    if (typeof shareLink === 'function') {\n        shareLink();\n    }\n\n    const shareLinkEl = document.getElementById('shareLink');\n    if (!shareLinkEl || typeof shareLinkEl.onclick !== 'function') {\n        if (typeof notificationControl !== 'undefined') {\n            notificationControl.info('Unavailable', 'Save the map first to enable sharing.');\n        }\n        return;\n    }\n\n    shareLinkEl.click();\n}\n\nfunction getMapLastAccessTimestamp(entry) {\n    if (!entry || !entry.lastAccess) return 0;\n    const timestamp = new Date(entry.lastAccess).getTime();\n    return Number.isFinite(timestamp) ? timestamp : 0;\n}\n\nfunction findNextMapStateToLoad(entries) {\n    if (!Array.isArray(entries) || entries.length === 0) return null;\n\n    const sorted = [...entries].sort((a, b) => {\n        // Prefer map states that are not marked as deleted/missing.\n        const aIsMarkedForDeletion = a.markedForDeletion === true;\n        const bIsMarkedForDeletion = b.markedForDeletion === true;\n        if (aIsMarkedForDeletion !== bIsMarkedForDeletion) {\n            return aIsMarkedForDeletion ? 1 : -1;\n        }\n\n        // Prefer persisted states over unsaved placeholder states\n        const aIsUnsaved = a.guid === 'new';\n        const bIsUnsaved = b.guid === 'new';\n        if (aIsUnsaved !== bIsUnsaved) {\n            return aIsUnsaved ? 1 : -1;\n        }\n\n        return getMapLastAccessTimestamp(b) - getMapLastAccessTimestamp(a);\n    });\n\n    return sorted[0] || null;\n}\n\nfunction setUnsavedMapName(mapCode, name) {\n    if (!mapCode) return false;\n\n    const savedMapsData = getSavedMaps();\n    const newEntry = savedMapsData.savedMaps.find(\n        m => m.mapCode === mapCode && m.guid === 'new'\n    );\n\n    if (!newEntry) return false;\n\n    newEntry.name = name || '';\n    setSavedMaps(savedMapsData);\n    return true;\n}\n\nfunction saveCurrentMapStateImmediately() {\n    if (typeof getMapState !== 'function' || typeof setMapState !== 'function') return;\n\n    const mapState = getMapState();\n    if (!mapState) return;\n\n    // Force state into savable mode and trigger immediate save.\n    if (mapState.change !== 'new') {\n        mapState.change = 'new';\n        setMapState(mapState);\n    }\n\n    if (typeof updateUserAndMap === 'function') {\n        updateUserAndMap(true);\n    }\n}\n\n/**\n * Handle returning to user's own maps from a shared map\n * Clears URL parameters, re-enables UI elements, and loads latest saved map\n */\nfunction handleReturnToMyMaps() {\n    debugLog('base', 'Returning to user maps from shared link');\n\n    // Clear global shared map flag\n    window.isViewingSharedMap = false;\n\n    // Clear the URL parameter\n    const url = new URL(window.location);\n    url.searchParams.delete('m');\n    window.history.replaceState({}, '', url);\n\n    // Hide the overlay\n    const sharedMapOverlay = document.getElementById('sharedMapOverlay');\n    if (sharedMapOverlay) {\n        sharedMapOverlay.style.display = 'none';\n    }\n\n    // Re-enable the map selector\n    const mapSelector = document.getElementById('mapSelector');\n    setControlInteractivity(mapSelector, true, 'Select a map');\n\n    // Re-enable the map manage button\n    const mapManageBtn = document.getElementById('openSavedMapsDialogBtn');\n    setControlInteractivity(mapManageBtn, true, 'Manage saved maps');\n\n    // Get the saved maps data and use lastOpenedIndex to find the map to return to\n    const savedMapsData = getSavedMaps();\n    let mapToLoad = null;\n\n    // First, try to use lastOpenedIndex (the map user was viewing before shared map)\n    if (savedMapsData.lastOpenedIndex >= 0 && savedMapsData.lastOpenedIndex < savedMapsData.savedMaps.length) {\n        mapToLoad = savedMapsData.savedMaps[savedMapsData.lastOpenedIndex];\n        debugLog('base', 'Loading map from lastOpenedIndex:', { index: savedMapsData.lastOpenedIndex, map: mapToLoad });\n    } else {\n        // Fallback: find any map marked as selected for current map code\n        const currentMapCode = localStorage.currentMap || 'olympus';\n        const mapsForCurrentCode = savedMapsData.savedMaps.filter(m => m.mapCode === currentMapCode);\n        mapToLoad = mapsForCurrentCode.find(m => m.selected === true);\n        if (!mapToLoad && mapsForCurrentCode.length > 0) {\n            mapToLoad = mapsForCurrentCode[0];\n        }\n        debugLog('base', 'Loading map from current map code fallback:', mapToLoad);\n    }\n\n    // Load the map by switching to its map type and reloading\n    if (mapToLoad && mapToLoad.guid) {\n        debugLog('base', 'Switching to user map:', mapToLoad);\n\n        // Update current map to the map we're loading\n        localStorage.currentMap = mapToLoad.mapCode;\n\n        // Mark this map as selected\n        savedMapsData.savedMaps.forEach(m => {\n            if (m.mapCode === mapToLoad.mapCode) {\n                m.selected = (m.guid === mapToLoad.guid);\n            }\n        });\n        setSavedMaps(savedMapsData);\n\n        // Reload the page to load the user's map\n        window.location.reload();\n    } else {\n        // No saved maps found, reload to get clean state\n        debugLog('base', 'No saved maps found, reloading page');\n        window.location.reload();\n    }\n}\n\n/**\n * Open the saved maps dialog\n * Filters and displays only maps for the current mapCode\n */\nfunction openSavedMapsDialog() {\n    const dialog = document.getElementById('savedMapsDialog');\n    const listContainer = document.getElementById('savedMapsListContainer');\n\n    if (!dialog || !listContainer) return;\n\n    // Get current map code\n    const currentMapCode = localStorage.currentMap || 'olympus';\n    const currentGuid = getGuid();\n\n    // Get current map display name from the dropdown\n    const mapSelector = document.getElementById('mapSelector');\n    const currentMapName = mapSelector ? mapSelector.options[mapSelector.selectedIndex]?.text : '';\n\n    // Update dialog header with map name\n    const dialogHeader = dialog.querySelector('.saved-maps-header h3');\n    if (dialogHeader) {\n        if (currentMapName) {\n            dialogHeader.innerHTML = `Manage Saved Maps<br><span style=\"font-size: 12px; font-weight: normal; opacity: 0.9;\">${currentMapName}</span>`;\n        } else {\n            dialogHeader.textContent = 'Manage Saved Maps';\n        }\n    }\n\n    // Get saved maps for current map code\n    const savedMapsData = getSavedMaps();\n    const mapsForCurrentCode = savedMapsData.savedMaps.filter(m => m.mapCode === currentMapCode);\n\n    // Clear and populate the list\n    listContainer.innerHTML = '';\n\n    if (mapsForCurrentCode.length === 0) {\n        // Show empty state\n        listContainer.innerHTML = `\n            <div class=\"saved-maps-empty\">\n                <i class=\"material-symbols-outlined\">folder_open</i>\n                <p>No saved maps for this location yet.</p>\n                <p>Click \"Add New Save\" below to create one.</p>\n            </div>\n        `;\n    } else {\n        // Render each map row (in array order)\n        mapsForCurrentCode.forEach((entry, index) => {\n            const rowHtml = renderMapRow(entry, entry.guid === currentGuid);\n            listContainer.insertAdjacentHTML('beforeend', rowHtml);\n        });\n\n        // Setup event listeners for all rows\n        setupRowEventListeners(listContainer);\n    }\n\n    // Check if there are any unsaved maps and disable Add New button accordingly\n    const hasUnsavedMaps = mapsForCurrentCode.some(m => m.guid === 'new');\n    const addNewBtn = document.getElementById('addNewMapBtn');\n    if (addNewBtn) {\n        addNewBtn.disabled = hasUnsavedMaps;\n        if (hasUnsavedMaps) {\n            addNewBtn.title = 'Please save or delete the current unsaved map first';\n        } else {\n            addNewBtn.title = '';\n        }\n    }\n\n    const addFromFileBtn = document.getElementById('addFromFileBtn');\n    if (addFromFileBtn) {\n        const disabledReason = getCurrentMapDataActionsDisabledReason(true);\n        const importHandlerAvailable = typeof loadMapStateFromFile === 'function';\n\n        addFromFileBtn.disabled = !!disabledReason || !importHandlerAvailable;\n        if (disabledReason) {\n            addFromFileBtn.title = disabledReason;\n        } else if (!importHandlerAvailable) {\n            addFromFileBtn.title = 'Import from file is currently unavailable.';\n        } else {\n            addFromFileBtn.title = '';\n        }\n    }\n\n    const addFromLinkBtn = document.getElementById('addFromLinkBtn');\n    if (addFromLinkBtn) {\n        addFromLinkBtn.disabled = true;\n        addFromLinkBtn.title = 'Coming soon';\n    }\n\n    // Show dialog\n    dialog.style.display = 'flex';\n}\n\n/**\n * Close the saved maps dialog\n */\nfunction closeSavedMapsDialog() {\n    closeAllMapMenus();\n\n    const dialog = document.getElementById('savedMapsDialog');\n    if (dialog) {\n        dialog.style.display = 'none';\n    }\n\n    // Update the current map name display in case it changed\n    updateCurrentMapNameDisplay();\n}\n\n/**\n * Render HTML for a single map row\n * @param {Object} entry - The saved map entry\n * @param {boolean} isActive - Whether this is the currently active map\n * @returns {string} HTML string for the row\n */\nfunction renderMapRow(entry, isActive) {\n    const isUnsaved = entry.guid === 'new';\n    const isReadOnly = !isUnsaved && getMapState()?.rights === 'ro' && isActive;\n    const isMarkedForDeletion = entry.markedForDeletion === true;\n\n    // Format timestamps\n    const createdText = entry.created\n        ? new Date(entry.created).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' })\n        : (isUnsaved ? 'Not saved yet' : 'Unknown');\n\n    const accessedText = entry.lastAccess\n        ? new Date(entry.lastAccess).toLocaleString(undefined, {\n            year: 'numeric',\n            month: 'short',\n            day: 'numeric',\n            hour: '2-digit',\n            minute: '2-digit'\n        })\n        : 'Never';\n\n    // Determine map name and escape for HTML\n    const mapName = entry.name && entry.name.trim() ? entry.name : '';\n    const escapedMapName = mapName.replace(/\"/g, '&quot;').replace(/'/g, '&#39;');\n    const placeholder = isUnsaved ? 'Unsaved Map' : 'Unnamed Map';\n\n    const activeClass = isActive ? ' active' : '';\n    const unsavedClass = isUnsaved ? ' unsaved' : '';\n    const highlightClass = isUnsaved ? ' unsaved-highlight' : '';\n    const deletionClass = isMarkedForDeletion ? ' marked-deleted' : '';\n    const openBtnText = isActive ? 'Current' : 'Open';\n    const openBtnDisabled = isActive ? ' disabled' : '';\n    const statusMetadataHtml = isMarkedForDeletion\n        ? `\n                <div class=\"saved-map-timestamp deletion\">\n                    <i class=\"material-symbols-outlined\">delete_forever</i>\n                    <span>Marked for deletion</span>\n                </div>\n            `\n        : `\n                <div class=\"saved-map-timestamp\">\n                    <i class=\"material-symbols-outlined\">schedule</i>\n                    <span>Accessed: ${accessedText}</span>\n                </div>\n            `;\n\n    return `\n        <div class=\"saved-map-row${activeClass}${highlightClass}${deletionClass}\" data-guid=\"${entry.guid}\">\n            <div class=\"saved-map-row-main\">\n                <input \n                    type=\"text\" \n                    class=\"saved-map-name-input${unsavedClass}\" \n                    value=\"${escapedMapName}\" \n                    placeholder=\"${placeholder}\"\n                    maxlength=\"30\"\n                    data-guid=\"${entry.guid}\"\n                />\n                <div class=\"saved-map-actions\">\n                    <button class=\"saved-map-btn open\" data-action=\"open\" data-guid=\"${entry.guid}\"${openBtnDisabled}>\n                        <i class=\"material-symbols-outlined\">folder_open</i>\n                        ${openBtnText}\n                    </button>\n                    <button class=\"saved-map-btn menu\" data-action=\"menu\" data-guid=\"${entry.guid}\" data-is-active=\"${isActive}\" data-is-readonly=\"${isReadOnly}\" aria-label=\"Map options\" data-tooltip=\"Map options\">\n                        <i class=\"material-symbols-outlined\">more_horiz</i>\n                    </button>\n                </div>\n            </div>\n            <div class=\"saved-map-name-limit\" aria-live=\"polite\">Maximum name length reached (${30}/${30})</div>\n            <div class=\"saved-map-metadata\">\n                <div class=\"saved-map-timestamp\">\n                    <i class=\"material-symbols-outlined\">event</i>\n                    <span>Created: ${createdText}</span>\n                </div>\n                ${statusMetadataHtml}\n            </div>\n        </div>\n    `;\n}\n\n/**\n * Setup event listeners for all rows in the list\n * @param {HTMLElement} container - The list container element\n */\nfunction setupRowEventListeners(container) {\n    ensureSavedMapsMenuGlobalHandlers();\n\n    // Input change events (with debouncing)\n    const inputs = container.querySelectorAll('.saved-map-name-input');\n    inputs.forEach(input => {\n        updateMapNameLengthLimitState(input);\n\n        let debounceTimer;\n        input.addEventListener('input', (e) => {\n            updateMapNameLengthLimitState(e.target);\n\n            clearTimeout(debounceTimer);\n            debounceTimer = setTimeout(() => {\n                const guid = e.target.dataset.guid;\n                const newName = e.target.value.trim();\n                updateMapComment(guid, newName);\n            }, 500); // Wait 500ms after user stops typing\n        });\n\n        // Also save on blur\n        input.addEventListener('blur', (e) => {\n            clearTimeout(debounceTimer);\n            const guid = e.target.dataset.guid;\n            const newName = e.target.value.trim();\n            updateMapComment(guid, newName);\n        });\n    });\n\n    // Button click events\n    const buttons = container.querySelectorAll('.saved-map-btn');\n    buttons.forEach(button => {\n        if (button.disabled) return;\n\n        button.addEventListener('click', (e) => {\n            const action = e.currentTarget.dataset.action;\n            const guid = e.currentTarget.dataset.guid;\n\n            if (action === 'open') {\n                handleOpenMap(guid);\n            } else if (action === 'menu') {\n                e.stopPropagation();\n                handleMapMenu(guid, e.currentTarget);\n            }\n        });\n    });\n}\n\nfunction executeCurrentMapMenuAction(action, guid) {\n    const currentGuidAvailable = typeof getGuid === 'function';\n    const currentGuid = currentGuidAvailable ? getGuid() : null;\n    const isCurrentMap = currentGuidAvailable ? guid === currentGuid : true;\n    const disabledReason = getCurrentMapDataActionsDisabledReason(isCurrentMap);\n\n    if (disabledReason) {\n        const popupTitle = isCurrentMap ? 'Unavailable' : 'Current Map Only';\n        showCurrentMapOnlyPopup(disabledReason, popupTitle);\n        return;\n    }\n\n    const actionHandlerMap = {\n        share: openCurrentMapShareDialog,\n        export: typeof saveMapStateToFile === 'function' ? saveMapStateToFile : null,\n        'clear-caves': typeof restoreCavesStates === 'function' ? restoreCavesStates : null,\n        'clear-ores': typeof restoreDepositStates === 'function' ? restoreDepositStates : null,\n        'clear-exotics': typeof restoreExoticsStates === 'function' ? restoreExoticsStates : null,\n        'clear-markers': typeof deleteAllCustomMarkers === 'function' ? deleteAllCustomMarkers : null\n    };\n\n    const actionHandler = actionHandlerMap[action];\n    if (typeof actionHandler !== 'function') {\n        if (typeof notificationControl !== 'undefined') {\n            notificationControl.info('Unavailable', 'This action is currently unavailable.');\n        }\n        return;\n    }\n\n    closeSavedMapsDialog();\n    setTimeout(() => {\n        actionHandler();\n    }, 0);\n}\n\nfunction showCurrentMapOnlyPopup(message = 'This action is enabled only for the active map.', title = 'Current Map Only') {\n\n    if (typeof showCustomConfirm === 'function') {\n        showCustomConfirm(title, message, () => { }, true, 'OK');\n        return;\n    }\n\n    if (typeof notificationControl !== 'undefined') {\n        notificationControl.info(title, message);\n    }\n}\n\nfunction ensureSavedMapsMenuGlobalHandlers() {\n    if (savedMapsMenuListenersInitialized) return;\n\n    document.addEventListener('click', (event) => {\n        if (!event.target.closest('.saved-map-floating-menu') && !event.target.closest('.saved-map-btn.menu')) {\n            closeAllMapMenus();\n        }\n    });\n\n    document.addEventListener('keydown', (event) => {\n        if (event.key === 'Escape') {\n            closeAllMapMenus();\n        }\n    });\n\n    savedMapsMenuListenersInitialized = true;\n}\n\nfunction closeAllMapMenus() {\n    const floatingMenu = document.getElementById('savedMapContextMenu');\n    if (floatingMenu) {\n        floatingMenu.remove();\n    }\n\n    activeSavedMapMenuGuid = null;\n}\n\nfunction updateMapNameLengthLimitState(inputElement) {\n    if (!inputElement) return;\n\n    const row = inputElement.closest('.saved-map-row');\n    const limitMessage = row ? row.querySelector('.saved-map-name-limit') : null;\n    if (!limitMessage) return;\n\n    const maxLength = inputElement.maxLength > 0 ? inputElement.maxLength : 30;\n    const reachedLimit = inputElement.value.length >= maxLength;\n    limitMessage.classList.toggle('visible', reachedLimit);\n}\n\n/**\n * Update a map's comment/name\n * @param {string} guid - The map GUID\n * @param {string} newName - The new name/comment\n */\nfunction updateMapComment(guid, newName) {\n    const savedMapsData = getSavedMaps();\n    const entry = savedMapsData.savedMaps.find(m => m.guid === guid);\n\n    if (entry) {\n        // Don't allow empty names - preserve existing name if newName is empty\n        // This prevents race conditions during map creation/save from clearing the name\n        if (newName === '' && entry.name) {\n            debugLog('base', 'Prevented empty name update, keeping existing name:', { guid, existingName: entry.name });\n            return;\n        }\n\n        entry.name = newName;\n        setSavedMaps(savedMapsData);\n        debugLog('base', 'Updated map name:', { guid, newName });\n\n        // Update display if this is the current map\n        const currentGuid = getGuid();\n        if (guid === currentGuid) {\n            updateCurrentMapNameDisplay();\n        }\n    }\n}\n\n/**\n * Handle opening a different map state\n * @param {string} guid - The GUID to switch to\n */\nfunction handleOpenMap(guid) {\n    if (!guid || guid === getGuid()) return;\n\n    const savedMapsData = getSavedMaps();\n    const selectedEntry = savedMapsData.savedMaps.find(m => m.guid === guid);\n    if (selectedEntry && typeof updateCurrentMapNameDisplay !== 'undefined') {\n        updateCurrentMapNameDisplay({\n            name: selectedEntry.name,\n            isUnsaved: guid === 'new'\n        });\n    }\n\n    closeSavedMapsDialog();\n\n    // Use the existing switchToMapStateByGuid function\n    if (typeof switchToMapStateByGuid !== 'undefined') {\n        switchToMapStateByGuid(guid);\n    }\n}\n\n/**\n * Handle map row menu action (placeholder for upcoming options)\n * @param {string} guid - The map GUID\n */\nfunction handleMapMenu(guid, triggerButton) {\n    if (!guid || !triggerButton) return;\n\n    const shouldCloseCurrent = activeSavedMapMenuGuid === guid;\n    closeAllMapMenus();\n    if (shouldCloseCurrent) {\n        return;\n    }\n\n    const isActive = triggerButton.dataset.isActive === 'true';\n    const isReadOnly = triggerButton.dataset.isReadonly === 'true';\n    const actionDisabledReason = getCurrentMapDataActionsDisabledReason(isActive);\n    const actionDisabled = !!actionDisabledReason;\n    const shareDisabledReason = getCurrentMapShareDisabledReason(isActive);\n    const shareDisabled = !!shareDisabledReason;\n\n    const menu = document.createElement('div');\n    menu.id = 'savedMapContextMenu';\n    menu.className = 'saved-map-floating-menu';\n    menu.setAttribute('role', 'menu');\n\n    const disabledAttr = actionDisabled ? 'true' : 'false';\n    const disabledClass = actionDisabled ? ' is-disabled' : '';\n    const disabledTitle = actionDisabled ? ` title=\"${actionDisabledReason}\"` : '';\n    const disabledReasonAttr = actionDisabled ? ` data-disabled-reason=\"${actionDisabledReason}\"` : '';\n    const shareDisabledAttr = shareDisabled ? 'true' : 'false';\n    const shareDisabledClass = shareDisabled ? ' is-disabled' : '';\n    const shareDisabledTitle = shareDisabled ? ` title=\"${shareDisabledReason}\"` : '';\n    const shareDisabledReasonAttr = shareDisabled ? ` data-disabled-reason=\"${shareDisabledReason}\"` : '';\n\n    menu.innerHTML = `\n        <button class=\"saved-map-menu-item${shareDisabledClass}\" data-action=\"share\" data-guid=\"${guid}\" data-disabled=\"${shareDisabledAttr}\" role=\"menuitem\" aria-disabled=\"${shareDisabledAttr}\"${shareDisabledTitle}${shareDisabledReasonAttr}>\n            <i class=\"material-symbols-outlined\">share</i>\n            Share Current Map\n        </button>\n        <button class=\"saved-map-menu-item${disabledClass}\" data-action=\"export\" data-guid=\"${guid}\" data-disabled=\"${disabledAttr}\" role=\"menuitem\" aria-disabled=\"${disabledAttr}\"${disabledTitle}${disabledReasonAttr}>\n            <i class=\"material-symbols-outlined\">download</i>\n            Export Map\n        </button>\n        <button class=\"saved-map-menu-item${disabledClass}\" data-action=\"clear-caves\" data-guid=\"${guid}\" data-disabled=\"${disabledAttr}\" role=\"menuitem\" aria-disabled=\"${disabledAttr}\"${disabledTitle}${disabledReasonAttr}>\n            <img src=\"icon/icon_cave.png\" alt=\"Caves\" class=\"menu-item-icon\" width=\"16\" height=\"16\" />\n            Clear Caves\n        </button>\n        <button class=\"saved-map-menu-item${disabledClass}\" data-action=\"clear-ores\" data-guid=\"${guid}\" data-disabled=\"${disabledAttr}\" role=\"menuitem\" aria-disabled=\"${disabledAttr}\"${disabledTitle}${disabledReasonAttr}>\n            <img src=\"icon/dov.png\" alt=\"Deep Ore Veins\" class=\"menu-item-icon\" width=\"16\" height=\"16\" />\n            Clear Ores\n        </button>\n        <button class=\"saved-map-menu-item${disabledClass}\" data-action=\"clear-exotics\" data-guid=\"${guid}\" data-disabled=\"${disabledAttr}\" role=\"menuitem\" aria-disabled=\"${disabledAttr}\"${disabledTitle}${disabledReasonAttr}>\n            <img src=\"icon/exotics_deposit.png\" alt=\"Exotics\" class=\"menu-item-icon\" width=\"16\" height=\"16\" />\n            Clear Exotics\n        </button>\n        <button class=\"saved-map-menu-item${disabledClass}\" data-action=\"clear-markers\" data-guid=\"${guid}\" data-disabled=\"${disabledAttr}\" role=\"menuitem\" aria-disabled=\"${disabledAttr}\"${disabledTitle}${disabledReasonAttr}>\n            <i class=\"material-symbols-outlined\" style=\"color: #ff4081; filter: drop-shadow(0 0 2px rgba(255, 64, 129, 0.3));\">map_pin_heart</i>\n            Clear Markers\n        </button>\n        <button class=\"saved-map-menu-item danger\" data-action=\"delete\" data-guid=\"${guid}\" role=\"menuitem\"${isReadOnly ? ' disabled' : ''}>\n            <i class=\"material-symbols-outlined\">delete</i>\n            Delete\n        </button>\n    `;\n\n    menu.addEventListener('click', (event) => {\n        const menuItem = event.target.closest('.saved-map-menu-item');\n        if (!menuItem) return;\n\n        event.stopPropagation();\n\n        const action = menuItem.dataset.action;\n        const itemGuid = menuItem.dataset.guid;\n        const isDisabledItem = menuItem.disabled || menuItem.dataset.disabled === 'true';\n        const disabledReason = menuItem.dataset.disabledReason || 'This action is currently unavailable.';\n\n        closeAllMapMenus();\n\n        if (isDisabledItem) {\n            const popupTitle = disabledReason === 'This action is enabled only for the active map.'\n                ? 'Current Map Only'\n                : 'Unavailable';\n            showCurrentMapOnlyPopup(disabledReason, popupTitle);\n            return;\n        }\n\n        if (action === 'delete') {\n            handleDeleteMap(itemGuid);\n        } else {\n            executeCurrentMapMenuAction(action, itemGuid);\n        }\n    });\n\n    document.body.appendChild(menu);\n    positionSavedMapFloatingMenu(menu, triggerButton);\n    activeSavedMapMenuGuid = guid;\n}\n\nfunction positionSavedMapFloatingMenu(menu, triggerButton) {\n    if (!menu || !triggerButton) return;\n\n    const buttonRect = triggerButton.getBoundingClientRect();\n    const spacing = 4;\n\n    menu.style.visibility = 'hidden';\n    menu.style.left = '0px';\n    menu.style.top = '0px';\n\n    const menuRect = menu.getBoundingClientRect();\n    const maxLeft = window.innerWidth - menuRect.width - 8;\n\n    let left = buttonRect.right - menuRect.width;\n    let top = buttonRect.bottom + spacing;\n\n    if (left < 8) left = 8;\n    if (left > maxLeft) left = maxLeft;\n\n    if (top + menuRect.height > window.innerHeight - 8) {\n        top = buttonRect.top - menuRect.height - spacing;\n    }\n    if (top < 8) top = 8;\n\n    menu.style.left = `${left}px`;\n    menu.style.top = `${top}px`;\n    menu.style.visibility = 'visible';\n}\n\nfunction getHttpStatusCodeFromError(error) {\n    if (!error) return undefined;\n\n    if (typeof error.status === 'number') {\n        return error.status;\n    }\n\n    if (typeof error.message === 'string') {\n        const match = error.message.match(/\\b(\\d{3})\\b/);\n        if (match) {\n            return Number(match[1]);\n        }\n    }\n\n    return undefined;\n}\n\n/**\n * Handle deleting a map state\n * @param {string} guid - The GUID to delete\n */\nfunction handleDeleteMap(guid) {\n    if (!guid) {\n        return;\n    }\n\n    const savedMapsData = getSavedMaps();\n    const entry = savedMapsData.savedMaps.find(m => m.guid === guid);\n    const mapName = entry?.name && entry.name.trim() ? entry.name : 'Unnamed Map';\n\n    showCustomConfirm(\n        'Delete Map',\n        `Are you sure you want to delete \"${mapName}\"? This will permanently delete it from the server. This action cannot be undone.`,\n        () => {\n            const deletedCurrentMap = guid === getGuid();\n\n            const finalizeLocalDeletion = (alreadyMissingOnServer = false) => {\n                const notificationTitle = alreadyMissingOnServer ? 'Map removed' : 'Map deleted';\n                const buildNotificationMessage = (loadedMapName = null) => {\n                    if (alreadyMissingOnServer) {\n                        if (loadedMapName) {\n                            return `\"${mapName}\" no longer exists on the server and was removed. Loaded \"${loadedMapName}\".`;\n                        }\n                        return `\"${mapName}\" no longer exists on the server and was removed from your list.`;\n                    }\n\n                    if (loadedMapName) {\n                        return `\"${mapName}\" has been deleted. Loaded \"${loadedMapName}\".`;\n                    }\n                    return `\"${mapName}\" has been deleted.`;\n                };\n\n                // Remove from localStorage\n                const latestSavedMapsData = getSavedMaps();\n                const index = latestSavedMapsData.savedMaps.findIndex(m => m.guid === guid);\n                if (index !== -1) {\n                    latestSavedMapsData.savedMaps.splice(index, 1);\n\n                    // Adjust global lastOpenedIndex\n                    if (latestSavedMapsData.lastOpenedIndex === index) {\n                        latestSavedMapsData.lastOpenedIndex = -1;\n                    } else if (latestSavedMapsData.lastOpenedIndex > index) {\n                        latestSavedMapsData.lastOpenedIndex--;\n                    }\n\n                    setSavedMaps(latestSavedMapsData);\n                }\n\n                // Get fresh copy of savedMaps after deletion to ensure we have correct state\n                const updatedSavedMapsData = getSavedMaps();\n\n                // Update UI and show loading overlay\n                if (deletedCurrentMap && typeof showMapLoading !== 'undefined') {\n                    showMapLoading();\n                }\n\n                // If we deleted the currently active map, load the latest saved map or create new\n                if (deletedCurrentMap) {\n                    const currentMapCode = localStorage.currentMap || 'olympus';\n                    debugLog('base', 'Deleted current map, checking for other saved maps');\n\n                    // Try to find another saved map for this location\n                    const remainingMaps = updatedSavedMapsData.savedMaps.filter(m => m.mapCode === currentMapCode);\n\n                    if (remainingMaps.length > 0) {\n                        const nextMap = findNextMapStateToLoad(remainingMaps);\n\n                        debugLog('base', 'Loading next map after deletion:', {\n                            guid: nextMap?.guid,\n                            name: nextMap?.name,\n                            lastAccess: nextMap?.lastAccess\n                        });\n\n                        // Handle unsaved state directly (no DB switch needed)\n                        if (nextMap && nextMap.guid === 'new') {\n                            if (typeof setGuid !== 'undefined') {\n                                setGuid('new');\n                            }\n                            if (typeof loadMapFromDb !== 'undefined') {\n                                loadMapFromDb(true);\n                            }\n                            if (typeof hideMapLoading !== 'undefined') {\n                                hideMapLoading();\n                            }\n                            closeSavedMapsDialog();\n                            notificationControl.success(notificationTitle, buildNotificationMessage(nextMap.name || 'Unnamed Map'));\n                            return;\n                        }\n\n                        // Load persisted map state from database\n                        if (nextMap && typeof switchToMapStateByGuid !== 'undefined') {\n                            switchToMapStateByGuid(nextMap.guid).then(() => {\n                                if (typeof hideMapLoading !== 'undefined') {\n                                    hideMapLoading();\n                                }\n                                closeSavedMapsDialog();\n                                notificationControl.success(notificationTitle, buildNotificationMessage(nextMap.name || 'Unnamed Map'));\n                            }).catch((error) => {\n                                console.error('Failed to load next map:', error);\n                                if (typeof hideMapLoading !== 'undefined') {\n                                    hideMapLoading();\n                                }\n                                createNewMapState(currentMapCode);\n                                closeSavedMapsDialog();\n                                notificationControl.success(notificationTitle, buildNotificationMessage());\n                            });\n                            return; // Exit early since we're handling notification in the promise\n                        }\n                    } else {\n                        // No other saved maps, create a new one\n                        debugLog('base', 'No other saved maps found, creating new state');\n                        if (typeof hideMapLoading !== 'undefined') {\n                            hideMapLoading();\n                        }\n                        createNewMapState(currentMapCode);\n                    }\n\n                    closeSavedMapsDialog();\n                } else {\n                    // Refresh the dialog to show updated list\n                    openSavedMapsDialog();\n                }\n\n                notificationControl.success(notificationTitle, buildNotificationMessage());\n            };\n\n            // Delete from server\n            deleteMapState(guid)\n                .then(() => {\n                    finalizeLocalDeletion(false);\n                })\n                .catch((error) => {\n                    if (getHttpStatusCodeFromError(error) === 404) {\n                        debugLog('base', 'Map already missing on server, removing local entry:', { guid, mapName });\n                        finalizeLocalDeletion(true);\n                        return;\n                    }\n\n                    notificationControl.alert('Delete failed', error.message || 'Could not delete map from server.');\n                });\n        },\n        false,\n        'Delete',\n        'Cancel',\n        null,\n        'danger'\n    );\n}\n\n/**\n * Handle adding a new map save\n */\nfunction handleAddNewMap() {\n    const currentMapCode = localStorage.currentMap || 'olympus';\n\n    // Generate default name with date\n    const now = new Date();\n    const dateStr = now.toLocaleDateString(undefined, {\n        year: 'numeric',\n        month: 'short',\n        day: 'numeric',\n        hour: '2-digit',\n        minute: '2-digit'\n    });\n    const defaultName = `New Map ${dateStr}`;\n\n    if (typeof showCustomPrompt !== 'undefined') {\n        showCustomPrompt(\n            'Create New Map Save',\n            'Enter a name for this map save:',\n            (mapName) => {\n                // If user cancelled (mapName is null), don't create the map\n                if (mapName === null) {\n                    return;\n                }\n\n                closeSavedMapsDialog();\n\n                // Use provided name or default\n                const finalName = mapName || defaultName;\n\n                // Create new map state\n                if (typeof createNewMapState !== 'undefined') {\n                    createNewMapState(currentMapCode, { suppressNotification: true });\n\n                    // Set name synchronously, then force immediate save to avoid 'new' GUID races.\n                    setUnsavedMapName(currentMapCode, finalName);\n                    updateCurrentMapNameDisplay();\n                    saveCurrentMapStateImmediately();\n                }\n            },\n            '',\n            'e.g., \"Week 300 Olympus\" or \"First Game\"',\n            'Create',\n            'Cancel',\n            { wide: true }\n        );\n    } else {\n        // Fallback if showCustomPrompt is not available\n        closeSavedMapsDialog();\n        if (typeof createNewMapState !== 'undefined') {\n            createNewMapState(currentMapCode, { suppressNotification: true });\n        }\n    }\n}\n\n/**\n * Handle adding a map save from file\n * Uses the same action as the main \"Import from file\" button\n */\nfunction handleAddFromFile() {\n    const disabledReason = getCurrentMapDataActionsDisabledReason(true);\n    if (disabledReason) {\n        showCurrentMapOnlyPopup(disabledReason, 'Unavailable');\n        return;\n    }\n\n    if (typeof loadMapStateFromFile !== 'function') {\n        if (typeof notificationControl !== 'undefined') {\n            notificationControl.info('Unavailable', 'Import from file is currently unavailable.');\n        }\n        return;\n    }\n\n    closeSavedMapsDialog();\n    setTimeout(() => {\n        loadMapStateFromFile();\n    }, 0);\n}\n\n// Call initSavedMapsUI after the page is fully loaded and persistent data is loaded\n// This will be called from map.js after load_persistent() completes\nif (typeof window !== 'undefined') {\n    // Export functions that might be called from other modules\n    window.updateCurrentMapNameDisplay = updateCurrentMapNameDisplay;\n    window.initSavedMapsUI = initSavedMapsUI;\n    window.cleanupUnsavedMapEntries = cleanupUnsavedMapEntries;\n    window.skipCleanupDuringImport = false; // Initialize cleanup flag\n    window.skipLoadDuringImport = false; // Initialize load flag\n}\n"
          },
